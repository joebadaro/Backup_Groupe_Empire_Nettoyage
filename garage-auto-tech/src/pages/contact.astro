---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Garage Auto-Tech S M">
    <main class="page-content">
        <section class="page-header">
            <div class="container animate-fade-in">
                <h1>Contactez-nous</h1>
                <p>Nous sommes là pour vous aider</p>
            </div>
        </section>

        <section class="section-padding">
            <div class="container">
                <div class="contact-grid">
                    <!-- Info -->
                    <div class="contact-info">
                        <h2>Coordonnées</h2>
                        <div class="info-item">
                            <h3>📍 Adresse</h3>
                            <p>765, rue Verchères,<br />Longueuil QC J4K 2Y8</p>
                        </div>
                        <div class="info-item">
                            <h3>📞 Téléphone</h3>
                            <p><a href="tel:450-646-0664">450-646-0664</a></p>
                        </div>
                        <div class="info-item">
                            <h3>🕒 Heures d'ouverture</h3>
                            <p>Lundi - Vendredi: 8h00 - 17h00</p>
                            <p>Samedi - Dimanche: Fermé</p>
                        </div>
                    </div>

                    <!-- Map -->
                    <div class="map-container">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2794.506575123689!2d-73.50499!3d45.53999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4cc91b6706e40d7f%3A0x123456789!2s765%20Rue%20Verch%C3%A8res%2C%20Longueuil%2C%20QC%20J4K%202Y8!5e0!3m2!1sen!2sca!4v1620000000000!5m2!1sen!2sca"
                            width="100%"
                            height="400"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                        >
                        </iframe>
                    </div>
                </div>
            </div>
        </section>

        <!-- Simple Contact Form Section -->
        <section class="section-padding bg-secondary">
            <div class="container">
                <div class="form-wrapper">
                    <div class="text-center mb-lg">
                        <h2>Envoyez-nous un message</h2>
                        <p class="text-dark">
                            Une question ou une demande de rendez-vous ?
                            Écrivez-nous.
                        </p>
                    </div>
                    <form class="contact-form">
                        <div class="form-group">
                            <label for="name">Nom</label>
                            <input type="text" id="name" name="name" required />
                        </div>
                        <div class="form-group">
                            <label for="email">Courriel</label>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                            />
                        </div>
                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea
                                id="message"
                                name="message"
                                rows="5"
                                required></textarea>
                        </div>
                        <button type="submit" class="btn btn-block"
                            >Envoyer</button
                        >
                    </form>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .page-header {
        background-color: var(--color-darker);
        padding: 8rem 0 4rem;
        text-align: center;
        background-image:
            linear-gradient(rgba(15, 28, 46, 0.9), rgba(15, 28, 46, 0.8)),
            url("https://images.unsplash.com/photo-1517524008697-84bbe3c3fd98?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80");
        background-size: cover;
        background-position: center;
    }

    .page-header h1 {
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }
    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.8);
    }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
    }

    .info-item {
        margin-bottom: 2rem;
    }
    .info-item h3 {
        color: var(--color-primary);
        margin-bottom: 0.5rem;
        font-size: 1.3rem;
    }

    .map-container iframe {
        border-radius: var(--border-radius);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    .bg-secondary {
        background-color: var(--color-secondary);
        color: var(--color-text-dark);
    }
    .text-dark {
        color: var(--color-text-dark);
    }

    .form-wrapper {
        max-width: 700px;
        margin: 0 auto;
    }

    .contact-form {
        background: white;
        padding: 3rem;
        border-radius: var(--border-radius);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 600;
        color: var(--color-dark);
    }

    input,
    textarea {
        width: 100%;
        padding: 0.8rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-family: var(--font-body);
        font-size: 1rem;
    }

    input:focus,
    textarea:focus {
        border-color: var(--color-primary);
        outline: none;
    }

    .btn-block {
        width: 100%;
        cursor: pointer;
    }

    @media (max-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        .contact-form {
            padding: 1.5rem;
        }
    }
</style>
