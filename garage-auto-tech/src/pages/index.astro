---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Garage Auto-Tech S M | Mécanique Générale Longueuil">
	<main>
		<!-- Hero Section -->
		<section class="hero">
			<div class="hero-overlay"></div>
			<div class="container hero-content animate-fade-in">
				<div class="hero-logo-container mb-md">
					<span class="hero-text-red">Garage</span>
					<span class="hero-text-gold">Auto-Tech</span>
					<span class="hero-text-red">S.M.</span>
				</div>
				<h1>
					L'Expertise Automobile <br /><span class="text-gradient"
						>De Confiance</span
					>
				</h1>

				<p class="hero-subtitle">
					Plus de 35 ans d'expérience au service de votre sécurité. <br
						class="hidden-mobile"
					/>
					Mécanique Générale • Pneus • Entretiens
				</p>

				<div class="hero-actions">
					<a href="tel:450-646-0664" class="btn">450-646-0664</a>
					<a href="#services" class="btn btn-outline">Nos Services</a>
				</div>
			</div>
		</section>

		<!-- Brands Section -->
		<section class="brands-section">
			<div class="container">
				<p class="text-center text-muted">
					Experts avec toutes les grandes marques
				</p>
				<div class="brands-grid">
					<img
						src="https://cdn.simpleicons.org/audi/white"
						alt="Audi"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/volkswagen/white"
						alt="Volkswagen"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/bmw/white"
						alt="BMW"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/chrysler/white"
						alt="Chrysler"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/ford/white"
						alt="Ford"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/honda/white"
						alt="Honda"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/toyota/white"
						alt="Toyota"
						class="brand-logo"
					/>
					<img
						src="https://cdn.simpleicons.org/mitsubishi/white"
						alt="Mitsubishi"
						class="brand-logo"
					/>
				</div>
			</div>
		</section>

		<!-- Features / Intro -->
		<section
			class="section-padding"
			id="about"
			style="background-color: var(--color-darker);"
		>
			<div class="container">
				<div class="grid-2">
					<div class="content-block fade-up">
						<small
							class="text-primary text-uppercase"
							style="letter-spacing: 2px;">À Propos de Nous</small
						>
						<h2 class="mb-lg">
							Votre Garage de Quartier à Longueuil
						</h2>
						<p
							class="text-muted"
							style="font-size: 1.1rem; margin-bottom: 2rem;"
						>
							Chez <strong>Garage Auto-Tech S M</strong>, nous
							combinons expertise technique et service client
							exceptionnel. Situé au cœur de Longueuil, nous
							sommes dédiés à assurer la sécurité et la
							performance de votre véhicule.
						</p>
						<ul class="feature-list">
							<li class="fade-up stagger-1">
								<span class="text-primary">✓</span> Service transparent
								et honnête
							</li>
							<li class="fade-up stagger-2">
								<span class="text-primary">✓</span> Techniciens certifiés
							</li>
							<li class="fade-up stagger-3">
								<span class="text-primary">✓</span> Équipement de
								diagnostic moderne
							</li>
						</ul>
					</div>
					<div class="image-block fade-up stagger-2">
						<img
							src="/images/garage-interior.jpg"
							alt="Intérieur du Garage Auto-Tech S M"
							class="about-image"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Experts Section -->
		<section class="section-experts">
			<div class="container">
				<div class="text-center mb-lg fade-up">
					<small class="text-primary text-uppercase"
						>Notre Équipe</small
					>
					<h2>Nos Mécaniciens Spécialisés</h2>
				</div>
				<div class="experts-grid">
					<div class="expert-card fade-up stagger-1">
						<div class="expert-img-wrapper">
							<img
								src="/images/mechanic-2.png"
								alt="Mécanicien spécialiste"
								class="expert-img"
							/>
						</div>
						<div class="expert-info">
							<h3>Expertise Moteur</h3>
							<p>Diagnostic précis et réparation complexe.</p>
						</div>
					</div>
					<div class="expert-card fade-up stagger-2">
						<div class="expert-img-wrapper">
							<img
								src="/images/mechanic-1.jpg"
								alt="Mécanicien pneus"
								class="expert-img"
							/>
						</div>
						<div class="expert-info">
							<h3>Service Rapide</h3>
							<p>Installation de pneus et maintenance.</p>
						</div>
					</div>
					<div class="expert-card fade-up stagger-3">
						<div class="expert-img-wrapper">
							<img
								src="/images/mechanic-3.jpg"
								alt="Diagnostic"
								class="expert-img"
							/>
						</div>
						<div class="expert-info">
							<h3>Minutie & Détail</h3>
							<p>Travail soigné pour l'électronique.</p>
						</div>
					</div>
					<div class="expert-card fade-up stagger-4">
						<div class="expert-img-wrapper">
							<img
								src="/images/mechanic-4.jpg"
								alt="Équipe"
								class="expert-img"
							/>
						</div>
						<div class="expert-info">
							<h3>Une Équipe Passionnée</h3>
							<p>Service courtois et ambiance conviviale.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Services -->
		<section id="services" class="section-padding">
			<div class="container">
				<div class="text-center mb-lg fade-up">
					<small class="text-primary text-uppercase"
						>Nos Services</small
					>
					<h2>Solutions Complètes</h2>
				</div>

				<div class="services-grid">
					<div class="service-card fade-up stagger-1">
						<div class="service-image-container">
							<img
								src="/images/services/mechanic-general.jpg"
								alt="Mécanique Générale"
								class="service-image"
							/>
						</div>
						<div class="service-content">
							<h3>Mécanique Générale</h3>
							<p>
								Réparations complètes pour toutes marques et
								modèles. Moteur, transmission, et plus.
							</p>
						</div>
					</div>
					<div class="service-card fade-up stagger-2">
						<div class="service-image-container">
							<img
								src="/images/services/brakes-suspension.png"
								alt="Freins et Suspension"
								class="service-image"
							/>
						</div>
						<div class="service-content">
							<h3>Freins et Suspension</h3>
							<p>
								Entretien des freins, plaquettes, disques et
								système de suspension pour votre sécurité.
							</p>
						</div>
					</div>
					<div class="service-card fade-up stagger-3">
						<div class="service-image-container">
							<img
								src="/images/services/electronic-diagnostic.png"
								alt="Diagnostic Électronique"
								class="service-image"
							/>
						</div>
						<div class="service-content">
							<h3>Diagnostic Électronique</h3>
							<p>
								Identification précise des problèmes grâce à nos
								outils de diagnostic de pointe.
							</p>
						</div>
					</div>
					<div class="service-card fade-up stagger-1">
						<div class="service-image-container">
							<img
								src="/images/services/tires-wheels.png"
								alt="Pneus et Roues"
								class="service-image"
							/>
						</div>
						<div class="service-content">
							<h3>Pneus et Roues</h3>
							<p>
								Vente, installation et balancement de pneus.
								Changement saisonnier rapide.
							</p>
						</div>
					</div>
					<div class="service-card fade-up stagger-2">
						<div class="service-image-container">
							<img
								src="/images/services/oil-change.png"
								alt="Changement d'Huile"
								class="service-image"
							/>
						</div>
						<div class="service-content">
							<h3>Changement d'Huile</h3>
							<p>
								Maintenance régulière pour prolonger la durée de
								vie de votre moteur.
							</p>
						</div>
					</div>
					<div class="service-card fade-up stagger-3">
						<div class="service-image-container">
							<img
								src="/images/services/ac-service.png"
								alt="Climatisation"
								class="service-image"
							/>
						</div>
						<div class="service-content">
							<h3>Climatisation</h3>
							<p>
								Entretien et réparation de systèmes d'air
								climatisé.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CTA / Map -->
		<section class="cta-section">
			<div class="container text-center fade-up">
				<h2 style="color: white; margin-bottom: 1rem;">
					Besoin d'une réparation rapide ?
				</h2>
				<p style="color: rgba(255,255,255,0.9); font-size: 1.1rem;">
					Passez nous voir au 765, rue Verchères, Longueuil QC J4K 2Y8
				</p>
				<div class="btn-group">
					<a href="tel:450-646-0664" class="btn btn-white"
						>450-646-0664</a
					>
					<a
						href="https://maps.google.com/?q=765+rue+Verchères+Longueuil+QC+J4K+2Y8"
						target="_blank"
						class="btn btn-outline-white">Voir sur la carte</a
					>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Hero */
	.hero {
		min-height: 85vh;
		background-color: #05080f;
		/* Layered background: Gradient Overlay + Image */
		background-image:
			radial-gradient(
				circle at 50% 30%,
				rgba(26, 39, 66, 0.85) 0%,
				rgba(5, 8, 15, 0.98) 100%
			),
			url("https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?ixlib=rb-1.2.1&auto=format&fit=crop&w=1920&q=80");
		background-size: cover;
		background-position: center;
		background-attachment: fixed; /* Parallax effect for premium feel */
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		padding-top: 80px;
	}

	/* Subtle texture overlay for depth - kept but made more subtle */
	.hero::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
		z-index: 1;
		pointer-events: none;
	}

	/* Gradient Glow Effect */
	.hero-overlay {
		position: absolute;
		top: -20%;
		right: -10%;
		width: 600px;
		height: 600px;
		background: radial-gradient(
			circle,
			rgba(56, 189, 248, 0.15) 0%,
			transparent 70%
		);
		filter: blur(80px);
		z-index: 1;
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		max-width: 900px;
		text-align: center;
		padding: 0 1.5rem;
	}

	/* Hero Logo Special Styling */
	.hero-logo-container {
		display: flex;
		align-items: center;
		gap: 0.5rem; /* Reduced gap */
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 0.5rem; /* Reduced bottom margin */
	}

	.hero-text-red {
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: clamp(1.5rem, 5vw, 3rem);
		color: #ff0000; /* Pure, vivid red */
		text-shadow: 0 0 25px rgba(255, 0, 0, 0.6); /* Strong glow */
		text-transform: uppercase;
		letter-spacing: 0.2em;
	}

	.hero-text-gold {
		font-family: var(--font-heading);
		font-weight: 900;
		font-size: clamp(3rem, 10vw, 6.5rem);
		background: linear-gradient(
			110deg,
			#cf8f2e 10%,
			#ffd700 30%,
			#ffecb3 50%,
			#ffd700 70%,
			#cf8f2e 90%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 200% auto;
		animation: shine 3s linear infinite; /* Moving shine effect */
		text-transform: uppercase;
		letter-spacing: -0.02em;
		filter: drop-shadow(
			0 5px 15px rgba(0, 0, 0, 0.8)
		); /* Deep shadow for contrast */
		position: relative;
		z-index: 1;
	}

	.hero-text-sm {
		font-size: clamp(2rem, 6vw, 4rem);
	}

	@media (min-width: 768px) {
		.hero-logo-container {
			flex-direction: row;
			align-items: baseline;
			gap: 1.5rem;
		}
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.5rem);
		margin-bottom: 1.5rem;
		line-height: 1.2;
		font-weight: 700;
	}

	.text-gradient {
		background: linear-gradient(90deg, #fff, #94a3b8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero-subtitle {
		font-size: clamp(1.1rem, 3vw, 1.4rem);
		color: var(--color-text-muted);
		margin-bottom: 3rem;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.hero-actions {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		justify-content: center;
		align-items: center;
	}

	@media (min-width: 480px) {
		.hero-actions {
			flex-direction: row;
		}
	}

	.btn {
		width: 100%;
		max-width: 280px;
		box-shadow: 0 4px 20px rgba(255, 77, 77, 0.3);
		font-size: 1.1rem;
		padding: 1rem 2rem;
	}

	.btn-outline {
		width: 100%;
		max-width: 280px;
		border-color: rgba(255, 255, 255, 0.2);
		color: white;
	}

	.btn-outline:hover {
		background: white;
		color: var(--color-dark);
		border-color: white;
	}

	/* Brands Section */
	.brands-section {
		padding: 3rem 0;
		background: #020617;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
		z-index: 2;
	}

	.text-muted {
		color: var(--color-text-muted);
		font-size: 0.85rem;
		letter-spacing: 2px;
		margin-bottom: 2rem;
		text-transform: uppercase;
		font-weight: 600;
	}

	.brands-grid {
		display: flex;
		justify-content: center;
		align-items: center;
		flex-wrap: wrap;
		gap: 2rem;
	}

	@media (min-width: 768px) {
		.brands-grid {
			justify-content: space-between;
		}
	}

	.brand-logo {
		height: 35px;
		width: auto;
		filter: grayscale(100%) opacity(0.5);
		transition: var(--transition);
	}

	.brand-logo:hover {
		filter: grayscale(0%) opacity(1);
		transform: scale(1.1);
	}

	/* Sections General */
	.section-padding {
		padding: 5rem 0;
	}

	/* Services Section Overhaul */
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	.service-card {
		background: var(--color-card-bg);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: var(--border-radius);
		overflow: hidden;
		transition: var(--transition);
		position: relative;
		group: true;
	}

	.service-card:hover {
		transform: translateY(-8px);
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.1);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
	}

	.service-image-container {
		height: 220px;
		overflow: hidden;
		position: relative;
	}

	.service-image-container::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 50%;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
	}

	.service-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.service-card:hover .service-image {
		transform: scale(1.1);
	}

	.service-content {
		padding: 2rem;
		position: relative;
	}

	.service-card h3 {
		font-size: 1.5rem;
		margin-bottom: 0.8rem;
		color: white;
		transition: var(--transition);
	}

	.service-card:hover h3 {
		color: var(--color-primary);
	}

	.service-card p {
		color: var(--color-text-muted);
		line-height: 1.6;
		font-size: 0.95rem;
		margin-bottom: 0;
	}

	/* Decoration line */
	.service-card::before {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 3px;
		background: var(--color-primary);
		transition: width 0.3s ease;
	}

	.service-card:hover::before {
		width: 100%;
	}

	/* Experts Section */
	.section-experts {
		background: linear-gradient(180deg, var(--color-dark) 0%, #0f1929 100%);
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		padding: 5rem 0;
	}

	.experts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2.5rem;
	}

	.expert-card {
		background: rgba(255, 255, 255, 0.02);
		border-radius: var(--border-radius);
		padding: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.03);
		transition: var(--transition);
	}

	.expert-card:hover {
		background: rgba(255, 255, 255, 0.04);
		transform: translateY(-5px);
	}

	.expert-img-wrapper {
		border-radius: var(--border-radius);
		overflow: hidden;
		height: 300px;
		margin-bottom: 1.5rem;
	}

	.expert-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.expert-info {
		text-align: center;
	}

	.expert-info h3 {
		color: white;
		font-size: 1.3rem;
		margin-bottom: 0.5rem;
	}

	.expert-info p {
		color: var(--color-text-muted);
		font-size: 0.9rem;
	}

	/* Feature Section */
	.grid-2 {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
	}

	@media (min-width: 900px) {
		.grid-2 {
			grid-template-columns: 1fr 1fr;
			gap: 5rem;
		}
	}

	.about-image {
		width: 100%;
		border-radius: var(--border-radius-lg);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.feature-list {
		margin-top: 2rem;
		display: grid;
		gap: 1rem;
	}

	.feature-list li {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 1.1rem;
		color: var(--color-text);
		padding: 1rem;
		background: rgba(255, 255, 255, 0.03);
		border-radius: var(--border-radius);
	}

	/* CTA */
	.cta-section {
		background: linear-gradient(135deg, var(--color-primary), #d90429);
		padding: 5rem 0;
		position: relative;
		overflow: hidden;
	}

	.cta-section::after {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
