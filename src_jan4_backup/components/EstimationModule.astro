                                    fieldPhone.style.display = "block";
                                    fieldEmail.style.display = "none";
                                    inputPhone.required = true;
                                    inputEmail.required = false;

                                    // Update label text for SMS
                                    const phoneLabelText =
                                        document.getElementById(
                                            "label-phone-text",
                                        );
                                    if (phoneLabelText)
                                        phoneLabelText.innerText =
                                            "Téléphone (mobile pour SMS) *";
                                } else {
                                    // Style Email as active
                                    labelEmail.style.background = "white";
                                    labelEmail.style.fontWeight = "600";
                                    labelEmail.style.color = "#1a237e";
                                    labelEmail.style.boxShadow =
                                        "0 2px 8px rgba(0,0,0,0.1)";

                                    labelSMS.style.background = "transparent";
                                    labelSMS.style.fontWeight = "500";
                                    labelSMS.style.color = "#666";
                                    labelSMS.style.boxShadow = "none";

                                    // Show/hide fields
                                    fieldEmail.style.display = "block";
                                    fieldPhone.style.display = "block"; // Always show Phone
                                    inputEmail.required = true;
                                    inputPhone.required = true; // Always require Phone

                                    // Update label text for Email (Remove "mobile pour SMS")
                                    const phoneLabelText =
                                        document.getElementById(
                                            "label-phone-text",
                                        );
                                    if (phoneLabelText)
                                        phoneLabelText.innerText =
                                            "Téléphone *";
                                }
                            });
                        });
                    }

                    // Form Submission Logic
                    const contactForm = document.getElementById("contact-form");
                    if (contactForm) {
                        contactForm.addEventListener("submit", async (e) => {
                            e.preventDefault();
                            console.log("Desktop Form Submit Triggered");

                            try {
                                const inputName = document.getElementById(
                                    "input-name",
                                ) as HTMLInputElement;
                                const inputCity = document.getElementById(
                                    "input-city",
                                ) as HTMLInputElement;
                                const inputNotes = document.getElementById(
                                    "input-notes",
                                ) as HTMLTextAreaElement;
                                const inputAddress = document.getElementById(
                                    "input-address",
                                ) as HTMLInputElement;

                                const deliveryMethod = (
                                    document.querySelector(
                                        'input[name="delivery"]:checked',
                                    ) as HTMLInputElement
                                )?.value;

                                if (!inputName || !deliveryMethod) return;

                                const name = inputName.value;
                                const city = inputCity?.value || "";
                                const address = inputAddress?.value || "";
                                const notes = inputNotes?.value || "";
                                const phone = inputPhone?.value || "";
                                const email = inputEmail?.value || "";

                                // Get summary of selected items
                                const summary =
                                    STATE.lastCartItems
                                        ?.map(
                                            (item) =>
                                                `${item.label}: ${item.price.toFixed(2)}$`,
                                        )
                                        .join("\n") || "";

                                const total = STATE.total || 0;

                                // Build message
                                const message = `Nouvelle demande d'estimation\n\nNom: ${name}\nVille: ${city}\nAdresse: ${address}\n${deliveryMethod === "sms" ? "Téléphone" : "Email"}: ${deliveryMethod === "sms" ? phone : email}\n\nDétails:\n${summary}\n\nTOTAL: ${total.toFixed(2)}$${notes ? "\n\nNotes: " + notes : ""}`;

                                // Generate PDF
                                // Calculate unique service images
                                const uniqueImages = new Set<string>();
                                (STATE.lastCartItems || []).forEach((item) => {
                                    const img = getItemImage(item.rawId);
                                    if (img) uniqueImages.add(img);
                                });

                                const pdfData: EstimationData = {
                                    clientName: name,
                                    clientEmail: email,
                                    clientPhone: phone,
                                    clientCity: city,
                                    clientAddress: address, // New Address Field
                                    clientNotes: notes,
                                    items: STATE.lastCartItems || [],
                                    total: STATE.total || 0,
                                    lang: STATE.lang,
                                    serviceImages: Array.from(uniqueImages),
                                };
                                console.log(
                                    "Calling generateEstimationPDF from Desktop...",
                                );
                                const pdfBlob =
                                    await generateEstimationPDF(pdfData);

                                console.log(
                                    "generateEstimationPDF returned. Sending to API...",
                                );

                                // SEND TO API
                                const formData = new FormData();
                                formData.append(
                                    "pdf",
                                    pdfBlob,
                                    `Estimation_${name.replace(/\s+/g, "_")}.pdf`,
                                );
                                formData.append("clientName", name);
                                formData.append("clientEmail", email);
                                formData.append("clientPhone", phone);
                                formData.append("clientCity", city);
                                formData.append("clientAddress", address); // New Address Field
                                formData.append("clientNotes", notes);
                                formData.append(
                                    "deliveryMethod",
                                    deliveryMethod,
                                );

                                const response = await fetch(
                                    "/api/send-estimate",
                                    {
                                        method: "POST",
                                        body: formData,
                                    },
                                );

                                if (response.ok) {
                                    alert(
                                        STATE.lang === "fr"
                                            ? `✅ Demande envoyée avec succès!\n\nVotre estimation a été téléchargée et envoyée par courriel.`
                                            : `✅ Request sent successfully!\n\nYour estimate has been downloaded and emailed to you.`,
                                    );
                                } else {
                                    const errText = await response.text();
                                    console.error("API Error:", errText);
                                    throw new Error("Erreur API Email");
                                }

                                console.log("Form submitted:", {
                                    name,
                                    city,
                                    phone,
                                    email,
                                    notes,
                                    deliveryMethod,
                                    summary,
                                    total,
                                });
                            } catch (err) {
                                console.error("Desktop Submit Error:", err);
                                alert("FATAL ERROR: " + err);
                            }
                        });
                    }

                    const closeModalBtn =
                        document.getElementById("close-modal-btn");
                    const closeOverlayBtn = document.getElementById(
                        "close-modal-btn-overlay",
                    );
                    const widget = document.getElementById("estimation-widget");

                    const closeFunc = () => {
                        if (widget) widget.style.display = "none";
                        // Show sticky bar again
                        const sticky = document.querySelector(
                            ".mobile-sticky-bar",
                        ) as HTMLElement;
                        if (sticky) sticky.style.display = "flex";
                    };

                    if (closeModalBtn) closeModalBtn.onclick = closeFunc;
                    if (closeOverlayBtn) closeOverlayBtn.onclick = closeFunc;

                    // Logic to HIDE sticky bar when opening
                    const openEstBtn = document.getElementById(
                        "btn-open-estimation",
                    );
                    if (openEstBtn) {
                        // We need to attach this logic or ensure module self-manages.
                        // Since this init runs once, we can override the click or add a MutationObserver on widget display?
                        // The open button click is in Header.astro mostly...
                        // Let's use the MutationObserver below to handle it robustly!
                    }

                    // Close when clicking outside (on the overlay itself)
                    if (widget) {
                        widget.onclick = (e) => {
                            if (e.target === widget) {
                                closeFunc();
                            }
                        };
                    }

                    if (els.btnNext) els.btnNext.onclick = nextStep;
                    if (els.btnNext) els.btnNext.onclick = nextStep;
                    if (els.btnBack) els.btnBack.onclick = prevStep;

                    // Mobile Back Buttons
                    const mbBack = document.getElementById("mobile-back-btn");
                    if (mbBack) mbBack.onclick = prevStep;
                    const mbBackReview = document.getElementById(
                        "mobile-back-btn-review",
                    );
                    if (mbBackReview) mbBackReview.onclick = prevStep;
                    const mbBackContact = document.getElementById(
                        "mobile-back-btn-contact",
                    );
                    if (mbBackContact) mbBackContact.onclick = prevStep;
                    const mbBackSummary = document.getElementById(
                        "mobile-back-btn-summary",
                    ); // The old one, maybe unused now?
                    if (mbBackSummary) mbBackSummary.onclick = prevStep;

                    if (els.btnAddMore) {
                        els.btnAddMore.onclick = () => {
                            STATE.step = 1;
                            updateUI();
                            window.scrollTo({ top: 0, behavior: "smooth" });
                            const grid =
                                document.getElementById("services-container");
                            if (grid) {
                                grid.classList.remove("blink-highlight");
                                void grid.offsetWidth;
                                grid.classList.add("blink-highlight");
                                setTimeout(
                                    () =>
                                        grid.classList.remove(
                                            "blink-highlight",
                                        ),
                                    2000,
                                );
                            }
                        };
                    }

                    if (els.servicesContainer) {
                        els.servicesContainer.addEventListener("click", (e) => {
                            const target = e.target as HTMLElement;
                            const card = target.closest(".service-card");
                            if (card && els.servicesContainer?.contains(card)) {
                                const id = card.getAttribute("data-service-id");
                                if (id) {
                                    console.log(
                                        "Service Clicked via Delegation:",
                                        id,
                                    );
                                    toggleService(id, card as HTMLElement);
                                }
                            }
                        });
                    }

                    window.renderServices(); // Call Global Render

                    // Mobile Cart Toggle
                    const btnToggleDetails =
                        document.getElementById("btn-toggle-details");
                    const sideBar = document.querySelector(".modal-sidebar");
                    if (btnToggleDetails && sideBar) {
                        btnToggleDetails.onclick = () => {
                            sideBar.classList.toggle("expanded");
                            const isExpanded =
                                sideBar.classList.contains("expanded");
                            const txt =
                                STATE.lang === "fr"
                                    ? "Voir détails"
                                    : "View Details";
                            btnToggleDetails.innerHTML = isExpanded
                                ? `${txt} &#9660;` // Down Arrow
                                : `${txt} &#9650;`; // Up Arrow
                        };
                    }

                    refreshAllText();

                    // SCROLL LOCK OBSERVER
                    const estWidget =
                        document.getElementById("estimation-widget");
                    if (estWidget) {
                        const observer = new MutationObserver((mutations) => {
                            mutations.forEach((mutation) => {
                                if (
                                    mutation.type === "attributes" &&
                                    mutation.attributeName === "style"
                                ) {
                                    const display = estWidget.style.display;
                                    if (
                                        display === "flex" ||
                                        display === "block"
                                    ) {
                                        document.body.style.overflow = "hidden"; // Lock scroll
                                        const sticky = document.querySelector(
                                            ".mobile-sticky-bar",
                                        ) as HTMLElement;
                                        if (sticky)
                                            sticky.style.display = "none"; // Hide sticky bar
                                    } else {
                                        document.body.style.overflow = ""; // Unlock scroll
                                        const sticky = document.querySelector(
                                            ".mobile-sticky-bar",
                                        ) as HTMLElement;
                                        if (sticky)
                                            sticky.style.display = "flex"; // Restore sticky bar
                                    }
                                }
                            });
                        });
                        observer.observe(estWidget, {
                            attributes: true,
                            attributeFilter: ["style"],
                        });
                    }

                    // --- MOBILE INIT LOGIC ---
                    function toggleMobileStep(stepIndex: number) {
                        STATE.step = stepIndex;
                        const steps = document.querySelectorAll(".mobile-step");
                        steps.forEach((s) => s.classList.remove("active"));

                        if (stepIndex === 1)
                            document
                                .getElementById("mobile-step-services")
                                ?.classList.add("active");
                        if (stepIndex === 2) {
                            document
                                .getElementById("mobile-step-details")
                                ?.classList.add("active");
                            renderMobileDetails();
                        }
                        if (stepIndex === 3) {
                            document
                                .getElementById("mobile-step-summary-view")
                                ?.classList.add("active");
                            renderSummaryPage();
                        }
                        if (stepIndex === 4) {
                            document
                                .getElementById("mobile-step-contact")
                                ?.classList.add("active");
                        }

                        // Button State
                        const btn = document.getElementById("mobile-next-btn");
                        if (btn) {
                            if (stepIndex === 1)
                                btn.textContent = t({
                                    fr: "Continuer",
                                    en: "Next",
                                });
                            else if (stepIndex === 2)
                                btn.textContent = t({
                                    fr: "Voir sommaire & prix",
                                    en: "View Summary",
                                });
                            else if (stepIndex === 3)
                                btn.textContent = t({
                                    fr: "Finaliser la demande",
                                    en: "Finalize Request",
                                });
                            else if (stepIndex === 4) {
                                btn.style.display = "none"; // Hide on form step
                            } else {
                                btn.style.display = "block";
                            }
                        }

                        // Hide Total on Step 3 or 4
                        const footer = document.querySelector(
                            ".mobile-app-footer",
                        ) as HTMLElement;
                        if (footer)
                            footer.style.display =
                                stepIndex === 3 || stepIndex === 4
                                    ? "none"
                                    : "flex";
                    }

                    const mobClose =
                        document.getElementById("mobile-close-btn");
                    if (mobClose) {
                        mobClose.onclick = () => {
                            const v = document.getElementById(
                                "mobile-estimation-view",
                            );
                            if (v) v.style.display = "none";
                            document.body.style.overflow = "";
                            // Show sticky bar
                            const s = document.querySelector(
                                ".mobile-sticky-bar",
                            ) as HTMLElement;
                            if (s) s.style.display = "flex";
                        };
                    }

                    const mobNext = document.getElementById("mobile-next-btn");
                    if (mobNext) {
                        mobNext.onclick = () => {
                            if (STATE.step === 1) toggleMobileStep(2);
                            else if (STATE.step === 2) toggleMobileStep(3);
                            else if (STATE.step === 3) toggleMobileStep(4);
                        };
                    }
                    const mobBack = document.getElementById("mobile-back-btn");
                    if (mobBack) mobBack.onclick = () => toggleMobileStep(1);

                    const mobBackSum = document.getElementById(
                        "mobile-back-btn-summary",
                    );
                    if (mobBackSum)
                        mobBackSum.onclick = () => toggleMobileStep(2);

                    // Mobile Delivery Toggle Logic
                    const mobLabelSMS =
                        document.getElementById("mobile-label-sms");
                    const mobLabelEmail =
                        document.getElementById("mobile-label-email");
                    const mobFieldPhone =
                        document.getElementById("mobile-field-phone");
                    const mobFieldEmail =
                        document.getElementById("mobile-field-email");
                    const mobInputEmail = document.getElementById(
                        "mobile-input-email",
                    ) as HTMLInputElement;
                    const mobInputPhone = document.getElementById(
                        "mobile-input-phone",
                    ) as HTMLInputElement;

                    if (
                        mobLabelSMS &&
                        mobLabelEmail &&
                        mobFieldPhone &&
                        mobFieldEmail
                    ) {
                        const mobDeliveryRadios = document.querySelectorAll(
                            'input[name="mobile-delivery"]',
                        );

                        mobDeliveryRadios.forEach((radio) => {
                            radio.addEventListener("change", (e) => {
                                const target = e.target as HTMLInputElement;
                                if (target.value === "sms") {
                                    // Style SMS as active
                                    mobLabelSMS.style.background = "white";
                                    mobLabelSMS.style.fontWeight = "600";
                                    mobLabelSMS.style.color = "#1a237e";
                                    mobLabelSMS.style.boxShadow =
                                        "0 2px 5px rgba(0,0,0,0.05)";

                                    mobLabelEmail.style.background =
                                        "transparent";
                                    mobLabelEmail.style.fontWeight = "500";
                                    mobLabelEmail.style.color = "#666";
                                    mobLabelEmail.style.boxShadow = "none";

                                    // Show/hide fields
                                    mobFieldPhone.style.display = "block";
                                    mobFieldEmail.style.display = "none";

                                    // Update placeholder for SMS
                                    const mobPhoneInput =
                                        document.getElementById(
                                            "mobile-input-phone",
                                        ) as HTMLInputElement;
                                    if (mobPhoneInput)
                                        mobPhoneInput.placeholder =
                                            "Téléphone (mobile pour SMS) *";
                                } else {
                                    // Style Email as active
                                    mobLabelEmail.style.background = "white";
                                    mobLabelEmail.style.fontWeight = "600";
                                    mobLabelEmail.style.color = "#1a237e";
                                    mobLabelEmail.style.boxShadow =
                                        "0 2px 5px rgba(0,0,0,0.05)";

                                    mobLabelSMS.style.background =
                                        "transparent";
                                    mobLabelSMS.style.fontWeight = "500";
                                    mobLabelSMS.style.color = "#666";
                                    mobLabelSMS.style.boxShadow = "none";

                                    // Show/hide fields
                                    mobFieldEmail.style.display = "block";
                                    mobFieldPhone.style.display = "block"; // Always show Phone

                                    // Update placeholder for Email (Remove "mobile pour SMS")
                                    const mobPhoneInput =
                                        document.getElementById(
                                            "mobile-input-phone",
                                        ) as HTMLInputElement;
                                    if (mobPhoneInput)
                                        mobPhoneInput.placeholder =
                                            "Téléphone *";
                                }
                            });
                        });
                    }

                    const mobSubmit =
                        document.getElementById("mobile-submit-btn");
                    if (mobSubmit) {
                        mobSubmit.onclick = async () => {
                            try {
                                const nameInput = document.getElementById(
                                    "mobile-input-name",
                                ) as HTMLInputElement;
                                const cityInput = document.getElementById(
                                    "mobile-input-city",
                                ) as HTMLInputElement;
                                const notesInput = document.getElementById(
                                    "mobile-input-notes",
                                ) as HTMLTextAreaElement;
                                const phoneInput = document.getElementById(
                                    "mobile-input-phone",
                                ) as HTMLInputElement;
                                const emailInput = document.getElementById(
                                    "mobile-input-email",
                                ) as HTMLInputElement;
                                const addressInput = document.getElementById(
                                    "mobile-input-address",
                                ) as HTMLInputElement;

                                const deliveryMethod = (
                                    document.querySelector(
                                        'input[name="mobile-delivery"]:checked',
                                    ) as HTMLInputElement
                                )?.value;

                                if (!nameInput || !nameInput.value) {
                                    alert(
                                        STATE.lang === "fr"
                                            ? "Veuillez entrer votre nom."
                                            : "Please enter your name.",
                                    );
                                    return;
                                }
                                if (!deliveryMethod) return;

                                if (
                                    deliveryMethod === "sms" &&
                                    !phoneInput.value
                                ) {
                                    alert(
                                        STATE.lang === "fr"
                                            ? "Veuillez entrer votre numéro de téléphone."
                                            : "Please enter your phone number.",
                                    );
                                    return;
                                }
                                if (deliveryMethod === "email") {
                                    if (!emailInput.value) {
                                        alert(
                                            STATE.lang === "fr"
                                                ? "Veuillez entrer votre courriel."
                                                : "Please enter your email.",
                                        );
                                        return;
                                    }
                                    // Also check phone for email delivery
                                    if (!phoneInput.value) {
                                        alert(
                                            STATE.lang === "fr"
                                                ? "Veuillez entrer votre numéro de téléphone."
                                                : "Please enter your phone number.",
                                        );
                                        return;
                                    }
                                }

                                const name = nameInput.value;
                                const city = cityInput?.value || "";
                                const address = addressInput?.value || "";
                                const notes = notesInput?.value || "";
                                const phone = phoneInput?.value || "";
                                const email = emailInput?.value || "";

                                // Get summary
                                const summary =
                                    STATE.lastCartItems
                                        ?.map(
                                            (item) =>
                                                `${item.label}: ${item.price.toFixed(2)}$`,
                                        )
                                        .join("\n") || "";

                                const total = STATE.total || 0;

                                // Generate PDF
                                console.log("Starting PDF Generation...");
                                // Calculate unique service images
                                const uniqueImages = new Set<string>();
                                (STATE.lastCartItems || []).forEach((item) => {
                                    const img = getItemImage(item.rawId);
                                    if (img) uniqueImages.add(img);
                                });

                                const pdfData: EstimationData = {
                                    clientName: name,
                                    clientEmail: email,
                                    clientPhone: phone,
                                    clientCity: city,
                                    clientAddress: address, // New Address Field
                                    clientNotes: notes,
                                    items: STATE.lastCartItems || [],
                                    total: STATE.total || 0,
                                    lang: STATE.lang,
                                    serviceImages: Array.from(uniqueImages),
                                };
                                const pdfBlob =
                                    await generateEstimationPDF(pdfData);
                                console.log(
                                    "PDF Generation finished. Sending to API...",
                                );

                                // SEND TO API
                                const formData = new FormData();
                                formData.append(
                                    "pdf",
                                    pdfBlob,
                                    `Estimation_${name.replace(/\s+/g, "_")}.pdf`,
                                );
                                formData.append("clientName", name);
                                formData.append("clientEmail", email);
                                formData.append("clientPhone", phone);
                                formData.append("clientCity", city);
                                formData.append("clientAddress", address); // New Address Field
                                formData.append("clientNotes", notes);
                                formData.append(
                                    "deliveryMethod",
                                    deliveryMethod,
                                );

                                const response = await fetch(
                                    "/api/send-estimate",
                                    {
                                        method: "POST",
                                        body: formData,
                                    },
                                );

                                if (response.ok) {
                                    alert(
                                        STATE.lang === "fr"
                                            ? `✅ Demande envoyée avec succès!\n\nVotre estimation a été téléchargée et envoyée par courriel.`
                                            : `✅ Request sent successfully!\n\nYour estimate has been downloaded and emailed to you.`,
                                    );
                                } else {
                                    throw new Error("Erreur API Email Mobile");
                                }

                                console.log("Mobile Form submitted:", {
                                    name,
                                    city,
                                    phone,
                                    email,
                                    notes,
                                    deliveryMethod,
                                    summary,
                                    total,
                                });

                                // Close modal
                                const v = document.getElementById(
                                    "mobile-estimation-view",
                                );
                                if (v) v.style.display = "none";
                                document.body.style.overflow = "";
                                const s = document.querySelector(
                                    ".mobile-sticky-bar",
                                ) as HTMLElement;
                                if (s) s.style.display = "flex";
                            } catch (e) {
                                console.error("Mobile Submit Error:", e);
                                alert("Erreur: " + e);
                            }
                        };
                    }

                    // Mobile Intercept Observer Removed to prevent conflicts
                } catch (err: any) {
                    console.error(err);
                    const errDiv = document.createElement("div");
                    errDiv.style.position = "fixed";
                    errDiv.style.top = "0";
                    errDiv.style.left = "0";
                    errDiv.style.width = "100%";
                    errDiv.style.height = "100%";
                    errDiv.style.backgroundColor = "white";
                    errDiv.style.color = "red";
                    errDiv.style.zIndex = "10000";
                    errDiv.style.padding = "20px";
                    errDiv.style.fontSize = "16px";
                    errDiv.style.overflow = "auto";
                    errDiv.innerHTML =
                        "<h1>FATAL ERROR</h1><pre>" + err.stack + "</pre>";
                    document.body.appendChild(errDiv);
                }
            }

            // Initialize when DOM is ready
            document.addEventListener("DOMContentLoaded", init);

            // Additional Safety: If component loads late (Astro Islands)
            if (
                document.readyState === "complete" ||
                document.readyState === "interactive"
            ) {
                setTimeout(init, 100);
            }

            // Duplicate openEstimationWidget removed. Logic is now handled by the function added earlier.
        </script>
    </div>
</div>
