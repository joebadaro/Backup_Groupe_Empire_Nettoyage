---
// src/components/EstimationModule.astro
---

<!-- Main Container (Overlay) -->
<div id="estimation-widget" class="modal-overlay" style="display:none;">
    <div class="empire-modal">
        <!-- === LEFT: MAIN PROCESS === -->
        <div class="modal-main">
            <!-- Header -->
            <header class="modal-header">
                <h2 id="modal-title">Estimation Gratuite</h2>
                <div class="header-actions">
                    <button id="lang-toggle" class="lang-btn">EN</button>
                    <button
                        id="close-modal-btn"
                        class="close-btn"
                        title="Fermer">&times;</button
                    >
                </div>
            </header>

            <!-- Progress -->
            <div class="progress-bar">
                <div
                    id="progress-fill"
                    class="progress-fill"
                    style="width: 25%"
                >
                </div>
            </div>

            <!-- Content Area -->
            <div class="modal-content">
                <!-- STEP 1: SERVICES -->
                <div id="step-services" class="step active">
                    <h3 class="text-center mb-2">Choisissez vos services</h3>
                    <div class="welcome-banner">
                        <div class="welcome-banner-icon">&#x1F3F7;&#xFE0F;</div>
                        <div class="welcome-banner-text">
                            <h4>Obtenez votre estimation immédiate</h4>
                            <p>
                                Sélectionnez les services ci-dessous pour voir
                                les tarifs et obtenir un prix approximatif pour
                                vos besoins.
                            </p>
                        </div>
                    </div>
                    <div id="services-container" class="service-grid"></div>
                </div>

                <!-- STEP 2: DETAILS -->
                <div id="step-details" class="step">
                    <button
                        class="btn-text"
                        id="btn-back-to-services"
                        style="margin-bottom:10px; cursor:pointer;"
                        title="Retour">← Retour aux services</button
                    >
                    <h3 class="text-center">Détails de sélection</h3>
                    <div id="details-container"></div>
                </div>

                <!-- STEP 3: REVIEW SUMMARY (NEW) -->
                <div id="step-summary" class="step">
                    <h3 class="text-center">Vérifiez votre commande</h3>
                    <p class="text-center text-muted">
                        Veuillez revoir les articles sélectionnés avant de
                        finaliser.
                    </p>
                    <div
                        id="summary-container"
                        style="max-height: 400px; overflow-y: auto; margin: 20px 0; border: 1px solid #eee; border-radius: 8px; padding: 15px;"
                    >
                        <!-- Comprehensive List Injected Here via renderSummaryPage() -->
                    </div>
                </div>

                <!-- STEP 4: CONTACT FORM (Previously Step 3) -->
                <div id="step-contact" class="step">
                    <h3 class="text-center" style="margin-bottom:10px;">
                        Recevoir votre estimation
                    </h3>
                    <p
                        class="text-center"
                        style="color:#666; font-size:0.95rem; margin-bottom:25px;"
                    >
                        Choisissez comment recevoir votre <strong
                            >estimation gratuite</strong
                        >
                    </p>

                    <form
                        id="contact-form"
                        style="max-width:500px; margin:0 auto;"
                    >
                        <!-- Delivery Method Toggle -->
                        <div style="margin-bottom:25px;">
                            <label
                                style="display:block; font-weight:600; margin-bottom:12px; color:#333;"
                                >Recevoir mon estimation par</label
                            >
                            <div
                                style="display:flex; gap:12px; background:#f5f5f5; padding:6px; border-radius:12px;"
                            >
                                <label
                                    style="flex:1; text-align:center; padding:12px; border-radius:8px; cursor:pointer; transition:all 0.3s; background:white; font-weight:600; color:#1a237e; box-shadow:0 2px 8px rgba(0,0,0,0.1);"
                                    id="label-sms"
                                >
                                    <input
                                        type="radio"
                                        name="delivery"
                                        value="sms"
                                        checked
                                        style="display:none;"
                                    />
                                    <svg
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        style="vertical-align:middle; margin-right:6px;"
                                    >
                                        <rect
                                            x="5"
                                            y="2"
                                            width="14"
                                            height="20"
                                            rx="2"
                                            ry="2"></rect>
                                        <line x1="12" y1="18" x2="12.01" y2="18"
                                        ></line>
                                    </svg>
                                    Texto (SMS)
                                </label>
                                <label
                                    style="flex:1; text-align:center; padding:12px; border-radius:8px; cursor:pointer; transition:all 0.3s; background:transparent; font-weight:500; color:#666;"
                                    id="label-email"
                                >
                                    <input
                                        type="radio"
                                        name="delivery"
                                        value="email"
                                        style="display:none;"
                                    />
                                    <svg
                                        width="20"
                                        height="20"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        style="vertical-align:middle; margin-right:6px;"
                                    >
                                        <path
                                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                                        ></path>
                                        <polyline points="22,6 12,13 2,6"
                                        ></polyline>
                                    </svg>
                                    Courriel
                                </label>
                            </div>
                        </div>

                        <!-- Form Fields -->
                        <div style="display:grid; gap:16px;">
                            <div>
                                <label
                                    style="display:block; font-weight:600; margin-bottom:8px; color:#333; font-size:0.9rem;"
                                    >Nom complet *</label
                                >
                                <input
                                    type="text"
                                    id="input-name"
                                    required
                                    placeholder="Jean Dupont"
                                    style="width:100%; padding:14px; border:2px solid #e0e0e0; border-radius:10px; font-size:1rem; transition:all 0.3s;"
                                    onfocus="this.style.borderColor='#3949ab'; this.style.boxShadow='0 0 0 3px rgba(57,73,171,0.1)'"
                                    onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                />
                            </div>

                            <div id="field-phone">
                                <label
                                    id="label-phone-text"
                                    style="display:block; font-weight:600; margin-bottom:8px; color:#333; font-size:0.9rem;"
                                    >Téléphone (mobile pour SMS) *</label
                                >
                                <input
                                    type="tel"
                                    id="input-phone"
                                    required
                                    placeholder="514-555-1234"
                                    style="width:100%; padding:14px; border:2px solid #e0e0e0; border-radius:10px; font-size:1rem; transition:all 0.3s;"
                                    onfocus="this.style.borderColor='#3949ab'; this.style.boxShadow='0 0 0 3px rgba(57,73,171,0.1)'"
                                    onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                />
                            </div>

                            <div id="field-email" style="display:none;">
                                <label
                                    style="display:block; font-weight:600; margin-bottom:8px; color:#333; font-size:0.9rem;"
                                    >Adresse courriel *</label
                                >
                                <input
                                    type="email"
                                    id="input-email"
                                    placeholder="exemple@email.com"
                                    style="width:100%; padding:14px; border:2px solid #e0e0e0; border-radius:10px; font-size:1rem; transition:all 0.3s;"
                                    onfocus="this.style.borderColor='#3949ab'; this.style.boxShadow='0 0 0 3px rgba(57,73,171,0.1)'"
                                    onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                />
                            </div>

                            <div>
                                <label
                                    style="display:block; font-weight:600; margin-bottom:8px; color:#333; font-size:0.9rem;"
                                    >Ville *</label
                                >
                                <input
                                    type="text"
                                    id="input-city"
                                    required
                                    placeholder="Montréal"
                                    style="width:100%; padding:14px; border:2px solid #e0e0e0; border-radius:10px; font-size:1rem; transition:all 0.3s;"
                                    onfocus="this.style.borderColor='#3949ab'; this.style.boxShadow='0 0 0 3px rgba(57,73,171,0.1)'"
                                    onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                />
                            </div>

                            <div style="margin-bottom:20px;">
                                <label
                                    style="display:block; font-weight:600; margin-bottom:8px; color:#333; font-size:0.9rem;"
                                    >Adresse complète</label
                                >
                                <input
                                    type="text"
                                    id="input-address"
                                    placeholder="Ex: 1234 Rue Principale, Apt 101"
                                    style="width:100%; padding:14px; border:2px solid #e0e0e0; border-radius:10px; font-size:1rem; transition:all 0.3s;"
                                />
                            </div>

                            <div>
                                <label
                                    style="display:block; font-weight:600; margin-bottom:8px; color:#333; font-size:0.9rem;"
                                    >Notes ou demandes spéciales</label
                                >
                                <textarea
                                    id="input-notes"
                                    rows="4"
                                    placeholder="Ex: Code de porte, chien à la maison..."
                                    style="width:100%; padding:14px; border:2px solid #e0e0e0; border-radius:10px; font-size:1rem; transition:all 0.3s; resize:vertical; font-family:inherit;"
                                    onfocus="this.style.borderColor='#3949ab'; this.style.boxShadow='0 0 0 3px rgba(57,73,171,0.1)'"
                                    onblur="this.style.borderColor='#e0e0e0'; this.style.boxShadow='none'"
                                ></textarea>
                            </div>
                        </div>
                    </form>
                </div>

                <button
                    class="btn btn-primary"
                    type="submit"
                    id="btn-confirm-request"
                    style="margin-top:25px; width:100%; padding:16px; font-size:1.05rem; font-weight:700; background:linear-gradient(135deg, #1a237e 0%, #3949ab 100%); border:none; border-radius:12px; color:white; cursor:pointer; box-shadow:0 4px 16px rgba(26,35,126,0.3); transition:all 0.3s;"
                    onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(26,35,126,0.4)'"
                    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(26,35,126,0.3)'"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        style="vertical-align:middle; margin-right:8px;"
                    >
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    Envoyer mon estimation
                </button>

                <p
                    style="text-align:center; font-size:0.85rem; color:#999; margin-top:15px;"
                >
                    Vos informations sont confidentielles et sécurisées
                </p>
            </div>

            <!-- Important Note -->
            <div
                class="sidebar-note"
                style="margin: 30px auto 0; max-width:500px;"
            >
                <div class="note-title">📋 Note importante</div>
                <div class="note-body">
                    <p style="font-size:0.9rem;">
                        Les prix incluent le nettoyage à la vapeur avec
                        shampoing et le déplacement.
                    </p>
                    <p class="note-small" style="font-size:0.85rem;">
                        Avant de commencer, le technicien fera une
                        post-inspection, vérifiera votre devis et inspectera les
                        articles. Si un produit spécialisé est nécessaire, il
                        vous en avisera avant le début.
                    </p>
                </div>
            </div>

            <!-- Footer for Nav -->
            <footer class="modal-footer">
                <button
                    id="btn-back"
                    class="btn btn-secondary hidden"
                    style="border:none; color:#777;">Retour en arrière</button
                >
                <button
                    id="btn-add-more"
                    class="btn btn-secondary hidden"
                    style="color: #007bff; border-color: #007bff;"
                    >Ajouter d'autres articles à nettoyer</button
                >
                <button
                    id="btn-next"
                    class="btn btn-primary"
                    style="width:auto;">Continuer</button
                >
            </footer>
        </div>

        <!-- === RIGHT: STICKY SIDEBAR === -->
        <div class="modal-sidebar">
            <div class="cart-title">
                <div style="display:flex; align-items:center; gap:8px;">
                    <span>Ma Sélection</span>
                    <button
                        onclick="resetEstimation()"
                        id="btn-app-reset"
                        style="background:none; border:1px solid #ddd; border-radius:4px; font-size:0.7rem; cursor:pointer; padding:2px 6px; color:#666;"
                        title="Tout effacer / Reset all"
                    >
                        Recommencer ↺
                    </button>
                </div>
                <span
                    style="font-size:0.8rem; background:#EEE; padding:2px 6px; border-radius:10px;"
                    id="cart-count">0 items</span
                >
            </div>

            <div id="cart-list" class="cart-list">
                <!-- Items appear here -->
                <div style="text-align:center; color:#999; margin-top:50px;">
                    Votre panier est vide.
                </div>
            </div>

            <!-- Promo Messages Space -->
            <div id="promo-message-area" style="margin-bottom:10px;"></div>

            <!-- Total Block -->
            <div class="cart-total-block">
                <div class="cart-total-label">Subtotal</div>
                <div
                    id="live-subtotal"
                    class="cart-live-total"
                    style="font-size: 1.2rem; color: #666; display: none;"
                >
                    $0.00
                </div>
                <div class="cart-total-label">Total Estimé</div>
                <div id="live-total" class="cart-live-total">$0.00</div>
                <button
                    id="btn-toggle-details"
                    type="button"
                    style="display:none; margin-left:10px; font-size:0.9rem; background:none; border:none; text-decoration:underline; cursor:pointer; color:#007bff; font-weight:600;"
                >
                    Voir détails &#9650;
                </button>
                <!-- Warning Message (Min Order) inserted here -->
                <div
                    id="min-msg-sidebar"
                    style="font-size:0.8rem; margin-top:5px; display:none;"
                >
                </div>
            </div>

            <div
                style="text-align:center; font-size:0.7rem; color:#999; margin-top:10px;"
            >
                Taxes en sus.
            </div>
        </div>

        <button
            id="close-modal-btn-overlay"
            class="close-btn"
            style="position: absolute; top: -15px; right: -15px; background: white; border-radius: 50%; width: 30px; height: 30px; border: 1px solid #ccc; cursor:pointer;"
            >&times;</button
        >

        <!-- === MOBILE OPTIMIZED VIEW (New) === -->
        <div
            id="mobile-estimation-view"
            class="mobile-app-view"
            style="display:none;"
        >
            <header class="mobile-app-header">
                <div class="mobile-header-left">
                    <h2 id="mobile-title">Estimation</h2>
                </div>
                <button id="mobile-close-btn" class="mobile-close-btn"
                    >&times;</button
                >
            </header>

            <div class="mobile-app-content">
                <!-- Step 1: Mobile Services List -->
                <div id="mobile-step-services" class="mobile-step active">
                    <div class="mobile-welcome">
                        <h3>Sélectionnez vos services</h3>
                        <p>Touchez pour ajouter à l'estimation.</p>
                    </div>
                    <div id="mobile-services-list" class="mobile-list"></div>
                </div>

                <!-- Step 2: Mobile Details -->
                <div id="mobile-step-details" class="mobile-step">
                    <div class="mobile-step-header">
                        <button id="mobile-back-btn" class="mobile-back-link"
                            >← Retour</button
                        >
                        <h3>Détails</h3>
                    </div>
                    <div id="mobile-details-container"></div>
                </div>

                <!-- Step 3: Mobile Review Summary (NEW) -->
                <div id="mobile-step-summary-view" class="mobile-step">
                    <div class="mobile-step-header">
                        <button
                            id="mobile-back-btn-review"
                            class="mobile-back-link">← Retour</button
                        >
                        <h3>Sommaire</h3>
                    </div>
                    <div id="mobile-summary-container" style="padding: 10px;">
                    </div>
                </div>

                <!-- Step 4: Mobile Form (Previously Step 3) -->
                <div id="mobile-step-contact" class="mobile-step">
                    <div class="mobile-step-header">
                        <button
                            id="mobile-back-btn-contact"
                            class="mobile-back-link">← Retour</button
                        >
                        <h3>Finaliser</h3>
                    </div>
                    <div style="padding-top:10px;">
                        <p style="margin-bottom:20px; color:#666;">
                            Entrez vos infos pour recevoir la soumission.
                        </p>
                        <!-- Mobile Form Container -->
                        <div id="mobile-contact-form-container">
                            <div class="mobile-form-wrapper">
                                <!-- Mobile Delivery Toggle -->
                                <div style="margin-bottom:20px;">
                                    <label
                                        style="display:block; font-weight:600; margin-bottom:10px; color:#333; font-size:0.95rem;"
                                        >Recevoir mon estimation par</label
                                    >
                                    <div
                                        style="display:flex; gap:10px; background:#f5f5f5; padding:5px; border-radius:12px;"
                                    >
                                        <label
                                            style="flex:1; text-align:center; padding:12px; border-radius:10px; transition:all 0.3s; background:white; font-weight:600; color:#1a237e; box-shadow:0 2px 5px rgba(0,0,0,0.05);"
                                            id="mobile-label-sms"
                                        >
                                            <input
                                                type="radio"
                                                name="mobile-delivery"
                                                value="sms"
                                                checked
                                                style="display:none;"
                                            />
                                            <span
                                                style="display:flex; align-items:center; justify-content:center; gap:6px;"
                                            >
                                                <svg
                                                    width="18"
                                                    height="18"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    ><path
                                                        d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                                    ></path></svg
                                                >
                                                SMS
                                            </span>
                                        </label>
                                        <label
                                            style="flex:1; text-align:center; padding:12px; border-radius:10px; transition:all 0.3s; background:transparent; font-weight:500; color:#666;"
                                            id="mobile-label-email"
                                        >
                                            <input
                                                type="radio"
                                                name="mobile-delivery"
                                                value="email"
                                                style="display:none;"
                                            />
                                            <span
                                                style="display:flex; align-items:center; justify-content:center; gap:6px;"
                                            >
                                                <svg
                                                    width="18"
                                                    height="18"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    ><path
                                                        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                                                    ></path><polyline
                                                        points="22,6 12,13 2,6"
                                                    ></polyline></svg
                                                >
                                                Courriel
                                            </span>
                                        </label>
                                    </div>
                                </div>

                                <div style="display:grid; gap:12px;">
                                    <input
                                        type="text"
                                        id="mobile-input-name"
                                        placeholder="Nom complet *"
                                        class="mobile-input"
                                        style="width:100%; padding:14px; border:1px solid #ddd; border-radius:10px; font-size:1rem;"
                                    />

                                    <div id="mobile-field-phone">
                                        <input
                                            type="tel"
                                            id="mobile-input-phone"
                                            placeholder="Téléphone (mobile pour SMS) *"
                                            class="mobile-input"
                                            style="width:100%; padding:14px; border:1px solid #ddd; border-radius:10px; font-size:1rem;"
                                        />
                                    </div>

                                    <div
                                        id="mobile-field-email"
                                        style="display:none;"
                                    >
                                        <input
                                            type="email"
                                            id="mobile-input-email"
                                            placeholder="Adresse courriel *"
                                            class="mobile-input"
                                            style="width:100%; padding:14px; border:1px solid #ddd; border-radius:10px; font-size:1rem;"
                                        />
                                    </div>

                                    <input
                                        type="text"
                                        id="mobile-input-address"
                                        placeholder="Adresse complète"
                                        class="mobile-input"
                                        style="width:100%; padding:14px; border:1px solid #ddd; border-radius:10px; font-size:1rem; margin-bottom:12px;"
                                    />

                                    <input
                                        type="text"
                                        id="mobile-input-city"
                                        placeholder="Ville *"
                                        class="mobile-input"
                                        style="width:100%; padding:14px; border:1px solid #ddd; border-radius:10px; font-size:1rem;"
                                    />

                                    <textarea
                                        id="mobile-input-notes"
                                        rows="3"
                                        placeholder="Notes (Code de porte, etc...)"
                                        class="mobile-input"
                                        style="width:100%; padding:14px; border:1px solid #ddd; border-radius:10px; font-size:1rem; resize:none; font-family:inherit;"
                                    ></textarea>
                                </div>
                            </div>
                        </div>

                        <button
                            id="mobile-submit-btn"
                            class="btn-mobile-primary"
                            style="width:100%; margin-top:20px; box-shadow:0 4px 15px rgba(26, 35, 126, 0.3);"
                        >
                            Confirmer la demande
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mobile Bottom Bar (Sticky) -->
        <footer class="mobile-app-footer">
            <div class="mobile-footer-total">
                <span class="label">Total Estimé</span>
                <span id="mobile-live-total" class="value">0.00$</span>
            </div>
            <button id="mobile-next-btn" class="btn-mobile-primary">
                Continuer
            </button>
        </footer>

        <style is:global>
            /* EMPIRE PREMIUM THEME - "ÉLÉGANCE & PUISSANCE" */

            /* --- STATIC PROMO BANNER (FURNITURE) --- */
            .static-promo-banner {
                /* EMPIRE RED GRADIENT: Rich Red to Deep Black */
                background: linear-gradient(135deg, #8b0000 0%, #1a1a1a 100%);
                border: 2px solid #ff3333; /* Vibrant Red Border */
                border-radius: 12px;
                padding: 15px 20px;
                margin-bottom: 25px;
                display: flex;
                align-items: center;
                gap: 15px;
                box-shadow: 0 10px 25px rgba(200, 0, 0, 0.35); /* Red Glow */
                position: relative;
                overflow: hidden;
                transition: transform 0.3s ease;
            }

            .static-promo-banner:hover {
                transform: translateY(-2px);
                box-shadow: 0 15px 35px rgba(220, 20, 20, 0.5); /* Stronger Glow on Hover */
            }

            /* Shimmer Effect - Adjusted for Red */
            .static-promo-banner::before {
                content: "";
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(
                    to right,
                    transparent,
                    rgba(255, 255, 255, 0.2),
                    /* White shimmer fits red better */ transparent
                );
                transform: skewX(-25deg);
                animation: shimmer 4s infinite;
            }

            .promo-icon {
                font-size: 2.2rem;
                animation: pulseRed 3s infinite ease-in-out;
                filter: drop-shadow(
                    0 0 10px rgba(255, 215, 0, 0.6)
                ); /* Gold glow behind icon */
            }

            .promo-text {
                flex: 1;
                z-index: 1;
            }

            .promo-title {
                color: #ffd700; /* Keep Gold for Premium feel */
                font-family: var(--font-heading);
                font-weight: 800;
                font-size: 1.1rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                margin-bottom: 4px;
                text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
            }

            .promo-desc {
                color: #ffffff;
                font-size: 0.95rem;
                line-height: 1.35;
                font-weight: 600;
                text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
            }

            .perm-highlight {
                font-size: 1.4em; /* Significantly larger */
                color: #ffd700; /* Gold */
                font-weight: 800;
                text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
                vertical-align: middle;
            }

            @keyframes pulseRed {
                0% {
                    transform: scale(1);
                    filter: drop-shadow(0 0 5px rgba(255, 215, 0, 0.5));
                }
                50% {
                    transform: scale(1.1);
                    filter: drop-shadow(0 0 15px rgba(255, 215, 0, 0.9));
                }
                100% {
                    transform: scale(1);
                    filter: drop-shadow(0 0 5px rgba(255, 215, 0, 0.5));
                }
            }

            @keyframes shimmer {
                0% {
                    left: -100%;
                }
                100% {
                    left: 200%;
                }
            }

            .empire-modal {
                /* Brand Colors - Empire Gradient: Red to Black */
                --color-primary: #b71c1c;
                --color-primary-dark: #8e1616;
                /* Deep Red */
                --color-dark: #111827;
                /* Near Black */

                /* --- FOOTER / TOTAL --- */
                .modal-footer {
                    background: #fdfdfd;
                    border-top: 1px solid #eee;
                    padding: 20px 30px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    border-radius: 0 0 12px 12px;
                }

                /* Force Global for Dynamic Content */
                .details-total-bar,
                .total-service-box {
                    /* Black to Lime Green as requested - FORCE GLOBAL */
                    background: linear-gradient(
                        135deg,
                        #000000 0%,
                        #76ff03 100%
                    ) !important;
                    color: white !important;
                    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
                    padding: 15px 20px;
                    border-radius: 8px;
                    margin-top: 20px;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    font-weight: bold;
                    box-shadow: 0 4px 10px rgba(118, 255, 3, 0.3);
                    border: 1px solid rgba(255, 255, 255, 0.2);
                }
                --empire-gradient: linear-gradient(
                    135deg,
                    #b71c1c 0%,
                    #000000 100%
                );
                --empire-gold: #c5a059;
                /* Gold Accent */

                --color-bg-page: #f3f4f6;
                --color-bg-modal: #ffffff;

                --color-text-main: #1f2937;
                --color-text-sub: #6b7280;
                --color-border: #e5e7eb;

                /* Spacing & Radius */
                --radius-card: 16px;
                --radius-modal: 24px;

                /* Fonts */
                --font-heading: "Outfit", sans-serif;
                --font-body: "Inter", sans-serif;
            }

            .empire-modal *,
            .empire-modal *::before,
            .empire-modal *::after {
                box-sizing: border-box;
            }

            /* --- MODAL OVERLAY --- */
            .modal-overlay {
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0, 0, 0, 0.7);
                backdrop-filter: blur(5px);
                z-index: 9999;
                display: flex;
                justify-content: center;
                align-items: center;
            }

            /* --- MODAL BOX --- */
            .empire-modal {
                width: 95%;
                /* Responsive width */
                max-width: 1400px;
                height: 85vh;
                background: #fff;
                border-radius: var(--radius-modal);
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
                /* Deep Shadow */
                display: flex;
                overflow: hidden;
                position: relative;
                border: 1px solid rgba(0, 0, 0, 0.1);
                animation: scaleIn 0.3s ease-out;
            }

            @keyframes scaleIn {
                from {
                    transform: scale(0.9);
                    opacity: 0;
                }
                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }

            /* --- MAIN CONTENT (LEFT) --- */
            .modal-main {
                flex: 1;
                display: flex;
                flex-direction: column;
                background: #fff;
                position: relative;
                z-index: 10;
            }

            /* --- HEADER --- */
            .modal-header {
                background: linear-gradient(
                    135deg,
                    #000000 0%,
                    #1b5e20 100%
                ); /* Black to Green */
                color: white;
                padding: 20px 30px;
                position: relative;
                border-bottom: 4px solid #43a047; /* Bright Green Accent */
                border-radius: 12px 12px 0 0;
            }

            .modal-header h2 {
                font-family: var(--font-heading);
                font-weight: 700;
                font-size: 1.4rem;
                margin: 0;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
                text-align: center; /* Center the title */
                color: #ffffff; /* Ensure white color */
                width: 100%;
            }

            .header-actions {
                position: absolute;
                right: 15px;
                top: 50%;
                transform: translateY(-50%);
                display: flex;
                gap: 40px;
                align-items: center;
            }

            /* --- PROGRESS BAR --- */
            .progress-bar {
                background-color: #f0f0f0;
                height: 8px;
                width: 100%;
                overflow: hidden;
            }

            .progress-fill {
                background: linear-gradient(
                    to right,
                    #43a047,
                    #2e7d32
                ); /* Green Gradient */
                height: 100%;
                transition: width 0.4s ease;
            }

            /* --- STEPS / CONTENT --- */
            .modal-content {
                padding: 10px 20px;
                /* min-height: 400px; */
                overflow-y: auto;
                max-height: 60vh;
            }

            /* Text & Headings */
            .empire-modal .text-center {
                text-align: center;
            }

            .empire-modal h3 {
                font-family: var(--font-heading);
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--color-dark);
                margin-top: 0;
                margin-bottom: 0.75rem;
            }

            .empire-modal p {
                color: var(--color-text-sub);
                margin-top: 0;
                font-size: 1rem;
                line-height: 1.6;
            }

            /* STEP VISIBILITY */
            .step {
                display: none;
            }

            .step.active {
                display: block;
                animation: fadeInSlide 0.5s ease;
            }

            /* --- SERVICE GRID --- */
            .service-grid {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 6px; /* Reduced gap */
                padding: 5px;
            }

            .service-card {
                background: #fff;
                border: 1px solid var(--color-border);
                border-radius: var(--radius-card);
                padding: 4px; /* Minimal padding */
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: space-between;
                cursor: pointer;
                transition: all 0.3s ease;
                aspect-ratio: 1 / 1;
                min-height: auto;
                justify-content: space-between;
                position: relative;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            }

            .service-card:hover {
                transform: translateY(-5px);
                box-shadow:
                    0 20px 25px -5px rgba(0, 0, 0, 0.1),
                    0 10px 10px -5px rgba(0, 0, 0, 0.04);
                border-color: var(--empire-gold);
            }

            .service-card.selected {
                border-color: #28a745;
                background: #fff; /* Keep clean background */
                box-shadow:
                    0 0 0 3px #28a745,
                    0 10px 20px -5px rgba(40, 167, 69, 0.4); /* Stronger Green Glow */
                transform: translateY(-5px);
            }

            /* Hand-Drawn Checkmark Style */
            .service-card.selected::after {
                content: "✔";
                position: absolute;
                top: 2px;
                right: 5px;
                width: auto;
                height: auto;
                background: none;
                color: #28a745;
                font-size: 2.5rem;
                font-weight: 900;
                line-height: 1;
                display: block;
                transform: rotate(-10deg) scale(1.1);
                text-shadow: 3px 3px 0px white; /* Outline effect */
                z-index: 10;
                animation: stampIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

            @keyframes stampIn {
                from {
                    opacity: 0;
                    transform: rotate(20deg) scale(2);
                }
                to {
                    opacity: 1;
                    transform: rotate(-10deg) scale(1.1);
                }
            }

            .service-icon {
                width: 100%;
                height: 100%; /* Fill available space */
                flex: 1;
                margin-bottom: 0;
                border-radius: 6px;
                overflow: hidden;
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            /* Green Smoke Overlay */
            .service-icon::after {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(
                    135deg,
                    rgba(40, 167, 69, 0.4) 0%,
                    transparent 80%
                );
                opacity: 0;
                transition: opacity 0.3s ease;
                pointer-events: none;
                z-index: 5;
            }

            .service-card.selected .service-icon::after {
                opacity: 1; /* Show Green Smoke */
            }

            .service-icon img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                transition: transform 0.5s ease;
                padding: 2px;
            }

            .service-card:hover .service-icon img {
                transform: scale(1.1);
            }

            .service-card.selected .service-icon img {
                transform: scale(1.1);
                /* No filter on image itself, keep colors natural */
            }

            /* Update text label to be clearly visible below image */
            .service-label {
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--color-dark);
                line-height: 1.1;
                text-align: center;
                margin-top: 2px;
                padding-top: 0;
                width: 100%;
            }

            /* Duplicate .details-total-bar removed from here to avoid conflicts. 
       It is defined in the Global block above (line 252+). 
    */
            .persistent-promo-msg .promo-highlight {
                color: #ffd700;
                font-weight: bold;
                text-shadow: 0 1px 1px rgba(0, 0, 0, 0.3);
            }

            /* --- DETAILS FORM --- */
            .detail-section {
                margin-bottom: 24px;
                background: white;
                border: 1px solid var(--color-border);
                border-radius: var(--radius-card);
                padding: 24px;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
                transition: transform 0.2s;
            }

            .detail-section:hover {
                border-color: #d1d5db;
            }

            .detail-title {
                font-family: var(--font-heading);
                font-size: 1.2rem;
                font-weight: 700;
                color: var(--color-dark);
                border-bottom: 2px solid #f3f4f6;
                padding-bottom: 12px;
                margin-bottom: 20px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .detail-title::before {
                content: "";
                width: 4px;
                height: 20px;
                background: var(--empire-gradient);
                border-radius: 2px;
            }

            .item-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 16px;
                padding: 10px 0;
                border-bottom: 1px dashed #f3f4f6;
            }

            .item-row:last-child {
                border-bottom: none;
            }

            .qty-control {
                display: flex;
                align-items: center;
                gap: 12px;
                background: #f9fafb;
                padding: 6px 10px;
                border-radius: 10px;
                border: 1px solid var(--color-border);
            }

            .qty-btn {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                border: 1px solid var(--color-border);
                background: white;
                cursor: pointer;
                font-weight: bold;
                color: var(--color-dark);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.2s;
            }

            .qty-btn:hover {
                background: var(--color-primary);
                color: white;
                border-color: var(--color-primary);
            }

            .qty-value {
                min-width: 28px;
                text-align: center;
                font-weight: 700;
                font-size: 1.1rem;
            }

            /* --- SIDEBAR (RIGHT) --- */
            .modal-sidebar {
                width: 500px;
                min-width: 500px;
                background: #fafafa;
                border-left: 1px solid var(--color-border);
                display: flex;
                flex-direction: column;
                padding: 24px;
                position: relative;
                z-index: 20;
                box-shadow: -5px 0 15px rgba(0, 0, 0, 0.02);
            }

            .cart-title {
                font-family: var(--font-heading);
                font-size: 1rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: var(--color-dark);
                margin-bottom: 16px;
                padding-bottom: 8px;
                border-bottom: 2px solid #e5e7eb;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .cart-list {
                flex: 1;
                overflow-y: auto;
                padding-right: 4px;
            }

            /* --- PREMIUM 'WOW' POPUP STYLES (REMOVED - UNUSED) --- */
            /* .premium-modal-popup styles were removed to optimize performance */

            .cart-item-price {
                font-weight: 700;
                font-size: 0.9rem;
                color: #111;
            }

            .cart-item {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                padding: 12px 14px;
                margin-bottom: 8px;
                background: white;
                border-radius: 8px;
                border: 1px solid #e5e7eb;
                box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
            }

            .cart-item-name {
                font-size: 0.9rem;
                font-weight: 600;
                color: #374151;
            }

            .cart-item-price {
                font-weight: 700;
                font-size: 0.9rem;
                color: #111;
            }

            .cart-savings {
                margin-top: 16px;
                padding: 12px;
                border-radius: 8px;
                background: #ecfdf5;
                border: 1px solid #10b981;
                text-align: center;
                color: #059669;
                font-weight: 700;
                font-size: 1.1rem;
            }

            .cart-total-block {
                margin-top: auto;
                background: linear-gradient(135deg, #0f172a 0%, #1e40af 100%);
                /* Elegant Dark Blue Gradient */
                color: white;
                border-radius: 12px;
                padding: 24px;
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
                text-align: center;
                position: relative;
                overflow: hidden;
            }

            /* Subtle gradient sheen on total block */
            .cart-total-block::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: var(--empire-gradient);
            }

            .cart-total-label {
                font-size: 0.75rem;
                text-transform: uppercase;
                color: #9ca3af;
                margin-bottom: 4px;
                letter-spacing: 1px;
            }

            .cart-live-total {
                font-size: 2.5rem;
                font-weight: 800;
                color: white;
                font-family: var(--font-heading);
                line-height: 1.1;
                margin-bottom: 5px;
            }

            /* --- FOOTER / TOTAL --- */
            .modal-footer {
                background: #fdfdfd;
                border-top: 1px solid #eee;
                padding: 20px 30px;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-radius: 0 0 12px 12px;
            }

            .total-display {
                background: #000; /* Black bg for total */
                color: #43a047; /* Green Text */
                padding: 10px 20px;
                border-radius: 8px;
                font-family: var(--font-heading);
                font-size: 1.4rem;
                font-weight: 700;
                border: 1px solid #1b5e20;
            }

            /* --- BUTTONS --- */
            .empire-modal .btn {
                padding: 12px 28px;
                border-radius: 50px;
                /* Pill shape */
                font-weight: 700;
                font-size: 1rem;
                cursor: pointer;
                border: none;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                display: inline-flex;
                align-items: center;
                gap: 8px;
                letter-spacing: 0.02em;
                font-family: var(--font-heading);
            }

            .empire-modal .btn-primary {
                background: linear-gradient(
                    135deg,
                    #2e7d32 0%,
                    #1b5e20 100%
                ); /* Green Gradient */
                color: white;
                border: none;
                padding: 12px 30px;
                border-radius: 50px;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.3s;
                box-shadow: 0 4px 15px rgba(46, 125, 50, 0.3);
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .empire-modal .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(46, 125, 50, 0.4);
                background: linear-gradient(135deg, #43a047 0%, #2e7d32 100%);
            }

            .empire-modal .btn-secondary {
                background: white;
                border: 2px solid #e5e7eb;
                color: #374151;
            }

            .empire-modal .btn-secondary:hover {
                background: #f9fafb;
                border-color: #d1d5db;
                color: #111;
            }

            .btn-text {
                background: transparent;
                color: #6b7280;
                font-weight: 600;
                padding: 0;
            }

            .btn-text:hover {
                color: var(--color-primary);
            }

            .close-btn {
                position: absolute;
                top: 16px;
                right: 16px;
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.2);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                border: none;
                cursor: pointer;
                font-size: 1.5rem;
                transition: all 0.2s;
                z-index: 50;
            }

            .close-btn:hover {
                background: rgba(255, 255, 255, 0.4);
                transform: rotate(90deg);
            }

            /* Animation Keyframes */
            @keyframes fadeInSlide {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* Blink Highlight for Service Grid */
            @keyframes flashBorder {
                0% {
                    box-shadow: 0 0 0 0 rgba(183, 28, 28, 0);
                }

                50% {
                    box-shadow: 0 0 0 8px rgba(183, 28, 28, 0.2);
                }

                100% {
                    box-shadow: 0 0 0 0 rgba(183, 28, 28, 0);
                }
            }

            .blink-highlight .service-card {
                animation: flashBorder 0.8s ease 2;
            }

            /* Responsive */
            @media (max-width: 850px) {
                /* Hide external sticky bar when modal is open */
                /* Mobile sticky bar handling is done via JS MutationObserver now to avoid global hiding */
                /* .mobile-sticky-bar { display: none !important; } */

                /* Fix Header Layout: Flexbox, no overlap */
                .modal-header {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    padding: 15px;
                }
                .modal-header h2 {
                    text-align: left;
                    font-size: 1.1rem;
                    width: auto;
                    flex: 1;
                }
                .header-actions {
                    position: static !important;
                    transform: none !important;
                    gap: 15px !important;
                }

                /* Compact Service Cards (Smaller Images) */
                .service-card {
                    aspect-ratio: unset;
                    height: 125px; /* Compact height */
                }
                .service-icon {
                    height: 55%;
                }
                .service-label {
                    font-size: 0.75rem;
                    line-height: 1;
                }

                /* Compact Footer */
                .modal-footer {
                    padding: 10px 15px;
                    gap: 10px;
                }
                .modal-footer .btn {
                    padding: 10px 20px;
                    font-size: 0.9rem;
                    width: 100%;
                }

                .empire-modal {
                    border-radius: 0;
                    border: none;
                    height: 100vh;
                    width: 100%;
                    max-width: 100%;
                    margin: 0;
                }

                .modal-main {
                    height: auto;
                    flex: 1;
                    padding-bottom: 200px;
                }

                .modal-sidebar {
                    position: fixed;
                    bottom: 0;
                    left: 0;
                    width: 100%;
                    height: auto;
                    max-height: 12vh; /* Collapsed state */
                    min-width: unset;
                    border-left: none;
                    border-top: 1px solid #e5e7eb;
                    background: #fff;
                    padding: 16px;
                    z-index: 9999;
                    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
                    transition:
                        max-height 0.4s cubic-bezier(0.25, 1, 0.5, 1),
                        border-radius 0.4s;
                    overflow: hidden;
                    display: flex; /* Flex to handle expansion layout */
                    flex-direction: column;
                }

                .modal-sidebar.expanded {
                    max-height: 75vh;
                    border-radius: 20px 20px 0 0;
                    overflow-y: auto;
                }

                #btn-toggle-details {
                    display: inline-block !important;
                }

                /* Items hidden by default on mobile unless expanded */
                .modal-sidebar:not(.expanded) .cart-list,
                .modal-sidebar:not(.expanded) .promo-box,
                .modal-sidebar:not(.expanded) .cart-title,
                .modal-sidebar:not(.expanded) .cart-total-label,
                .modal-sidebar:not(.expanded) #promo-message-area {
                    display: none !important;
                }

                .modal-sidebar.expanded .cart-list {
                    display: block !important;
                    margin-bottom: 20px;
                    flex: 1;
                    /* Default order 0 is fine, will follow Title */
                }

                .modal-sidebar.expanded #promo-message-area {
                    display: block !important;
                    /* Default order is fine */
                }

                .modal-sidebar.expanded .cart-total-block {
                    order: -1;
                    margin-bottom: 10px;
                    border-bottom: 1px solid #eee;
                    padding-bottom: 10px;
                    flex-shrink: 0;
                }

                /* Target the disclaimer (last child) to be at the bottom */
                .modal-sidebar.expanded > div:last-child {
                    order: 10;
                    text-align: center;
                    padding-bottom: 20px;
                }

                #min-msg-sidebar {
                    display: block !important;
                    margin-bottom: 5px;
                    font-size: 0.75rem;
                    line-height: 1.2;
                }

                .cart-total-block {
                    padding: 0;
                    border: none;
                    box-shadow: none;
                    background: transparent;
                    color: #111;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    text-align: left;
                }

                .cart-total-block::before {
                    display: none;
                }

                .cart-live-total {
                    font-size: 1.5rem;
                    color: var(--color-primary);
                    margin: 0;
                }

                .modal-content {
                    padding: 15px 10px;
                }

                .service-grid {
                    grid-template-columns: repeat(2, 1fr);
                    gap: 8px;
                }

                .promo-highlight {
                    color: #ffd700;
                    /* Gold */
                    font-weight: bold;
                    font-style: italic;
                    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
                    font-size: 1.25rem;
                }

