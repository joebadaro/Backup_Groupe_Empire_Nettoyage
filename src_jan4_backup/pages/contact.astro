---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contactez-nous | Groupe Nettoyage Empire">
    <div class="page-header">
        <div class="container text-center fade-in-section">
            <h1 class="text-gradient">Contactez-nous</h1>
            <p class="lead-text">
                Deux façons simples d'obtenir votre prix rapidement.
            </p>
        </div>
    </div>
    <section class="section">
        <div class="container">
            <!-- 2 CHOICE LAYOUT -->
            <div class="choice-grid">
                <!-- CHOICE 1: CALL -->
                <div
                    class="choice-card card-call
        fade-in-section delay-100"
                >
                    <div class="card-icon-wrapper icon-phone-bg">
                        <span class="card-icon">📞</span>
                    </div>
                    <h2>Parler à un Expert</h2>
                    <p class="choice-desc">
                        Des conseils personnalisés et une estimation immédiate
                        avec nos spécialistes.
                    </p>
                    <div class="call-action">
                        <a href="tel:5148939939" class="btn-big-call">
                            (514) 893-9939
                        </a>
                        <span class="availability">Dispo 7j/7 • 8h à 20h</span>
                    </div>
                </div>
                <!-- CHOICE 2: ONLINE ESTIMATE -->
                <div class="choice-card card-online fade-in-section delay-200">
                    <div class="card-icon-wrapper icon-online-bg">
                        <span class="card-icon">⚡</span>
                    </div>
                    <h2>Estimation Instantanée</h2>
                    <p class="choice-desc">
                        Obtenez votre prix exact maintenant grâce à notre
                        calculateur intelligent.
                    </p>
                    <div class="online-action">
                        <button
                            id="btn-trigger-estimate-page"
                            class="btn-big-online"
                        >
                            Estimation Instantanée
                        </button>
                        <span class="availability"
                            >Rapide • Gratuit • Sans engagement</span
                        >
                    </div>
                </div>
            </div>
            <!-- TRUST SIGNALS BELOW -->
            <div class="trust-container-lower
fade-in-section delay-300">
                <div class="trust-item">
                    <span class="check-gold">✓</span>
                    <span>Satisfaction Garantie</span>
                </div>
                <div class="trust-item">
                    <span class="check-gold">✓</span>
                    <span>30+ Ans d'Expérience</span>
                </div>
                <div class="trust-item">
                    <span class="check-gold">✓</span>
                    <span>Produits Écologiques</span>
                </div>
            </div>
            <!--
MAP SECTION -->
            <div class="map-container fade-in-section delay-300">
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d44795.56877994073!2d-73.450!3d45.535!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4cc91b931934989d%3A0xe247c724771775!2sLongueuil%2C%20QC%20J3Y!5e0!3m2!1sen!2sca!4v1703000000000!5m2!1sen!2sca"
                    width="100%"
                    height="100%"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Zone desservie : Longueuil et
environs"></iframe>
            </div>
        </div>
    </section>
    <!-- Module d'estimation (Hidden by default, triggered by button) -->
    <!-- Module d'estimation (Hidden by default, triggered by button) -->

    <script>
        /* Trigger Estimation Module from Page Button */
        const pageEstBtn = document.getElementById("btn-trigger-estimate-page");
        if (pageEstBtn) {
            pageEstBtn.addEventListener("click", () => {
                const widget = document.getElementById("estimation-widget");
                if (widget) {
                    widget.style.display = "flex";
                }
            });
        }
    </script>
    <style>
        .page-header {
            background: var(--color-bg-light-blue);
            padding: 3rem 0;
            margin-bottom: 2rem;
        }
        .choice-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 4rem;
        }
        .choice-card {
            background: white;
            border: 1px solid var(--color-border);
            border-radius: 20px;
            padding: 3rem 2rem;
            text-align: center;
            transition:
                transform 0.3s ease,
                box-shadow 0.3s ease;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            overflow: hidden;
        } /* Elegant Hover Effect */
        .choice-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            border-color: var(--color-primary);
        }
        .card-icon-wrapper {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            font-size: 3rem;
        }
        .icon-phone-bg {
            background: #e3f2fd; /* Light Blue */
            color: var(--color-primary);
        }
        .icon-online-bg {
            background: #fff5f5; /* Light Red */
            color: var(--color-accent);
        }
        .choice-card h2 {
            font-family: var(--font-heading);
            font-size: 1.8rem;
            color: var(--color-dark);
            margin-bottom: 1rem;
        }
        .choice-desc {
            font-size: 1.05rem;
            color: #666;
            margin-bottom: 2rem;
            line-height: 1.6;
            max-width: 320px;
        }
        .btn-big-call {
            display: inline-block;
            background: var(--color-primary);
            color: white;
            font-size: 1.4rem;
            font-weight: 800;
            padding: 15px 35px;
            border-radius: 50px;
            text-decoration: none;
            box-shadow: 0 4px 15px rgba(10, 35, 66, 0.3);
            transition: all 0.3s;
        }
        .btn-big-call:hover {
            background: #0f3460;
            transform: scale(1.05);
        }
        .btn-big-online {
            display: inline-block;
            background: linear-gradient(
                135deg,
                var(--color-accent) 0%,
                #b71c1c 100%
            );
            color: white;
            font-size: 1.3rem;
            font-weight: 700;
            padding: 15px 35px;
            border-radius: 50px;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(211, 47, 47, 0.3);
            transition: all 0.3s;
        }
        .btn-big-online:hover {
            filter: brightness(1.1);
            transform: scale(1.05);
        }
        .availability {
            display: block;
            margin-top: 1rem;
            font-size: 0.85rem;
            color: #888;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        } /* Success/Trust Items */
        .trust-container-lower {
            display: flex;
            justify-content: center;
            gap: 3rem;
            margin-bottom: 3rem;
        }
        .trust-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--color-dark);
        }
        .check-gold {
            color: #c5a059;
            font-weight: 800;
            font-size: 1.2rem;
        }
        .map-container {
            height: 400px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-subtle);
            border: 1px solid #eee;
        }
        @media (max-width: 768px) {
            .choice-grid {
                grid-template-columns: 1fr;
            }
            .trust-container-lower {
                flex-direction: column;
                align-items: center;
                gap: 1rem;
            }
        }
    </style>
</Layout>
