const { service } = Astro.props;
---

<Layout
  title={`${service.seoTitle} | Empire Cleaning Group`}
  description={service.intro}
  image={service.image}
>
  <!-- ... existing styles ... -->
  <style define:vars={{ heroHeight: service.heroHeight || "auto" }}>
    .service-hero {
      min-height: var(--heroHeight);
      display: flex;
      align-items: center;
    }
  </style>

  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">{service.category}</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            {service.title}
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">{service.problem}</p>
          </div>

          <p class="lead-text fade-in-up delay-200">{service.intro}</p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-primary pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (Free Estimate)
            </a>
            <a href="/contact" class="btn btn-secondary-outline">
              <span class="icon">✉️</span> Online Quote
            </a>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          {
            service.slides && service.slides.length > 1 ? (
              <div class="slideshow-container">
                {service.slides.map((slide, index) => (
                  <img
                    src={slide}
                    alt={`${service.title} - Image ${index + 1}`}
                    class={`slide ${index === 0 ? "active" : ""}`}
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                ))}
              </div>
            ) : (
              <img
                src={service.image}
                alt={service.title}
                class="split-image"
                draggable="false"
              />
            )
          }
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <!-- PROCESS -->
          <div class="fade-in-section delay-100" style="margin-top: 0;">
            <h2 class="section-title text-gradient-empire">
              Our Approach (On Site)
            </h2>
            <div class="process-timeline">
              {
                service.process.map((step, index) => (
                  <div class="process-step">
                    <div class="step-marker">{index + 1}</div>
                    <div class="step-content">
                      <h3>{step.title}</h3>
                      <p>{step.desc}</p>
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- EQUIPMENT NOTE FOR PORTABLE -->
            {
              !service.hideEquipment && (
                <div
                  class="equipment-note fade-in-section delay-100"
                  style="margin-top: 2rem; background: #f9f9f9; padding: 1.5rem; border-radius: 8px; border-left: 3px solid var(--color-accent);"
                >
                  <h4 style="margin-bottom: 0.5rem; color: var(--color-primary);">
                    Adapted Equipment (Truck-mount or Portable)
                  </h4>
                  <p style="font-size: 0.95rem;">
                    We primarily use our <strong>truck-mount units</strong> for
                    maximum power. However, for high-rise condos or limited
                    access areas, we are equipped with{" "}
                    <strong>
                      high-performance professional portable machines
                    </strong>
                    . These units are nothing like rental machines : they
                    guarantee an expert result, no matter your floor.
                  </p>
                </div>
              )
            }
          </div>

          <!-- DYNAMIC SEO CONTENT (NEW) -->
          <div class="fade-in-section delay-100">
            <!-- TOGGLE BUTTON -->
            <div style="margin-top: 3rem;">
              <button id="toggle-seo-btn" class="btn-outline-reveal">
                Learn more about this service ▼
              </button>
            </div>

            <!-- HIDDEN CONTENT -->
            <div id="seo-content" class="seo-content-hidden">
              <hr class="separator" />
              <div set:html={service.details} />

              <div class="info-box">
                <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                  Adapted and Hygienic Service
                </h3>
                <p>
                  Our qualified team adapts each intervention according to your
                  specific needs. We intervene in both <strong
                    >residential</strong
                  >
                  and <strong>commercial premises</strong> in Montreal, Laval, and
                  on the South Shore, guaranteeing effective, durable, and respectful
                  cleaning of your investments.
                </p>
              </div>
            </div>
          </div>

          <!-- BENEFITS -->
          <div class="fade-in-section delay-200" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">Why choose us?</h2>
            <div class="benefits-grid">
              {
                service.benefits.map((benefit) => (
                  <div class="benefit-item">
                    <div class="check-circle">✓</div>
                    <span>{benefit}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- FAQ (Schema Friendly structure) -->
          {
            service.faq && (
              <div class="fade-in-section delay-300" style="margin-top: 3rem;">
                <h2 class="section-title text-gradient-empire">
                  Frequently Asked Questions
                </h2>
                <div class="faq-list">
                  {service.faq.map((item) => (
                    <div class="faq-item">
                      <p class="question">
                        <strong>Q : {item.q}</strong>
                      </p>
                      <p class="answer">{item.a}</p>
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <!-- SIDEBAR CTA (Sticky) -->
        <aside class="service-sidebar">
          <div class="sticky-card fade-in-section">
            <h3 class="card-title text-gradient-gold">Free Estimate</h3>
            <p class="card-desc">Call us for an immediate response.</p>

            <a
              href="tel:5148939939"
              class="btn btn-primary full-width pop-effect pulse-phone"
            >
              <span class="icon">📞</span> (514) 893-9939 (Free Estimate)
            </a>

            <p
              class="text-center"
              style="margin: 1rem 0; font-size: 0.9rem; color: #888;"
            >
              or
            </p>

            <a href="/contact" class="btn-secondary-outline full-width">
              Online Quote
            </a>

            <div class="guarantee-badge">
              <span>🌿 100% Ecological Products</span>
              <div style="margin-top: 5px; color: #ffbf00; font-weight: bold;">
                ★★★★★
              </div>
              <span style="font-size: 0.8rem; color: #666;"
                >Satisfied Clients</span
              >
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Toggle SEO Content
  const toggleBtn = document.getElementById("toggle-seo-btn");
  const seoContent = document.getElementById("seo-content");

  if (toggleBtn && seoContent) {
    toggleBtn.addEventListener("click", () => {
      seoContent.classList.toggle("visible");
      if (seoContent.classList.contains("visible")) {
        toggleBtn.textContent = "Show less ▲";
      } else {
        toggleBtn.textContent = "Learn more about this service ▼";
      }
    });
  }

  // Slideshow Logic
  const slides = document.querySelectorAll(".slide");
  if (slides.length > 0) {
    let currentSlide = 0;
    const intervalTime = 4000; // 4 seconds

    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, intervalTime);
  }
</script>

<style>
  /* NEW BUTTON STYLE */
  .btn-outline-reveal {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
