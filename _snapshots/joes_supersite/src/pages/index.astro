---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Groupe Nettoyage Empire - L'Excellence du Nettoyage au Québec"
  image="/images/catalog/photo-82.webp"
>
  <!-- 1. HERO SECTION: IMPACT VISUEL FORT (Bleu Foncé & Or) -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div
      class="container hero-content text-center"
      style="position: relative; z-index: 10;"
    >
      <div class="hero-badge fade-in-up">
        <span class="icon">🏆</span> Leader au Québec
      </div>
      <h1 class="hero-title fade-in-up">
        L'Art du Nettoyage <br />
        <span class="text-gradient-empire">Haut de Gamme</span>
      </h1>
      <p class="hero-subtitle fade-in-up delay-100">
        Tapis, Meubles et Matelas. Une propreté éclatante grâce à notre
        technologie de camion-usine exclusive et nos produits écologiques.
      </p>
      <div class="hero-actions fade-in-up delay-200">
        <a href="tel:5148939939" class="btn btn-glass pulse-btn">
          <span class="icon">📞</span> (514) 893-9939 (Estimation Gratuite)
        </a>
        <a href="/contact" class="btn btn-glass-outline">
          <span class="icon">📝</span> Soumission en ligne
        </a>
      </div>
    </div>

    <!-- Wave Separator Bottom -->
    <div class="wave-bottom">
      <svg viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg">
        <path
          fill="#ffffff"
          fill-opacity="1"
          d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,224C672,245,768,267,864,261.3C960,256,1056,224,1152,197.3C1248,171,1344,149,1392,138.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
        ></path>
      </svg>
    </div>
  </section>

  <!-- 2. TRUST INSIGNIA (Confiance Immédiate) -->
  <section class="trust-container">
    <div class="brand-watermark watermark-trust"></div>
    <div class="container trust-grid">
      <div class="trust-pill badge-google">
        <img
          src="/images/google-reviews-badge.png"
          alt="Google 5 Stars Review"
          width="110"
          height="auto"
          loading="eager"
        />
      </div>
      <div class="trust-pill badge-exp">
        <span class="icon">💎</span> 30+ ans d'expérience
      </div>
      <div class="trust-pill badge-eco">
        <span class="icon">🌿</span> 100% Écologique
      </div>
      <div class="trust-pill badge-local">
        <span class="icon">⚜️</span> Entreprise Québécoise
      </div>
    </div>
  </section>

  <!-- 3. SERVICES (Fond Bleu Pâle - Contraste Doux) -->
  <section class="section section-services">
    <div class="container">
      <div class="section-header text-center">
        <span class="tag-blue">Expertise Complète</span>
        <h2 class="title-dark-blue text-gradient-empire">
          Nos Solutions de Nettoyage
        </h2>
        <p class="lead-text">
          Une intervention ciblée pour chaque surface de votre intérieur.
        </p>
      </div>

      <div class="services-grid-modern">
        <!-- 1. Meubles & Divans -->
        <a
          href="/services/meubles-tissu"
          class="service-card-modern fade-in-section delay-100"
        >
          <img
            src="/images/services/services-4.webp"
            alt="Nettoyage de meubles et divans"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">🛋️</div>
            <h3>Meubles & Divans</h3>
            <p>
              Nettoyage en profondeur des tissus d'ameublement. Stop aux taches
              et odeurs.
            </p>
            <span class="link-text">Voir détails &rarr;</span>
          </div>
        </a>

        <!-- 2. Tapis Résidentiel -->
        <a
          href="/services/tapis-residentiel"
          class="service-card-modern fade-in-section delay-200"
        >
          <img
            src="/images/catalog/photo-tapis-clean.webp"
            alt="Nettoyage de tapis résidentiel"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">🏠</div>
            <h3>Tapis Résidentiel</h3>
            <p>
              Redonnez couleur et hygiène à vos tapis en laine, synthétique ou
              orientaux.
            </p>
            <span class="link-text">Voir détails &rarr;</span>
          </div>
        </a>

        <!-- 3. Tapis en Laine -->
        <a
          href="/services/tapis-laine"
          class="service-card-modern fade-in-section delay-300"
        >
          <img
            src="/images/catalog/photo-40-rotated.webp"
            alt="Nettoyage de tapis en laine"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">🧶</div>
            <h3>Tapis en Laine</h3>
            <p>
              Traitement délicat et spécialisé pour vos tapis en laine et fibres
              naturelles.
            </p>
            <span class="link-text">Voir détails &rarr;</span>
          </div>
        </a>

        <!-- 4. Matelas -->
        <a
          href="/services/matelas"
          class="service-card-modern fade-in-section delay-100"
        >
          <img
            src="/images/catalog/photo-matelas-custom.webp"
            alt="Nettoyage de matelas"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-red">🛏️</div>
            <h3>Nettoyage de Matelas et Désinfection</h3>
            <p>
              Élimination certifiée des acariens et bactéries pour un sommeil
              sain.
            </p>
            <span class="link-text">Voir détails &rarr;</span>
          </div>
        </a>

        <!-- 5. Céramique -->
        <a
          href="/services/ceramique"
          class="service-card-modern fade-in-section delay-200"
        >
          <img
            src="/images/catalog/photo-78.webp"
            alt="Nettoyage de tuiles et céramique"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">✨</div>
            <h3>Tuiles & Céramique</h3>
            <p>
              Restaurer l'éclat de vos planchers et joints avec notre nettoyage
              haute pression.
            </p>
            <span class="link-text">Voir détails &rarr;</span>
          </div>
        </a>

        <!-- 6. Meubles en Cuir -->
        <a
          href="/services/meubles-cuir"
          class="service-card-modern fade-in-section delay-300"
        >
          <img
            src="/images/catalog/photo-leather-final.webp"
            alt="Nettoyage de meubles en cuir"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">🛡️</div>
            <h3>Meubles en Cuir</h3>
            <p>
              Nettoyage et hydratation pour protéger votre cuir contre le
              dessèchement.
            </p>
            <span class="link-text">Voir détails &rarr;</span>
          </div>
        </a>
      </div>

      <div class="text-center mt-3">
        <a href="/services" class="btn btn-secondary-dark"
          >Voir tous nos services ➔</a
        >
      </div>
    </div>
  </section>

  <!-- 3.5 QUALITY DETAILS STRIP (New) -->
  <section class="section-quality-strip">
    <div
      class="quality-img"
      style="background-image: url('/images/catalog/photo-73.webp');"
    >
    </div>
    <div class="quality-content text-center">
      <h3>Le souci du détail</h3>
      <p>Une propreté méticuleuse, jusque dans les coins.</p>
    </div>
    <div
      class="quality-img"
      style="background-image: url('/images/catalog/photo-80.webp');"
    >
    </div>
  </section>

  <!-- 4. SECTION ÉCOLOGIQUE (Vert - Nature - Confiance) -->
  <section class="section section-eco">
    <div class="brand-watermark watermark-eco"></div>
    <div class="container split-eco">
      <div class="eco-content fade-in-section">
        <span class="tag-green">Engagement Vert</span>
        <h2 class="text-gradient-empire">Sécuritaire pour vos enfants</h2>
        <p class="eco-lead">
          Nous utilisons exclusivement des produits <strong
            >biodégradables et non-toxiques</strong
          >.
        </p>

        <ul class="eco-list">
          <li>
            <img
              src="/images/catalog/photo-8.webp"
              alt="Certification"
              class="icon-cert"
              style="width: 50px; height: auto;"
            />
            <div>
              <strong>Certifié Écologique</strong><br />Produits approuvés et
              sécuritaires.
            </div>
          </li>
          <li>
            <span class="check-green">👶</span>
            <div>
              <strong>Hypoallergénique</strong><br />Idéal pour les personnes
              asthmatiques.
            </div>
          </li>
          <li>
            <span class="check-green">🐾</span>
            <div>
              <strong>Pet Friendly</strong><br />Vos animaux peuvent circuler
              librement.
            </div>
          </li>
        </ul>
      </div>
      <div class="eco-image-wrapper fade-in-section delay-100">
        <div class="eco-circle-bg"></div>
        <img
          src="/images/services/services-4.webp"
          alt="Produits écologiques nettoyage"
          class="eco-img floating"
        />
      </div>
    </div>
  </section>

  <!-- 5. LA PUISSANCE (Fond Bleu Foncé - Tech - Sérieux) -->
  <section class="section section-dark-blue text-white">
    <div class="container">
      <div class="split-layout reverse-mobile">
        <div class="tech-image-wrapper">
          <img
            src="/images/camion-tech.webp"
            alt="Camion Usine Technologie"
            class="tech-img"
          />
          <div class="tech-badge">
            <span class="big-num">100°</span>
            <span class="tech-label">Vapeur</span>
          </div>
        </div>
        <div class="tech-content">
          <span class="tag-red">Technologie Supérieure</span>
          <h2>La Puissance du Camion-Usine</h2>
          <p>
            Pourquoi nos résultats sont-ils supérieurs ? Parce que nous ne
            comptons pas sur une petite machine portative louée.
          </p>

          <div class="stats-grid">
            <div class="stat-item">
              <span class="stat-val text-white">20x</span>
              <span class="stat-desc"
                >Plus puissant qu'un équipement standard</span
              >
            </div>
            <div class="stat-item">
              <span class="stat-val text-white">98%</span>
              <span class="stat-desc">D'humidité extraite (Séchage rapide)</span
              >
            </div>
          </div>

          <a href="/contact" class="btn btn-primary mt-2"
            >Demander une démonstration</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CONCLUSION CTA (Rouge/Action) -->
  <section class="cta-final">
    <div class="container text-center">
      <h2 class="cta-title text-gradient-empire">
        Ne laissez pas la saleté s'incruster
      </h2>
      <p>Obtenez votre estimation gratuite en moins de 2 minutes.</p>
      <div class="cta-buttons">
        <a href="tel:5148939939" class="btn btn-primary"
          >📞 Appeler (514) 893-9939</a
        >
        <a href="/contact" class="btn btn-outline-red">✉️ Soumission en ligne</a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  /* --- ANIMATIONS V3 (Staggered & Smooth) --- */
  .fade-in-section {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s ease-out;
    will-change: opacity, visibility;
  }
  .fade-in-section.is-visible {
    opacity: 1;
    transform: none;
  }

  .delay-100 {
    transition-delay: 100ms;
  }
  .delay-200 {
    transition-delay: 200ms;
  }
  .delay-300 {
    transition-delay: 300ms;
  }

  /* --- NEW HERO --- */
  .hero-section {
    position: relative;
    /* Rich "Living Room" Background with Overlay */
    background:
      linear-gradient(rgba(10, 35, 66, 0.85), rgba(10, 35, 66, 0.7)),
      url("/images/catalog/photo-82.webp");
    background-size: cover;
    background-position: center;
    background-attachment: fixed; /* Parallax Effect */
    color: white;
    padding: 12rem 0 14rem 0; /* More expansive padding */
    overflow: hidden;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(197, 160, 101, 0.2);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 10px 24px;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    backdrop-filter: blur(5px);
  }

  .hero-title {
    font-size: clamp(3.5rem, 7vw, 6rem); /* Bigger, Bolder */
    margin-bottom: 2rem;
    line-height: 1.05;
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.3); /* Deep Shadow */
  }

  .hero-subtitle {
    font-size: 1.3rem;
    color: #cbd5e1;
    max-width: 700px;
    margin: 0 auto 3rem auto;
  }

  /* Wave Separator */
  .wave-bottom {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    line-height: 0;
  }
  .wave-bottom svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 120px; /* Thicker wave */
    filter: drop-shadow(
      0 -5px 10px rgba(0, 0, 0, 0.1)
    ); /* Shadow under wave for depth */
  }

  /* --- TRUST INSIGNIA --- */
  .trust-container {
    margin-top: -60px; /* Overlap wave more */
    position: relative;
    z-index: 10;
    padding-bottom: 2rem;
    pointer-events: none;
  }
  .trust-grid {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    pointer-events: auto;
  }
  .trust-pill {
    background: white;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1); /* Deeper shadow */
    padding: 1.2rem 2.5rem;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 800;
    font-size: 1rem;
    color: var(--color-primary);
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .trust-pill:hover {
    transform: translateY(-5px) scale(1.05);
  }
  .trust-pill .icon {
    font-size: 1.4rem;
  }

  /* --- SERVICES MODERN --- */
  .section-services {
    background-color: var(--color-bg-light-blue);
    padding: 8rem 0; /* More breathing room */
    position: relative;
  }
  /* Decorative background element */
  .section-services::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(#e1e8ed 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0.3;
    pointer-events: none;
  }

  .tag-blue {
    color: var(--color-primary-light);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 10px;
  }
  .title-dark-blue {
    color: var(--color-primary);
    font-size: 3rem;
    margin-bottom: 1rem;
    font-weight: 800;
  }

  .services-grid-modern {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2.5rem;
    margin-top: 4rem;
    position: relative;
    z-index: 2;
  }

  .service-card-modern {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    height: 100%;
    border: 1px solid #fff;
  }

  .service-card-modern:hover {
    transform: translateY(-15px);
    box-shadow: 0 30px 60px rgba(10, 35, 66, 0.15);
    border-color: var(--color-accent);
  }

  .card-img {
    height: 240px;
    width: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .service-card-modern:hover .card-img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 2.5rem;
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-icon {
    position: absolute;
    top: -35px;
    right: 25px;
    width: 70px;
    height: 70px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    border: 4px solid var(--color-bg-light-blue);
  }

  .service-card-modern h3 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-weight: 700;
  }
  .service-card-modern p {
    color: var(--color-text-light);
    font-size: 1.05rem;
    flex: 1;
    line-height: 1.6;
  }
  .link-text {
    color: var(--color-accent);
    font-weight: 800;
    margin-top: 1.5rem;
    display: block;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .btn-secondary-dark {
    display: inline-block;
    margin-top: 4rem;
    color: var(--color-primary);
    font-weight: 800;
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: 4px;
    font-size: 1.1rem;
    transition: 0.3s;
  }
  .btn-secondary-dark:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* --- ECO SECTION --- */
  .section-eco {
    background: white;
    padding: 8rem 0;
    overflow: hidden;
  }
  .split-eco {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }
  .tag-green {
    color: var(--color-eco);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 10px;
  }
  .eco-lead {
    font-size: 1.3rem;
    color: #444;
    margin-bottom: 2.5rem;
    line-height: 1.5;
  }

  .eco-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .eco-list li {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .check-green {
    color: var(--color-eco);
    font-size: 1.6rem;
    background: var(--color-eco-light);
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    box-shadow: 0 5px 15px rgba(46, 125, 50, 0.2);
    flex-shrink: 0;
  }

  .eco-image-wrapper {
    position: relative;
  }
  .eco-circle-bg {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(
      circle,
      var(--color-eco-light) 0%,
      transparent 70%
    );
    border-radius: 50%;
    z-index: 0;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.8;
  }
  .eco-img {
    position: relative;
    z-index: 1;
    border-radius: 30px;
    box-shadow: 0 30px 80px rgba(46, 125, 50, 0.2);
    transform: rotate(-2deg);
    transition: 0.5s;
    width: 100%;
  }
  .eco-img:hover {
    transform: rotate(0deg) scale(1.02);
  }
  .floating {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0% {
      transform: translateY(0px) rotate(-2deg);
    }
    50% {
      transform: translateY(-15px) rotate(-1deg);
    }
    100% {
      transform: translateY(0px) rotate(-2deg);
    }
  }

  /* --- DARK TECH SECTION --- */
  .section-dark-blue {
    background-color: var(--color-primary);
    padding: 8rem 0;
    color: white;
    position: relative;
  }
  .tag-red {
    color: var(--color-brand-red);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    background: white;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.8rem;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin: 3rem 0;
  }
  .stat-val {
    display: block;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 5px;
  }
  .stat-desc {
    font-size: 1rem;
    opacity: 0.8;
    font-weight: 500;
  }

  .tech-image-wrapper {
    position: relative;
  }
  .tech-img {
    border-radius: 20px;
    border: 4px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    height: auto;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }
  .tech-badge {
    position: absolute;
    bottom: -30px;
    right: -30px;
    background: var(--color-brand-red);
    color: white;
    padding: 2rem;
    border-radius: 20px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
    text-align: center;
    border: 2px solid rgba(255, 255, 255, 0.2);
  }
  .big-num {
    font-size: 3rem;
    font-weight: 800;
    display: block;
    line-height: 1;
  }
  .tech-label {
    font-size: 1rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
  }

  /* --- CTA FINAL --- */
  .cta-final {
    background: linear-gradient(135deg, #f0f4f8, #ffffff);
    padding: 8rem 0;
  }
  .cta-title {
    color: var(--color-primary);
    font-size: 3rem;
    margin-bottom: 1.5rem;
    font-weight: 800;
