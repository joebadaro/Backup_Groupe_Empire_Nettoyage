---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Surfaces Spécialisées">
  <header class="page-header">
    <div class="container">
      <h1>Surfaces & Protection</h1>
      <p>Matelas, Céramique et Protection Anti-Tache</p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <div class="service-block">
        <h2>Nettoyage de Matelas</h2>
        <p>Nous passons 1/3 de notre vie au lit. Éliminez acariens et peaux mortes pour un sommeil sain.</p>
      </div>

      <div class="service-block">
        <h2>Nettoyage de Tuiles et Céramique</h2>
        <p>Redonnez la blancheur d'origine à vos joints de céramique grâce à notre pression industrielle.</p>
      </div>

       <div class="service-block">
        <h2>Protecteur Anti-Tache</h2>
        <p>Protégez vos investissements. Notre traitement hydrophobe repousse les liquides et prévient les taches permanentes.</p>
      </div>

      <div class="text-center" style="margin-top: 3rem;">
        <a href="/contact" class="btn btn-primary large-btn">Contactez-nous pour ces services</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header { background-color: var(--color-empire-blue); color: white; padding: 4rem 0; text-align: center; }
  .service-block { background: white; padding: 2rem; margin-bottom: 2rem; border-radius: 8px; box-shadow: var(--shadow-card); }
  .service-block h2 { color: var(--color-empire-blue); font-size: 1.5rem; }
</style>
