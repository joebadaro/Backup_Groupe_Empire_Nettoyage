---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nettoyage Céramique">
  <header class="page-header">
    <div class="container">
      <h1>Nettoyage Tuiles & Céramique</h1>
      <p>Vos planchers n'ont jamais été aussi propres.</p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <h2>Joints Sales ? Plus de problème.</h2>
      <p>Frotter à la brosse à dents est inutile. Notre turbo-nettoyeur utilise la pression contrôlée pour expulser la saleté incrustée dans les joints.</p>
      <br>
      <a href="/contact" class="btn btn-primary">Devis Céramique</a>
    </div>
  </section>
</Layout>

<style>
.page-header { background-color: var(--color-empire-blue); color: white; padding: 4rem 0; text-align: center; }
</style>
