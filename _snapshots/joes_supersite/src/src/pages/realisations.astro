---
import Layout from '../layouts/Layout.astro';

// Full List of Selected IDs
const ids = [
  5, 9, 10, 11, 14, 15, 16, 17, 18, 19, 
  22, 26, 27, 28, 29, 30, 31, 32, 34, 39, 46, 47, 
  50, 56, 58, 59, 60, 61, 62, 65, 66, 67, 69, 70,
  87, 88, 89, 90, 91, 92, 93
];

const rotatedIds = [32, 56, 58, 59, 60, 27, 39];

// SEO-Only Logic (Not shown in UI)
// Generates descriptive Alt text without grouping the UI
const galleryImages = ids.map((id) => ({
  src: `/images/catalog/photo-${id}${rotatedIds.includes(id) ? '-rotated' : ''}.webp`,
  id: id,
  alt: "Réalisation professionnelle Groupe Nettoyage Empire - Tapis, Meubles et Entretien", // Generic & Safe SEO
  isLarge: id === 66
}));
---

<Layout title="Nos Réalisations | Groupe Nettoyage Empire">
  
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <span class="sub-title text-accent">Galerie Photos</span>
      <h1 class="text-white">Nos Réalisations</h1>
      <p class="lead-text">L'excellence du nettoyage en images.</p>
    </div>
  </div>

  <section class="section" id="gallery-section">
    <div class="container">
      
      <!-- PURE GRID (No Filters, No Titles) -->
      <div class="smart-grid">
        {galleryImages.map((img) => (
          <div 
            class={`gallery-item fade-in-section ${img.isLarge ? 'span-2' : ''}`} 
            role="button"
            aria-label="Agrandir la photo"
          >
            <img 
              src={img.src} 
              alt={img.alt} 
              loading="lazy"
              class="gallery-img"
              data-full-src={img.src}
            />
            <!-- Visual hint for interaction -->
            <div class="overlay-hint">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
            </div>
          </div>
        ))}
      </div>

      <div class="cta-gallery text-center fade-in-section delay-200">
        <h2>Un résultat similaire vous intéresse ?</h2>
        <a href="/contact" class="btn btn-primary pulse-btn">Soumission en ligne</a>
      </div>

    </div>
  </section>

  <!-- ROBUST LIGHTBOX -->
  <div id="lightbox" class="lightbox">
    <button class="close-lightbox" aria-label="Fermer">&times;</button>
    <img class="lightbox-content" id="lightbox-img" alt="Vue agrandie">
  </div>

</Layout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // LIGHTBOX LOGIC
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.querySelector('.close-lightbox');
    const galleryItems = document.querySelectorAll('.gallery-item');

    if (lightbox && lightboxImg) {
      galleryItems.forEach(item => {
        item.addEventListener('click', () => {
          const img = item.querySelector('img');
          if (img) {
            lightboxImg.src = img.getAttribute('data-full-src');
            lightbox.classList.add('visible');
            document.body.style.overflow = 'hidden'; 
          }
        });
      });

      const close = () => {
        lightbox.classList.remove('visible');
        document.body.style.overflow = '';
      };

      closeBtn.addEventListener('click', close);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    }
  });
</script>

<style>
  /* Clean Header */
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, #002a55 100%);
    color: white;
    padding: 5rem 0 3rem 0;
    margin-bottom: 3rem;
  }
  .text-white { color: white; }
  .text-accent { color: var(--color-accent); font-weight: 700; text-transform: uppercase; letter-spacing: 2px; }
  .lead-text { font-size: 1.2rem; opacity: 0.9; margin-top: 0.5rem; font-weight: 300; }

  /* Gallery Grid */
  .smart-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.2rem;
    grid-auto-flow: dense;
  }

  .gallery-item {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    cursor: zoom-in;
    background: #e0e0e0;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.12);
    z-index: 10;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  
  .gallery-item:hover img {
    transform: scale(1.05); /* Subtle smooth zoom */
  }

  /* Overlay Hint */
  .overlay-hint {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0;
    transition: all 0.2s ease;
    background: rgba(0,0,0,0.3);
    border-radius: 50%;
    padding: 12px;
    display: flex;
    pointer-events: none;
  }
  
  .gallery-item:hover .overlay-hint {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    backdrop-filter: blur(2px);
  }

  /* Span Logic */
  .span-2 { grid-column: span 2; grid-row: span 2; }
  @media (max-width: 600px) {
    .smart-grid { grid-template-columns: 1fr 1fr; }
    .span-2 { grid-column: span 2; grid-row: span 2; }
  }

  /* Robust Lightbox */
  .lightbox {
    position: fixed;
    z-index: 9999;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.96); /* Darker professional background */
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .lightbox.visible { opacity: 1; pointer-events: all; }
  
  .lightbox-content {
    max-width: 95vw;
    max-height: 95vh;
    border-radius: 2px;
    box-shadow: 0 0 40px rgba(0,0,0,0.5);
    transform: scale(0.95);
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .lightbox.visible .lightbox-content { transform: scale(1); }

  .close-lightbox {
    position: absolute;
    top: 20px; right: 30px;
    background: none; border: none;
    color: white; font-size: 3rem;
    cursor: pointer; padding: 0;
    transition: transform 0.2s;
  }
  .close-lightbox:hover { transform: scale(1.1); color: var(--color-accent); }
  
  .cta-gallery {
    margin-top: 5rem;
    padding: 3rem;
    background: #f4f6f8;
    border-radius: 12px;
  }
  .cta-gallery h2 { margin-bottom: 0.5rem; color: var(--color-primary); }
</style>
