        "Prolongez la durée de vie de vos investissements. Nous utilisons uniquement des protecteurs professionnels non dilués pour une efficacité maximale.",
      problem:
        "Sans protection, les fibres absorbent les dégâts instantanément. Un bon protecteur vous donne le temps de réagir.",
      process: [
        {
          title: "Consultation & Choix",
          desc: "Le technicien identifie votre matériau et vous présente les options : Scotchgard (3M), Teflon (Dupont) ou protecteurs au Carbone.",
        },
        {
          title: "Recommandation",
          desc: "Nous vous expliquons les différences et vous conseillons le produit le plus durable pour votre usage spécifique.",
        },
        {
          title: "Application Pro",
          desc: "Vaporisation de la quantité exacte recommandée par le manufacturier (sans dilution) pour une protection optimale.",
        },
      ],
      benefits: [
        "Marques reconnues",
        "Produits PURS (Non dilués)",
        "Adapté au Tissu, Cuir, Tapis",
      ],
      faq: [
        {
          q: "Est-ce que l'eau va perler ?",
          a: "Cela dépend du tissu et du produit choisi. Le but principal est d'empêcher la tache de se fixer, vous donnant le temps d'éponger.",
        },
        {
          q: "Est-ce nécessaire ?",
          a: "C'est une option fortement recommandée pour protéger votre investissement à long terme, mais le choix final vous appartient.",
        },
      ],
    },
  ];

  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout
  title={`${service.seoTitle} | Groupe Nettoyage Empire`}
  description={service.intro}
  image={service.image}
>
  <style define:vars={{ heroHeight: service.heroHeight || "auto" }}>
    .service-hero {
      min-height: var(--heroHeight);
      display: flex;
      align-items: center;
    }
  </style>

  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">{service.category}</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            {service.title}
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">Le Problème :</h3>
            <p class="problem-text">{service.problem}</p>
          </div>

          <p class="lead-text fade-in-up delay-200">{service.intro}</p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-primary pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (Estimation Gratuite)
            </a>
            <a href="/contact" class="btn btn-secondary-outline">
              <span class="icon">✉️</span> Soumission en ligne
            </a>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <img
            src={service.image}
            alt={service.title}
            class="split-image"
            draggable="false"
          />
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <!-- PROCESS -->
          <div class="fade-in-section delay-100" style="margin-top: 0;">
            <h2 class="section-title text-gradient-empire">
              Notre Approche (Sur Place)
            </h2>
            <div class="process-timeline">
              {
                service.process.map((step, index) => (
                  <div class="process-step">
                    <div class="step-marker">{index + 1}</div>
                    <div class="step-content">
                      <h3>{step.title}</h3>
                      <p>{step.desc}</p>
                    </div>
                  </div>
                ))
              }
            </div>

            <!-- EQUIPMENT NOTE FOR PORTABLE -->
            <div
              class="equipment-note fade-in-section delay-100"
              style="margin-top: 2rem; background: #f9f9f9; padding: 1.5rem; border-radius: 8px; border-left: 3px solid var(--color-accent);"
            >
              <h4 style="margin-bottom: 0.5rem; color: var(--color-primary);">
                Équipement Adapté (Camion ou Portable)
              </h4>
              <p style="font-size: 0.95rem;">
                Nous utilisons prioritairement nos <strong
                  >camions-usines</strong
                > pour une puissance maximale. Toutefois, pour les condos en hauteur
                ou les accès limités, nous sommes équipés de <strong
                  >machines portatives professionnelles haute-performance</strong
                >. Ces unités n'ont rien à voir avec les machines de location :
                elles garantissent un résultat expert, peu importe votre étage.
              </p>
            </div>
          </div>

          <!-- BENEFITS -->
          <div class="fade-in-section delay-200" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">
              Pourquoi nous choisir ?
            </h2>
            <div class="benefits-grid">
              {
                service.benefits.map((benefit) => (
                  <div class="benefit-item">
                    <div class="check-circle">✓</div>
                    <span>{benefit}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- FAQ (Schema Friendly structure) -->
          {
            service.faq && (
              <div class="fade-in-section delay-300" style="margin-top: 3rem;">
                <h2 class="section-title text-gradient-empire">
                  Questions Fréquentes
                </h2>
                <div class="faq-list">
                  {service.faq.map((item) => (
                    <div class="faq-item">
                      <p class="question">
                        <strong>Q : {item.q}</strong>
                      </p>
                      <p class="answer">{item.a}</p>
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <!-- SIDEBAR CTA (Sticky) -->
        <aside class="service-sidebar">
          <div class="sticky-card fade-in-section">
            <h3 class="card-title text-gradient-gold">Estimation Gratuite</h3>
            <p class="card-desc">Appelez-nous pour une réponse immédiate.</p>

            <a
              href="tel:5148939939"
              class="btn btn-primary full-width pop-effect pulse-phone"
            >
              <span class="icon">📞</span> (514) 893-9939 (Estimation Gratuite)
            </a>

            <p
              class="text-center"
              style="margin: 1rem 0; font-size: 0.9rem; color: #888;"
            >
              ou
            </p>

            <a href="/contact" class="btn-secondary-outline full-width">
              Soumission en ligne
            </a>

            <div class="guarantee-badge">
              <span>🌿 Produits 100% Écologiques</span>
              <div style="margin-top: 5px; color: #ffbf00; font-weight: bold;">
                ★★★★★
              </div>
              <span style="font-size: 0.8rem; color: #666;"
                >Clients Satisfaits</span
              >
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* HERO */
  /* SPLIT SCREEN HERO (Sky Blue Theme) */
  .split-hero-container {
    background-color: #fff; /* Reset container to white */
    padding-top: 0; /* Remove container padding so image hits top */
    padding-bottom: 0;
    overflow: hidden;
    width: 100vw;
  }

  .full-width-split {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 100vh; /* Full viewport height */
  }

  /* LEFT TEXT COLUMN */
  .split-content {
    background-color: #ecf6ff; /* Blue visible ONLY here */
    padding: 150px 4rem 4rem 10%; /* Add header offset internal padding */
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  /* Remove dark texture, add subtle light shine */
  .split-content::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      circle at top left,
      #ffffff 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: -1;
  }

  .service-cat-badge {
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }

  .split-title {
    font-size: clamp(2.5rem, 3.5vw, 4rem);
    color: var(--color-primary); /* Dark Blue text */
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .problem-statement {
    background: #ffffff; /* White box */
    border-left: 4px solid #ff4444; /* Red border returns for alertness */
    padding: 1.5rem;
    border-radius: 0;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); /* Soft blue shadow */
  }

  .problem-title {
    font-size: 1rem;
    color: #cc0000;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    font-weight: 700;
  }

  .problem-text {
    font-size: 1.05rem;
    color: var(--color-text-main);
    font-style: italic;
  }

  .lead-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text-main); /* Dark grey text */
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
