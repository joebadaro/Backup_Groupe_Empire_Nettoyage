---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  const services = [
    {
      slug: "tapis-residentiel",
      title: "Nettoyage de tapis résidentiel",
      seoTitle: "Expert Nettoyage Tapis Tésidentiel à Domicile",
      category: "Tapis",
      icon: "🏠",
      image: "/images/catalog/photo-tapis-clean.webp",
      imagePosition: "center top", // Anchor to top
      heroHeight: "70vh", // Taller to maximize image size in contain mode
      heroFit: "contain", // Force image to fit fully without cropping
      intro:
        "Vos tapis sont le filtre à air de votre maison. Avec le temps, ils accumulent poussière, acariens et allergènes. Notre nettoyage à domicile protège vos planchers tout en assainissant votre air.",
      problem:
        "Taches tenaces, trafic intense ou besoin d'un rafraîchissement hygiénique ? Les méthodes grand public laissent souvent des résidus savonneux.",
