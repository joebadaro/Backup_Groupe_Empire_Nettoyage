---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Nettoyage de Meubles">
  <header class="page-header">
    <div class="container">
      <h1>Nettoyage de Meubles & Divans</h1>
      <p>Prolongez la durée de vie de vos tissus d'ameublement.</p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <div class="content-grid">
        <div class="image-content">
             <img src="/images/service-meubles.jpg" alt="Nettoyage de sofa" class="rounded-img shadow-premium">
        </div>
        <div class="text-content">
          <h2>Soin délicat pour tissus précieux</h2>
          <p>Qu'il s'agisse de coton, microfibre, velours ou cuir, nous avons la technique adaptée.</p>
          
          <h3>Notre Processus</h3>
          <ol class="process-list">
            <li>Inspection du tissu et test de couleur.</li>
            <li>Prétraitement des taches tenaces.</li>
            <li>Injection-extraction à température contrôlée.</li>
            <li>Péparation des fibres (brossage) et désodorisation.</li>
          </ol>

          <br>
          <a href="/contact" class="btn btn-primary">Demander un prix</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header { background-color: var(--color-empire-blue); color: white; padding: 4rem 0; text-align: center; }
  .content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .rounded-img { border-radius: 8px; width: 100%; }
  
  .process-list { margin: 1.5rem 0 2rem 1.5rem; }
  .process-list li { margin-bottom: 0.5rem; }

  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .image-content { order: -1; } }
</style>
