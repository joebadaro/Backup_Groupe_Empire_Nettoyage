---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Nettoyage Tapis Commercial">
  <header class="page-header">
    <div class="container">
      <h1>Nettoyage de Tapis Commercial</h1>
      <p>L'image de votre entreprise commence par la propreté.</p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <h2>Solutions pour Bureaux et Commerces</h2>
      <p>
        Un service d'entretien professionnel conçu pour vos espaces d'affaires.
      </p>
      <ul>
        <li>Plans d'entretien régulier</li>
        <li>Nettoyage de chaises de bureau et cubicules</li>
        <li>Tarifs compétitifs au pied carré</li>
      </ul>
      <br />
      <a href="/contact" class="btn btn-primary">Soumission en ligne</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-empire-blue);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }
</style>
