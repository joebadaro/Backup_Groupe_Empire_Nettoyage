---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contactez-nous | Groupe Nettoyage Empire">
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <h1 class="text-gradient">Demandez votre estimation gratuite</h1>
      <div
        class="trust-pill badge-google"
        style="display:inline-block; margin: 0.5rem 0; width: auto; padding: 4px 15px;"
      >
        <img
          src="/images/google-reviews-badge.png"
          alt="Google 5 Stars"
          width="100"
          height="auto"
          style="display: block;"
        />
      </div>
      <p class="lead-text">Appelez-nous pour une réponse immédiate.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <!-- FORMULAIRE -->
        <div class="contact-form-wrapper fade-in-section">
          <h2>Formulaire de demande</h2>
          <p class="form-intro">
            Préférez-vous une réponse rapide ? <a
              href="tel:5148939939"
              style="color: var(--color-primary); font-weight: bold;"
              >Appelez-nous au (514) 893-9939</a
            >.
          </p>

          <form
            class="contact-form"
            name="contact"
            method="POST"
            action="https://formsubmit.co/info@groupenettoyageempire.com"
          >
            <!-- FormSubmit Config -->
            <input
              type="hidden"
              name="_subject"
              value="Nouvelle demande de soumission - Site Web"
            />
            <input
              type="hidden"
              name="_next"
              value="https://groupenettoyageempire.com/merci"
            />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <div class="form-grid">
              <div class="form-group">
                <label for="name">Nom complet *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Votre nom"
                />
              </div>

              <div class="form-group">
                <label for="city">Ville *</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  required
                  placeholder="Votre ville"
                />
              </div>

              <div class="form-group">
                <label for="phone">Numéro de téléphone *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  placeholder="(514) 000-0000"
                />
              </div>

              <div class="form-group">
                <label for="email">Courriel (Optionnel)</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="Pour recevoir la soumission par écrit"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="address">Adresse complète (Optionnel)</label>
              <input
                type="text"
                id="address"
                name="address"
                placeholder="Numéro, rue, appartement"
              />
            </div>

            <div class="form-group">
              <label for="service">Service(s) désiré(s) *</label>
              <select id="service" name="service" required>
                <option value="" disabled selected>Choisir un service...</option
                >
                <option value="Tapis Résidentiel"
                  >Nettoyage de tapis résidentiel</option
                >
                <option value="Tapis Commercial"
                  >Nettoyage de tapis commercial</option
                >
                <option value="Tapis Synthétique"
                  >Nettoyage de tapis synthétique à domicile</option
                >
                <option value="Tapis Laine"
                  >Nettoyage de tapis en laine à domicile</option
                >
                <option value="Tapis Orientaux"
                  >Nettoyage de tapis orientaux à domicile</option
                >
                <option value="Meubles Tissu"
                  >Nettoyage de meubles en tissu</option
                >
                <option value="Meubles Cuir"
                  >Nettoyage de meubles en cuir</option
                >
                <option value="Matelas"
                  >Nettoyage et désinfection de matelas</option
                >
                <option value="Céramique"
                  >Nettoyage de tuiles de céramique</option
                >
                <option value="Protecteur"
                  >Application de protecteurs antitâches (Tissus/Cuir/Tapis)</option
                >
                <option value="Autre">Autre demande</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Détails ou questions</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="Ex: Grandeur des pièces, type de taches, code d'accès..."
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary full-width"
              >Envoyer la demande</button
            >
          </form>
        </div>

        <!-- INFO SIDEBAR -->
        <div class="contact-info fade-in-section delay-100">
          <div class="info-card">
            <h3>Contact Rapide</h3>
            <div
              class="info-item"
              style="background: #fdfdfd; padding: 15px; border-left: 4px solid var(--color-primary);"
            >
              <span class="icon">📞</span>
              <div>
                <strong>Par Téléphone (Prioritaire)</strong>
                <a href="tel:5148939939" class="phone-big"
                  >(514) 893-9939 (Estimation Gratuite)</a
                >
              </div>
            </div>
            <div class="info-item">
              <span class="icon">✉️</span>
              <div>
                <strong>Courriel</strong>
                <a href="mailto:Info@groupenettoyageempire.com"
                  >Info@groupenettoyageempire.com</a
                >
              </div>
            </div>
            <div class="info-item">
              <span class="icon">📍</span>
              <div>
                <strong>Zones desservies</strong>
                <p>Grand Montréal, Rive-Nord, Rive-Sud.</p>
              </div>
            </div>
          </div>

          <div class="trust-box">
            <h3>Conseil d'expert</h3>
            <ul class="check-list">
              <li>
                🔍 <strong>Inspection Complète :</strong> Avant de commencer le nettoyage,
                notre technicien effectue toujours une inspection complète des tapis,
                tissus ou surfaces.
              </li>
              <li>
                💬 <strong>Transparence :</strong> Si des ajustements ou traitements
                sont recommandés, vous en êtes informé avec toutes les options disponibles.
              </li>
              <li>
                ✅ <strong>Votre Décision :</strong> Aucune intervention additionnelle
                n’est effectuée sans votre accord. Le nettoyage est toujours réalisé
                selon vos besoins.
              </li>
            </ul>
          </div>

          <!-- Map Placeholder -->
          <!-- Google Map -->
          <div class="map-container fade-in-section delay-200">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d44795.56877994073!2d-73.450!3d45.535!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4cc91b931934989d%3A0xe247c724771775!2sLongueuil%2C%20QC%20J3Y!5e0!3m2!1sen!2sca!4v1703000000000!5m2!1sen!2sca"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Zone desservie : Longueuil et environs"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-bg-light-blue);
    padding: 4rem 0;
    margin-bottom: 2rem;
  }

  .lead-text {
    font-size: 1.2rem;
    color: var(--color-text-light);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
  }

  .contact-form-wrapper {
    background: white;
    padding: 2.5rem;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-subtle);
    border: 1px solid #eee;
  }

  .form-intro {
    margin-bottom: 2rem;
    color: #666;
    font-style: italic;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--color-primary);
    font-size: 0.95rem;
  }

  input,
  select,
  textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    transition: 0.3s;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--color-accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(197, 160, 101, 0.1);
  }

  .full-width {
    width: 100%;
    margin-top: 1rem;
  }

  /* Info Sidebar */
  .info-card {
    background: white;
    padding: 2rem;
    border-radius: var(--border-radius-md);
    margin-bottom: 2rem;
    box-shadow: var(--shadow-subtle);
  }

  .info-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: center;
  }

  .icon {
    font-size: 1.5rem;
  }

  .phone-big {
    display: block;
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-accent);
  }

  .trust-box {
    background: var(--color-primary);
    color: white;
    padding: 2rem;
    border-radius: var(--border-radius-md);
    margin-bottom: 2rem;
  }

  .trust-box h3 {
    color: white;
    margin-bottom: 1rem;
    font-size: 1.2rem;
  }

  .check-list li {
    margin-bottom: 1rem;
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .map-container {
    height: 300px;
    border-radius: var(--border-radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-subtle);
    border: 1px solid #eee;
  }

  @media (max-width: 800px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
