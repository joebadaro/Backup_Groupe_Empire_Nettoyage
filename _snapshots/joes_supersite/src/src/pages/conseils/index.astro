---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    slug: 'erreurs-taches-tapis',
    title: '3 Erreurs Fatales à Éviter sur une Tache',
    excerpt: 'Frotter est la pire chose à faire. Découvrez comment réagir pour sauver votre tapis.',
    date: '17 Décembre 2024',
    category: 'Entretien',
    icon: '🛑'
  },
  {
    slug: 'urine-animaux-tapis',
    title: 'Animaux : Pourquoi l\'odeur revient toujours ?',
    excerpt: 'L\'urine cristallise dans la fibre. Un simple nettoyage de surface ne suffit pas.',
    date: '14 Décembre 2024',
    category: 'Animaux',
    icon: '🐶'
  },
  {
    slug: 'preparer-visite-nettoyage',
    title: '5 minutes pour préparer votre visite',
    excerpt: 'Faut-il passer l\'aspirateur ? Bouger les meubles ? Notre check-list simple.',
    date: '12 Décembre 2024',
    category: 'Guide',
    icon: '📋'
  },
  {
    slug: 'frequence-nettoyage-tapis',
    title: 'À quelle fréquence nettoyer vos tapis ?',
    excerpt: 'Allergies, poussière, santé : les vraies recommandations pour une maison saine.',
    date: '10 Décembre 2024',
    category: 'Santé',
    icon: '📅'
  },
  {
    slug: 'entretien-cuir-erreurs',
    title: 'Cuir : Arrêtez les lingettes pour bébé !',
    excerpt: 'Les produits de pharmacie encrassent le cuir. Voici la vraie méthode.',
    date: '08 Décembre 2024',
    category: 'Entretien',
    icon: '🛋️'
  },
  {
    slug: 'nettoyage-vapeur-vs-location',
    title: 'Machine de Location vs Camion-Usine',
    excerpt: 'Pourquoi la location d\'épicerie ne vaut pas un nettoyage professionnel.',
    date: '15 Décembre 2024',
    category: 'Comparatif',
    icon: '🚛'
  }
];
---

<Layout title="Conseils de l'Expert | Groupe Nettoyage Empire">
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <h1 class="text-gradient">Conseils de l'Expert</h1>
      <p class="intro">Astuces, guides et recommandations pour l'entretien de vos surfaces.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      
      <div class="blog-grid fade-in-section delay-100">
        {posts.map(post => (
          <a href={`/conseils/${post.slug}`} class="blog-card">
            <div class="card-icon">{post.icon}</div>
            <div class="card-content">
              <span class="card-cat">{post.category}</span>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>
              <span class="read-more">Lire l'article &rarr;</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-bg-light-blue);
    padding: 4rem 0;
    text-align: center;
    border-bottom: 1px solid #eee;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 1rem auto 0 auto;
    font-size: 1.2rem;
    color: var(--color-text-light);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding: 4rem 0;
  }

  .blog-card {
    background: white;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-subtle);
    transition: transform 0.2s;
    border: 1px solid #eee;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-accent);
  }

  .card-icon {
    font-size: 3rem;
    background: #f9f9f9;
    padding: 2rem;
    text-align: center;
  }

  .card-content {
    padding: 2rem;
  }

  .card-cat {
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .blog-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.3rem;
    line-height: 1.3;
  }

  .blog-card p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  .read-more {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 0.9rem;
  }
</style>
