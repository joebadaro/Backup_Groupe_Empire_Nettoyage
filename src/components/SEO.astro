---
interface Props {
    title: string;
    description: string;
    image?: string;
    article?: boolean;
    serviceType?: string;
    serviceArea?: string[];
}

const {
    title,
    description,
    image = "/images/catalog/photo-tapis-clean.webp", // Keeping the fixed image as it is better
    article = false,
} = Astro.props;

const siteUrl = "https://groupenettoyageempire.com";

// Hreflang Logic
const { pathname } = Astro.url;
const isEn = pathname.startsWith("/en");
const cleanPath = pathname.replace(/\/$/, "") || "/";

let frPath = isEn ? cleanPath.replace("/en", "") || "/" : cleanPath;
let enPath = isEn ? cleanPath : "/en" + (cleanPath === "/" ? "" : cleanPath);

const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const frURL = new URL(frPath, siteUrl);
const enURL = new URL(enPath, siteUrl);
const socialImageURL = new URL(image, siteUrl);

const jsonLD = {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "@id": `${siteUrl}/#organization`,
    name: "Groupe Nettoyage Empire",
    alternateName: "Nettoyage Empire",
    slogan: "L'Excellence du Nettoyage au Québec",
    description:
        "Service professionnel de nettoyage de tapis, meubles et matelas à Montréal, Laval et Rive-Sud. Technologie de camion-usine, produits écologiques et expertise de 30+ ans.",
    image: [socialImageURL, `${siteUrl}/images/catalog/team-van-back.webp`],
    logo: `${siteUrl}/images/logo-empire.png`,
    telephone: "(514) 893-9939",
    email: "info@groupenettoyageempire.com",
    address: {
        "@type": "PostalAddress",
        streetAddress: "",
        addressLocality: "Longueuil",
        addressRegion: "QC",
        postalCode: "J3Y",
        addressCountry: "CA",
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: 45.5369,
        longitude: -73.4983,
    },
    areaServed: [
        {
            "@type": "City",
            name: "Montréal",
            "@id": "https://www.wikidata.org/wiki/Q340",
        },
        {
            "@type": "City",
            name: "Longueuil",
        },
        {
            "@type": "City",
            name: "Brossard",
        },
        {
            "@type": "City",
            name: "Boucherville",
        },
        {
            "@type": "City",
            name: "Laval",
        },
        {
            "@type": "Place",
            name: "Rive-Sud de Montréal",
        },
        {
            "@type": "Place",
            name: "Rive-Nord de Montréal",
        },
    ],
    url: siteUrl,
    priceRange: "$$",
    paymentAccepted: ["Cash", "Credit Card", "Debit Card", "Interac"],
    currenciesAccepted: "CAD",
    openingHoursSpecification: [
        {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday",
                "Sunday",
            ],
            opens: "08:00",
            closes: "20:00",
        },
    ],
    sameAs: [
        "https://www.facebook.com/NettoyageEmpire/",
        "https://www.youtube.com/@NettoyageEmpire",
        "https://instagram.com/groupenettoyageempire",
    ],
    aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "5",
        reviewCount: "150",
        bestRating: "5",
    },
    foundingDate: "1990",
    numberOfEmployees: {
        "@type": "QuantitativeValue",
        value: 15,
    },
    knowsAbout: [
        "Nettoyage de tapis",
        "Nettoyage de meubles",
        "Nettoyage de matelas",
        "Désinfection",
        "Extraction à la vapeur",
        "Produits écologiques",
        "Nettoyage commercial",
        "Nettoyage résidentiel",
    ],
    hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Services de Nettoyage",
        itemListElement: [
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: "Nettoyage de tapis résidentiel",
                    name: "Nettoyage de Tapis Résidentiel",
                    description:
                        "Nettoyage professionnel de tapis à domicile avec camion-usine. Élimination des taches, allergènes et odeurs.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: "Montréal, Laval, Rive-Sud",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: "Nettoyage de meubles",
                    name: "Nettoyage de Meubles et Divans",
                    description:
                        "Nettoyage de sofas, divans et fauteuils en tissu ou cuir. Traitement anti-taches et désodorisation.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: "Montréal, Laval, Rive-Sud",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: "Nettoyage et désinfection de matelas",
                    name: "Nettoyage et Désinfection de Matelas",
                    description:
                        "Élimination certifiée des acariens, bactéries et allergènes pour un sommeil sain.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: "Montréal, Laval, Rive-Sud",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: "Nettoyage de tapis commercial",
                    name: "Nettoyage de Tapis Commercial",
                    description:
                        "Solutions professionnelles pour bureaux et espaces commerciaux. Service hors heures disponible.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
