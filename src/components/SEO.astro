---
interface Props {
    title: string;
    description: string;
    image?: string;
    article?: boolean;
    serviceType?: string;
    serviceArea?: string[];
    robots?: string;
}

const {
    title,
    description,
    image = "/images/catalog/photo-tapis-clean.webp", // Keeping the fixed image as it is better
    article = false,
    robots,
} = Astro.props;

const siteUrl = "https://groupenettoyageempire.com";

// Hreflang Logic
const { pathname } = Astro.url;
const isEn = pathname.startsWith("/en");
const isEnTips = pathname.startsWith("/en/tips");
const cleanPath = pathname.replace(/\/$/, "") || "/";

let frPath = isEn ? cleanPath.replace("/en", "") || "/" : cleanPath;
let enPath = isEn ? cleanPath : "/en" + (cleanPath === "/" ? "" : cleanPath);

// Use cleaned path to avoid canonical mismatches (e.g. trailing slash)
const canonicalURL = new URL(cleanPath, siteUrl);
const frURL = new URL(frPath, siteUrl);
const enURL = new URL(enPath, siteUrl);
const socialImageURL = new URL(image, siteUrl);

const jsonLD = {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "ProfessionalService"],
    "@id": `${siteUrl}/#organization`,
    name: "Groupe Nettoyage Empire",
    alternateName: "Nettoyage Empire",
    slogan: "L'Excellence du Nettoyage au Québec",
    description: isEn
        ? "Premium carpet, upholstery and mattress cleaning services in Montreal and Quebec. Eco-friendly solutions and truck-mount technology."
        : "Service professionnel de nettoyage de tapis, meubles et matelas à Montréal, Laval et Rive-Sud. Technologie de camion-usine, produits écologiques et expertise de 30+ ans.",
    image: [socialImageURL, `${siteUrl}/images/catalog/team-van-back.webp`],
    logo: `${siteUrl}/images/logo-empire.png`,
    telephone: "(514) 893-9939",
    email: "info@groupenettoyageempire.com",
    address: {
        "@type": "PostalAddress",
        streetAddress: undefined,
        addressLocality: "Longueuil",
        addressRegion: "QC",
        postalCode: "J3Y",
        addressCountry: "CA",
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: 45.5369,
        longitude: -73.4983,
    },
    areaServed: [
        {
            "@type": "City",
            name: "Montréal",
            "@id": "https://www.wikidata.org/wiki/Q340",
        },
        {
            "@type": "City",
            name: "Longueuil",
        },
        {
            "@type": "City",
            name: "Brossard",
        },
        {
            "@type": "City",
            name: "Boucherville",
        },
        {
            "@type": "City",
            name: "Laval",
        },
        {
            "@type": "City",
            name: "Saint-Bruno-de-Montarville",
        },
        {
            "@type": "City",
            name: "Saint-Lambert",
        },
        {
            "@type": "City",
            name: "Saint-Jean-sur-Richelieu",
        },
        {
            "@type": "City",
            name: "La Prairie",
        },
        {
            "@type": "City",
            name: "Candiac",
        },
        {
            "@type": "City",
            name: "Beloeil",
        },
        {
            "@type": "City",
            name: "Châteauguay",
        },
        {
            "@type": "Place",
            name: isEn ? "South Shore of Montreal" : "Rive-Sud de Montréal",
        },
        {
            "@type": "Place",
            name: isEn ? "North Shore of Montreal" : "Rive-Nord de Montréal",
        },
    ],
    url: siteUrl,
    priceRange: "$$",
    paymentAccepted: ["Cash", "Credit Card", "Debit Card", "Interac"],
    currenciesAccepted: "CAD",
    openingHoursSpecification: [
        {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: [
                "Monday",
                "Tuesday",
                "Wednesday",
                "Thursday",
                "Friday",
                "Saturday",
                "Sunday",
            ],
            opens: "08:00",
            closes: "20:00",
        },
    ],
    sameAs: [
        "https://www.facebook.com/NettoyageEmpire/",
        "https://www.youtube.com/@NettoyageEmpire",
        "https://instagram.com/groupenettoyageempire",
    ],
    aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: "5",
        reviewCount: "150",
        bestRating: "5",
    },
    foundingDate: "1990",
    numberOfEmployees: {
        "@type": "QuantitativeValue",
        value: 15,
    },
    knowsAbout: isEn
        ? [
              "Carpet cleaning",
              "Upholstery cleaning",
              "Mattress cleaning",
              "Disinfection",
              "Steam extraction",
              "Eco-friendly products",
              "Commercial cleaning",
              "Residential cleaning",
          ]
        : [
              "Nettoyage de tapis",
              "Nettoyage de meubles",
              "Nettoyage de matelas",
              "Désinfection",
              "Extraction à la vapeur",
              "Produits écologiques",
              "Nettoyage commercial",
              "Nettoyage résidentiel",
          ],
    hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: isEn ? "Cleaning Services" : "Services de Nettoyage",
        itemListElement: [
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: isEn
                        ? "Residential Carpet Cleaning"
                        : "Nettoyage de tapis résidentiel",
                    name: isEn
                        ? "Residential Carpet Cleaning"
                        : "Nettoyage de Tapis Résidentiel",
                    description:
                        isEn
                            ? "Professional in-home carpet cleaning with truck-mount technology. Removes stains, allergens and odors."
                            : "Nettoyage professionnel de tapis à domicile avec camion-usine. Élimination des taches, allergènes et odeurs.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: isEn
                        ? "Montreal, Laval, South Shore"
                        : "Montréal, Laval, Rive-Sud",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: isEn ? "Upholstery & Furniture Cleaning" : "Nettoyage de meubles",
                    name: isEn ? "Upholstery & Furniture Cleaning" : "Nettoyage de Meubles et Divans",
                    description:
                        isEn
                            ? "Cleaning for fabric and leather sofas, couches and armchairs. Stain treatment and deodorizing."
                            : "Nettoyage de sofas, divans et fauteuils en tissu ou cuir. Traitement anti-taches et désodorisation.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: isEn
                        ? "Montreal, Laval, South Shore"
                        : "Montréal, Laval, Rive-Sud",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: isEn ? "Mattress Cleaning & Disinfection" : "Nettoyage et désinfection de matelas",
                    name: isEn ? "Mattress Cleaning & Disinfection" : "Nettoyage et Désinfection de Matelas",
                    description:
                        isEn
                            ? "Certified removal of dust mites, bacteria and allergens for healthier sleep."
                            : "Élimination certifiée des acariens, bactéries et allergènes pour un sommeil sain.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: isEn
                        ? "Montreal, Laval, South Shore"
                        : "Montréal, Laval, Rive-Sud",
                },
            },
            {
                "@type": "Offer",
                itemOffered: {
                    "@type": "Service",
                    serviceType: isEn
                        ? "Commercial Carpet Cleaning"
                        : "Nettoyage de tapis commercial",
                    name: isEn
                        ? "Commercial Carpet Cleaning"
                        : "Nettoyage de Tapis Commercial",
                    description:
                        isEn
                            ? "Professional solutions for offices and commercial spaces. After-hours service available."
                            : "Solutions professionnelles pour bureaux et espaces commerciaux. Service hors heures disponible.",
                    provider: {
                        "@id": `${siteUrl}/#organization`,
                    },
                    areaServed: isEn
                        ? "Montreal, Laval, South Shore"
                        : "Montréal, Laval, Rive-Sud",
                },
            },
        ],
    },
};

const webSiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    url: siteUrl,
    name: "Groupe Nettoyage Empire",
    description: isEn
        ? "The Excellence of Cleaning in Quebec"
        : "L'Excellence du Nettoyage au Québec",
    publisher: {
        "@id": `${siteUrl}/#organization`,
    },
    inLanguage: ["fr", "en"],
};

// Generate BreadcrumbList Schema dynamically based on URL path
const pathSegments = cleanPath.split("/").filter((segment) => segment !== "");
const isEnPath = pathSegments[0] === "en";

// Remove 'en' from path segments for breadcrumb generation if present
const breadcrumbSegments = isEnPath ? pathSegments.slice(1) : pathSegments;

let itemListElement = [
    {
        "@type": "ListItem",
        position: 1,
        name: isEnPath ? "Home" : "Accueil",
        item: isEnPath ? `${siteUrl}/en` : siteUrl,
    },
];

let currentPath = isEnPath ? "/en" : "";
breadcrumbSegments.forEach((segment, index) => {
    currentPath += `/${segment}`;
    
    // Format name (capitalize first letter, replace hyphens with spaces)
    let name = segment.replace(/-/g, " ");
    name = name.charAt(0).toUpperCase() + name.slice(1);

    // Special cases
    if (segment === "services") {
        name = "Services";
    }

    itemListElement.push({
        "@type": "ListItem",
        position: index + 2,
        name: name,
        item: `${siteUrl}${currentPath}`,
    });
});

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: itemListElement,
};

---

<!-- Essential Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
<meta name="description" content={description} />
<meta
    name="robots"
    content={
        robots ??
        "index, follow, max-image-preview:large, max-snippet:-1"
    }
/>
<link rel="canonical" href={canonicalURL} />
{!isEnTips && <link rel="alternate" hreflang="fr" href={frURL} />}
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="x-default" href={isEnTips ? enURL : frURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? "article" : "website"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImageURL} />
<meta property="og:site_name" content="Groupe Nettoyage Empire" />
<meta property="og:locale" content={isEn ? "en_CA" : "fr_CA"} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<!-- Schema.org JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />
<script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
