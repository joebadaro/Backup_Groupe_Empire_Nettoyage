---
const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith("/en");
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="container footer-grid">
      <!-- 1. Brand Identity -->
      <div class="footer-col brand-col">
        <div class="logo-group">
          <span class="logo-surtitle">{isEn ? "Group" : "Groupe"}</span>
          <span class="logo-title text-gradient-gold"
            >{isEn ? "Empire Cleaning" : "Nettoyage Empire"}</span
          >
        </div>
        <p class="brand-desc">
          {
            isEn
              ? "Excellence in residential and commercial cleaning. Quality commitment and certified ecological products."
              : "L'excellence en nettoyage résidentiel et commercial. Engagement qualité et produits écologiques certifiés."
          }
        </p>
        <div class="badges-row">
          <img
          src="/images/google-reviews-badge.png"
          alt="Google Reviews"
          class="footer-google-badge"
          width="110"
          height="61"
        />
          <div class="trust-badge">
            <span class="icon">🛡️</span>
            {isEn ? "Satisfaction Guaranteed" : "Garantie Satisfaction"}
          </div>
        </div>
      </div>

      <!-- 2. Navigation -->
      <div class="footer-col links-col">
        <h4 class="footer-heading">{isEn ? "Company" : "Entreprise"}</h4>
        <ul class="footer-nav">
          <li><a href={isEn ? "/en" : "/"}>{isEn ? "Home" : "Accueil"}</a></li>
          <li>
            <a href={isEn ? "/en/about" : "/about"}
              >{isEn ? "About" : "À Propos"}</a>
          </li>
          <li>
            <a href={isEn ? "/en/equipe" : "/equipe"}
              >{isEn ? "Our Team" : "Notre Équipe"}</a>
          </li>
          <!-- <li><a href={isEn ? "/en/conseils" : "/conseils"}>{isEn ? "Expert Tips" : "Conseils d'Experts"}</a></li> -->
          <li>
            <a href={isEn ? "/en/contact" : "/contact"}
              >{isEn ? "Quote Request" : "Demande de Soumission"}</a>
          </li>
          <li>
            <a href={isEn ? "/en/produits" : "/produits"}
              >{isEn ? "Professional products" : "Produits professionnels"}</a>
          </li>
        </ul>
      </div>

      <!-- 3. Services -->
      <div class="footer-col links-col">
        <h4 class="footer-heading">{isEn ? "Our Services" : "Nos Services"}</h4>
        <ul class="footer-nav">
          <li>
            <a
              href={isEn
                ? "/en/services/nettoyage-tapis-residentiel"
                : "/services/nettoyage-tapis-residentiel"}
              >{isEn ? "Carpet Cleaning" : "Nettoyage de Tapis"}</a
            >
          </li>
          <li>
            <a
              href={isEn
                ? "/en/services/meubles-cuir"
                : "/services/meubles-cuir"}
              >{
                isEn ? "Leather & Fabric Furniture" : "Meubles en Cuir & Tissus"
              }</a>
          </li>
          <li>
            <a
              href={isEn
                ? "/en/services/nettoyage-desinfection-matelas"
                : "/services/nettoyage-desinfection-matelas"}
              >{isEn ? "Mattress & Disinfection" : "Matelas & Désinfection"}</a
            >
          </li>
          <li>
            <a
              href={isEn
                ? "/en/services/nettoyage-tuiles-ceramique"
                : "/services/nettoyage-tuiles-ceramique"}
              >{isEn ? "Tile & Grout" : "Céramique & Joints"}</a
            >
          </li>
        </ul>
      </div>

      <!-- 4. Contact -->
      <div class="footer-col contact-col">
        <h4 class="footer-heading">
          {isEn ? "Customer Service" : "Service Client"}
        </h4>
        <div class="contact-info">
          <a href="tel:5148939939" class="contact-row highlight">
            <span class="icon-circle">📞</span>
            <div class="info-text">
              <span class="label"
                >{isEn ? "By phone (7/7)" : "Par téléphone (7/7)"}</span
              >
              <span class="value">(514) 893-9939</span>
            </div>
          </a>

          <a href="mailto:Info@groupenettoyageempire.com" class="contact-row">
            <span class="icon-circle">✉️</span>
            <div class="info-text">
              <span class="label">{isEn ? "By email" : "Par courriel"}</span>
              <span class="value">Info@groupenettoyageempire.com</span>
            </div>
          </a>

          <div class="contact-row">
            <span class="icon-circle">📍</span>
            <div class="info-text">
              <span class="label"
                >{isEn ? "Service Area" : "Zone de service"}</span
              >
              <span class="value"
                >{
                  isEn
                    ? "Greater Montreal & North/South Shore"
                    : "Grand Montréal & Rive-Nord/Sud"
                }</span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Villes Desservies (SEO Locales) -->
      <div class="footer-col animation-float" style="animation-delay: 0.3s">
        <h4 class="footer-heading">{isEn ? "Cities Served" : "Villes Desservies"}</h4>
        <ul class="footer-nav">
          <li><a href={isEn ? "/en/services/nettoyage-tapis-montreal" : "/services/nettoyage-tapis-montreal"}>{isEn ? "Carpet Cleaning Montreal" : "Nettoyage Tapis Montréal"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-laval" : "/services/nettoyage-tapis-laval"}>{isEn ? "Carpet Cleaning Laval" : "Nettoyage Tapis Laval"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-longueuil" : "/services/nettoyage-tapis-longueuil"}>{isEn ? "Carpet Cleaning Longueuil" : "Nettoyage Tapis Longueuil"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-brossard" : "/services/nettoyage-tapis-brossard"}>{isEn ? "Carpet Cleaning Brossard" : "Nettoyage Tapis Brossard"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-boucherville" : "/services/nettoyage-tapis-boucherville"}>{isEn ? "Carpet Cleaning Boucherville" : "Nettoyage Tapis Boucherville"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-saint-bruno" : "/services/nettoyage-tapis-saint-bruno"}>{isEn ? "Carpet Cleaning Saint-Bruno" : "Nettoyage Tapis Saint-Bruno"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-saint-lambert" : "/services/nettoyage-tapis-saint-lambert"}>{isEn ? "Carpet Cleaning Saint-Lambert" : "Nettoyage Tapis Saint-Lambert"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-saint-jean" : "/services/nettoyage-tapis-saint-jean"}>{isEn ? "Carpet Cleaning Saint-Jean" : "Nettoyage Tapis Saint-Jean"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-la-prairie" : "/services/nettoyage-tapis-la-prairie"}>{isEn ? "Carpet Cleaning La Prairie" : "Nettoyage Tapis La Prairie"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-candiac" : "/services/nettoyage-tapis-candiac"}>{isEn ? "Carpet Cleaning Candiac" : "Nettoyage Tapis Candiac"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-beloeil" : "/services/nettoyage-tapis-beloeil"}>{isEn ? "Carpet Cleaning Beloeil" : "Nettoyage Tapis Beloeil"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-chateauguay" : "/services/nettoyage-tapis-chateauguay"}>{isEn ? "Carpet Cleaning Châteauguay" : "Nettoyage Tapis Châteauguay"}</a></li>
          <li><a href={isEn ? "/en/services/nettoyage-tapis-rive-sud" : "/services/nettoyage-tapis-rive-sud"}>{isEn ? "Carpet Cleaning South Shore" : "Nettoyage Tapis Rive-Sud"}</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-bar">
      <div class="copyright">
        &copy; {new Date().getFullYear()}
        {isEn ? "Empire Cleaning Group" : "Groupe Nettoyage Empire"}. {
          isEn ? "All rights reserved." : "Tous droits réservés."
        }
      </div>
      <div class="legal">
        <a href={isEn ? "/en/confidentialite" : "/confidentialite"}
          >{isEn ? "Privacy Policy" : "Politique de confidentialité"}</a
        >
        <a href="/sitemap-index.xml">{isEn ? "Sitemap" : "Plan du site"}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* --- Professional Variables --- */
  :root {
    --footer-bg: #0b0f19; /* Very dark rich blue */
    --footer-text: #94a3b8;
    --footer-accent: #f0c14b; /* Goldish */
    --footer-border: rgba(255, 255, 255, 0.08);
  }

  .site-footer {
    background-color: var(--footer-bg);
    color: var(--footer-text);
    font-size: 0.95rem;
    border-top: 2px solid var(--footer-accent); /* Thin professional gold line */
  }

  /* --- Top Section --- */
  .footer-top {
    padding: 4rem 0 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 1fr 1.2fr 1fr; /* Adjusted for new column */
    gap: 3rem;
  }

  /* Brand */
  .logo-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1.2rem;
  }
  .logo-surtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.7;
    margin-bottom: 4px;
  }
  .logo-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
  }
  .text-gradient-gold {
    background: linear-gradient(135deg, #ffffff 40%, #f0c14b 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .brand-desc {
    line-height: 1.6;
    margin-bottom: 2rem;
    opacity: 0.8;
  }

  .badges-row {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .badge-img {
    width: 100px;
    height: auto;
    opacity: 0.9;
    transition: opacity 0.3s;
  }
  .badge-img:hover {
    opacity: 1;
  }

  .trust-badge {
    background: rgba(255, 255, 255, 0.05);
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 6px;
    border: 1px solid var(--footer-border);
  }

  /* Headings */
  .footer-heading {
    color: #fff;
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--footer-border);
    display: inline-block;
    min-width: 50px;
  }

  /* Navigation */
  .footer-nav {
    list-style: none;
    padding: 0;
  }
  .footer-nav li {
    margin-bottom: 10px;
  }
  .footer-nav a {
    color: var(--footer-text);
    text-decoration: none;
    transition: 0.3s;
    display: inline-block;
  }
  .footer-nav a:hover {
    color: white;
    transform: translateX(4px);
  }

  /* Contact */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .contact-row {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    transition: 0.3s;
  }
  .contact-row:hover .icon-circle {
    background: var(--footer-accent);
    color: #000;
  }
  .contact-row:hover .value {
    color: white;
  }

  .icon-circle {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: 0.3s;
  }
  .info-text {
    display: flex;
    flex-direction: column;
  }
  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.6;
  }
  .value {
    color: #e2e8f0;
    font-weight: 500;
    transition: 0.3s;
  }

  .highlight .value {
    color: var(--footer-accent);
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* --- Bottom Bar --- */
  .footer-bottom {
    background-color: rgba(0, 0, 0, 0.3);
    padding: 1.5rem 0;
    border-top: 1px solid var(--footer-border);
    font-size: 0.85rem;
  }
  .bottom-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    opacity: 0.7;
  }
  .legal a {
    color: inherit;
    text-decoration: none;
    margin-left: 20px;
    transition: 0.3s;
  }
  .legal a:hover {
    color: white;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: left;
    }
    .bottom-bar {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }
    .legal a {
      margin: 0 10px;
    }
  }
</style>
