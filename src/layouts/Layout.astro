---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EstimationModule from "../components/EstimationModule.astro";

import SEO from "../components/SEO.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  robots?: string;
}

const { title, image, robots } = Astro.props;

const isEn = Astro.url.pathname.startsWith("/en");
const defaultDescription = isEn
  ? "Premium carpet, upholstery and mattress cleaning services in Montreal and Quebec. Eco-friendly solutions and truck-mount technology."
  : "Groupe Nettoyage Empire - Spécialistes du nettoyage de tapis, divans et carpettes.";

const description = Astro.props.description ?? defaultDescription;
---

<!doctype html>
<html lang={Astro.url.pathname.startsWith("/en") ? "en" : "fr"}>
  <head>
    <meta name="version" content="2.0.0-perf-optimized" />
    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-PLACEHOLDER');
    </script>
    <!-- End Google Tag Manager -->

    <SEO
      title={title}
      description={description}
      image={image}
      robots={robots}
    />
    <!-- Pages peuvent injecter des preloads LCP / meta additionnels (ex. accueil hero mobile) -->
    <slot name="head" />
    {image && <link rel="preload" as="image" href={image} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Load fonts immediately (no media="print" trick): deferred load caused Combining marks / Latin-ext to fallback to system serif before extra subsets arrived. -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      // Global Scroll Reveal
      document.addEventListener("DOMContentLoaded", () => {
        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.1,
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target); // Only animate once
            }
          });
        }, observerOptions);

        document.querySelectorAll(".fade-in-section").forEach((section) => {
          observer.observe(section);
        });

        // Track Visit (SMS Notification)
        const sessionKey = "visit_tracked_sms";
        if (!sessionStorage.getItem(sessionKey)) {
          fetch("/.netlify/functions/track-visit", { method: "POST" })
            .then((res) => {
              if (!res.ok) console.error("TRACKING FAILED:", res.status);
            })
            .then(() => sessionStorage.setItem(sessionKey, "true"))
            .catch((err) => console.error("Tracking error:", err));
        }
      });
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PLACEHOLDER"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Global Estimation Module -->
    <EstimationModule />

    <!-- MOBILE STICKY CTA BAR (Phone Only) -->
    <div class="mobile-sticky-bar">
      <a href="tel:5148939939" class="sticky-btn btn-call">
        <span class="icon" aria-hidden="true">📞</span>
        <span class="sticky-btn-label">
          {
            Astro.url.pathname.startsWith("/en")
              ? "Call for Estimate"
              : "Appeler pour une estimation"
          }
        </span>
      </a>
      <button
        type="button"
        onclick="window.openEstimationWidget()"
        class="sticky-btn btn-quote"
      >
        <span class="icon" aria-hidden="true">📝</span>
        <span class="sticky-btn-label">
          {
            Astro.url.pathname.startsWith("/en")
              ? "Instant Estimate"
              : "Estimation Instantanée"
          }
        </span>
      </button>
    </div>

    <style>
      /* GLOBAL GRADIENT BACKGROUND (Distinct) */
      body {
        /* Clearly visible Blue-Grey to White */
        background: linear-gradient(135deg, #cbdceb 0%, #ffffff 100%);
        background-attachment: fixed;
        min-height: 100vh;
      }

      /* fixed + scroll on iOS/Android often causes parallax/jank; desktop keeps fixed */
      @media (max-width: 768px) {
        body {
          background-attachment: scroll;
        }
      }

      /* MOBILE STICKY BAR — shared FR/EN; dimensions locked so EN matches FR (FR copy often wraps) */
      .mobile-sticky-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(12px);
        box-shadow: 0 -5px 20px rgba(0, 0, 0, 0.15);
        z-index: 9999;
        display: flex;
        align-items: stretch;
        padding: 8px 12px;
        gap: 10px;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
        transform: translateY(100%);
        animation: slideUp 0.5s 1s forwards;
        box-sizing: border-box;
      }

      .mobile-sticky-bar .sticky-btn {
        flex: 1;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 3.5rem; /* matches ~2 lines FR labels + padding */
        padding: 10px 12px;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.85rem;
        line-height: 1.2;
        text-decoration: none;
        text-align: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-sizing: border-box;
        font-family: inherit;
        cursor: pointer;
        -webkit-appearance: none;
        appearance: none;
        margin: 0;
      }

      .mobile-sticky-bar .sticky-btn-label {
        flex: 1;
        min-width: 0;
        display: block;
        text-align: center;
        line-height: 1.2;
        word-wrap: break-word;
        overflow-wrap: break-word;
      }

      .mobile-sticky-bar .sticky-btn:active {
        transform: scale(0.96);
      }

      /* BLUE BUTTON (Call) */
      .btn-call {
        background: linear-gradient(
          135deg,
          #001f3f 0%,
          #004a9f 100%
        ); /* Empire Blue Gradient */
        color: #ffffff !important;
        box-shadow: 0 4px 12px rgba(0, 31, 63, 0.4);
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
      }

      /* RED BUTTON (Quote) */
      .btn-quote {
        background: linear-gradient(
          135deg,
          #8b0000 0%,
          #ff5252 100%
        ); /* Rich Red Gradient */
        color: #ffffff !important; /* White Text */
        box-shadow: 0 4px 12px rgba(183, 28, 28, 0.4);
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
      }

      @keyframes slideUp {
        to {
          transform: translateY(0);
        }
      }

      /* HIDE MOBILE BAR ON DESKTOP */
      @media (min-width: 768px) {
        .mobile-sticky-bar {
          display: none !important;
        }
      }

      /* Adjust footer so it doesn't get covered (sticky bar min-height aligned FR/EN) */
      @media (max-width: 767px) {
        footer {
          padding-bottom: 80px;
        }
      }
    </style>
  </body>
</html>
