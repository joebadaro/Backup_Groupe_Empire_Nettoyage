---
import Layout from '../layouts/Layout.astro';

interface Props {
  title: string;
  description?: string;
  robots?: string;
  /** Si défini, affiché en H1 ; `title` sert pour la balise &lt;title&gt; (ex. suffixe SEO). */
  heading?: string;
  backHref?: string;
  backLabel?: string;
}

const { title, description, robots, heading, backHref = "/conseils", backLabel = "← Retour aux conseils" } = Astro.props;
const h1Text = heading ?? title;
const isEnPath = Astro.url.pathname.startsWith("/en");
---

<Layout title={title} description={description} robots={robots}>
  <div class="article-container">
    <div class="container small-container">
      <a href={backHref} class="back-link">{backLabel}</a>
      <h1>{h1Text}</h1>
      <div class="article-content">
        <slot />
      </div>
      
      <div class="cta-box">
        <h3>{isEnPath ? "Need help with this?" : "Besoin d'aide avec ceci ?"}</h3>
        <a href={isEnPath ? "/en/contact" : "/contact"} class="btn btn-primary">{isEnPath ? "Contact an expert" : "Contacter un expert"}</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .article-container { padding: 4rem 0; }
  .small-container { max-width: 800px; margin: 0 auto; }
  .back-link { display: block; margin-bottom: 2rem; color: #666; }
  h1 { font-size: 2.5rem; margin-bottom: 2rem; color: var(--color-empire-blue); }
  
  .article-content { font-size: 1.1rem; line-height: 1.8; color: var(--color-text-main); }
  /* Make simple standard markdown-like content look good globally in articles */
  :global(.article-content h2) { margin-top: 2rem; margin-bottom: 1rem; font-size: 1.5rem; }
  :global(.article-content ul) { margin-bottom: 1.5rem; padding-left: 1.5rem; list-style: disc; }
  :global(.article-content ol) { margin-bottom: 1.5rem; padding-left: 1.5rem; list-style: decimal; }
  :global(.article-content p) { margin-bottom: 1.5rem; }

  .cta-box {
    margin-top: 4rem;
    padding: 3rem;
    background: #f4f4f4;
    border-radius: 8px;
    text-align: center;
  }
</style>
