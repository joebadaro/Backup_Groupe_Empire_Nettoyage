---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Merci | Groupe Nettoyage Empire">
    <section class="section">
        <div class="container text-center">
            <div class="fade-in-section">
                <div class="check-icon">✓</div>
                <h1 class="text-gradient">Demande Reçue !</h1>
                <p class="lead-text">
                    Merci de nous avoir contactés.<br />
                    Un membre de notre équipe vous répondra sous peu.
                </p>

                <div class="actions">
                    <a href="/" class="btn btn-primary">Retour à l'accueil</a>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .section {
        padding: 8rem 0;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .check-icon {
        font-size: 5rem;
        color: var(--color-eco);
        margin-bottom: 2rem;
        background: var(--color-eco-light);
        width: 120px;
        height: 120px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem auto;
    }

    .lead-text {
        font-size: 1.4rem;
        color: var(--color-text-main);
        margin-bottom: 3rem;
    }
</style>
