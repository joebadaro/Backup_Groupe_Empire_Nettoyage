---
import Layout from "../../../layouts/Layout.astro";
---

<Layout
  title="Tile & Grout Cleaning at Home | Empire Cleaning"
  description="Expert tile, ceramic, and grout cleaning service (Montreal, Laval, South Shore). Eliminate embedded dirt and restore the shine of your floors."
>
  <!-- SPLIT SCREEN HERO: BLOCK 1 -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT -->
        <div class="split-content fade-in-section bg-gradient-premium">
          <span class="service-cat-badge">SURFACES</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Tile & Grout Cleaning
          </h1>

          <!-- BLOCK 1: INTRO (VISIBLE) -->
          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Are your grout lines blackened and your tiles lost their shine?
              Embedded dirt and soap residue resist traditional mopping.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Revitalize your floors with our professional service. We deep clean
            tiles and grout for hygienic surfaces that look like new.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-gradient-green pulse-btn">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green"
            >
              <span class="icon">⚡</span> Online Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/tuile-slide-new-1.webp"
              alt="Before-after tile grout cleaning Montreal - Professional result"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/tuile-slide-new-2.webp"
              alt="Professional ceramic floor cleaning Laval - Empire Cleaning Group"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-3.webp"
              alt="Impeccable kitchen ceramic South Shore - Deep grout cleaning"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-4.webp"
              alt="Sparkling ceramic floor Longueuil - Like-new result"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-5.webp"
              alt="Before-after ceramic cleaning comparison Montreal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-6.webp"
              alt="High pressure tile cleaning Laval - Professional technique"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-7.webp"
              alt="High pressure cleaning machine ceramic South Shore"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-8.webp"
              alt="Impeccable ceramic cleaning result Montreal - Empire Cleaning"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <div class="fade-in-section delay-100">
            <!-- TOGGLE BUTTON (INITIAL VIEW) -->
            <div style="margin-top: 1rem;">
              <button id="toggle-seo-btn" class="btn-outline-reveal">
                Learn more about ceramic cleaning ▼
              </button>
            </div>

            <!-- HIDDEN CONTENT -->
            <div id="seo-content" class="seo-content-hidden">
              <hr class="separator" />

              <h3 style="color: var(--color-primary);">
                Restore the like-new shine to your floors
              </h3>
              <p>
                <strong>Ceramic</strong> is a durable and aesthetic covering, present
                in many homes and commercial spaces in <strong>Montreal</strong
                >, <strong>Laval</strong>, and on the <strong
                  >South Shore</strong
                >. Whether it's ceramic floors in your kitchen, bathroom,
                office, or commercial space, it requires regular maintenance to
                maintain its beauty and durability.
              </p>

              <p style="margin-top: 1rem;">
                At <strong>Empire Cleaning</strong>, we offer a professional <strong
                  >ceramic cleaning</strong
                > service, adapted to all types of floors. Our cleaning process uses
                <strong>specialized and ecological products</strong>, capable of
                effectively eliminating embedded dirt, soap residue, lime
                traces, stains, grease, and bacteria, without damaging the
                surface.
              </p>

              <p style="margin-top: 1rem;">
                Thanks to our professional controlled high-pressure techniques, <strong
                  >grout is also deep cleaned</strong
                >, preventing mold accumulation and stubborn residues.
              </p>

              <br />

              <h3
                class="section-title text-gradient-empire"
                style="font-size: 1.5rem; margin-bottom: 1rem;"
              >
                The benefits of our service:
              </h3>

              <ul class="benefit-list">
                <li>
                  <strong>Restores shine and cleanliness</strong> to tiles and grout
                </li>
                <li>
                  <strong>Eliminates stains, residue</strong>, grease, and
                  bacteria
                </li>
                <li>
                  <strong>Preserves durability</strong> and appearance of your surfaces
                </li>
                <li>
                  <strong>Produces a quick</strong> and hygienic result
                </li>
              </ul>

              <!-- BLOCK: CUSTOMIZATION -->
              <div class="info-box">
                <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                  Adapted and Hygienic Service
                </h3>
                <p>
                  Our qualified team adapts each intervention according to the
                  ceramic type and dirt level. We intervene in both <strong
                    >residences</strong
                  > and <strong>commercial premises</strong>, guaranteeing
                  effective, durable, and respectful cleaning of your surfaces.
                </p>
              </div>

              <br />
              <!-- CLOSING -->
              <p>
                Choosing <strong>Empire Cleaning</strong> for cleaning your ceramic
                means opting for a professional, efficient, and ecological service
                that ensures the beauty and longevity of your floors daily.
              </p>
              <p style="margin-top: 0.5rem;">
                Contact us today for a <strong>free estimate</strong>.
              </p>
            </div>
          </div>
        </div>

        <!-- SIDEBAR CTA (Sticky) -->
        <aside class="service-sidebar">
          <div class="sticky-card fade-in-section">
            <h3 class="card-title text-gradient-gold">Free Estimate</h3>
            <p class="card-desc">Call us for an immediate response.</p>

            <a
              href="tel:5148939939"
              class="btn btn-gradient-green full-width pop-effect pulse-phone"
            >
              <span class="icon">📞</span> (514) 893-9939 (Free Estimate)
            </a>

            <p
              class="text-center"
              style="margin: 1rem 0; font-size: 0.9rem; color: #888;"
            >
              or
            </p>

            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green full-width"
            >
              Online Quote
            </button>

            <div class="guarantee-badge">
              <span>🌿 100% Ecological Products</span>
              <div style="margin-top: 5px; color: #ffbf00; font-weight: bold;">
                ★★★★★
              </div>
              <span style="font-size: 0.8rem; color: #666;"
                >Satisfied Clients</span
              >
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple Cross-Fade Slideshow (Standardized)
  const slides = document.querySelectorAll(".slide");

  if (slides.length > 0) {
    let currentSlide = 0;
    const intervalTime = 4000; // 4 seconds

    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, intervalTime);
  }

  // Toggle SEO Content
  const toggleBtn = document.getElementById("toggle-seo-btn");
  const seoContent = document.getElementById("seo-content");

  if (toggleBtn && seoContent) {
    toggleBtn.addEventListener("click", () => {
      seoContent.classList.toggle("visible");
      if (seoContent.classList.contains("visible")) {
        toggleBtn.textContent = "Show less ▲";
      } else {
        toggleBtn.textContent = "Learn more about ceramic cleaning ▼";
      }
    });
  }
</script>

<style>
  /* HERO */
  /* SPLIT SCREEN HERO (Sky Blue Theme) */
  .split-hero-container {
    background-color: #fff; /* Reset container to white */
    padding-top: 0; /* Remove container padding so image hits top */
    padding-bottom: 0;
    overflow: hidden; /* CRITICAL: Prevent slides from spilling out */
    width: 100vw;
  }

  .full-width-split {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 80vh; /* Consistent viewport height */
  }

  /* LEFT TEXT COLUMN */
  .split-content {
    /* Background handled by utility class */
    padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  /* ... skipping ... */

  /* RIGHT IMAGE COLUMN */
  .split-image-wrapper {
    position: relative;
    height: 100%;
    min-height: 500px;
    width: 100%;
    margin: 0;
    background-color: #f0f0f0; /* Slight gray background while loading */
    overflow: hidden; /* Ensure blur doesn't bleed */
  }

  /* Slideshow Styles */
  .slideshow-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden; /* CRITICAL: Prevent slides from spilling out */
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; /* RESTORED TO COVER AS REQUESTED */
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    z-index: 1;
  }

  .slide.active {
    opacity: 1;
    z-index: 2;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .split-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .split-content {
      padding: 3rem 1.5rem;
      order: 1; /* Content first */
    }

    .split-image-wrapper {
      order: 2; /* Image second */
      height: 400px;
      min-height: 0;
    }

    .lead-text {
      max-width: 100%;
    }
  }

  /* LAYOUT */
  .service-layout {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 5rem;
  }

  /* TYPOGRAPHY */
  .split-title {
    font-size: clamp(2.5rem, 3.5vw, 4rem);
    color: var(--color-primary); /* Dark Blue text */
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .problem-statement {
    background: #ffffff;
    border-left: 4px solid #ff4444;
    padding: 1.5rem;
    border-radius: 4px; /* Slight radius */
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3);
  }

  .problem-title {
    color: #cc0000;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    font-size: 1.1rem; /* Adjusted for visibility */
    display: block;
  }
  .section-title {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  /* Benefit List Styles from original */
  .benefit-list {
    margin: 2rem 0;
    list-style: none; /* Ensure no default bullets */
    padding: 0;
  }

  .benefit-list li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    font-size: 1.05rem;
  }

  .benefit-list li::before {
    content: "✓";
    color: #d32f2f; /* Empire Red or Gold */
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .info-box {
    background-color: #f8f9fa;
    border-left: 4px solid var(--color-accent);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 4px;
  }

  /* NEW BUTTON STYLE */
  .btn-outline-reveal {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    padding: 0.75rem 1.5rem; /* Nice padding */
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    border-radius: 4px; /* Rounded corners */
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-outline-reveal:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .cta-group {
      display: none !important;
    }
  }
  .seo-content-hidden {
    display: none;
    margin-top: 2rem;
    padding-top: 1rem;
    animation: fadeIn 0.5s ease-in-out;
  }

  .seo-content-hidden.visible {
    display: block;
  }

  /* Animation */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .separator {
    border: 0;
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    margin: 1.5rem 0;
  }

  /* SIDEBAR */
  .service-sidebar {
    position: relative;
  }

  .sticky-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 2rem;
    border: 1px solid #eee;
  }

  .card-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: 800;
  }

  .card-desc {
    color: #666;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .full-width {
    width: 100%;
    margin-bottom: 0.5rem;
    justify-content: center;
  }

  .guarantee-badge {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px dashed #eee;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .service-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
