---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Tile & Grout Cleaning | Montreal, Laval & South Shore"
  description="Expert in high-pressure ceramic and grout cleaning. Removal of grease, mold, and application of protective sealant. Residential & commercial service."
>
  <!-- SPLIT SCREEN HERO: BLOCK 1 -->
  <div class="split-hero-container mobile-hero-stack">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">FLOORS & SURFACES</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Tile & Grout Cleaning
          </h1>

          <div class="mobile-hero-slideshow fade-in-up delay-050">
            <div class="slideshow-container">
              <img
                src="/images/catalog/tuile-optimized.webp"
                alt="Professional tile and grout cleaning - Impeccable result"
                class="slide active"
                width="1200"
                height="800"
                loading="eager"
              />
              <img
                src="/images/catalog/tuile-slide-new-2.webp"
                alt="Professional ceramic floor cleaning Laval - Empire Group"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile-slide-new-3.webp"
                alt="Impeccable ceramic kitchen South Shore - Deep grout cleaning"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile2-optimized.webp"
                alt="Ceramic floor cleaned and restored by professionals - Montreal"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile3-v3.webp"
                alt="High pressure tile and grout cleaning - Impeccable result"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile-before-after-v3.webp"
                alt="Before and after cleaning very dirty ceramic joints"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
            </div>
            <div class="image-overlay-gradient"></div>
          </div>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Have your grout lines turned black or gray? Mopping only moves dirt 
              into the pores of the grout. Without high-pressure cleaning, bacteria 
              and grease accumulate, making your floors look dull and unsanitary.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Restore the original look of your floors. Our <strong>controlled high-pressure</strong> 
            turbo technology deep cleans joints and restores the shine to your ceramic, 
            without splashing and with almost immediate drying.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-primary pulse-btn">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-outline-reveal"
            >
              <span class="icon">⚡</span> Instant Free Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/tuile-optimized.webp"
              alt="Professional tile and grout cleaning - Impeccable result"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/tuile-slide-new-2.webp"
              alt="Professional ceramic floor cleaning Laval - Empire Group"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-3.webp"
              alt="Impeccable ceramic kitchen South Shore - Deep grout cleaning"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile2-optimized.webp"
              alt="Ceramic floor cleaned and restored by professionals - Montreal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile3-v3.webp"
              alt="High pressure tile and grout cleaning - Impeccable result"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-before-after-v3.webp"
              alt="Before and after cleaning very dirty ceramic joints"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          
          <div class="fade-in-section delay-100" style="margin-top: 0;">
            <h2 class="section-title text-gradient-empire">
              Our Turbo Process (High Pressure)
            </h2>
            <div class="process-timeline" style="margin-bottom: 3rem;">
              <div class="process-step">
                <div class="step-marker">1</div>
                <div class="step-content">
                  <h3>Inspection and Pre-treatment</h3>
                  <p>Identification of the tile type (ceramic, porcelain, natural stone) and application of an alkaline cleaning agent specifically designed to break down grease and soap residue.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">2</div>
                <div class="step-content">
                  <h3>Mechanical Agitation of Joints</h3>
                  <p>We use specialized brushes to vigorously scrub each grout line. This mechanical action is essential to release embedded black dirt before extraction.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">3</div>
                <div class="step-content">
                  <h3>High Pressure Turbo Wash (200°F)</h3>
                  <p>Our machine projects pressurized hot water inside a closed rotating head. It cleans and vacuums simultaneously, guaranteeing zero splashing on your walls or cabinets.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">4</div>
                <div class="step-content">
                  <h3>Neutralization and Drying</h3>
                  <p>A final pH-balanced rinse removes any sticky residue. We then use high-power fans to ensure fast drying, ready for the final step.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">5</div>
                <div class="step-content">
                  <h3>Protection (Grout Sealant)</h3>
                  <p>Optional but vital: we apply a professional protective sealant that penetrates the grout pores to make it waterproof, preventing dirt from embedding again.</p>
                </div>
              </div>
            </div>

            <div class="info-box fade-in-section delay-100">
              <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                Why do your joints turn black so quickly?
              </h3>
              <p>
                Grout is like a sponge: it is extremely porous. When you mop your floor, dirty water ends up accumulating in the "hollows" of the joints. Once the water evaporates, only the dirt remains at the bottom.
                Only a high-pressure extraction cleaning can "empty" these pores. Applying a **protective sealant** after cleaning is the best investment to keep your joints white for years.
              </p>
            </div>
          </div>

          <!-- BENEFITS SECTION -->
          <div class="fade-in-section delay-200" style="margin-top: 4rem;">
            <h2 class="section-title text-gradient-empire">
              Advantages of our professional cleaning
            </h2>
            <div class="benefits-grid">
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Total Hygiene:</strong> Eliminates bacteria, mold, and allergens lodged in porous joints.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Floor Like New:</strong> Rediscover the original color of your grout without scrubbing it yourself for hours.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Zero Splashing:</strong> Our rotating equipment contains all water and suction inside the cleaning head.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Durable Protection:</strong> Our high-quality sealants facilitate your future household cleanings.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Fast Service:</strong> A standard kitchen is cleaned and protected in just 2 to 3 hours.</span>
              </div>
            </div>
          </div>

          <!-- ZONES DESSERVIES -->
          <div class="zones-section" style="margin-top: 4rem; margin-bottom: 3rem;">
            <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Service Areas — Tile and Ceramic</h3>
            <p>We serve the entire Greater Montreal Area with our high-performance mobile units.</p>

            <div class="city-group">
                <p class="city-lead">🏙️ Montreal (East and West)</p>
                <div class="badges-container">
                    <span class="badge badge-blue">📍 Montreal</span>
                    <span class="badge badge-blue">📍 Westmount</span>
                    <span class="badge badge-blue">📍 Mount Royal</span>
                    <span class="badge badge-blue">📍 Outremont</span>
                    <span class="badge badge-blue">📍 LaSalle</span>
                    <span class="badge badge-blue">📍 Ahuntsic</span>
                </div>
            </div>

            <div class="city-group">
                <p class="city-lead">🏘️ Laval</p>
                <div class="badges-container">
                    <span class="badge badge-blue">📍 Laval (all neighborhoods)</span>
                    <span class="badge badge-blue">📍 Chomedey</span>
                    <span class="badge badge-blue">📍 Duvernay</span>
                    <span class="badge badge-blue">📍 Fabreville</span>
                </div>
            </div>

            <div class="city-group">
                <p class="city-lead">🌿 Montreal South Shore</p>
                <div class="badges-container">
                    <span class="badge badge-green">📍 Longueuil</span>
                    <span class="badge badge-green">📍 Brossard</span>
                    <span class="badge badge-green">📍 Saint-Hubert</span>
                    <span class="badge badge-green">📍 Boucherville</span>
                    <span class="badge badge-green">📍 Saint-Lambert</span>
                </div>
            </div>
          </div>

          <!-- FAQ SECTION -->
          <div class="fade-in-section delay-300" style="margin-top: 3rem;">
              <h2 class="section-title text-gradient-empire">
                  Frequently Asked Questions — Tile & Grout
              </h2>
              <FAQSchema
                  faqs={[
                      {
                          question: "How long should I wait before walking on the floor?",
                          answer: "Thanks to our powerful suction, the floor is dry to the touch almost immediately. However, if we apply a protective sealant, we recommend waiting about 2 to 4 hours before walking on it with shoes, and 24 hours before mopping with water.",
                      },
                      {
                          question: "Will your machine splash water on my kitchen cabinets?",
                          answer: "Not at all. We use a 'Turbo' tool which is a hermetically sealed bell. High-pressure water is projected inside this bell and instantly sucked up by the vacuum. Your walls, baseboards, and cabinets remain perfectly dry from start to finish.",
                      },
                      {
                          question: "Can you clean moldy shower grout?",
                          answer: "Yes, we can remove surface mold and soap scum. However, if the mold has penetrated *behind* the grout or if the silicone is deeply blackened, cleaning will not be enough; a replacement of the silicone joint (caulking) might be necessary.",
                      },
                      {
                          question: "What is the difference between steam cleaning and your method?",
                          answer: "Steam alone often lacks the impact force to dislodge hardened grease. Our system combines heat (200°F), controlled pressure (800-1200 PSI), and industrial suction. It is the combination of these three forces that allows the extraction of dirt from the bottom of the grout.",
                      },
                      {
                          question: "Does the sealant change the color of my grout?",
                          answer: "We generally use an invisible penetrating sealant that does not change the natural appearance of your grout. It protects from the inside. If you wish to change the color of your grout, there are colored sealants (ColorSeal), but it is a separate specialized service.",
                      },
                      {
                          question: "Do you also clean kitchen backsplashes?",
                          answer: "Yes! We use smaller hand tools, specifically designed for vertical surfaces, to clean your backsplashes and shower walls with the same efficiency as your floors.",
                      },
                  ]}
              />
          </div>

        </div>

        <!-- SIDEBAR -->
        <aside class="service-sidebar">
          <div class="sticky-card fade-in-section">
            <h3 class="card-title text-gradient-gold">Free Estimate</h3>
            <p class="card-desc">Restore the shine to your floors today.</p>
            <a href="tel:5148939939" class="btn btn-gradient-green full-width pop-effect pulse-phone">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <div style="margin: 1rem 0; text-align: center; color: #888; font-size: 0.9rem;">or</div>
            <button onclick="window.openEstimationWidget()" class="btn btn-gradient-green full-width">
              Instant Quote
            </button>
            <div class="guarantee-badge">
              <span>💎 Joints Protected & Waterproof</span>
              <div style="margin-top: 5px; color: #ffbf00; font-weight: bold;">★★★★★</div>
              <span style="font-size: 0.8rem; color: #666;">Pro & Clean Service</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function () {
    document.querySelectorAll(".slideshow-container").forEach((container) => {
      const slides = container.querySelectorAll(".slide");
      if (slides.length <= 1) return;
      let currentSlide = 0;
      setInterval(() => {
        slides[currentSlide].classList.remove("active");
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add("active");
      }, 4000);
    });
  })();
</script>

  <style>
    /* HERO */
    /* SPLIT SCREEN HERO (Sky Blue Theme) */
    .split-hero-container {
      background-color: #fff; /* Reset container to white */
      padding-top: 0; /* Remove container padding so image hits top */
      padding-bottom: 0;
      overflow: hidden; /* CRITICAL: Prevent slides from spilling out */
      width: 100vw;
    }
    .full-width-split {
      width: 100%;
      max-width: none;
      padding: 0;
      margin: 0;
    }
    .split-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      align-items: stretch;
      min-height: 80vh; /* Consistent viewport height */
    }
    /* LEFT TEXT COLUMN */
    .split-content {
      /* Background handled by utility class */
      padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      z-index: 2;
    }
    .service-cat-badge {
      text-transform: uppercase;
      color: var(--color-accent);
      font-weight: 700;
      letter-spacing: 2px;
      font-size: 0.85rem;
      display: block;
      margin-bottom: 1rem;
    }
    .split-title {
      font-size: clamp(2.5rem, 3.5vw, 4rem);
      color: var(--color-primary); /* Dark Blue text */
      margin-bottom: 2rem;
      line-height: 1.1;
    }
    .problem-statement {
      background: #ffffff;
      border-left: 4px solid #ff4444;
      padding: 1.5rem;
      border-radius: 4px; /* Slight radius */
      margin-bottom: 2rem;
      box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3);
    }
    .problem-title {
      color: #cc0000;
      font-weight: 800;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      font-size: 1.1rem; /* Adjusted for visibility */
      display: block;
    }
    .lead-text {
      font-size: 1.15rem;
      line-height: 1.7;
      color: var(--color-text-main); /* Dark grey text */
      margin-bottom: 2.5rem;
      max-width: 650px;
    }
    .cta-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    @media (max-width: 900px) {
      .cta-group {
        display: none !important;
      }
    }
    /* RIGHT IMAGE COLUMN */
    .split-image-wrapper {
      position: relative;
      height: 100%;
      min-height: 500px;
      width: 100%;
      margin: 0;
      background-color: #f0f0f0; /* Slight gray background while loading */
      overflow: hidden; /* Ensure blur doesn't bleed */
    }
    /* Slideshow Styles */
    .slideshow-container {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden; /* CRITICAL: Prevent slides from spilling out */
    }
    .slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover; /* RESTORED TO COVER AS REQUESTED */
      opacity: 0;
      transition: opacity 1.5s ease-in-out;
      z-index: 1;
    }
    .slide.active {
      opacity: 1;
      z-index: 2;
    }
    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .split-layout {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .lead-text {
        max-width: 100%;
      }
    }
    /* LAYOUT */
    .service-layout {
      display: grid;
      grid-template-columns: 1.8fr 1fr;
      gap: 5rem;
    }
    /* TYPOGRAPHY */
    .section-title {
      font-size: 1.8rem;
      color: var(--color-primary);
      margin-bottom: 1.5rem;
      border-bottom: 2px solid #eee;
      padding-bottom: 0.5rem;
      display: inline-block;
    }
    /* Benefit List Styles from original */
    .benefit-list {
      margin: 2rem 0;
      list-style: none; /* Ensure no default bullets */
      padding: 0;
    }
    .benefit-list li {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      position: relative;
      font-size: 1.05rem;
    }
    .benefit-list li::before {
      content: "✓";
      color: #d32f2f; /* Empire Red or Gold */
      position: absolute;
      left: 0;
      font-weight: bold;
    }
    .info-box {
      background-color: #f8f9fa;
      border-left: 4px solid var(--color-accent);
      padding: 1.5rem;
      margin: 2rem 0;
      border-radius: 4px;
    }
    /* NEW BUTTON STYLE */
    .btn-outline-reveal {
      background: transparent;
      border: 2px solid var(--color-primary);
      color: var(--color-primary);
      padding: 0.75rem 1.5rem; /* Nice padding */
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      border-radius: 4px; /* Rounded corners */
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .btn-outline-reveal:hover {
      background: var(--color-primary);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }
    .seo-content-hidden {
      display: none;
      margin-top: 2rem;
      padding-top: 1rem;
      animation: fadeIn 0.5s ease-in-out;
    }
    .seo-content-hidden.visible {
      display: block;
    }
    /* Animation */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .separator {
      border: 0;
      height: 1px;
      background: rgba(0, 0, 0, 0.1);
      margin: 1.5rem 0;
    }
    /* SIDEBAR */
    .service-sidebar {
      position: relative;
    }
    .sticky-card {
      background: white;
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      position: sticky;
      top: 2rem;
      border: 1px solid #eee;
    }
    .card-title {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      font-weight: 800;
    }
    .card-desc {
      color: #666;
      margin-bottom: 1.5rem;
      font-size: 0.95rem;
    }
    .full-width {
      width: 100%;
      margin-bottom: 0.5rem;
      justify-content: center;
    }
    .guarantee-badge {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px dashed #eee;
      text-align: center;
      font-size: 0.9rem;
      color: var(--color-accent);
      font-weight: 600;
    }
    @media (max-width: 900px) {
      .service-layout {
        grid-template-columns: 1fr;
      }
    }
    
    /* Utility class to prevent aggressive zooming on specific images */
    .img-contain {
      object-fit: contain !important;
      background-color: transparent !important;
    }
  </style>
</Layout>
