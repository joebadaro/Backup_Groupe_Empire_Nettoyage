---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
    title="At-Home Mattress Cleaning & Disinfection | Montreal, Laval, South Shore"
    description="Professional mattress cleaning: dust mites, urine odors, and allergens eliminated. At-home service. Montreal, Laval & South Shore. 4h drying. Free quote."
>
    <!-- SPLIT SCREEN HERO: BLOCK 1 -->
    <div class="split-hero-container">
        <div class="container full-width-split">
            <div class="split-layout">
                <!-- LEFT COLUMN: CONTENT -->
                <div class="split-content fade-in-section bg-gradient-premium">
                    <span class="service-cat-badge">FURNITURE</span>
                    <h1 class="split-title fade-in-up text-gradient-empire">
                        Mattress Cleaning & Disinfection
                    </h1>

                    <!-- BLOCK 1: INTRO (VISIBLE) -->
                    <div class="problem-statement fade-in-up delay-100">
                        <h3 class="problem-title">The Problem:</h3>
                        <p class="problem-text">
                            We spend 1/3 of our lives in bed. A mattress can double
                            in weight in 10 years due to the accumulation of dead skin,
                            sweat (yellow stains), and millions of dust mites.
                            Vacuuming is no longer enough.
                        </p>
                    </div>

                    <p class="lead-text fade-in-up delay-200">
                        Reduce your allergies and sanitize your bedroom. We
                        offer an <strong>at-home mattress cleaning and disinfection service</strong> that destroys 99.9% of allergens,
                        eliminates urine odors, and revives your bed.
                    </p>

                    <div class="cta-group fade-in-up delay-300">
                        <a
                            href="tel:5148939939"
                            class="btn btn-gradient-green pulse-btn"
                        >
                            <span class="icon">📞</span> (514) 893-9939
                        </a>
                        <button
                            onclick="window.openEstimationWidget()"
                            class="btn btn-gradient-green"
                        >
                            <span class="icon">⚡</span> Instant Online Quote
                        </button>
                    </div>
                </div>

                <!-- RIGHT COLUMN: IMAGE -->
                <div class="split-image-wrapper fade-in-section delay-200">
                    <div class="slideshow-container">
                        <img
                            src="/images/catalog/teck-empire-matress-optimized.webp"
                            alt="Empire Group Expert deep mattress cleaning - Montreal"
                            class="slide active"
                            width="1200"
                            height="800"
                            fetchpriority="high"
                            loading="eager"
                        />
                        <img
                            src="/images/catalog/photo-matelas-2.webp"
                            alt="At-home mattress disinfection Montreal - Dust mite elimination"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                        <img
                            src="/images/catalog/kid-dog-matress-optimized.webp"
                            alt="Safe mattress disinfection for children and pets - Montreal"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                        <img
                            src="/images/catalog/photo-matelas-6.webp"
                            alt="Professional mattress cleaning service Laval - Empire Group"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                        <img
                            src="/images/catalog/photo-matelas-8.webp"
                            alt="Eco-friendly mattress disinfection South Shore - Healthy sleep"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                        <img
                            src="/images/catalog/woman-matress-optimized.webp"
                            alt="Restful sleep after professional mattress cleaning - Empire Group"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                    </div>
                    <div class="image-overlay-gradient"></div>
                </div>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="container">
            <div class="service-layout" style="display: block;">
                <!-- MAIN CONTENT (Centered, No Sidebar) -->
                <div
                    class="service-main"
                    style="max-width: 800px; margin: 0 auto;"
                >
                    <div class="fade-in-section delay-100" style="margin-top: 2rem;">
                        <!-- VISIBLE CONTENT: PROCESS -> LIST -> PROTECTION -->
                        <div>
                            <hr class="separator" />
                            <h3 style="color: var(--color-primary);">
                                Our Disinfection Process (5 Steps)
                            </h3>
                            <p>
                                A simple vacuuming will never solve a urine odor problem
                                or a dust mite infestation. At
                                <strong>Empire Cleaning Group</strong>, we apply a strict hygiene protocol:
                            </p>
                            
                            <ul class="benefit-list" style="margin-top: 1.5rem; margin-bottom: 2rem;">
                                <li>
                                    <strong>1. Visual Inspection:</strong> Identifying organic stains
                                    (bacterial sweat, blood, urine) invisible to the naked eye to target the treatment.
                                </li>
                                <li>
                                    <strong>2. Dry Vibratory Vacuuming:</strong> A crucial step to mechanically dislodge
                                    dead skin and dust mite droppings buried deep within before wetting the fabric.
                                </li>
                                <li>
                                    <strong>3. Bio-Active Enzyme Treatment:</strong> Application of solutions that literally "digest"
                                    the bacteria responsible for stubborn odors of urine, vomit, or accumulated sweat.
                                </li>
                                <li>
                                    <strong>4. High-Temperature Steam Cleaning:</strong> Our injection-extraction equipment
                                    injects very hot water that kills 99.9% of dust mites on contact,
                                    while rinsing away contaminants.
                                </li>
                                <li>
                                    <strong>5. Powerful Vacuuming & Drying:</strong> We remove up to 95% of the moisture.
                                    The mattress is sanitized, deodorized, and ready for the night in a few hours.
                                </li>
                            </ul>

                            <h3
                                class="section-title text-gradient-empire"
                                style="font-size: 1.5rem; margin-bottom: 1rem;"
                            >
                                Health benefits:
                            </h3>
                            <ul class="benefit-list">
                                <li>
                                    <strong>Deeper sleep</strong> and immediate reduction of morning allergy symptoms (congestion).
                                </li>
                                <li>
                                    <strong>Elimination of organic odors</strong> (child/pet urine, sweat) destroyed at the source.
                                </li>
                                <li>
                                    Treatment aimed at <strong>lightening stubborn yellow stains and rings</strong>.
                                </li>
                                <li>
                                    <strong>100% eco-friendly products</strong>: perfectly safe for baby's skin.
                                </li>
                                <li>
                                    Ultra-fast drying (4h to 6h) to <strong>sleep in your bed the very same evening</strong>.
                                </li>
                            </ul>

                            <div style="margin-top: 3rem;">
                                <h3 style="color: var(--color-primary); margin-bottom: 1rem;">
                                    Why entrust your mattress disinfection to experts?
                                </h3>
                                <p>
                                    The mattress is the most used item in your home, but paradoxically 
                                    the most neglected during spring cleaning. Whether you live in <strong>Montreal</strong>, 
                                    <strong>Laval</strong>, <strong>Longueuil</strong> or elsewhere on the 
                                    <strong>South Shore</strong>, ambient humidity combined with human body heat 
                                    turns an unmaintained mattress into a perfect incubator for dust mites and 
                                    bacterial growth.
                                </p>
                                <p style="margin-top: 1rem;">
                                    Many people try to clean stains (child/pet urine, 
                                    sweat, blood) with supermarket products. The result? The mattress becomes 
                                    soaked deeply, bacteria proliferate in the damp foam, and 
                                    a permanent musty odor sets in.
                                </p>
                                <p style="margin-top: 1rem;">
                                    With <strong>Empire Cleaning Group</strong>, injection-extraction 
                                    guarantees that the cleaning solution penetrates the fibers to kill contaminants 
                                    before being <strong>immediately suctioned</strong> by our 
                                    high-performance extraction equipment. Water never stagnates in your mattress foam (whether it's 
                                    memory foam, latex, or spring), guaranteeing a sterile and 
                                    safe environment.
                                </p>
                            </div>


                            <!-- BLOCK 6 -->
                            <p>
                                Improve your sleep quality and your
                                home's cleanliness with professional mattress
                                cleaning from <strong>Empire Cleaning Group</strong>.
                            </p>
                            <p style="margin-top: 0.5rem;">
                                Contact us today for a <strong>quick quote</strong> and dependable service.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- NEW SECTIONS: BENEFITS & FAQ -->
    <section class="section" style="padding-top: 0;">
        <div class="container">
            <div class="service-layout" style="display: block;">
                <!-- Full width for these bottom sections -->
                <div
                    class="service-main"
                    style="max-width: 800px; margin: 0 auto;"
                >
                    <!-- BENEFITS -->
                    <div
                        class="fade-in-section delay-200"
                        style="margin-top: 3rem;"
                    >
                        <h2 class="section-title text-gradient-empire">
                            Why choose us?
                        </h2>
                        <div class="benefits-grid">
                            <div class="benefit-item">
                                <div class="check-circle">✓</div>
                                <span>Elimination of 99% of allergens & mites</span>
                            </div>
                            <div class="benefit-item">
                                <div class="check-circle">✓</div>
                                <span>Eco-friendly, odorless disinfection</span>
                            </div>
                            <div class="benefit-item">
                                <div class="check-circle">✓</div>
                                <span>Fast drying (a few hours)</span>
                            </div>
                        </div>
                    </div>

                    <!-- ZONES DESSERVIES -->
                    <div class="zones-section" style="margin-top: 3rem; margin-bottom: 3rem;">
                        <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Service Areas — Mattress Cleaning</h3>
                        <p>We travel anywhere in the Greater Montreal Area with our high-performance mobile units.</p>

                        <div class="city-group">
                            <p class="city-lead">🏙️ Montreal (East & West)</p>
                            <div class="badges-container">
                                <span class="badge badge-blue">📍 Montreal (all boroughs)</span>
                                <span class="badge badge-blue">📍 Westmount</span>
                                <span class="badge badge-blue">📍 Mount Royal</span>
                                <span class="badge badge-blue">📍 Outremont</span>
                                <span class="badge badge-blue">📍 LaSalle</span>
                                <span class="badge badge-blue">📍 And much more...</span>
                            </div>
                        </div>

                        <div class="city-group">
                            <p class="city-lead">🏘️ Laval</p>
                            <div class="badges-container">
                                <span class="badge badge-blue">📍 Laval (entire city)</span>
                                <span class="badge badge-blue">📍 Chomedey</span>
                                <span class="badge badge-blue">📍 Sainte-Rose</span>
                                <span class="badge badge-blue">📍 Vimont</span>
                            </div>
                        </div>

                        <div class="city-group">
                            <p class="city-lead">🌿 Montreal South Shore</p>
                            <div class="badges-container">
                                <span class="badge badge-green">📍 Longueuil</span>
                                <span class="badge badge-green">📍 Brossard</span>
                                <span class="badge badge-green">📍 Saint-Lambert</span>
                                <span class="badge badge-green">📍 Saint-Hubert</span>
                                <span class="badge badge-green">📍 Greenfield Park</span>
                                <span class="badge badge-green">📍 Saint-Bruno</span>
                                <span class="badge badge-green">📍 Boucherville</span>
                                <span class="badge badge-green">📍 And much more...</span>
                            </div>
                        </div>
                        
                        <p class="contact-footer">Need a quick appointment? Call us at <strong>(514) 893-9939</strong>.</p>
                    </div>

                    <!-- FAQ -->
                    <div class="fade-in-section delay-300" style="margin-top: 3rem;">
                        <h2 class="section-title text-gradient-empire">
                            Frequently Asked Questions — Mattress Cleaning
                        </h2>
                        <FAQSchema
                            faqs={[
                                {
                                    question:
                                        "Can you remove yellow sweat stains from my mattress?",
                                    answer: "We remove 100% of bacteria and restore total hygiene to the area. However, concerning visual appearance, it's important to know that sweat (which contains sebum and acids) acts as a dye on the white fabric of the mattress over time. If the yellow ring is recent, we eliminate it very well. If it has been there for 5 years, we will significantly lighten it, but a slight permanent yellowish trace (fiber stain) may remain. You will, however, sleep on a clinically clean mattress.",
                                },
                                {
                                    question:
                                        "How do you treat child or pet urine (bedwetting)?",
                                    answer: "This is our most requested specialty. Urine becomes highly alkaline as it dries and harbors bacteria that release gases (bad odor). A regular shampoo won't mask this. We use a heavy enzymatic treatment: bio-active enzymes penetrate the foam and literally 'digest' the uric acid crystals and bacteria for about 15 minutes. Then, we perform a complete extraction with very hot water. The odor is permanently destroyed at the source.",
                                },
                                {
                                    question:
                                        "How long before I can sleep on my mattress again?",
                                    answer: "Generally, you should expect between 4 and 6 hours of drying time. Our industrial-grade equipment massively extracts moisture, leaving the surface of the mattress only slightly damp to the touch (not soaked). If we clean in the morning or early afternoon, you are guaranteed to be able to sleep in fresh sheets that very evening. A simple ceiling fan greatly accelerates this process.",
                                },
                                {
                                    question:
                                        "Does the very hot steam kill bed bugs?",
                                    answer: "Yes, the temperature generated by our system kills bed bugs and their eggs on the first contact. HOWEVER, we are not an extermination service. For an active infestation in the walls and the box spring of the bedroom, cleaning alone will not be enough to eradicate the problem in the long term. We often intervene AFTER your exterminator's treatment to clean dried blood stains, chemical soot, and extract dead bed bugs from the mattress.",
                                },
                                {
                                    question:
                                        "Is it safe to clean my memory foam mattress (Tempur-Pedic)?",
                                    answer: "Completely safe. Memory foam is dense and acts like a giant sponge if improperly cleaned, which could cause internal mold. Our certified technicians strictly control the water flow (low-moisture cleaning method). We deep clean the cover encasing the foam without ever saturating or damaging the internal cellular structure of the mattress. This is the method recommended by manufacturers.",
                                },
                                {
                                    question:
                                        "Should I have my mattress cleaned even if it is relatively new?",
                                    answer: "It all depends on your sensitivities. A human loses about 1.5 grams of dead skin per day (mostly in their bed), which is the main meal for thousands of dust mites. For people suffering from asthma, dust mite allergies, or chronic morning nasal congestion, the Lung Association recommends a professional mattress cleaning every year or two, even if there is no visible stain.",
                                },
                            ]}
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script is:inline>
        // Force script to run immediately using is:inline
        (function () {
            // Slideshow Logic
            const slides = document.querySelectorAll(".slide");
            if (slides.length > 0) {
                let currentSlide = 0;
                const intervalTime = 4000; // 4 seconds
                setInterval(() => {
                    slides[currentSlide].classList.remove("active");
                    currentSlide = (currentSlide + 1) % slides.length;
                    slides[currentSlide].classList.add("active");
                }, intervalTime);
            }
        })();
    </script>

    <style>
        /* HERO */
        /* SPLIT SCREEN HERO (Sky Blue Theme) */
        .split-hero-container {
            background-color: #fff; /* Reset container to white */
            padding-top: 0; /* Remove container padding so image hits top */
            padding-bottom: 0;
            overflow: hidden;
            width: 100vw;
        }
        .full-width-split {
            width: 100%;
            max-width: none;
            padding: 0;
            margin: 0;
        }
        .split-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
            align-items: stretch;
            min-height: 80vh; /* Consistent viewport height */
        }
        /* LEFT TEXT COLUMN */
        .split-content {
            background-color: #ffffff;
            padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            z-index: 2;
        }
        .service-cat-badge {
            text-transform: uppercase;
            color: var(--color-accent);
            font-weight: 700;
            letter-spacing: 2px;
            font-size: 0.85rem;
            display: block;
            margin-bottom: 1rem;
        }
        .split-title {
            font-size: clamp(2.5rem, 3.5vw, 4rem);
            color: var(--color-primary); /* Dark Blue text */
            margin-bottom: 2rem;
            line-height: 1.1;
        }
        .problem-statement {
            background: #ffffff; /* White box */
            border-left: 4px solid #ff4444; /* Red border returns for alertness */
            padding: 1.5rem;
            border-radius: 0;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); /* Soft blue shadow */
        }
        .problem-title {
            font-size: 1rem;
            color: #cc0000;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            font-weight: 700;
        }
        .problem-text {
            font-size: 1.05rem;
            color: var(--color-text-main);
            font-style: italic;
        }
        .lead-text {
            font-size: 1.15rem;
            line-height: 1.7;
            color: var(--color-text-main); /* Dark grey text */
            margin-bottom: 2.5rem;
            max-width: 650px;
        }
        .cta-group {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        @media (max-width: 900px) {
            .cta-group {
                display: none !important;
            }
        }
        /* Reset Secondary Button for Light Mode */
        .split-content .btn-secondary-outline {
            border-color: #ddd;
            color: #666;
        }
        .split-content .btn-secondary-outline:hover {
            background: white;
            color: var(--color-primary);
            border-color: var(--color-primary);
        }
        /* RIGHT IMAGE COLUMN */
        .split-image-wrapper {
            position: relative;
            height: 100%;
            min-height: 500px;
            width: 100%;
            border-radius: 0;
            transform: none;
            box-shadow: none;
            margin: 0;
            background-color: #fff; /* Ensure white background if image loads late */
        }
        /* Slideshow Styles reused but adapted for full height */
        .slideshow-container {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: opacity 1.5s ease-in-out;
        }
        .slide.active {
            opacity: 1;
        }
        /* RESPONSIVE */
        @media (max-width: 1024px) {
            .split-layout {
                grid-template-columns: 1fr;
                min-height: auto;
            }
            .split-content {
                padding: 3rem 1.5rem;
                order: 1; /* Content first */
            }
            .split-image-wrapper {
                order: 2; /* Image second */
                height: 400px;
                min-height: 0;
            }
            .lead-text {
                max-width: 100%;
            }
        }
        /* LAYOUT */
        .service-layout {
            display: grid;
            grid-template-columns: 1.8fr 1fr;
            gap: 5rem;
        }
        /* TYPOGRAPHY */
        .section-title {
            font-size: 1.8rem;
            color: var(--color-primary);
            margin-bottom: 1.5rem;
            border-bottom: 2px solid #eee;
            padding-bottom: 0.5rem;
            display: inline-block;
        }
        /* Benefit List Styles from original */
        .benefit-list {
            margin: 2rem 0;
            list-style: none; /* Ensure no default bullets */
            padding: 0;
        }
        .benefit-list li {
            margin-bottom: 1rem;
            padding-left: 1.5rem;
            position: relative;
            font-size: 1.05rem;
        }
        .benefit-list li::before {
            content: "✓";
            color: #d32f2f; /* Empire Red or Gold */
            position: absolute;
            left: 0;
            font-weight: bold;
        }
        .info-box {
            background-color: #f8f9fa;
            border-left: 4px solid var(--color-accent);
            padding: 1.5rem;
            margin: 2rem 0;
            border-radius: 4px;
        }
        /* NEW BUTTON STYLE */
        .btn-outline-reveal {
            background: transparent;
            border: 2px solid var(--color-primary);
            color: var(--color-primary);
            padding: 0.75rem 1.5rem; /* Nice padding */
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            border-radius: 4px; /* Rounded corners */
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-outline-reveal:hover {
            background: var(--color-primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }
        .seo-content-hidden {
            display: none;
            margin-top: 2rem;
            padding-top: 1rem;
            animation: fadeIn 0.5s ease-in-out;
        }
        /* Animation */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .separator {
            border: 0;
            height: 1px;
            background: rgba(0, 0, 0, 0.1);
            margin: 1.5rem 0;
        }
        /* SIDEBAR */
        .service-sidebar {
            position: relative;
        }
        .sticky-card {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 2rem;
            border: 1px solid #eee;
        }
        .card-title {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            font-weight: 800;
        }
        .card-desc {
            color: #666;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }
        .full-width {
            width: 100%;
            margin-bottom: 0.5rem;
            justify-content: center;
        }
        .guarantee-badge {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px dashed #eee;
            text-align: center;
            font-size: 0.9rem;
            color: var(--color-accent);
            font-weight: 600;
        }
        @media (max-width: 900px) {
            .service-layout {
                grid-template-columns: 1fr;
            }
        }
        /* Floating Image Style */
        .floating-img-container {
            width: 100%;
            margin: 2rem 0;
            text-align: center;
            overflow: hidden;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        /* ZONES */
        .city-group { margin-bottom: 1.5rem; }
        .city-lead { font-weight: 700; color: var(--color-primary); margin-bottom: 0.6rem; }
        .badges-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .badge { padding: 0.4rem 0.9rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid transparent; }
        .badge-blue { background: #e8f4fd; border-color: #c5dff0; }
        .badge-green { background: #f0faf0; border-color: #b8ddb8; }
        .contact-footer { margin-top: 1.5rem; font-style: italic; color: #666; }
        .floating-img {
            width: 100%;
            height: auto;
            max-height: 300px;
            object-fit: cover;
            border-radius: 12px;
            animation: float-sleep 6s ease-in-out infinite;
        }
        @keyframes float-sleep {
            0% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
            100% {
                transform: translateY(0px);
            }
        }
        /* NEW SECTIONS CSS */
        .benefits-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .benefit-item {
            display: flex;
            align-items: center;
            gap: 15px;
            background: white;
            padding: 1rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            border: 1px solid #eee;
        }
        .check-circle {
            width: 25px;
            height: 25px;
            background: #e6f7e6;
            color: #2e7d32;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.9rem;
            flex-shrink: 0;
        }
        .faq-list {
            margin-top: 1.5rem;
        }
