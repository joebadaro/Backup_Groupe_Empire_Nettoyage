---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Mattress Cleaning & Disinfection at Home"
  description="Expert mattress cleaning service (Montreal, Laval, South Shore). Elimination of dust mites, urine stains, and allergens. Ecological disinfection for healthy sleep."
>
  <!-- SPLIT SCREEN HERO: BLOCK 1 -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT -->
        <div class="split-content fade-in-section bg-gradient-premium">
          <span class="service-cat-badge">FURNITURE</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Mattress Cleaning & Disinfection
          </h1>

          <!-- BLOCK 1: INTRO (VISIBLE) -->
          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Do you suffer from allergies, morning nasal congestion, or does
              your mattress have yellow rings? Vacuuming alone is not enough to
              eliminate embedded dust mites and bacteria.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Spend a third of your life in a healthy environment. We offer a
            complete <strong>in-home mattress cleaning and disinfection</strong> service
            that eliminates allergens, stains, and odors for good.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-gradient-green pulse-btn">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green"
            >
              <span class="icon">⚡</span> Online Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/photo-matelas-2.webp"
              alt="Mattress cleaning disinfection at home Montreal - Dust mite elimination"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/photo-matelas-6.webp"
              alt="Professional mattress cleaning service Laval - Empire Cleaning Group"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />

            <img
              src="/images/catalog/photo-matelas-8.webp"
              alt="Ecological mattress disinfection South Shore - Healthy sleep"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout" style="display: block;">
        <!-- MAIN CONTENT (Centered, No Sidebar) -->
        <div class="service-main" style="max-width: 800px; margin: 0 auto;">
          <div class="fade-in-section delay-100">
            <!-- TOGGLE BUTTON (INITIAL VIEW) -->
            <div style="margin-top: 1rem;">
              <button id="toggle-seo-btn" class="btn-outline-reveal">
                Learn more about mattress disinfection ▼
              </button>
            </div>

            <!-- HIDDEN CONTENT: PROCESS -> LIST -> PROTECTION -->
            <div id="seo-content" class="seo-content-hidden">
              <hr class="separator" />

              <h3 style="color: var(--color-primary);">
                Healthy sleep starts with a clean mattress
              </h3>
              <p>
                A clean mattress is essential for healthy and restorative sleep.
                At <strong>Empire Cleaning Group</strong>, we offer a
                professional <strong>in-home mattress cleaning</strong> service in
                <strong>Montreal</strong>, <strong>Laval</strong>, and on the <strong
                  >South Shore</strong
                >, designed to eliminate dust, stains, dust mites, and allergens
                embedded in the fibers.
              </p>
              <p style="margin-top: 1rem;">
                Thanks to our <strong>deep cleaning technology</strong>, we use
                safe and ecological methods that disinfect effectively without
                harsh chemicals. This process neutralizes bacteria and bad odors
                while extending the life of your mattress.
              </p>
              <p style="margin-top: 1rem;">
                Our team of specialists adapts the treatment according to the
                type of mattress – <strong
                  >memory foam, latex, hybrid, or spring</strong
                > – to preserve its quality and comfort.
              </p>

              <!-- Floating Sleep Image -->
              <div class="floating-img-container fade-in-section">
                <img
                  src="/images/catalog/photo-matelas-floating.webp"
                  alt="Restorative sleep clean mattress Longueuil - Health and comfort"
                  class="floating-img"
                  width="1200"
                  height="675"
                  loading="lazy"
                />
              </div>

              <br />

              <h3
                class="section-title text-gradient-empire"
                style="font-size: 1.5rem; margin-bottom: 1rem;"
              >
                The benefits of our service:
              </h3>

              <ul class="benefit-list">
                <li>
                  <strong>Elimination of dust mites and allergens</strong>
                </li>
                <li>
                  <strong>Complete disinfection</strong> for a healthier environment
                </li>
                <li>
                  <strong>Quick drying</strong> and impeccable result
                </li>
                <li>
                  <strong>Safe products</strong> for the whole family
                </li>
              </ul>

              <!-- Additional Image -->
              <div
                class="fade-in-section"
                style="margin: 2rem 0; text-align: center;"
              >
                <img
                  src="/images/catalog/photo-matelas-1.webp"
                  alt="Technician cleaning mattress Montreal - Professional in-home service"
                  class="rounded-img shadow-premium"
                  style="width: 100%; max-width: 600px; border-radius: 8px;"
                  width="1200"
                  height="800"
                  loading="lazy"
                />
              </div>

              <!-- BLOCK 4: PROTECTION - REMOVED AS REQUESTED -->

              <br />
              <!-- BLOCK 6 -->
              <p>
                Improve your sleep quality and your home's cleanliness thanks to <strong
                  >Empire Cleaning Group</strong
                >'s professional mattress cleaning.
              </p>
              <p style="margin-top: 0.5rem;">
                Contact us today for a <strong>quick quote</strong> and trusted service.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW SECTIONS: BENEFITS & FAQ -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="service-layout" style="display: block;">
        <!-- Full width for these bottom sections -->
        <div class="service-main" style="max-width: 800px; margin: 0 auto;">
          <!-- BENEFITS -->
          <div class="fade-in-section delay-200" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">Why choose us?</h2>
            <div class="benefits-grid">
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>99% allergen & dust mite elimination</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>Ecological disinfection without odor</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>Quick drying (few hours)</span>
              </div>
            </div>
          </div>

          <!-- FAQ with Schema Component -->
          <FAQSchema
            title="Frequently Asked Questions"
            faqs={[
              {
                question:
                  "How to effectively eliminate dust mites from a mattress?",
                answer:
                  "Dust mite elimination requires a two-step approach: disinfection and deep extraction. At Empire Cleaning Group, we use a specialized process that combines injection of ecological anti-dust mite solutions with high-power extraction. This method eliminates up to 99% of dust mites, their droppings, and associated allergens. Unlike a simple vacuum or aerosol products, our technique acts deeply in all layers of the mattress. The treatment is completed with a disinfection that creates an environment hostile to dust mites, significantly reducing their reappearance. For allergic people, we recommend annual or bi-annual cleaning.",
              },
              {
                question:
                  "How long does it take for a mattress to dry after professional cleaning?",
                answer:
                  "A professionally cleaned mattress with our injection-extraction method generally dries in 4 to 6 hours. Our high-suction equipment extracts 95% of moisture immediately after treatment, leaving the mattress only slightly damp to the touch. Drying time may vary depending on the type of mattress (memory foam, springs, latex), thickness, and room ventilation conditions. To speed up drying, we recommend opening windows and using a fan. Unlike full saturation methods, you can generally reuse your bed the same evening.",
              },
              {
                question:
                  "Can mattress cleaning really eliminate urine stains and odors?",
                answer:
                  "Yes, absolutely. Urine stains and odors require specific enzymatic treatment that we master perfectly. Enzymes break down uric acid crystals that cause persistent odors, even after the visual stain has disappeared. For severe cases where urine has penetrated deep into the mattress, we apply the treatment in several steps with pause time to allow enzymes to work. In 95% of cases, we completely eliminate the odor and stain in a single intervention. For very damaged mattresses, we honestly assess whether replacement would be more appropriate.",
              },
              {
                question:
                  "Does professional mattress cleaning damage memory foam?",
                answer:
                  "No, on the contrary. Our method is specifically adapted for each type of mattress, including memory foam which is more delicate. We use a low-moisture technique and pH-neutral products that do not affect the viscoelastic properties of the foam. Manufacturers actually recommend periodic professional cleaning to extend mattress life. The accumulation of sweat, body oils, and dust mites can actually degrade foam faster than proper cleaning. Our process preserves the cellular structure of the foam while eliminating contaminants.",
              },
            ]}
          />
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  // Force script to run immediately using is:inline
  (function () {
    // Slideshow Logic
    const slides = document.querySelectorAll(".slide");
    if (slides.length > 0) {
      let currentSlide = 0;
      const intervalTime = 4000; // 4 seconds

      setInterval(() => {
        slides[currentSlide].classList.remove("active");
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add("active");
      }, intervalTime);
    }

    // Toggle Logic
    const toggleBtn = document.getElementById("toggle-seo-btn");
    const seoContent = document.getElementById("seo-content");

    if (toggleBtn && seoContent) {
      toggleBtn.addEventListener("click", function () {
        if (seoContent.style.display === "block") {
          seoContent.style.display = "none";
          toggleBtn.textContent = "Learn more about mattress disinfection ▼";
        } else {
          seoContent.style.display = "block";
          seoContent.classList.add("visible");
          toggleBtn.textContent = "Show less ▲";
        }
      });
    }
  })();
</script>

<style>
  /* HERO */
  /* SPLIT SCREEN HERO (Sky Blue Theme) */
  .split-hero-container {
    background-color: #fff; /* Reset container to white */
    padding-top: 0; /* Remove container padding so image hits top */
    padding-bottom: 0;
    overflow: hidden;
    width: 100vw;
  }

  .full-width-split {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 80vh; /* Consistent viewport height */
  }

  /* LEFT TEXT COLUMN */
  .split-content {
    background-color: #ffffff;
    padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .service-cat-badge {
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }

  .split-title {
    font-size: clamp(2.5rem, 3.5vw, 4rem);
    color: var(--color-primary); /* Dark Blue text */
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .problem-statement {
    background: #ffffff; /* White box */
    border-left: 4px solid #ff4444; /* Red border returns for alertness */
    padding: 1.5rem;
    border-radius: 0;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); /* Soft blue shadow */
  }

  .problem-title {
    font-size: 1rem;
    color: #cc0000;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    font-weight: 700;
  }

  .problem-text {
    font-size: 1.05rem;
    color: var(--color-text-main);
    font-style: italic;
  }

  .lead-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text-main); /* Dark grey text */
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .cta-group {
      display: none !important;
    }
  }

  /* Reset Secondary Button for Light Mode */
  .split-content .btn-secondary-outline {
    border-color: #ddd;
    color: #666;
  }
  .split-content .btn-secondary-outline:hover {
    background: white;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* RIGHT IMAGE COLUMN */
  .split-image-wrapper {
    position: relative;
    height: 100%;
    min-height: 500px;
    width: 100%;
    border-radius: 0;
    transform: none;
    box-shadow: none;
    margin: 0;
    background-color: #fff; /* Ensure white background if image loads late */
  }

  /* Slideshow Styles reused but adapted for full height */
  .slideshow-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .slide.active {
    opacity: 1;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .split-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .split-content {
      padding: 3rem 1.5rem;
      order: 1; /* Content first */
    }

    .split-image-wrapper {
      order: 2; /* Image second */
      height: 400px;
      min-height: 0;
    }

    .lead-text {
      max-width: 100%;
    }
  }

  /* LAYOUT */
  .service-layout {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 5rem;
  }

  /* TYPOGRAPHY */
  .section-title {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  /* Benefit List Styles from original */
  .benefit-list {
    margin: 2rem 0;
    list-style: none; /* Ensure no default bullets */
    padding: 0;
  }

  .benefit-list li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    font-size: 1.05rem;
  }

  .benefit-list li::before {
    content: "✓";
    color: #d32f2f; /* Empire Red or Gold */
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .info-box {
    background-color: #f8f9fa;
    border-left: 4px solid var(--color-accent);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 4px;
  }

  /* NEW BUTTON STYLE */
  .btn-outline-reveal {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    padding: 0.75rem 1.5rem; /* Nice padding */
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    border-radius: 4px; /* Rounded corners */
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .btn-outline-reveal:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }

  .seo-content-hidden {
    display: none;
    margin-top: 2rem;
    padding-top: 1rem;
    animation: fadeIn 0.5s ease-in-out;
  }

  /* Animation */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .separator {
    border: 0;
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    margin: 1.5rem 0;
  }

  /* SIDEBAR */
  .service-sidebar {
    position: relative;
  }

  .sticky-card {
    background: white;
    padding: 2rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 2rem;
    border: 1px solid #eee;
  }

  .card-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: 800;
  }

  .card-desc {
    color: #666;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .full-width {
    width: 100%;
    margin-bottom: 0.5rem;
    justify-content: center;
  }

  .guarantee-badge {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px dashed #eee;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .service-layout {
      grid-template-columns: 1fr;
    }
  }

  /* Floating Image Style */
  .floating-img-container {
    width: 100%;
    margin: 2rem 0;
    text-align: center;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  .floating-img {
    width: 100%;
    height: auto;
    max-height: 300px;
    object-fit: cover;
    border-radius: 12px;
    animation: float-sleep 6s ease-in-out infinite;
  }

  @keyframes float-sleep {
    0% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
    100% {
      transform: translateY(0px);
    }
  }

  /* NEW SECTIONS CSS */
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: 15px;
    background: white;
    padding: 1rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    border: 1px solid #eee;
  }

  .check-circle {
    width: 25px;
    height: 25px;
    background: #e6f7e6;
    color: #2e7d32;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .faq-list {
    margin-top: 1.5rem;
  }

  .faq-item {
    background: #f9f9f9;
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    border-left: 3px solid var(--color-primary);
  }

  .question {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .answer {
    color: var(--color-text-main);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
