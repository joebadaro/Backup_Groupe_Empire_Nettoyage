---
import Layout from "../../../layouts/Layout.astro";
---

<Layout
  title="Carpet Cleaning"
  description="Expert in residential and commercial carpet cleaning. Industrial steam technology for superior results. Elimination of stains and allergens."
>
  <header class="page-header">
    <div class="container">
      <h1>Carpet Cleaning</h1>
      <p>
        Restore the original brilliance of your carpets with our steam technology.
      </p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <div class="content-grid">
        <div class="text-content">
          <h2>Why choose our carpet cleaning?</h2>
          <p>
            Your carpets act as air filters, trapping dust,
            allergens, and bacteria. A simple vacuuming is not enough.
          </p>

          <ul class="benefit-list">
            <li>
              <strong>Allergen elimination:</strong> We remove up to
              99% of dust mites and bacteria.
            </li>
            <li>
              <strong>Quick drying:</strong> Thanks to our powerful suction, your
              carpets are dry in a few hours.
            </li>
            <li>
              <strong>Eco-friendly products:</strong> Safe for your children
              and pets.
            </li>
          </ul>

          <button
            onclick="window.openEstimationWidget()"
            class="btn btn-primary"
          >
            Instant Online Estimate
          </button>
        </div>
        <div class="image-content">
          <img
            src="/images/service-tapis-optimized.webp"
            alt="Professional carpet cleaning"
            class="rounded-img shadow-premium"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-empire-blue);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .benefit-list {
    margin: 2rem 0;
  }

  .benefit-list li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
  }

  .benefit-list li::before {
    content: "✓";
    color: var(--color-gold);
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .rounded-img {
    border-radius: 8px;
    width: 100%;
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
