---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Residential Carpet & Stair Cleaning | Montreal, Laval & South Shore"
  description="Professional residential carpet and stair cleaning with truck-mount unit. Eliminates allergens, stains, and odors. Montreal, Laval & South Shore. Fast drying. Free estimate."
>
  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">CARPETS & STAIRS</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Residential Carpet & Stair Cleaning
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Your living room carpets and stairs (high-traffic areas) act
              as giant filters. They trap dust, sand,
              allergens, and body oils (from bare feet) that crush the fibers.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Protect your flooring investment. Our steam cleaning
            by injection-extraction eliminates contaminants, revives colors,
            and lifts the fibers of your wall-to-wall carpets and stair treads.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-gradient-green pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (Speak to an Expert)
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green"
            >
              <span class="icon">⚡</span> Instant Online Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual / Slideshow) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/photo-9.webp"
              alt="Steam carpet cleaning Laval - Professional technology"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />

            <img
              src="/images/catalog/photo-15.webp"
              alt="Residential carpet cleaning result Longueuil - Empire Group"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-34.webp"
              alt="Home carpet cleaning service Brossard - Guaranteed quality"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-67.webp"
              alt="Impeccable residential carpet after cleaning Montreal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-142.webp"
              alt="Before-after carpet cleaning Empire Group - Professional result"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-143.webp"
              alt="Clean and healthy carpet - Eliminating allergens Laval"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-144.webp"
              alt="30 years carpet cleaning expertise - Empire Group South Shore"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-133.webp"
              alt="At-home carpet cleaning service Longueuil - Without moving furniture"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <!-- BENEFIT LIST & SEO CONTENT -->
          <div class="fade-in-section delay-100">
            <h2 class="section-title text-gradient-empire">
              Our Expert Process (5 Steps)
            </h2>

            <p>
              Unlike rental machines that leave your carpets soaked and
              stiff, we use a professional 5-step method to
              guarantee an exceptional and lasting result:
            </p>

            <ul class="benefit-list" style="margin-bottom: 3rem;">
              <li>
                <strong>1. Targeted Pre-treatment:</strong> Application of an enzymatic solution
                on high-traffic areas (hallways, landings) to break down oils.
              </li>
              <li>
                <strong>2. Agitation and Brushing:</strong> Gentle mechanical action to
                lift crushed fibers and detach abrasive sand embedded at the base.
              </li>
              <li>
                <strong>3. Steam Cleaning (Extraction):</strong> Our high-pressure equipment
                injects very hot water (steam) and vacuums it instantly
                with the dirt, killing 99% of dust mites and bacteria.
              </li>
              <li>
                <strong>4. Neutralizing Rinse:</strong> Crucial step to balance the pH.
                Your carpets will NEVER remain sticky or stiff (which attracts dirt).
              </li>
              <li>
                <strong>5. Fast Drying:</strong> Thanks to our industrial suction
                (truck-mount or professional portable), your carpets are damp, not soaked, and
                generally dry in 3 to 6 hours.
              </li>
            </ul>

            <div style="margin-top: 3rem; background-color: #f8f9fa; border-left: 4px solid var(--color-accent); padding: 2rem; border-radius: 8px;">
              <h3 style="color: var(--color-primary); margin-bottom: 1rem;">
                ⭐ Specialty: Stair Carpet Cleaning
              </h3>
              <p>
                <strong>Stairs</strong> endure the most friction in a home. The nose of the
                step quickly becomes stained with body oils (from walking barefoot or in socks), and the
                riser accumulates black scuff marks from shoes.
              </p>
              <p style="margin-top: 1rem;">
                Cleaning a staircase requires specific equipment. Our technicians use
                <strong>specialized manual extraction tools</strong> designed to perfectly fit the angle of
                each step (nose and riser) and clean right into the corners of the landings. We eliminate dark
                wear lines and restore volume to flattened steps.
              </p>
            </div>

            <div style="margin-top: 3rem;">
              <hr class="separator" />
              <h3>Why trust your carpet cleaning to professionals?</h3>
              <p>
                Your wall-to-wall carpets act as the largest filter in your home in <strong>Montreal</strong>, 
                <strong>Laval</strong>, <strong>Longueuil</strong> or elsewhere on the <strong>South Shore</strong>. 
                This natural filter traps dust, pollen, allergens, and pollution that enter 
                through your windows. However, like any filter, once full, it begins to release these 
                contaminants into the air you breathe with every step.
              </p>
              <p style="margin-top: 1rem;">
                At <strong>Empire Cleaning Group</strong>, we work in all types of housing.
                Whether you are in a bungalow requiring the suction power of our 
                <strong>truck-mount</strong>, or in a condo on the 15th floor requiring our 
                <strong>professional portable units</strong>, we have the perfect equipment to deep extract 
                the abrasive sand that cuts your carpet fibers at the base.
              </p>
              <p style="margin-top: 1rem;">
                Our process adapts to all fibers (nylon, polyester, olefin, Berber, wool). 
                Regular professional cleaning doesn't just improve the look of your living room or 
                basement; it extends the life of your investment and truly cleanses 
                indoor air quality for your entire family.
              </p>

              <!-- BLOCK 4: PROTECTION -->
              <div class="info-box" style="margin-top: 2rem;">
                <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                  Stain Protection (Carpet Protector)
                </h3>
                <p>
                  Particularly recommended for <strong>stairs and hallways</strong>, we offer
                  the application of <a href="/en/services/protecteur" style="color: var(--color-primary); font-weight: bold; text-decoration: underline;">professional post-cleaning fabric protector</a>. It creates an
                  invisible barrier that prevents liquids from immediately penetrating the fiber, making it easier to clean up
                  small daily spills and slowing the wear of your high-traffic areas for 1 to 10 years depending on the chosen product.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW SECTIONS: BENEFITS & FAQ -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="service-layout" style="display: block;">
        <!-- Full width for these bottom sections -->
        <div class="service-main" style="max-width: 800px; margin: 0 auto;">
          <!-- BENEFITS -->
          <div class="fade-in-section delay-200" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">
              Why choose us?
            </h2>
            <div class="benefits-grid">
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>Systematic floor protection</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>40+ products for all stains</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>Truck-Mount or Portable Pro depending on access</span>
              </div>
            </div>
          </div>

          <!-- SERVICED ZONES -->
          <div class="zones-section" style="margin-top: 3rem; margin-bottom: 3rem;">
            <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Service Areas — Carpet Cleaning</h3>
            <p>We serve the entire Greater Montreal Area with our high-performance mobile units.</p>

            <div class="city-group">
              <p class="city-lead">🏙️ Montreal (East and West)</p>
              <div class="badges-container">
                <span class="badge badge-blue">📍 Montreal (all boroughs)</span>
                <span class="badge badge-blue">📍 Westmount</span>
                <span class="badge badge-blue">📍 Mount Royal</span>
                <span class="badge badge-blue">📍 Outremont</span>
                <span class="badge badge-blue">📍 LaSalle</span>
                <span class="badge badge-blue">📍 And more...</span>
              </div>
            </div>

            <div class="city-group">
              <p class="city-lead">🏘️ Laval</p>
              <div class="badges-container">
                <span class="badge badge-blue">📍 Laval (entire city)</span>
                <span class="badge badge-blue">📍 Chomedey</span>
                <span class="badge badge-blue">📍 Sainte-Rose</span>
                <span class="badge badge-blue">📍 Vimont</span>
              </div>
            </div>

            <div class="city-group">
              <p class="city-lead">🌿 Montreal South Shore</p>
              <div class="badges-container">
                <span class="badge badge-green">📍 Longueuil</span>
                <span class="badge badge-green">📍 Brossard</span>
                <span class="badge badge-green">📍 Saint-Lambert</span>
                <span class="badge badge-green">📍 Saint-Hubert</span>
                <span class="badge badge-green">📍 Greenfield Park</span>
                <span class="badge badge-green">📍 Saint-Bruno</span>
                <span class="badge badge-green">📍 Boucherville</span>
                <span class="badge badge-green">📍 And more...</span>
              </div>
            </div>
            
            <p class="contact-footer">Need a quick appointment? Call us at <strong>(514) 893-9939</strong>.</p>
          </div>

          <!-- FAQ -->
          <div class="fade-in-section delay-300" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">
              Frequently Asked Questions — Carpet Cleaning
            </h2>
            <FAQSchema
              faqs={[
                {
                  question:
                    "How much does stair carpet cleaning cost?",
                  answer:
                    "Stair cleaning is billed differently than a standard room, usually per step or per flight of stairs. The rate includes full cleaning of the nose, riser, and small landings if any. Contact us for a precise free estimate based on the number of steps in your home.",
                },
                {
                  question:
                    "How do you clean stair carpets specifically?",
                  answer:
                    "We use a specialized manual hot water tool (stair tool). This equipment allows us to apply the solution under high pressure and extract dirt exactly at the angle of the step and on the nose (the dirtiest area). This manual precision restores volume to crushed fibers, which a standard machine cannot do.",
                },
                {
                  question:
                    "Do you clean carpets in high-rise condos (apartments) without exterior access?",
                  answer:
                    "Yes, absolutely. If you live in a condo tower in Montreal, Laval, or the South Shore where our truck-mount hoses cannot reach (from the 3rd floor up), we use our high-performance professional portable extraction units. These machines connect to your water supply and offer comparable results without requiring long exterior hoses.",
                },
                {
                  question:
                    "How often should residential wall-to-wall carpets be professionally cleaned?",
                  answer:
                    "It is recommended to have your residential carpets professionally cleaned every 12 to 18 months to prevent abrasive wear from hidden sand. In homes with young children, pets, or for high-traffic areas like hallways and stairs, cleaning every 6 to 9 months will considerably extend the life of your carpet.",
                },
                {
                  question:
                    "Does carpet cleaning really remove pet stains and odors?",
                  answer:
                    "Yes. While each stain is unique, our professional process includes specific enzymatic treatments for pet accidents (urine, vomit). Enzymes destroy the bacteria responsible for foul odors embedded in the fibers and padding, offering a much deeper result than a simple surface shampoo.",
                },
                {
                  question:
                    "How long does it take for a living room or stair carpet to dry after cleaning?",
                  answer:
                    "Drying time is generally between 3 and 6 hours thanks to our industrial equipment that extracts up to 95% of moisture. Factors influencing drying: carpet thickness (dense Shag or plush carpets take longer), house temperature, ambient humidity, and air circulation. You can walk on it in clean socks almost immediately.",
                },
                {
                  question:
                    "Do I need to empty the room of all my furniture before you arrive?",
                  answer:
                    "No, it's not necessary to empty everything. We simply ask you to remove small objects, toys, floor lamps, and small light tables or chairs. Our technicians will carefully clean around large heavy furniture (sectional sofas, king beds, large dressers). If a medium-sized piece of furniture needs to be moved slightly to clean underneath, we place plastic protectors under the legs to avoid staining the damp carpet.",
                },
                {
                  question:
                    "Is steam cleaning safe for children (babies) and pets?",
                  answer:
                    "Totally. We use eco-friendly, non-toxic, and biodegradable cleaning solutions. Most importantly, our neutralizing rinse step ensures that no chemical residue (soap) remains on your carpet fibers. It is the safest method for toddlers crawling on the floor and for your pets.",
                },
              ]}
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple Cross-Fade Slideshow
  const slides = document.querySelectorAll(".slide");

  if (slides.length > 0) {
    let currentSlide = 0;
    const intervalTime = 4000; // 4 seconds

    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, intervalTime);
  }


</script>

<style>
  /* HERO */
  /* SPLIT SCREEN HERO (Sky Blue Theme) */
  .split-hero-container {
    background-color: #fff; /* Reset container to white */
    padding-top: 0; /* Remove container padding so image hits top */
    padding-bottom: 0;
    overflow: hidden;
    width: 100vw;
  }

  .full-width-split {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 80vh; /* Consistent viewport height */
  }

  /* LEFT TEXT COLUMN */
  .split-content {
    background-color: #ffffff; /* User requested NO BLUE Background for text */
    padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .service-cat-badge {
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }

  .split-title {
    font-size: clamp(2.5rem, 3.5vw, 4rem);
    color: var(--color-primary); /* Dark Blue text */
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .problem-statement {
    background: #ffffff; /* White box */
    border-left: 4px solid #ff4444; /* Red border returns for alertness */
    padding: 1.5rem;
    border-radius: 0;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); /* Soft blue shadow */
  }

  .problem-title {
    font-size: 1rem;
    color: #cc0000;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    font-weight: 700;
  }

  .problem-text {
    font-size: 1.05rem;
    color: var(--color-text-main);
    font-style: italic;
  }

  .lead-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text-main); /* Dark grey text */
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .cta-group {
      display: none !important;
    }
  }

  /* RIGHT IMAGE COLUMN */
  .split-image-wrapper {
    position: relative;
    height: 100%;
    min-height: 500px;
    width: 100%;
    margin: 0;
    overflow: hidden;
  }

  .slideshow-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .slide.active {
    opacity: 1;
  }

  .image-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.2), transparent);
    pointer-events: none;
    z-index: 2;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .split-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .split-content {
      padding: 3rem 1.5rem;
      order: 1; /* Content first */
    }

    .split-image-wrapper {
      order: 2; /* Image second */
      height: 400px;
      min-height: 0;
    }
  }

  /* LAYOUT */
  .service-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
  }

  /* TYPOGRAPHY */
  .section-title {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  .benefit-list {
    margin: 2rem 0;
    list-style: none;
    padding: 0;
  }

  .benefit-list li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    font-size: 1.05rem;
  }

  .benefit-list li::before {
    content: "✓";
    color: #d32f2f;
    position: absolute;
    left: 0;
    font-weight: bold;
  }

  .info-box {
    background-color: #f8f9fa;
    border-left: 4px solid var(--color-accent);
    padding: 1.5rem;
    border-radius: 4px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: 15px;
    background: white;
    padding: 1rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    border: 1px solid #eee;
  }

  .check-circle {
    width: 25px;
    height: 25px;
    background: #e6f7e6;
    color: #2e7d32;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  .separator {
    border: 0;
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    margin: 1.5rem 0;
  }

  /* ZONES */
  .city-group { margin-bottom: 1.5rem; }
  .city-lead { font-weight: 700; color: var(--color-primary); margin-bottom: 0.6rem; }
  .badges-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .badge { padding: 0.4rem 0.9rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid transparent; }
  .badge-blue { background: #e8f4fd; border-color: #c5dff0; }
  .badge-green { background: #f0faf0; border-color: #b8ddb8; }
  .contact-footer { margin-top: 1.5rem; font-style: italic; color: #666; }

  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
