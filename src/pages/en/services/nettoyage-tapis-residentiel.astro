---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Residential Carpet Cleaning"
  description="Professional residential carpet cleaning in Montreal and South Shore. Elimination of stains, odors, and dust mites. Quick drying with truck-mount unit."
>
  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">CARPETS</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Residential Carpet Cleaning
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Your carpets act as air filters, trapping dust, allergens, and
              bacteria. A simple vacuum is not enough.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Protect your family's health. Our steam cleaning eliminates
            contaminants and restores your carpets to like-new condition.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-gradient-green pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (Free Estimate)
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green"
            >
              <span class="icon">⚡</span> Online Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual / Slideshow) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/photo-86.webp"
              alt="Professional residential carpet cleaning Montreal - Empire Cleaning Group"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/photo-9.webp"
              alt="Steam carpet cleaning Laval - Professional equipment"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-48.webp"
              alt="Truck-mount carpet extraction South Shore - Professional equipment"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-15.webp"
              alt="Clean residential carpet Longueuil - Empire Cleaning results"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-34.webp"
              alt="At-home carpet cleaning service Brossard - Quality guaranteed"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-67.webp"
              alt="Impeccable carpet after professional cleaning Montreal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-142.webp"
              alt="Before-after carpet cleaning Empire Group - Professional results"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-143.webp"
              alt="Clean healthy carpet - Allergen removal Laval"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-144.webp"
              alt="Carpet cleaning expertise 30 years - Empire Group South Shore"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-133.webp"
              alt="At-home carpet cleaning Longueuil - No furniture moving required"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <!-- BENEFIT LIST & SEO CONTENT -->
          <div class="fade-in-section delay-100">
            <h2 class="section-title text-gradient-empire">
              Our Approach (On Site)
            </h2>

            <p>
              We use a proven method to guarantee exceptional results directly
              at your home:
            </p>

            <ul class="benefit-list">
              <li>
                <strong>Allergen elimination:</strong> We remove up to 99% of dust
                mites and bacteria.
              </li>
              <li>
                <strong>Quick drying:</strong> Thanks to our powerful suction, your
                carpets are dry in a few hours.
              </li>
              <li>
                <strong>Eco-friendly products:</strong> Safe for your children and
                pets.
              </li>
            </ul>

            <div style="margin-top: 2rem;">
              <button id="toggle-seo-btn" class="btn-text-reveal">
                Learn more about residential carpet cleaning ▼
              </button>
            </div>

            <div id="seo-content" class="seo-content-hidden">
              <hr class="separator" />
              <h3>Revitalize your carpets</h3>
              <p>
                At <strong>Empire Cleaning</strong>, we offer a professional
                <strong>residential carpet cleaning</strong> service directly at your
                home. Our <strong>extraction injection</strong> techniques, also known
                as
                <strong>steam cleaning</strong>, ensure deep cleaning to
                eliminate dust, stains, allergens, and bad odors while
                preserving the softness and colors of your carpets.
              </p>
              <p>
                Our process combines <strong>biodegradable products</strong> and high-performance
                equipment. Excess water and solution are carefully extracted to promote
                <strong>quick drying</strong> and limit the risk of mold. Each intervention
                is adapted to the type of carpet (wool, synthetic fibers, Berber,
                shaggy, long-pile carpets) to obtain optimal results without damaging
                the fibers.
              </p>
              <p>
                A clean carpet improves the aesthetics of the home and the <strong
                  >indoor air quality</strong
                >. Thanks to our expertise, your carpets regain their original
                shine and their lifespan is extended. Our service is neat and
                punctual, at home, in <strong>Montreal</strong>
                and <strong>Laval</strong> as well as on the <strong
                  >South Shore</strong
                > (Longueuil and surroundings).
              </p>

              <h3>Why choose Empire Cleaning?</h3>
              <ul>
                <li>
                  <strong>Quick service</strong> and professional in-home care
                </li>
                <li>
                  <strong>Safe</strong> products for children and animals
                </li>
                <li>
                  Targeted stain removal and <strong>anti-odor</strong> treatment
                  on request
                </li>
                <li>
                  Lasting results, maintenance advice after the intervention
                </li>
              </ul>

              <!-- BLOCK 4: PROTECTION -->
              <div class="info-box">
                <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                  Stain Protection
                </h3>
                <p>
                  In addition to cleaning, we also offer the application of a
                  stain protector, creating an invisible barrier that
                  facilitates future maintenance and protects your investment.
                </p>
              </div>

              <p>
                Treat yourself to a clean, healthy, and welcoming interior with
                our residential carpet cleaning service. Contact <strong
                  >Empire Cleaning Group</strong
                >
                for a quick quote and specialized, ecological, and effective maintenance.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW SECTIONS: BENEFITS & FAQ -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="service-layout" style="display: block;">
        <!-- Full width for these bottom sections -->
        <div class="service-main" style="max-width: 800px; margin: 0 auto;">
          <!-- BENEFITS -->
          <div class="fade-in-section delay-200" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">Why choose us?</h2>
            <div class="benefits-grid">
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>Systematic floor protection</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>40+ products for all stains</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span>Truck-mount or Portable Pro depending on access</span>
              </div>
            </div>
          </div>

          <!-- FAQ with Schema Component -->
          <FAQSchema
            title="Frequently Asked Questions"
            faqs={[
              {
                question:
                  "What is the best method for cleaning a residential carpet?",
                answer:
                  "Hot water extraction (also called steam cleaning) is the most effective technique and recommended by carpet manufacturers. At Empire Cleaning Group, we use this method with our truck-mount unit which offers 20 times more power than portable equipment. This technique deeply eliminates dirt, allergens, and bacteria while preserving fibers. Hot water combined with our ecological products dissolves stains, then our ultra-powerful suction system extracts 98% of moisture for quick drying in 3-6 hours.",
              },
              {
                question:
                  "Is professional carpet cleaning safe for children and pets?",
                answer:
                  "Absolutely. All our cleaning products are 100% biodegradable, hypoallergenic, and certified ecological. They contain no toxic or irritating chemicals. Your children and pets can walk on the carpets as soon as they are dry, usually after 3 to 6 hours. We even recommend regular cleaning for families with young children, as it eliminates up to 99% of dust mites and allergens that accumulate in the fibers.",
              },
              {
                question:
                  "How long does it take for a carpet to dry after professional cleaning?",
                answer:
                  "Thanks to our truck-mount unit and its ultra-powerful suction, our carpets dry in 3 to 6 hours, much faster than portable equipment which can require 12 to 24 hours. Drying speed depends on several factors: fiber type, carpet thickness, room temperature and ventilation. We extract 98% of moisture during the intervention, which considerably reduces the risk of mold and allows your family to reuse the spaces quickly.",
              },
              {
                question:
                  "What is the difference between a truck-mount and portable equipment for cleaning carpets?",
                answer:
                  "The difference is major in terms of results. Our truck-mount generates suction power and water temperature far superior to any portable equipment. Concretely, this means: deeper extraction of dirt (down to the base of fibers), more complete elimination of soap residues, 2 to 3 times faster drying, and better elimination of stubborn stains. Portable equipment may be suitable for light touch-ups, but for deep cleaning that extends the life of your carpets, the truck-mount is unmatched.",
              },
              {
                question: "Can you remove pet odors from carpets?",
                answer:
                  "Yes, we specialize in eliminating pet odors. Our three-step process includes: 1) identifying affected areas (sometimes invisible to the naked eye), 2) applying enzymatic treatments that neutralize odor molecules at the source, and 3) deep cleaning with complete extraction. For severe cases of urine that has penetrated the underpad, we also offer specialized treatments. In 95% of cases, we completely eliminate odors in a single intervention.",
              },
            ]}
          />
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple Cross-Fade Slideshow
  const slides = document.querySelectorAll(".slide");

  if (slides.length > 0) {
    let currentSlide = 0;
    const intervalTime = 4000; // 4 seconds

    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, intervalTime);
  }

  // Toggle SEO Content
  const toggleBtn = document.getElementById("toggle-seo-btn");
  const seoContent = document.getElementById("seo-content");

  if (toggleBtn && seoContent) {
    toggleBtn.addEventListener("click", () => {
      seoContent.classList.toggle("visible");
      if (seoContent.classList.contains("visible")) {
        toggleBtn.textContent = "Show less ▲";
      } else {
        toggleBtn.textContent =
          "Learn more about residential carpet cleaning ▼";
      }
    });
  }
</script>

<style>
  /* HERO */
  /* SPLIT SCREEN HERO (Sky Blue Theme) */
  .split-hero-container {
    background-color: #fff; /* Reset container to white */
    padding-top: 0; /* Remove container padding so image hits top */
    padding-bottom: 0;
    overflow: hidden;
    width: 100vw;
  }

  .full-width-split {
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 80vh; /* Consistent viewport height */
  }

  /* LEFT TEXT COLUMN */
  .split-content {
    background-color: #ffffff; /* User requested NO BLUE Background for text */
    padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .service-cat-badge {
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }

  .split-title {
    font-size: clamp(2.5rem, 3.5vw, 4rem);
    color: var(--color-primary); /* Dark Blue text */
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .problem-statement {
    background: #ffffff; /* White box */
    border-left: 4px solid #ff4444; /* Red border returns for alertness */
    padding: 1.5rem;
    border-radius: 0;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); /* Soft blue shadow */
  }

  .problem-title {
    font-size: 1rem;
    color: #cc0000;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    font-weight: 700;
  }

  .problem-text {
    font-size: 1.05rem;
    color: var(--color-text-main);
    font-style: italic;
  }

  .lead-text {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--color-text-main); /* Dark grey text */
    margin-bottom: 2.5rem;
    max-width: 650px;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .cta-group {
      display: none !important;
    }
  }

  /* Reset Secondary Button for Light Mode */
  .split-content .btn-secondary-outline {
    border-color: #ddd;
    color: #666;
  }
  .split-content .btn-secondary-outline:hover {
    background: white;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* RIGHT IMAGE COLUMN */
  .split-image-wrapper {
    position: relative;
    height: 100%;
    min-height: 500px;
    width: 100%;
    border-radius: 0;
    transform: none;
    box-shadow: none;
    margin: 0;
    background-color: #fff; /* Ensure white background if image loads late */
  }

  /* Slideshow Styles reused but adapted for full height */
  .slideshow-container {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .slide.active {
    opacity: 1;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .split-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .split-content {
      padding: 3rem 1.5rem;
      order: 1; /* Content first */
    }

    .split-image-wrapper {
      order: 2; /* Image second */
      height: 400px;
      min-height: 0;
    }

    .lead-text {
      max-width: 100%;
    }
  }

  /* LAYOUT */
  .service-layout {
    display: grid;
    grid-template-columns: 1fr; /* Full width for content now since we have a different layout */
    gap: 5rem;
  }

  /* TYPOGRAPHY */
  .section-title {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #eee;
    padding-bottom: 0.5rem;
    display: inline-block;
  }

  /* SEO Content & Toggle Styles */
  .btn-text-reveal {
    background: none;
    border: none;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 4px;
    padding: 0;
    margin-bottom: 1rem;
    transition: color 0.3s;
  }

  .btn-text-reveal:hover {
    color: var(--color-accent);
  }

  .seo-content-hidden {
    display: none;
    margin-top: 1rem;
    animation: fadeIn 0.5s ease-in-out;
  }

  .seo-content-hidden.visible {
    display: block;
  }

  .separator {
    border: 0;
    height: 1px;
    background: rgba(0, 0, 0, 0.1);
    margin: 1.5rem 0;
  }

  /* Benefit List Styles from original */
  .benefit-list {
    margin: 2rem 0;
    list-style: none; /* Ensure no default bullets */
    padding: 0;
  }

  .benefit-list li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    font-size: 1.05rem;
  }

  .benefit-list li::before {
    content: "✓";
    color: #d32f2f; /* Empire Red or Gold */
    position: absolute;
    left: 0;
    font-weight: bold;
  }
</style>
