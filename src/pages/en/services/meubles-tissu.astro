---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Steam Sofa and Fabric Furniture Cleaning | Montreal, Laval, South Shore"
  description="Professional steam cleaning (injection-extraction) for sofas, couches, and fabric furniture at home. Elimination of stains, odors, and allergens. Montreal, Laval & South Shore. Free quote."
>
  <!-- SPLIT SCREEN HERO (Standardized) -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">UPHOLSTERY</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Sofa, Couch, Armchair & Fabric Furniture Cleaning
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Your sofas accumulate sebum, dust, and stains every day. Contact zones (armrests, headrests) get dirty, and allergens become embedded in the padding.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Bring your furniture back to life with our <strong>steam cleaning</strong> using hot water injection-extraction. We deep clean fabric sofas, couches, and armchairs directly at your home — without moving your furniture.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-primary pulse-btn">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <button onclick="window.openEstimationWidget()" class="btn btn-outline-reveal">
              <span class="icon">⚡</span> Instant Free Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Carousel) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/sofa-slide-hero-1.webp"
              alt="Empire Cleaning Technician cleaning upholstered chair - Montreal"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/sofa-slide-hero-2.webp"
              alt="Daniel cleaning grey sectional sofa - Empire Group Professional"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-16.webp"
              alt="Deep fabric couch cleaning"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-33.webp"
              alt="Microfiber sofa stain removal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-119.webp"
              alt="Professional armchair cleaning"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-129.webp"
              alt="Steam extraction on fabric furniture"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-170.webp"
              alt="Couch cleaning Laval"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-171.webp"
              alt="Furniture cleaning expert South Shore"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-172.webp"
              alt="Before-after sofa cleaning"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/meuble-exterieur-optimized.webp"
              alt="Professional patio furniture cleaning - Montreal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="content-section">
    <div class="container alternate-layout">
      <div class="service-main-content">
        
        <div class="info-block">
          <h2 class="text-gradient-empire">Why have your sofa professionally cleaned?</h2>
          <p>A sofa is much more than a piece of furniture: it's the heart of your living room. Unfortunately, it acts as a magnet for dust, pet hair, and body oils. These elements accumulate, eventually creating unpleasant odors and dulling the original colors of your fabric.</p>
          <p>Our <strong>injection-extraction</strong> cleaning uses pH-balanced solutions that dislodge dirt without leaving sticky residue, extending the life of your furniture in the process.</p>
        </div>

        <div class="info-block" style="margin-top: 2.5rem;">
          <h3 style="color: var(--color-primary); margin-bottom: 1rem;">Fabrics and types of furniture treated</h3>
          <p>We master the art of cleaning for all types of textile upholstery:</p>
          <ul class="check-list">
            <li><strong>Sofa and sectional:</strong> microfiber, cotton, linen, and synthetic blends.</li>
            <li><strong>Armchairs and chairs:</strong> dining chairs, wing chairs, and recliners.</li>
            <li><strong>Delicate fabrics:</strong> velvet, chenille, and natural fibers requiring special care.</li>
            <li><strong>Commercial furniture:</strong> office chairs and waiting room armchairs.</li>
          </ul>
        </div>

        <div class="pro-tip">
          <h4>💡 Technician's advice: the cover test</h4>
          <p>If your cushion covers are removable, avoid putting them in the washing machine. The heat from the dryer can shrink the cover, making reassembly impossible. Our on-site cleaning method treats the fabric directly on the padding, without any risk of deformation.</p>
        </div>

        <!-- SERVICED ZONES -->
        <div class="zones-section" style="margin-top: 3rem;">
          <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Service Areas — Sofa Cleaning</h3>
          <p>We travel anywhere in the Greater Montreal Area with our high-performance mobile units.</p>

          <div class="city-group">
            <p class="city-lead">🏙️ Montreal (East & West)</p>
            <div class="badges-container">
              <span class="badge badge-blue">📍 Montreal (all boroughs)</span>
              <span class="badge badge-blue">📍 Westmount</span>
              <span class="badge badge-blue">📍 Mount Royal</span>
              <span class="badge badge-blue">📍 Outremont</span>
              <span class="badge badge-blue">📍 LaSalle</span>
              <span class="badge badge-blue">📍 And much more...</span>
            </div>
          </div>

          <div class="city-group">
            <p class="city-lead">🏘️ Laval</p>
            <div class="badges-container">
              <span class="badge badge-blue">📍 Laval (entire city)</span>
              <span class="badge badge-blue">📍 Chomedey</span>
              <span class="badge badge-blue">📍 Sainte-Rose</span>
              <span class="badge badge-blue">📍 Vimont</span>
            </div>
          </div>

          <div class="city-group">
            <p class="city-lead">🌿 Montreal South Shore</p>
            <div class="badges-container">
              <span class="badge badge-green">📍 Longueuil</span>
              <span class="badge badge-green">📍 Brossard</span>
              <span class="badge badge-green">📍 Saint-Lambert</span>
              <span class="badge badge-green">📍 Saint-Hubert</span>
              <span class="badge badge-green">📍 Greenfield Park</span>
              <span class="badge badge-green">📍 Saint-Bruno</span>
              <span class="badge badge-green">📍 Boucherville</span>
              <span class="badge badge-green">📍 And much more...</span>
            </div>
          </div>
          
          <p class="contact-footer">Need a quick appointment? Call us at <strong>(514) 893-9939</strong>.</p>
        </div>

        <!-- PROCESSUS -->
        <div class="process-section" style="margin-top: 4rem;">
          <h2 class="text-gradient-empire">Our 5-Step Process</h2>
          <div class="process-steps">
            <div class="step">
              <div class="step-num">1</div>
              <div class="step-text">
                <h3>Inspection & Testing</h3>
                <p>Fiber identification to choose the exact product and ensure color stability.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">2</div>
              <div class="step-text">
                <h3>Targeted Stain Removal</h3>
                <p>Manual treatment of stubborn stains (wine, food, grease) with neutralizing agents.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">3</div>
              <div class="step-text">
                <h3>Steam Cleaning (Injection-Extraction)</h3>
                <p>High-temperature steam washing that breaks down grease, kills bacteria, and extracts deeply embedded dirt.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">4</div>
              <div class="step-text">
                <h3>Neutralizing Rinse</h3>
                <p>Complete removal of soapy residue for a soft fabric that won't attract dirt faster afterward.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">5</div>
              <div class="step-text">
                <h3>Brushing & Drying</h3>
                <p>Manual alignment of fibers for a perfect aesthetic finish and accelerated drying.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- VISIBLE EDUCATIONAL CONTENT -->
        <div style="margin-top: 3rem;">
          <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Extend the life of your living room</h3>
          <p style="line-height: 1.7; color: #444; margin-bottom: 1rem;">Body oils and sweat are your sofas' #1 enemies. In Montreal, our technicians often notice that the areas where people rest their heads and arms are the first to degrade. Our <strong>steam extraction cleaning</strong> removes these corrosive oils, preserving fiber integrity and extending your furniture's life by several years.</p>
          <p style="line-height: 1.7; color: #444;">We also strongly recommend applying a <a href="/en/services/protecteur" style="color: var(--color-primary); font-weight: bold; text-decoration: underline;">professional stain protector</a> after cleaning. This invisible barrier prevents liquids from penetrating instantly, giving you time to wipe it up before a stain forms (ideal for coffee, wine, and small accidents).</p>
        </div>

        <!-- SIGNS YOUR SOFA NEEDS CLEANING -->
        <div style="margin-top: 3rem; background: #f8fbff; padding: 2rem; border-radius: 12px; border: 1px solid #dce8f5;">
          <h3 style="color: var(--color-primary); margin-bottom: 1.2rem; font-size: 1.4rem;">🛋️ 5 signs your sofa needs steam cleaning</h3>
          <ul class="check-list">
            <li><strong>Persistent odors</strong> — A stale or sweat/pet odor even after airing out the room indicates that bacteria are embedded deep in the padding.</li>
            <li><strong>Gray or yellowed areas</strong> — Armrests, headrests, and seats change color with the accumulation of sebum and body dirt.</li>
            <li><strong>Stubborn stains</strong> — If wiping with water is no longer enough, the stain has penetrated the fibers and requires a professional steam treatment.</li>
            <li><strong>Allergies in the living room</strong> — Frequent sneezing, itchy eyes, or nasal congestion on the couch indicate an accumulation of dust mites and allergens.</li>
            <li><strong>Dulling fabric or pilling</strong> — Excessive pilling or loss of luster are often caused by dirt residues that wear out fibers from the inside.</li>
          </ul>
        </div>

        <!-- PRICING -->
        <div class="pricing-section" style="margin-top: 4rem;">
          <h2 class="text-gradient-empire">What influences the cost of cleaning</h2>
          <p>The cost of a sofa cleaning varies according to several logical criteria:</p>
          <div class="pricing-grid">
            <div class="price-card">
              <div class="price-icon">📐</div>
              <h3>Number of Seats</h3>
              <p>The rate is based on the dimension (armchair, 2-3 seater sofa, or sectional).</p>
            </div>
            <div class="price-card">
              <div class="price-icon">🛋️</div>
              <h3>Fabric Type</h3>
              <p>Certain delicate fabrics like velvet or natural fibers take more time.</p>
            </div>
            <div class="price-card">
              <div class="price-icon">🦠</div>
              <h3>Stains & Odors</h3>
              <p>The enzymatic treatment for urine or strong odors requires extra steps.</p>
            </div>
            <div class="price-card">
              <div class="price-icon">🏠</div>
              <h3>Number of Items</h3>
              <p>Enjoy multi-service discounts if you have several pieces of furniture cleaned.</p>
            </div>
          </div>
        </div>

        <!-- FAQ with Schema Component (rich snippets Google) -->
        <FAQSchema
          title="Frequently Asked Questions — Fabric Furniture Cleaning"
          faqs={[
              {
                question: "Is steam cleaning a sofa effective?",
                answer: "Yes, steam cleaning by injection-extraction is the most effective method for fabric furniture. High-temperature steam breaks down body oils, kills bacteria and dust mites, and the extraction immediately vacuums the dirt-laden water. The result is incomparable to a standard household cleaner or a consumer steam cleaner whose suction is insufficient to extract deep dirt.",
              },
              {
                question: "How long does it take for the sofa to dry after steam cleaning?",
                answer: "On average, drying takes between 4 and 8 hours after our intervention. This depends on the humidity in your home, the type of fabric, and ventilation. Opening windows or using a fan reduces this time. Our high-power extraction removes up to 95% of moisture immediately, leaving the sofa slightly damp rather than soaked.",
              },
              {
                question: "How often should I get my sofa professionally cleaned?",
                answer: "For a household of 2 to 4 people without pets, an annual cleaning is recommended. With young children, pets, or allergy sufferers, we recommend every 6 to 9 months. In practice, our technicians observe that most clients wait too long: after 2 years without cleaning, soil is more difficult to treat and fibers may be permanently damaged.",
              },
              {
                question: "What do the W, S, and W-S codes on my sofa's tag mean?",
                answer: "These codes on your sofa's label specify the cleaning method recommended by the manufacturer: W = water-based cleaning only, S = solvent only (no water), W-S = both methods are acceptable, X = vacuum only. During our inspection, our technician always checks this code to choose the right product and avoid damaging the fabric.",
              },
              {
                question: "Do I need to remove the cushions before the technician arrives?",
                answer: "No, it's not necessary. Our technician removes and repositions the cushions themselves as part of the service. This allows us to also inspect and clean crevices and hidden areas beneath the cushions, which are often the dirtiest parts of the sofa.",
              },
              {
                question: "Can you eliminate urine odors (children or pets) on a fabric sofa?",
                answer: "Absolutely. We use professional enzymatic solutions that break down uric acid molecules at their source, rather than just masking them with perfume. For cases where urine has penetrated down to the padding, we apply a deep treatment with an enzymatic dwell time. In over 90% of cases, the odor is completely eliminated in a single visit.",
              },
              {
                question: "Is the cleaning safe for my children and pets?",
                answer: "Yes, we exclusively use certified eco-friendly and biodegradable products, with no harmful chemical residues. Once the sofa is dry (4 to 8 hours), it is perfectly safe for the whole family, including babies and pets. Our products are also free of harsh perfumes and are environmentally friendly.",
              },
            ]}
          />
        </div>

      </div>

      <!-- SIDEBAR -->
      <aside class="service-sidebar">
        <div class="sticky-cta">
          <h3>Free Estimate</h3>
          <a href="tel:5148939939" class="btn btn-primary full-width">(514) 893-9939</a>
          <button onclick="window.openEstimationWidget()" class="btn btn-outline full-width">Online Estimate</button>
          <div class="guarantee">⭐ 100% Satisfaction Guarantee</div>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  /* HERO SPLIT LAYOUT (Standardized) */
  .split-hero-container {
    background-color: #fff;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
    width: 100vw;
  }
  .full-width-split { width: 100%; max-width: none; padding: 0; margin: 0; }
  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 80vh;
  }
  .split-content {
    background-color: #ffffff;
    padding: 100px 4rem 4rem 10%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .service-cat-badge {
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }
  .split-title {
    font-size: clamp(2.2rem, 3.5vw, 3.8rem);
    color: var(--color-primary);
    margin-bottom: 2rem;
    line-height: 1.1;
  }
  .problem-statement {
    background: #ffffff;
    border-left: 4px solid #ff4444;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3);
  }
  .problem-title { font-size: 1rem; color: #cc0000; margin-bottom: 0.5rem; text-transform: uppercase; font-weight: 700; }
  .problem-text { font-size: 1.05rem; color: var(--color-text-main); font-style: italic; }
  .lead-text { font-size: 1.1rem; line-height: 1.7; color: var(--color-text-main); margin-bottom: 2.5rem; max-width: 650px; }
  .cta-group { display: flex; gap: 1rem; flex-wrap: wrap; }
  .split-image-wrapper { position: relative; height: 100%; min-height: 500px; width: 100%; overflow: hidden; }
  .slideshow-container { position: relative; width: 100%; height: 100%; overflow: hidden; }
  .slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 1.5s ease-in-out; }
  .slide.active { opacity: 1; }
  .image-overlay-gradient { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.2), transparent); pointer-events: none; z-index: 2; }

  /* BUTTON STYLES (Standardized) */
  .btn-outline-reveal {
    background: transparent; border: 2px solid var(--color-primary); color: var(--color-primary);
    padding: 0.75rem 1.5rem; font-weight: 700; font-size: 1rem; cursor: pointer;
    border-radius: 4px; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 0.5rem;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  .btn-outline-reveal:hover { background: var(--color-primary); color: white; transform: translateY(-2px); }

  .content-section { padding: 5rem 0; }
  .alternate-layout { display: grid; grid-template-columns: 1fr 350px; gap: 4rem; }
  .info-block h2 { font-size: 2.2rem; margin-bottom: 1.5rem; }
  .info-block p { line-height: 1.7; color: #444; margin-bottom: 1rem; font-size: 1.1rem; }
  .check-list { list-style: none; padding: 0; }
  .check-list li { padding: 0.5rem 0 0.5rem 1.75rem; position: relative; border-bottom: 1px solid #f0f0f0; }
  .check-list li::before { content: "✓"; position: absolute; left: 0; color: #2e7d32; font-weight: bold; }

  .pro-tip { background: #fffdf0; border-left: 4px solid var(--color-accent); padding: 1.5rem; border-radius: 8px; margin-top: 2rem; }
  .pro-tip h4 { color: #856404; margin-bottom: 0.5rem; }

  /* ZONES */
  .city-group { margin-bottom: 1.5rem; }
  .city-lead { font-weight: 700; color: var(--color-primary); margin-bottom: 0.6rem; }
  .badges-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .badge { padding: 0.4rem 0.9rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid transparent; }
  .badge-blue { background: #e8f4fd; border-color: #c5dff0; }
  .badge-green { background: #f0faf0; border-color: #b8ddb8; }
  .contact-footer { margin-top: 1.5rem; font-style: italic; color: #666; }

  /* PROCESS */
  .process-steps { margin-top: 2rem; }
  .step { display: flex; gap: 1.5rem; margin-bottom: 1.5rem; }
  .step-num { min-width: 32px; height: 32px; background: var(--color-primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; margin-top: 5px; }
  .step-text h3 { font-size: 1.1rem; margin-bottom: 0.25rem; }
  .step-text p { color: #555; line-height: 1.5; }

  /* REVEAL */
  .btn-reveal { background: none; border: 1px solid #ccc; padding: 0.6rem 1.2rem; border-radius: 6px; color: #666; font-size: 0.9rem; cursor: pointer; }
  .seo-content { margin-top: 1.5rem; padding: 1.5rem; background: #f9f9f9; border-radius: 8px; }
  .seo-content.hidden { display: none; }

  /* PRICING */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2rem; }
  .price-card { background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #eee; transition: all 0.2s; }
  .price-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
  .price-icon { font-size: 2rem; margin-bottom: 1rem; }
  .price-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--color-primary); }
  .price-card p { font-size: 0.9rem; color: #666; line-height: 1.5; }
  .price-note { margin-top: 2rem; text-align: center; font-weight: bold; color: var(--color-primary); }

  /* FAQ */
  .faq-list { margin-top: 2rem; }
  .faq-item { margin-bottom: 1.5rem; border-bottom: 1px dashed #eee; padding-bottom: 1.5rem; }
  .question { font-weight: 700; color: var(--color-primary); font-size: 1.1rem; margin-bottom: 0.5rem; }
  .answer { color: #555; line-height: 1.6; }

  /* SIDEBAR */
  .sticky-cta { position: sticky; top: 100px; background: white; border: 1px solid #eee; padding: 2rem; border-radius: 15px; box-shadow: 0 15px 40px rgba(0,0,0,0.05); text-align: center; }
  .sticky-cta h3 { margin-bottom: 1rem; color: var(--color-primary); }
  .sticky-cta p { font-size: 0.95rem; color: #666; margin-bottom: 2rem; }
  .guarantee { margin-top: 1.5rem; font-size: 0.9rem; font-weight: bold; color: #2e7d32; }

  @media (max-width: 992px) {
    .split-layout { grid-template-columns: 1fr; }
    .alternate-layout { grid-template-columns: 1fr; }
    .split-title { font-size: 2.2rem; }
    .split-image-wrapper { height: 400px; min-height: 0; }
  }
</style>

<script>
  // Slideshow Logic
  const slides = document.querySelectorAll(".slide");
  let currentSlide = 0;

  function nextSlide() {
    slides[currentSlide].classList.remove("active");
    currentSlide = (currentSlide + 1) % slides.length;
    slides[currentSlide].classList.add("active");
  }

  if (slides.length > 1) {
    setInterval(nextSlide, 4000);
  }
</script>
