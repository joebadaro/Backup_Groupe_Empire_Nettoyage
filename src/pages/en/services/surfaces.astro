---
import Layout from "../../../layouts/Layout.astro";
---

<Layout
  title="Surfaces & Protection | Empire Cleaning Group"
  description="At-home mattress cleaning, tile & grout cleaning, and stain protector application. Service in the Greater Montreal area."
>
  <header class="page-header">
    <div class="container">
      <h1>Surfaces & Protection</h1>
      <p>Mattress, Tile and Stain Protection</p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <div class="service-block">
        <h2>Mattress Cleaning</h2>
        <p>We spend 1/3 of our lives in bed. Eliminate dust mites and dead skin for healthy sleep.</p>
      </div>

      <div class="service-block">
        <h2>Tile and Grout Cleaning</h2>
        <p>Restore the original whiteness of your grout lines with our industrial pressure cleaning.</p>
      </div>

       <div class="service-block">
        <h2>Stain Protector</h2>
        <p>Protect your investments. Our hydrophobic treatment repels liquids and prevents permanent stains.</p>
      </div>

      <div class="text-center" style="margin-top: 3rem;">
        <a href="/en/contact" class="btn btn-primary large-btn">Contact us for these services</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header { background-color: var(--color-empire-blue); color: white; padding: 4rem 0; text-align: center; }
  .service-block { background: white; padding: 2rem; margin-bottom: 2rem; border-radius: 8px; box-shadow: var(--shadow-card); }
  .service-block h2 { color: var(--color-empire-blue); font-size: 1.5rem; }
</style>
