---
import Layout from "../../../layouts/Layout.astro";

const services = [
  {
    slug: "tapis-commercial",
    title: "Commercial Carpet Cleaning",
    seoTitle: "Commercial Office Carpet Cleaning Service",
    category: "Commercial",
    icon: "🏢",
    image: "/images/catalog/photo-18.webp",
    heroFit: "contain",
    heroHeight: "70vh",
    intro:
      "Your company's image begins with cleanliness. We offer flexible solutions directly in your offices for an impeccable result without heavy logistics.",
    problem:
      "Intense traffic, winter salt, and coffee create stains that regular housekeeping simply cannot remove.",
    process: [
      {
        title: "Inspection & Quote",
        desc: "Evaluation of the areas to be treated (hallways, offices) and selection of products according to the type of commercial fiber.",
      },
      {
        title: "Customized Cleaning",
        desc: "Use of specific products for heavy traffic or food stains.",
      },
      {
        title: "Quick Drying",
        desc: "Maximum extraction to allow the reuse of the premises as soon as possible.",
      },
    ],
    benefits: [
      "Service adapted to your needs",
      "Free estimate",
      "Insured and professional team",
    ],
    faq: [
      {
        q: "How long does it take?",
        a: "We work quickly thanks to our high-performance equipment so as not to disrupt your daily operations.",
      },
    ],
    details: `
      <h3 style="color: var(--color-primary); margin-bottom: 1rem;">An impeccable image for your business</h3>
      <p>Office carpets endure intense traffic, accumulating salt, coffee, and dirt. Our flexible commercial service (available evenings and weekends) allows us to clean your spaces without interrupting your daily operations.</p>
      <p style="margin-top: 1rem;">We use encapsulation or steam extraction solutions depending on the fiber type (carpet tiles or broadloom), guaranteeing ultra-fast drying so your premises are ready by the next morning.</p>
    `,
  },
  {
    slug: "tapis-synthetique",
    title: "In-Home Synthetic Carpet Cleaning",
    seoTitle: "Synthetic Carpet Steam Cleaning At Home | Montreal Laval South Shore",
    category: "Carpets",
    icon: "🧶",
    image: "/images/catalog/photo-27-fixed.webp",
    slides: [
      "/images/catalog/photo-27-fixed.webp",
      "/images/catalog/photo-47.webp",
      "/images/catalog/carpet-synt-optimized.webp",
    ],
    heroFit: "contain",
    heroHeight: "70vh",
    intro:
      "Synthetic carpets (nylon, polyester, olefin) accumulate oils, grease, and embedded dirt that a vacuum alone cannot remove. Our steam cleaning restores original colors and sanitizes fibers directly at your home, without moving the rug.",
    problem:
      "Do your synthetic carpets look dull, sticky, or fade despite vacuuming? It's often a buildup of body oils and soap residue trapped in the fibers — invisible but very real.",
    process: [
      {
        title: "Inspection & Fiber Identification",
        desc: "Our technician begins by precisely identifying the synthetic fiber type: nylon, polyester, olefin, or polypropylene. Each fiber reacts differently — this step determines the exact protocol to apply and avoids any damage to colors or texture.",
      },
      {
        title: "Targeted Degreasing Pre-treatment",
        desc: "We apply a professional degreasing pre-spray on critical areas (walkways, entryways, friction zones). This specialized product penetrates the film of body oil and grease accumulated in synthetic fibers to loosen it before extraction — a step most cleaners skip.",
      },
      {
        title: "Manual Stain Removal",
        desc: "Specific stains (oil, coffee, ink, urine, wine) receive a targeted enzymatic or chemical treatment, chosen from our 40+ professional products. Each stain is worked individually with the right neutralizing agent.",
      },
      {
        title: "Steam Cleaning (Hot Water Extraction)",
        desc: "The main step: our high-pressure equipment injects a hot solution into the fibers and simultaneously vacuums the dirt-laden water. The high-temperature steam breaks down bacteria and mites. The powerful extraction leaves your carpet clean and only slightly damp.",
      },
      {
        title: "Neutralizing Rinse & Fiber Grooming",
        desc: "We finish with a pH-balanced neutralizing rinse that removes any cleaning product residue. Soap residues are the #1 cause of carpets re-soiling quickly. We then manually groom the fibers with a carpet rake for a flawless finish.",
      },
    ],
    benefits: [
      "Professional deep degreasing (removes oily film)",
      "Steam cleaning: bacteria and dust mites eliminated",
      "Neutralizing rinse — no sticky residue left behind",
      "Restores shine and softness to synthetic fibers",
      "100% on-site service — no transportation, immediate results",
    ],
    faq: [
      {
        q: "Will you take my synthetic rug to clean it in a warehouse?",
        a: "No, absolutely not. The entire cleaning process is done on-site, in front of you, in your home. This choice is not just a convenience: it is also more effective. We use your water and our high-performance mobile equipment. You see the result immediately.",
      },
      {
        q: "Is steam cleaning safe for synthetic carpets (nylon, polyester)?",
        a: "Yes, provided the right protocol is used — which our certified technicians do. Synthetic fibers tolerate the heat and controlled moisture of our extraction method very well.",
      },
      {
        q: "Why do my synthetic carpets get dirty faster after I clean them myself?",
        a: "This is the classic problem with rental machines and commercial products: they leave detergent residues in the fibers. These residues act like a dirt magnet. Our professional neutralizing rinse eliminates these residues at the source.",
      },
      {
        q: "How long does it take for a synthetic carpet to dry after steam cleaning?",
        a: "Between 2 and 5 hours on average, depending on carpet thickness and room ventilation. Synthetic fibers have the advantage of being naturally hydrophobic. Our powerful extraction removes up to 95% of moisture at the end of the intervention.",
      },
      {
        q: "Can you remove cooking oil or grease stains on a synthetic carpet?",
        a: "That is precisely the specialty of our treatment for synthetic fibers. Olefin and polypropylene are particularly sensitive to lipid buildup. Our professional degreasing pre-treatment is designed to loosen this film before extraction. In the vast majority of cases, we completely eliminate these stains.",
      },
    ],
    details: `
      <h3 style="color: var(--color-primary); margin-bottom: 1rem;">Expertise for modern synthetic fibers — Nylon, Polyester, Olefin</h3>
      <p>Synthetic carpets are the most common in homes across <strong>Montreal</strong>, <strong>Laval</strong>, and the <strong>South Shore</strong>. Nylon, polyester, olefin, and acrylic make up the vast majority of residential carpets sold today. These fibers are durable and stain-resistant on the surface, but they have one major weakness: they tend to grab and hold onto body oils and greases at the fiber level — creating an invisible film that dulls colors and makes the carpet sticky.</p>
      <p style="margin-top: 1rem;">A simple vacuum cleaner, no matter how powerful, cannot remove this greasy film. This is exactly why our <strong>hot water extraction steam cleaning</strong> is the method recommended by all synthetic carpet manufacturers. The heat of the steam liquefies the greases, our pre-treatment solution loosens them, and our high-power extraction vacuums them out of the fibers.</p>
    `,
  },
  {
    slug: "tapis-laine",
    title: "In-Home Wool Carpet Cleaning",
    seoTitle: "Expert Wool Carpet Cleaning At Home",
    category: "Carpets",
    icon: "🐑",
    image: "/images/catalog/photo-39-fixed.webp",
    slides: [
      "/images/catalog/photo-39-fixed.webp",
      "/images/catalog/wool-steam-optimized.webp",
      "/images/catalog/photo-176.webp",
      "/images/catalog/photo-177.webp",
    ],
    heroFit: "contain",
    heroHeight: "70vh",
    intro:
      "Natural fiber requires precise expertise. We clean your wool rugs directly on-site with certified pH-neutral products (Wool-Safe), without any danger to your hardwood floors.",
    problem:
      "A wool rug is a giant filter for your home. It traps an impressive amount of dust, abrasive sand, and allergens. Improper cleaning with overly alkaline products or water that is too hot risks 'cooking' the animal fiber (browning) or causing irreversible shrinkage.",
    process: [
      {
        title: "Inspection and Fiber Testing",
        desc: "We first verify the exact composition of your rug (pure wool, synthetic blend, hand-knotted) and test dye stability before applying anything.",
      },
      {
        title: "Specialized Deep Dry Vacuuming (Dusting)",
        desc: "Wool holds a lot of sand and dry particles at its base that cut fibers over time. Meticulous vacuuming is crucial before any wet treatment.",
      },
      {
        title: "Wool-Safe Pre-treatment (Neutral pH)",
        desc: "Application of a cleaner specifically formulated for animal fibers. It gently dislodges body oils and embedded dirt without opening or damaging the natural scales of the wool.",
      },
      {
        title: "Controlled Extraction (Low Temperature)",
        desc: "We use our high-performance extractor with controlled lukewarm water. Cleaning is done without thermal shock to avoid any risk of shrinkage or color bleeding.",
      },
      {
        title: "Neutralization and Safe Drying",
        desc: "A final rinse brings the fiber's pH back to its natural state, restoring softness and colors. Powerful extraction ensures moisture does not penetrate the backing, thus protecting your wood floors.",
      },
    ],
    benefits: [
      "Wool-Safe certified products (neutral pH) for animal fibers",
      "No risk of shrinkage or discoloration",
      "Safe drying: no danger to hardwood floors",
      "Elimination of abrasive sand that prematurely wears the rug",
      "Convenient at-home service (no heavy transport required)",
    ],
    faq: [
      {
        q: "Will my wool rug smell like wet sheep after cleaning?",
        a: "Yes, this is completely normal. Pure wool naturally gives off an animal odor when damp — it's proof that it's a real natural fiber and not synthetic. This smell completely and quickly disappears as soon as the rug is dry (usually in a few hours).",
      },
      {
        q: "Is it safe to clean my wool rug directly on my hardwood floor?",
        a: "Absolutely. Our technicians use a controlled-moisture extraction method. We clean the wool fibers deeply, but we never soak the backing of the rug. Moisture does not bleed through, guaranteeing complete safety for your hardwood or floating floor underneath.",
      },
      {
        q: "What is the difference between cleaning a wool rug and a synthetic rug?",
        a: "The difference is major. Wool is a delicate animal fiber (like hair) that requires a neutral pH (between 5.5 and 7) and lukewarm temperatures. Using synthetic products on wool will chemically burn it (persistent browning) or cause irreversible shrinkage.",
      },
      {
        q: "Can you remove dog or cat urine on a wool rug?",
        a: "Yes, but it requires a very specific enzymatic treatment. We use gentle enzymes that digest uric acid crystals without attacking the animal fiber. The chances of success are high, especially if the accident is recent. Never use alkaline pet store products on wool.",
      },
      {
        q: "Why is it important to have a wool rug professionally cleaned regularly?",
        a: "The structure of wool (microscopic scales) hides dirt exceptionally well. A wool rug can hold up to its own weight in dust and sand before looking visibly dirty. This gritty sand acts like sandpaper every time you walk on it, cutting fibers at the base. An annual professional cleaning eliminates this abrasive sand and prolongs the rug's life.",
      },
    ],
    details: `
      <h3 style="color: var(--color-primary); margin-bottom: 1rem;">Wool-Safe Expertise for your natural fibers in Montreal and Laval</h3>
      <p>Wool is arguably the most luxurious and durable fiber for a residential rug, but it is also the least forgiving during cleaning. Typical mistakes by non-specialized companies or rental machines (overly alkaline products, boiling water) often result in fiber browning (chemical cooking phenomenon), color loss (bleeding), or disastrous shrinkage.</p>
      <p style="margin-top: 1rem;">At <strong>Empire Cleaning Group</strong>, our technicians understand the biochemistry of wool. We only use certified <strong>"Wool-Safe"</strong> formulas that respect the natural pH of animal fiber. Our extraction equipment provides powerful cleaning to dislodge allergens and dust mites without ever leaving the carpet backing damp.</p>
    `,
  },
  {
    slug: "tapis-orientaux",
    title: "In-Home Oriental Rug Cleaning",
    seoTitle: "Persian & Oriental Rug Cleaning At Home",
    category: "Carpets",
    icon: "🕌",
    image: "/images/catalog/photo-oriental-custom.webp",
    slides: [
      "/images/catalog/photo-oriental-custom.webp",
      "/images/catalog/photo-178.webp",
      "/images/catalog/photo-179.webp",
      "/images/catalog/photo-180.webp",
      "/images/catalog/photo-181.webp",
    ],
    heroFit: "contain",
    heroHeight: "70vh",
    intro:
      "Your Persian, silk, and hand-knotted wool rugs represent a major investment. You do not want to send them to an unknown warehouse. We clean them 100% on-site, right before your eyes, with absolute mastery of vegetable dyes and delicate fibers.",
    problem:
      "The industry is full of horror stories of oriental rugs sent to a 'factory' that return months later discolored, shrunk, or worse, never return at all. Furthermore, the natural (vegetable) dyes used in real Persian rugs are extremely unstable (color bleeding). Cleaning with too high a pH will cause red or blue colors to bleed permanently into light patterns and fringes.",
    process: [
      {
        title: "Colorfastness Test",
        desc: "The most critical step. We meticulously test each color with a specific solution before any intervention to ensure there will be no bleeding of vegetable dyes.",
      },
      {
        title: "Specialized Dry Vacuuming (Dusting)",
        desc: "Hand-knotted rugs have very tight knots that trap abrasive sand. We perform expert deep vacuuming to eliminate these dry particles that cut the base of the rug before applying anything wet.",
      },
      {
        title: "Application of Color Stabilizers",
        desc: "If the test reveals instability, we apply a stabilizing agent (mordant) to lock in the colors. We then use a certified neutral pH shampoo for real wool and silk, applied manually.",
      },
      {
        title: "Very Low Moisture Extraction",
        desc: "We adapt the water pressure and suction of our equipment to respect the ancient weave. Cleaning is ALWAYS done in the natural direction of the pile to preserve the shine and texture.",
      },
      {
        title: "Fringe Adjustment and Floor Protection",
        desc: "Cotton fringes receive a separate, gentle treatment. The rug stays in place during the entire process: our waterproof protections guarantee the absolute safety of your hardwood floor underneath.",
      },
    ],
    benefits: [
      "100% at-home cleaning (no chance of loss or exchange)",
      "Rigorous anti-bleeding test (colorfastness guaranteed)",
      "Safe for silk, real wool, and vegetable dyes",
      "Brings patterns back to life without alkaline chemicals",
      "Absolute waterproof protection of your floor during intervention",
    ],
    faq: [
      {
        q: "Why do you clean oriental rugs on-site instead of in a workshop?",
        a: "Because it is the only way to guarantee you 100% total transparency. You see exactly what products are used on your precious rugs, you don't live with an empty living room for weeks, and above all, there is absolutely no risk of loss, exchange of your rug, or hidden surprise fees.",
      },
      {
        q: "Are the colors of my Persian rug at risk of bleeding?",
        a: "Not with us. Color bleeding happens when an inexperienced cleaner uses overly alkaline products or overly hot water on natural vegetable dyes. Our mandatory colorfastness test and use of pH stabilizers prevent this disaster.",
      },
      {
        q: "My oriental rug is hand-knotted, will your big machines damage it?",
        a: "We do not use aggressive rotary brushes on hand-knotted rugs. Our technicians use specific manual tools and always clean strictly in the direction of the pile so as not to damage the knots or reverse the texture of the natural fibers.",
      },
      {
        q: "How do you clean the white fringes of my rug?",
        a: "The fringes are the very extension of the rug's canvas (usually cotton) and are not cleaned in the same way as the wool in the center. We use a specific product to restore the whiteness of the cotton and clean them manually with a soft brush to prevent them from fraying or tearing in the machine.",
      },
      {
        q: "Will you damage my hardwood floor underneath the rug during the intervention?",
        a: "No, it is 100% safe. We rigorously control moisture during extraction. We clean the fiber without soaking the backing of the rug. Moisture never penetrates to your hardwood or engineered floor.",
      },
    ],
    details: `
      <h3 style="color: var(--color-primary); margin-bottom: 1rem;">The truth about cleaning Oriental and Persian rugs</h3>
      <p>The oriental rug cleaning industry is often nebulous. Many services offer to take your precious Persian, Turkish, Afghan, or Chinese rug to a "factory" for weeks, sometimes without providing you with a physical address. The truth is that a professional deep cleaning can very well be carried out directly in the comfort of your home in <strong>Montreal</strong>, <strong>Laval</strong>, or the <strong>South Shore</strong>.</p>
      <p style="margin-top: 1rem;">The main danger of a hand-knotted rug lies in its vegetable dyes (madder, indigo) which are naturally unstable. A standard cleaner using cheap commercial shampoos will permanently damage these works of art. At <strong>Empire Cleaning Group</strong>, craftsmanship meets technology. Our approach guarantees total respect for traditional weaving techniques: mandatory color tests (colorfastness), certified Wool-Safe products, cleaning with the grain of the pile, and total transparency since everything happens right before your eyes. Your investment is in good hands.</p>
    `,
  },
];

export function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

const { service: serviceParam } = Astro.params;
const service = services.find((s) => s.slug === serviceParam);

if (!service) {
  return Astro.redirect("/404");
}
---

<Layout
  title={`${service.seoTitle} | Empire Cleaning Group`}
  description={service.intro}
  image={service.image}
>
  <style define:vars={{ heroHeight: service.heroHeight || "auto" }}>
    .service-hero {
      min-height: var(--heroHeight);
      display: flex;
      align-items: center;
    }
  </style>

  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">{service.category}</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            {service.title}
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">{service.problem}</p>
          </div>

          <p class="lead-text fade-in-up delay-200">{service.intro}</p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-primary pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (Talk to an Expert)
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-outline-reveal"
            >
              <span class="icon">⚡</span> Instant Online Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          {
            service.slides && service.slides.length > 1 ? (
              <div class="slideshow-container">
                {service.slides.map((slide, index) => (
                  <img
                    src={slide}
                    alt={`${service.title} - Image ${index + 1}`}
                    class={`slide ${index === 0 ? "active" : ""}`}
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                ))}
              </div>
            ) : (
              <img
                src={service.image}
                alt={service.title}
                class="split-image"
                draggable="false"
              />
            )
          }
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <!-- PROCESS -->
          <div class="fade-in-section delay-100" style="margin-top: 0;">
            <h2 class="section-title text-gradient-empire">
              Our Approach (On Site)
            </h2>
            <div class="process-timeline">
              {
                service.process.map((step, index) => (
                  <div class="process-step">
                     <div class="step-marker">{index + 1}</div>
                     <div class="step-content">
                       <h3>{step.title}</h3>
                       <p>{step.desc}</p>
                     </div>
                  </div>
                ))
              }
            </div>

            <!-- EQUIPMENT NOTE FOR PORTABLE -->
            {
              !service.hideEquipment && (
                <div
                  class="equipment-note fade-in-section delay-100"
                  style="margin-top: 2rem; background: #f9f9f9; padding: 1.5rem; border-radius: 8px; border-left: 3px solid var(--color-accent);"
                >
                  <h4 style="margin-bottom: 0.5rem; color: var(--color-primary);">
                    Adapted Equipment (Truck-Mount or Portable)
                  </h4>
                  <p style="font-size: 0.95rem;">
                    We primarily use our <strong>truck-mount units</strong> for maximum power. However, for high-rise condos or restricted access, we are equipped with <strong>high-performance professional portable machines</strong>. These units have nothing in common with rental machines: they guarantee an expert result, no matter your floor.
                  </p>
                </div>
              )
            }
          </div>

          <!-- DYNAMIC SEO CONTENT (NEW) -->
          <div class="fade-in-section delay-100" style="margin-top: 3rem;">
            <!-- VISIBLE CONTENT -->
            <div>
              <hr class="separator" />
              <div set:html={service.details} />

              <div class="info-box">
                <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                  Adapted and Hygienic Service
                </h3>
                <p>
                  Our qualified team adapts each intervention to your specific needs. We service both <strong>residential</strong> and <strong>commercial locations</strong> in Montreal, Laval, and the South Shore, ensuring an effective, durable cleaning that respects your investments.
                </p>
              </div>
            </div>
          </div>

          <!-- BENEFITS -->
          <div class="fade-in-section delay-200" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">
              Why Choose Us?
            </h2>
            <div class="benefits-grid">
              {
                service.benefits.map((benefit) => (
                  <div class="benefit-item">
                    <div class="check-circle">✓</div>
                    <span>{benefit}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- SERVICED ZONES -->
          <div class="zones-section" style="margin-top: 3rem; margin-bottom: 3rem;">
            <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Service Areas — {service.title}</h3>
            <p>We travel anywhere in the Greater Montreal Area with our high-performance mobile units.</p>

            <div class="city-group">
              <p class="city-lead">🏙️ Montreal (East & West)</p>
              <div class="badges-container">
                <span class="badge badge-blue">📍 Montreal (all boroughs)</span>
                <span class="badge badge-blue">📍 Westmount</span>
                <span class="badge badge-blue">📍 Mount Royal</span>
                <span class="badge badge-blue">📍 Outremont</span>
                <span class="badge badge-blue">📍 LaSalle</span>
                <span class="badge badge-blue">📍 And much more...</span>
              </div>
            </div>

            <div class="city-group">
              <p class="city-lead">🏘️ Laval</p>
              <div class="badges-container">
                <span class="badge badge-blue">📍 Laval (entire city)</span>
                <span class="badge badge-blue">📍 Chomedey</span>
                <span class="badge badge-blue">📍 Sainte-Rose</span>
                <span class="badge badge-blue">📍 Vimont</span>
              </div>
            </div>

            <div class="city-group">
              <p class="city-lead">🌿 Montreal South Shore</p>
              <div class="badges-container">
                <span class="badge badge-green">📍 Longueuil</span>
                <span class="badge badge-green">📍 Brossard</span>
                <span class="badge badge-green">📍 Saint-Lambert</span>
                <span class="badge badge-green">📍 Saint-Hubert</span>
                <span class="badge badge-green">📍 Greenfield Park</span>
                <span class="badge badge-green">📍 Saint-Bruno</span>
                <span class="badge badge-green">📍 Boucherville</span>
                <span class="badge badge-green">📍 And much more...</span>
              </div>
            </div>
            
            <p class="contact-footer">Need a quick appointment? Call us at <strong>(514) 893-9939</strong>.</p>
          </div>

          <!-- FAQ -->
          {
            service.faq && (
              <div class="fade-in-section delay-300" style="margin-top: 3rem;">
                <h2 class="section-title text-gradient-empire">
                  Frequently Asked Questions
                </h2>
                <div class="faq-list">
                  {service.faq.map((item) => (
                    <div class="faq-item">
                      <p class="question">
                        <strong>Q: {item.q}</strong>
                      </p>
                      <p class="answer">{item.a}</p>
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <!-- SIDEBAR CTA (Sticky) -->
        <aside class="service-sidebar">
          <div class="sticky-card fade-in-section">
            <h3 class="card-title text-gradient-gold">
              Instant Free Quote
            </h3>
            <p class="card-desc">Call us for an immediate response.</p>

            <a
              href="tel:5148939939"
              class="btn btn-gradient-green full-width pop-effect pulse-phone"
            >
              <span class="icon">📞</span> (514) 893-9939 (Talk to an Expert)
            </a>

            <p
              class="text-center"
              style="margin: 1rem 0; font-size: 0.9rem; color: #888;"
            >
              or
            </p>

            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green full-width"
            >
              Instant Online Quote
            </button>

            <div class="guarantee-badge">
              <span>🌿 100% Eco-Friendly Products</span>
              <div style="margin-top: 5px; color: #ffbf00; font-weight: bold;">
                ★★★★★
              </div>
              <span style="font-size: 0.8rem; color: #666;"
                >Satisfied Clients</span
              >
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Slideshow Logic
  const slides = document.querySelectorAll(".slide");
  if (slides.length > 0) {
    let currentSlide = 0;
    const intervalTime = 4000; // 4 seconds

    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, intervalTime);
  }
</script>

<style>
  /* ZONES */
