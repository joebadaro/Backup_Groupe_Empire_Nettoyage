---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Commercial Carpet Cleaning Montreal | Offices, Businesses & CPEs | Empire Group"
  description="Professional commercial carpet cleaning in Montreal, Laval and South Shore. Injection-extraction for offices, CPEs and commercial spaces. After-hours service available. Free on-site estimate."
>
  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">COMMERCIAL</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Commercial Carpet Cleaning
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">The Problem:</h3>
            <p class="problem-text">
              Your company's image starts with cleanliness. Stained or dusty
              carpets harm your reputation and the air quality in your offices.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            A professional maintenance service designed for your business
            spaces. Flexible plans, quick drying, and impeccable results for
            offices and businesses — with <strong>zero interruption</strong> to your operations.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-gradient-green pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (Talk to an Expert)
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green"
            >
              <span class="icon">⚡</span> Instant Online Estimate
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual / Slideshow) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/photo-14.webp"
              alt="Commercial carpet cleaning Montreal office - Empire Cleaning Group"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/photo-18.webp"
              alt="Commercial building corridor carpet maintenance Laval"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-19.webp"
              alt="Conference room carpet cleaning South Shore"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-30.webp"
              alt="Fast-drying commercial carpet truck-mount Longueuil"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-31.webp"
              alt="Impeccable store entrance carpet Montreal - Professional result"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container alternate-layout">
      <div class="service-main-content">

        <div class="info-block">
          <h2 class="text-gradient-empire">Commercial Expertise and Large Spaces</h2>
          <p>The appearance of your professional premises—from majestic entrance halls to reception areas—is the first impression you give to your clients and employees. At <strong>Empire Cleaning Group</strong>, we understand that stained carpets or those encrusted with winter calcium (salt) harm your reputation.</p>
          <p>Our specialized service for businesses in <strong>Montreal</strong>, <strong>Laval</strong> and the <strong>South Shore</strong> guarantees ultra-high-performance cleaning for all traffic levels, without ever interrupting your business hours thanks to our flexible schedules (evenings and weekends).</p>
        </div>

        <div class="info-block" style="margin-top: 2.5rem;">
          <h3 style="color: var(--color-primary); margin-bottom: 1rem;">Adapted solutions for every industry</h3>
          <ul class="check-list">
            <li><strong>Office buildings:</strong> Cubicles, conference rooms and common areas.</li>
            <li><strong>Retail stores:</strong> High-traffic entrance carpets (salt/calcium elimination).</li>
            <li><strong>Hotels and restaurants:</strong> Printed commercial carpets, corridors and auxiliary chairs.</li>
            <li><strong>Childcare centers (CPE):</strong> Disinfection without harsh chemicals (safe for infants).</li>
          </ul>
        </div>

        <!-- 5-STEP COMMERCIAL PROTOCOL -->
        <div class="process-section" style="margin-top: 4rem;">
          <h2 class="text-gradient-empire">Our Commercial Protocol (5 Steps)</h2>
          <p style="margin-bottom: 2rem;">We do not use the "bonnet cleaning" method (surface buffing) which pushes dirt downward. We use injection-extraction (high-temperature steam) for deep sanitation.</p>
          <div class="process-steps">
            <div class="step">
              <div class="step-num">1</div>
              <div class="step-text">
                <h3>Logistical Inspection & Estimate</h3>
                <p>Analysis of high-traffic zones (main corridors), stain types (coffee, ink, salt) and planning the intervention outside business hours for zero interruption.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">2</div>
              <div class="step-text">
                <h3>Anti-Calcium & Degreaser Treatment</h3>
                <p>Application of a specific industrial pre-treatment that dissolves salt crusts, urea and body grease accumulations embedded in the carpet fibers.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">3</div>
              <div class="step-text">
                <h3>Vacuuming and Mechanical Brushing</h3>
                <p>Agitation of fibers with counter-rotating brushes to lift the crushed pile of commercial carpet and loosen deeply embedded dirt at the base.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">4</div>
              <div class="step-text">
                <h3>High-Power Steam Extraction</h3>
                <p>Using our top-of-the-line equipment (powerful truck-mount or commercial portable for office towers) to rinse and extract 95% of moisture.</p>
              </div>
            </div>
            <div class="step">
              <div class="step-num">5</div>
              <div class="step-text">
                <h3>Accelerated Drying & Service Report</h3>
                <p>Placement of axial fans (air movers) if needed to guarantee premises are dry and ready for use the next morning. Delivery of a certified service report.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- WHY CHOOSE US B2B -->
        <div class="fade-in-section delay-200" style="margin-top: 4rem;">
          <h2 class="section-title text-gradient-empire">
            Why choose Empire Group for B2B?
          </h2>
          <div class="benefits-grid">
            <div class="benefit-item">
              <div class="check-circle">✓</div>
              <span><strong>Flexible scheduling:</strong> Evening, night or weekend interventions with no hidden fees.</span>
            </div>
            <div class="benefit-item">
              <div class="check-circle">✓</div>
              <span><strong>Liability insurance:</strong> Full $2M coverage for your peace of mind in corporate environments.</span>
            </div>
            <div class="benefit-item">
              <div class="check-circle">✓</div>
              <span><strong>Certified technicians:</strong> Uniformed, discreet, professional staff with completed background checks.</span>
            </div>
            <div class="benefit-item">
              <div class="check-circle">✓</div>
              <span><strong>Very fast drying:</strong> Thanks to our superior extraction, your premises are usable within a few hours.</span>
            </div>
            <div class="benefit-item">
              <div class="check-circle">✓</div>
              <span><strong>Multi-location capacity:</strong> We can serve multiple branches throughout the greater metropolitan area.</span>
            </div>
          </div>
        </div>

        <!-- SERVICE ZONES -->
        <div class="zones-section" style="margin-top: 4rem;">
          <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Service Area — Commercial Sector</h3>
          <p>We cover all business hubs of the greater metropolitan area with dedicated commercial units.</p>

          <div class="city-group">
            <p class="city-lead">🏙️ Montreal (Business Hubs)</p>
            <div class="badges-container">
              <span class="badge badge-blue">📍 Downtown (Office Towers)</span>
              <span class="badge badge-blue">📍 Old Montreal</span>
              <span class="badge badge-blue">📍 Anjou Industrial Park</span>
              <span class="badge badge-blue">📍 Saint-Laurent Technopark</span>
              <span class="badge badge-blue">📍 Pointe-Claire & West Island</span>
            </div>
          </div>

          <div class="city-group">
            <p class="city-lead">🏘️ Laval & North Shore</p>
            <div class="badges-container">
              <span class="badge badge-blue">📍 Centropolis & Chomedey</span>
              <span class="badge badge-blue">📍 Centro Industrial Park</span>
              <span class="badge badge-blue">📍 Sainte-Rose (Businesses)</span>
            </div>
          </div>

          <div class="city-group">
            <p class="city-lead">🌿 South Shore of Montreal</p>
            <div class="badges-container">
              <span class="badge badge-green">📍 DIX30 District (Brossard)</span>
              <span class="badge badge-green">📍 Longueuil Industrial Park</span>
              <span class="badge badge-green">📍 Boucherville (Eiffel Sector)</span>
              <span class="badge badge-green">📍 Saint-Bruno-de-Montarville</span>
            </div>
          </div>
        </div>

        <!-- FAQ with Schema Component -->
        <div class="fade-in-section delay-300" style="margin-top: 4rem; margin-bottom: 3rem;">
          <h2 class="section-title text-gradient-empire">
            Frequently Asked Questions — Commercial Service
          </h2>
          <FAQSchema
            faqs={[
              {
                question: "What is the best cleaning method for commercial carpets in high-traffic areas?",
                answer: "Hot water extraction steam cleaning is the most effective method for commercial carpets (deep restoration). Unlike encapsulation or bonnet cleaning (buffing) which only clean the surface and trap dirt, our extraction method deeply removes salt, winter calcium and body oils that accumulate. This extends carpet life and prevents premature fiber crushing.",
              },
              {
                question: "How long do I need to close my offices after commercial carpet cleaning?",
                answer: "Zero hours of closure. We work outside your peak hours (evenings or weekends) to minimize business interruptions. Thanks to our very high-suction equipment, commercial carpets (which have very short pile) most often dry in 2 to 4 hours. The next morning, your premises are completely dry, fresh and ready for regular traffic.",
              },
              {
                question: "Do I need to move office furniture before your arrival?",
                answer: "No, we handle most of the logistics. We simply ask you to clear the floor (boxes, papers) and remove small trash cans or wheeled office chairs from the areas to be cleaned. We professionally clean around cubicles, heavy desks and filing cabinets without moving them to avoid any breakage or disconnection of IT equipment (servers/cables).",
              },
              {
                question: "Do you offer annual preventive maintenance contracts?",
                answer: "Absolutely. Waiting until the carpet is visibly dirty is often too late. We offer scheduled maintenance plans (quarterly or semi-annual) for very high-traffic corridors and annual plans for closed offices. Preventive contracts guarantee a fixed rate and technically extend the life of your floor coverings by 3 to 5 years.",
              },
              {
                question: "How do you remove hard white calcium (salt) crust at the entrance to my business?",
                answer: "Calcium (sodium chloride) is highly alkaline and burns commercial fibers if not treated. We apply a specific acid neutralizer that chemically dissolves hardened salt crystals without damaging the carpet. We then proceed with massive hot water extraction. This is an essential treatment in Quebec every spring.",
              },
              {
                question: "Can you clean our office chairs or fabric cubicle panels?",
                answer: "Yes, our commercial service is comprehensive. We clean over 500 ergonomic chairs and fabric partition panels (cubicles) every year. We use specialized manual extraction tools that remove coffee stains, printer toner and body sebum without staining the metal or plastic components of chairs.",
              },
            ]}
          />
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // Simple Cross-Fade Slideshow
  const slides = document.querySelectorAll(".slide");

  if (slides.length > 0) {
    let currentSlide = 0;
    const intervalTime = 4000; // 4 seconds

    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, intervalTime);
  }
</script>

<style>
  /* HERO */
  .split-hero-container {
    background-color: #fff;
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
    width: 100vw;
  }
  .full-width-split { width: 100%; max-width: none; padding: 0; margin: 0; }
  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-items: stretch;
    min-height: 80vh;
  }
  .split-content {
    background-color: #ffffff;
    padding: 100px 4rem 4rem 10%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .service-cat-badge {
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 1rem;
  }
  .split-title {
    font-size: clamp(2.5rem, 3.5vw, 4rem);
    color: var(--color-primary);
    margin-bottom: 2rem;
    line-height: 1.1;
  }
  .problem-statement {
    background: #ffffff;
    border-left: 4px solid #ff4444;
    padding: 1.5rem;
    border-radius: 0;
    margin-bottom: 2rem;
    box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3);
  }
  .problem-title { font-size: 1rem; color: #cc0000; margin-bottom: 0.5rem; text-transform: uppercase; font-weight: 700; }
  .problem-text { font-size: 1.05rem; color: var(--color-text-main); font-style: italic; }
  .lead-text { font-size: 1.15rem; line-height: 1.7; color: var(--color-text-main); margin-bottom: 2.5rem; max-width: 650px; }
  .cta-group { display: flex; gap: 1rem; flex-wrap: wrap; }
  @media (max-width: 900px) { .cta-group { display: none !important; } }
  .split-image-wrapper { position: relative; height: 100%; min-height: 500px; width: 100%; border-radius: 0; transform: none; box-shadow: none; margin: 0; background-color: #fff; }
  .slideshow-container { position: relative; width: 100%; height: 100%; overflow: hidden; }
  .slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 1.5s ease-in-out; }
  .slide.active { opacity: 1; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .split-layout { grid-template-columns: 1fr; min-height: auto; }
    .split-content { padding: 3rem 1.5rem; order: 1; }
    .split-image-wrapper { order: 2; height: 400px; min-height: 0; }
    .lead-text { max-width: 100%; }
  }

  /* LAYOUT */
  .alternate-layout { max-width: 900px; margin: 0 auto; }
  .service-main-content { width: 100%; }
  .section-title { font-size: 1.8rem; color: var(--color-primary); margin-bottom: 1.5rem; border-bottom: 2px solid #eee; padding-bottom: 0.5rem; display: inline-block; }

  .info-block { margin-bottom: 1rem; }
  .info-block p { line-height: 1.7; color: var(--color-text-main); margin-bottom: 1rem; }

  /* CHECK LIST */
  .check-list { list-style: none; padding: 0; margin: 0; }
  .check-list li {
    padding: 0.6rem 0 0.6rem 2rem;
    position: relative;
    font-size: 1.05rem;
    border-bottom: 1px dotted #eee;
  }
  .check-list li::before { content: "✓"; color: var(--color-empire-red); position: absolute; left: 0; font-weight: bold; }

  /* PROCESS STEPS */
  .process-steps { display: flex; flex-direction: column; gap: 0; }
  .step {
    display: grid;
    grid-template-columns: 50px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid #eee;
    align-items: flex-start;
  }
  .step:last-child { border-bottom: none; }
  .step-num {
    width: 44px;
    height: 44px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: bold;
    flex-shrink: 0;
  }
  .step-text h3 { color: var(--color-primary); font-size: 1.1rem; margin-bottom: 0.4rem; }
  .step-text p { color: #555; line-height: 1.6; font-size: 0.95rem; margin: 0; }

  /* BENEFITS */
  .benefits-grid { display: flex; flex-direction: column; gap: 1rem; }
  .benefit-item { display: flex; gap: 1rem; align-items: flex-start; padding: 1rem; background: #fafafa; border-radius: 8px; border: 1px solid #eee; }
  .check-circle { width: 28px; height: 28px; min-width: 28px; border-radius: 50%; background: var(--color-primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.9rem; margin-top: 2px; }

  /* ZONES */
  .city-group { margin-bottom: 1.5rem; margin-top: 1.5rem; }
  .city-lead { font-weight: 700; color: var(--color-primary); margin-bottom: 0.6rem; }
  .badges-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .badge { padding: 0.4rem 0.9rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid transparent; }
  .badge-blue { background: #e8f4fd; border-color: #c5dff0; }
  .badge-green { background: #f0faf0; border-color: #b8ddb8; }
</style>
