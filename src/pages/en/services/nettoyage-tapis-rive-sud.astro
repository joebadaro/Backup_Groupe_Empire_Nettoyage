---
import Layout from "../../../layouts/Layout.astro";
import FAQSchema from "../../../components/FAQSchema.astro";
---

<Layout
  title="Carpet Cleaning South Shore | Brossard, Longueuil, Boucherville"
  description="Expert carpet cleaning service on the South Shore of Montreal. Our truck-mount unit covers Longueuil, Brossard, and Boucherville. Fast drying guaranteed."
>
  <!-- SPLIT SCREEN HERO -->
  <div class="split-hero-container">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT (Hook) -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">CARPET & STAIRS • SOUTH SHORE</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Residential Carpet Cleaning on the South Shore
          </h1>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">Home Maintenance:</h3>
            <p class="problem-text">
              Suburban homes see a lot of action: kids, pets, frequent trips from the garage or backyard. Your carpets, basements, and stairs absorb all this daily dust and sand.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Protect your comfort on the South Shore of Montreal. Our truck-mount process injects steam at very high temperatures to extract embedded dirt, thereby restoring the brilliance of your carpets with minimal drying time.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-gradient-green pulse-btn">
              <span class="icon">📞</span> (514) 893-9939 (South Shore Quote)
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-gradient-green"
            >
              <span class="icon">⚡</span> Free Online Quote
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE (Visual / Slideshow) -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/resultat-tapis-propre-longueuil.webp"
              alt="Professional carpet cleaning technology in Longueuil"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/photo-34.webp"
              alt="In-home carpet cleaning service Brossard"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-144.webp"
              alt="Truck-mount generator for cleaning in Brossard and Longueuil"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          <!-- BENEFIT LIST & SEO CONTENT -->
          <div class="fade-in-section delay-100">
            <h2 class="section-title text-gradient-empire">
             Unmatched Results with Our Truck-Mount
            </h2>

            <p>
              Forget renting machines at the supermarket. Those shampooers leave your carpets waterlogged with soapy residue that attracts even more dirt. For your South Shore residence, trust true steam extraction cleaning:
            </p>

            <ul class="benefit-list" style="margin-bottom: 3rem;">
               <li>
                <strong>1. Pre-treatment:</strong> We target stubborn stains and high-traffic areas.
              </li>
              <li>
                <strong>2. Agitation:</strong> Specialized brush to lift flattened fibers on stairs.
              </li>
              <li>
                <strong>3. Industrial Steam:</strong> The power of the truck-mount dislodges 99%
                of dust mites, sand, and allergens buried at the base of the carpet.
              </li>
              <li>
                <strong>4. Complete Rinse:</strong> Avoids chemical residues. Your carpets will be ultra-soft to the touch.
              </li>
              <li>
                <strong>5. Accelerated Drying:</strong> Say goodbye to waiting entire days (generally dry in 4 hours).
              </li>
            </ul>

            <div style="margin-top: 3rem; background-color: #f8f9fa; border-left: 4px solid var(--color-accent); padding: 2rem; border-radius: 8px;">
               <h3 style="color: var(--color-primary); margin-bottom: 1rem;">
                🛡️ South Shore Tip: The Protector Option (Teflon)
              </h3>
              <p>
                Many of our suburban clients with large families add a post-cleaning fabric protector.
              </p>
              <p style="margin-top: 1rem;">
                This product acts as an invisible shield. If you spill coffee or if the pet drops something (especially common in living rooms and stairs), the liquid will bead up instead of being absorbed, giving you time to wipe it without staining.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW SECTIONS: BENEFITS & FAQ -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="service-layout" style="display: block;">
        <div class="service-main" style="max-width: 800px; margin: 0 auto;">
          
          <!-- ZONES DESSERVIES -->
          <div class="zones-section" style="margin-top: 3rem; margin-bottom: 3rem;">
            <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">We Crisscross the South Shore of Montreal</h3>
            <p>From Brossard to Boucherville, our technicians get to your home quickly:</p>

            <div class="city-group">
              <div class="badges-container">
                <span class="badge badge-green">📍 Longueuil, Old Longueuil, and Saint-Hubert</span>
                <span class="badge badge-green">📍 Brossard (Sectors A, B, C, L, M, O, R...)</span>
                <span class="badge badge-green">📍 Saint-Lambert & Lemoyne</span>
                <span class="badge badge-green">📍 Boucherville</span>
                <span class="badge badge-green">📍 Saint-Bruno-de-Montarville</span>
                <span class="badge badge-green">📍 Greenfield Park</span>
                 <span class="badge badge-green">📍 La Prairie, Candiac & Delson</span>
              </div>
            </div>
            <p class="contact-footer">Book an appointment on the South Shore: <strong>(514) 893-9939</strong>.</p>
          </div>

          <!-- FAQ -->
          <div class="fade-in-section delay-300" style="margin-top: 3rem;">
            <h2 class="section-title text-gradient-empire">
              Frequently Asked Questions — South Shore
            </h2>
            <FAQSchema
              faqs={[
                 {
                  question:
                    "How long does it take to clean my carpets with your truck-mount?",
                  answer:
                    "For an average house with a living room, a basement, and a staircase, the cleaning generally takes between 1h and 2h. Our ultra-powerful equipment allows us to be fast while guaranteeing maximum water extraction for quick drying.",
                },
                {
                  question:
                    "Do you need to plug into our electricity or water on the South Shore?",
                  answer:
                    "Our truck-mount is independent; it generates its own heat and suction. We only hook up to your exterior water outlet (garden hose bib or laundry tub) to supply water, but we have our own reserve if that's not possible.",
                },
                {
                   question:
                    "Do we have to pay travel fees for you to come to Boucherville or Brossard?",
                  answer:
                    "No. We have technicians dedicated to the South Shore sector every day. Our prices always include travel.",
                }
              ]}
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const slides = document.querySelectorAll(".slide");
  if (slides.length > 0) {
    let currentSlide = 0;
    setInterval(() => {
      slides[currentSlide].classList.remove("active");
      currentSlide = (currentSlide + 1) % slides.length;
      slides[currentSlide].classList.add("active");
    }, 4000);
  }
</script>

<style>
  /* Base styles */
  .split-hero-container { background-color: #fff; padding-top: 0; padding-bottom: 0; overflow: hidden; width: 100vw; }
  .full-width-split { width: 100%; max-width: none; padding: 0; margin: 0; }
  .split-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 0; align-items: stretch; min-height: 80vh; }
  .split-content { background-color: #ffffff; padding: 100px 4rem 4rem 10%; display: flex; flex-direction: column; justify-content: center; position: relative; z-index: 2; }
  .service-cat-badge { text-transform: uppercase; color: var(--color-accent); font-weight: 700; letter-spacing: 2px; font-size: 0.85rem; display: block; margin-bottom: 1rem; }
  .split-title { font-size: clamp(2.5rem, 3.5vw, 4rem); color: var(--color-primary); margin-bottom: 2rem; line-height: 1.1; }
  .city-group { margin-bottom: 1.5rem; }
  .badges-container { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .badge { padding: 0.4rem 0.9rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid transparent; }
  .badge-green { background: #f0faf0; border-color: #b8ddb8; }
  .problem-statement { background: #ffffff; border-left: 4px solid #ff4444; padding: 1.5rem; border-radius: 0; margin-bottom: 2rem; box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); }
  .problem-title { font-size: 1rem; color: #cc0000; margin-bottom: 0.5rem; text-transform: uppercase; font-weight: 700; }
  .problem-text { font-size: 1.05rem; color: var(--color-text-main); font-style: italic; }
  .lead-text { font-size: 1.15rem; line-height: 1.7; color: var(--color-text-main); margin-bottom: 2.5rem; max-width: 650px; }
  .cta-group { display: flex; gap: 1rem; flex-wrap: wrap; }
  @media (max-width: 900px) { .cta-group { display: none !important; } }
  .split-image-wrapper { position: relative; height: 100%; min-height: 500px; width: 100%; }
  .slideshow-container { position: relative; width: 100%; height: 100%; overflow: hidden; }
  .slide { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 1.5s ease-in-out; }
  .slide.active { opacity: 1; }
  @media (max-width: 1024px) {
    .split-layout { grid-template-columns: 1fr; min-height: auto; }
    .split-content { padding: 3rem 1.5rem; order: 1; }
    .split-image-wrapper { order: 2; height: 400px; min-height: 0; }
    .lead-text { max-width: 100%; }
  }
  .service-layout { display: grid; grid-template-columns: 1fr; gap: 5rem; }
  .section-title { font-size: 1.8rem; color: var(--color-primary); margin-bottom: 1.5rem; border-bottom: 2px solid #eee; padding-bottom: 0.5rem; display: inline-block; }
  .separator { border: 0; height: 1px; background: rgba(0, 0, 0, 0.1); margin: 1.5rem 0; }
  .benefit-list { margin: 2rem 0; list-style: none; padding: 0; }
  .benefit-list li { margin-bottom: 1rem; padding-left: 1.5rem; position: relative; font-size: 1.05rem; }
  .benefit-list li::before { content: "✓"; color: #d32f2f; position: absolute; left: 0; font-weight: bold; }
  .contact-footer { margin-top: 1.5rem; font-style: italic; color: #666; }
</style>
