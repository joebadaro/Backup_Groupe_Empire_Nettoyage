---
import Layout from "../../../layouts/Layout.astro";
---

<Layout
  title="Leather Furniture Cleaning | Empire Cleaning Group"
  description="Professional leather sofa and armchair cleaning, conditioning, and protection. Restore softness and finish with specialized products."
>
  <header class="page-header">
    <div class="container">
      <h1>Leather Sofa Cleaning & Conditioning</h1>
      <p>
        Leather is a premium material that requires proper maintenance and care.
      </p>
    </div>
  </header>

  <section class="section-padding">
    <div class="container">
      <h2>Protection and Restoration</h2>
      <p>
        We do more than surface cleaning; we condition leather to help prevent
        dryness and cracking.
      </p>
      <p>
        Our products are designed for aniline, semi-aniline, and pigmented
        leather finishes.
      </p>
      <br />
      <a href="/en/contact" class="btn btn-primary">Get a Leather Quote</a>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-empire-blue);
    color: white;
    padding: 4rem 0;
    text-align: center;
  }
</style>
