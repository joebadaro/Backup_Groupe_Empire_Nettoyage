---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="About Us — Empire Cleaning Group"
  description="For over 30 years, Empire Cleaning Group has been a reference in specialized cleaning across the Greater Montreal area. Certified technicians, eco-friendly products, and an approach without subcontractors."
>
  <div class="about-container">
    <div class="container">
      <h1>Our Story</h1>
      <p class="intro">
        For over 30 years, Empire Cleaning Group has been a reference in
        specialized cleaning across the Greater Montreal area.
      </p>
      
      <div class="mission-box">
        <h2>Our Mission</h2>
        <p>
          Provide the most complete and hygienic cleaning possible by
          combining exceptional customer service and cutting-edge
          technologies.
        </p>
      </div>

      <h2>Our Team</h2>
      <p>
        Our technicians are certified, continuously trained, and dedicated
        to your satisfaction. We do not outsource: every expert is part of
        the Empire family.
      </p>
    </div>
  </div>
</Layout>

<style>
  .about-container { padding: 4rem 0; }
  h1 { font-size: 3rem; margin-bottom: 2rem; }
  .intro { font-size: 1.2rem; margin-bottom: 3rem; max-width: 800px; }
  .mission-box { background-color: var(--color-background); padding: 2rem; border-left: 5px solid var(--color-gold); margin-bottom: 3rem; }
</style>
