---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Privacy Policy | Empire Cleaning Group">
    <section class="section">
        <div class="container">
            <h1>Privacy Policy</h1>
            <p>
                Last updated: {new Date().toLocaleDateString("en-CA")}
            </p>

            <div class="content">
                <p>
                    Empire Cleaning Group is committed to protecting your
                    privacy. This policy explains how we collect and use your
                    information.
                </p>

                <h2>1. Information Collection</h2>
                <p>
                    We collect information that you voluntarily provide to us
                    via our contact forms (name, phone, address, email) for the
                    sole purpose of responding to your quote requests.
                </p>

                <h2>2. Data Usage</h2>
                <p>Your data is used solely to:</p>
                <ul>
                    <li>Contact you for an estimate.</li>
                    <li>Schedule a cleaning appointment.</li>
                </ul>
                <p>We do not sell or share your data with third parties.</p>

                <h2>3. Cookies</h2>
                <p>
                    This site may use cookies to improve your browsing
                    experience.
                </p>

                <h2>4. Contact</h2>
                <p>
                    For any questions, contact us at:
                    info@groupenettoyageempire.com
                </p>
            </div>
        </div>
    </section>
</Layout>

<style>
    .section {
        padding: 8rem 0;
    }
    h1 {
        color: var(--color-primary);
        margin-bottom: 2rem;
    }
    h2 {
        font-size: 1.5rem;
        margin-top: 2rem;
        margin-bottom: 1rem;
        color: var(--color-primary);
    }
    .content {
        max-width: 800px;
        font-size: 1.1rem;
        line-height: 1.6;
    }
</style>
