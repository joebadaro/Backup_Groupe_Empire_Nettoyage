---
import Layout from "../../../layouts/Layout.astro";

const posts = [
  {
    slug: 'urine-animaux-tapis',
    title: 'Why Does Pet Urine Odor Always Come Back?',
    excerpt: 'Discover the science behind urine stains. Understand why vinegar fails and how enzymes destroy uric acid crystals.',
    date: 'March 17, 2026',
    category: 'Pets & Odors',
    icon: '🐶'
  },
  {
    slug: 'erreurs-taches-tapis',
    title: 'The Ultimate Carpet Stain Removal Guide',
    excerpt: 'Learn emergency steps to save your carpet. Discover the fatal mistakes and how to treat red wine, coffee, and blood.',
    date: 'March 17, 2026',
    category: 'Maintenance',
    icon: '🛑'
  },
  {
    slug: 'nettoyage-vapeur-vs-location',
    title: 'Rental Machine vs. Professional Truck-Mount',
    excerpt: 'Why renting a supermarket carpet machine can ruin your carpets. A complete technical comparison.',
    date: 'March 17, 2026',
    category: 'Comparison',
    icon: '🚛'
  }
];
---

<Layout
  title="Expert Tips & Blog | Empire Cleaning Group"
  description="Expert tips and guides for professional surface care: carpet maintenance, stain removal, and pet odor solutions. Practical recommendations from Empire Cleaning Group."
  robots="noindex,nofollow"
>
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <h1 class="text-gradient">Expert Tips</h1>
      <p class="intro">Comprehensive guides, tips, and recommendations to preserve your investments.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      
      <div class="blog-grid fade-in-section delay-100">
        {posts.map(post => (
          <a href={`/en/tips/${post.slug}`} class="blog-card">
            <div class="card-icon">{post.icon}</div>
            <div class="card-content">
              <span class="card-cat">{post.category}</span>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>
              <span class="read-more">Read Article &rarr;</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-bg-light-blue);
    padding: 4rem 0;
    text-align: center;
    border-bottom: 1px solid #eee;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 1rem auto 0 auto;
    font-size: 1.2rem;
    color: var(--color-text-light);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding: 4rem 0;
  }

  .blog-card {
    background: white;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-subtle);
    transition: transform 0.2s;
    border: 1px solid #eee;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-accent);
  }

  .card-icon {
    font-size: 3rem;
    background: #f9f9f9;
    padding: 2rem;
    text-align: center;
  }

  .card-content {
    padding: 2rem;
  }

  .card-cat {
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .blog-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.3rem;
    line-height: 1.3;
  }

  .blog-card p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  .read-more {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 0.9rem;
  }
</style>
