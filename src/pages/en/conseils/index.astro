---
import Layout from "../../../layouts/Layout.astro";

const posts = [
  {
    slug: "erreurs-taches-tapis",
    title: "3 Fatal Mistakes to Avoid on a Stain",
    excerpt:
      "Rubbing is the worst thing to do. Discover how to react to save your carpet.",
    date: "December 17, 2024",
    category: "Maintenance",
    icon: "🛑",
  },
  {
    slug: "urine-animaux-tapis",
    title: "Pets: Why does the smell always come back?",
    excerpt:
      "Urine crystallizes in the fiber. Simple surface cleaning is not enough.",
    date: "December 14, 2024",
    category: "Pets",
    icon: "🐶",
  },
  {
    slug: "preparer-visite-nettoyage",
    title: "5 minutes to prepare for your visit",
    excerpt: "Should you vacuum? Move furniture? Our simple checklist.",
    date: "December 12, 2024",
    category: "Guide",
    icon: "📋",
  },
  {
    slug: "frequence-nettoyage-tapis",
    title: "How often should you clean your carpets?",
    excerpt:
      "Allergies, dust, health: real recommendations for a healthy home.",
    date: "December 10, 2024",
    category: "Health",
    icon: "📅",
  },
  {
    slug: "entretien-cuir-erreurs",
    title: "Leather: Stop using baby wipes!",
    excerpt: "Drugstore products clog leather. Here is the real method.",
    date: "December 08, 2024",
    category: "Maintenance",
    icon: "🛋️",
  },
  {
    slug: "nettoyage-vapeur-vs-location",
    title: "Rental Machine vs Truck-Mount Unit",
    excerpt: "Why grocery store rentals are not worth professional cleaning.",
    date: "December 15, 2024",
    category: "Comparison",
    icon: "🚛",
  },
];
---

<Layout
  title="Expert Tips | Empire Cleaning Group"
  description="Expert Tips: maintenance and stain/odor treatment guides for carpets, upholstery and surfaces. Professional methods and practical recommendations from our technicians."
>
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <h1 class="text-gradient">Expert Tips</h1>
      <p class="intro">
        Tips, guides, and recommendations for maintaining your surfaces.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="blog-grid fade-in-section delay-100">
        {
          posts.map((post) => (
            <a href={`/en/conseils/${post.slug}`} class="blog-card">
              <div class="card-icon">{post.icon}</div>
              <div class="card-content">
                <span class="card-cat">{post.category}</span>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
                <span class="read-more">Read article &rarr;</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-bg-light-blue);
    padding: 4rem 0;
    text-align: center;
    border-bottom: 1px solid #eee;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 1rem auto 0 auto;
    font-size: 1.2rem;
    color: var(--color-text-light);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    padding: 4rem 0;
  }

  .blog-card {
    background: white;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-subtle);
    transition: transform 0.2s;
    border: 1px solid #eee;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
    border-color: var(--color-accent);
  }

  .card-icon {
    font-size: 3rem;
    background: #f9f9f9;
    padding: 2rem;
    text-align: center;
  }

  .card-content {
    padding: 2rem;
  }

  .card-cat {
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .blog-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.3rem;
    line-height: 1.3;
  }

  .blog-card p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .read-more {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 0.9rem;
  }
</style>
