---
import ArticleLayout from "../../../layouts/ArticleLayout.astro";

const pageTitle = "How Often Should Carpets Be Professionally Cleaned? | Expert Tips | Empire Cleaning Group";
const heading = "How Often Should Carpets Be Professionally Cleaned?";
const description =
  "Visible dirt appears late. Follow practical cleaning intervals based on home traffic, pets, and allergy sensitivity.";
---

<ArticleLayout
  title={pageTitle}
  description={description}
  heading={heading}
  backHref="/en/conseils"
  backLabel="← Back to expert tips"
>
  <div class="article-meta" style="margin-bottom: 2rem; color: #666; font-style: italic;">
    <span>Category: Health</span> | <span>Updated: December 10, 2024</span>
  </div>

  <p class="lead" style="font-size: 1.2rem; line-height: 1.6; color: var(--color-primary); font-weight: 500;">
    Carpets trap dust, pollen, and allergens. Waiting until visible staining appears is usually too late for preventive
    maintenance.
  </p>

  <h2>Recommended intervals</h2>

  <div
    style="background-color: #f8f9fa; border-left: 4px solid var(--color-accent); padding: 1.5rem; margin: 2rem 0; border-radius: 4px;"
  >
    <ul style="margin: 0; padding-left: 1.25rem;">
      <li style="margin-bottom: 0.65rem;">
        <strong>Standard household:</strong> every 12 to 18 months.
      </li>
      <li style="margin-bottom: 0.65rem;">
        <strong>Families with children:</strong> every 6 to 12 months.
      </li>
      <li style="margin-bottom: 0.65rem;">
        <strong>Homes with pets:</strong> about every 6 months.
      </li>
      <li style="margin-bottom: 0;">
        <strong>Allergy-prone homes:</strong> every 4 to 6 months.
      </li>
    </ul>
  </div>

  <h2>Health and durability benefits</h2>
  <p>
    Regular deep cleaning supports indoor air quality and extends carpet lifespan while preserving texture and
    appearance.
  </p>
</ArticleLayout>
