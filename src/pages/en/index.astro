---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Empire Cleaning Group - Cleaning Excellence in Quebec"
  description="Premier cleaning services for carpets, upholstery, and mattresses in Montreal and Quebec. Eco-friendly solutions and truck-mount technology."
>
  <!-- 1. HERO SECTION: IMPACT VISUEL FORT (Bleu Foncé & Or) -->
  <!-- 1. HERO SECTION: IMPACT VISUEL FORT (Bleu Foncé & Or) -->
  <section class="hero-section">
    <!-- SLIDESHOW BACKGROUND -->
    <div class="hero-slideshow">
      <!-- Slide 1: Artistic Living Room -->
      <img
        src="/images/catalog/hero-slide-2.webp"
        srcset="/images/catalog/hero-slide-2-mobile.webp 800w, /images/catalog/hero-slide-2.webp 1920w"
        sizes="(max-width: 768px) 100vw, 100vw"
        alt="Professional carpet and sofa cleaning in Montreal - Empire Cleaning Group"
        class="hero-slide active"
        fetchpriority="high"
        loading="eager"
        style="opacity: 1 !important; transition: none !important;"
        width="1920"
        height="1080"
      />

      <!-- Slide 3: New Office Carpet -->
      <img
        src="/images/catalog/hero-slide-office.webp"
        srcset="/images/catalog/hero-slide-office-mobile.webp 800w, /images/catalog/hero-slide-office.webp 1920w"
        sizes="(max-width: 768px) 100vw, 100vw"
        alt="Nettoyage de tapis bureau et commercial"
        class="hero-slide"
      />
    </div>

    <div class="hero-overlay"></div>
    <div
      class="container hero-content text-center"
      style="position: relative; z-index: 10;"
    >
      <div class="hero-badge animate-on-load">
        <span class="badge-main">
          <img
            src="/images/choix-quebec-optimized.webp"
            alt="Consumer Choice Award"
            class="badge-icon-img"
            width="40"
            height="40"
          />
          The #1 Choice
        </span>
        <span class="badge-sub">of consumers in Quebec</span>
      </div>

      <h1 class="hero-title animate-on-load delay-1">
        The Art of Cleaning <br />
        <span class="text-gradient-tricolor">Premium</span>
      </h1>
      <p class="hero-subtitle animate-on-load delay-2">
        Carpets, Furniture and Mattresses. Sparkling cleanliness thanks to our
        exclusive truck-mount technology and eco-friendly products.
      </p>
      <div class="hero-actions animate-on-load delay-3">
        <a href="tel:5148939939" class="btn btn-glass pulse-btn">
          <span class="icon">📞</span> (514) 893-9939 (Free Estimate)
        </a>
        <a href="/contact" class="btn btn-glass-outline">
          <span class="icon">📝</span> Online Quote
        </a>
      </div>
    </div>

    <!-- Wave Separator Bottom -->
    <div class="wave-bottom">
      <svg viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg">
        <path
          fill="#ffffff"
          fill-opacity="1"
          d="M0,224L48,213.3C96,203,192,181,288,181.3C384,181,480,203,576,224C672,245,768,267,864,261.3C960,256,1056,224,1152,197.3C1248,171,1344,149,1392,138.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
        ></path>
      </svg>
    </div>
  </section>

  <!-- 2. TRUST INSIGNIA (Confiance Immédiate) -->
  <section class="trust-container">
    <div class="brand-watermark watermark-trust"></div>
    <div class="container trust-grid">
      <div class="trust-pill badge-google">
        <img
          src="/images/google-reviews-badge.png"
          alt="Google 5 Stars Review"
          width="110"
          height="auto"
          loading="eager"
        />
      </div>
      <div class="trust-pill badge-exp">
        <span class="icon">💎</span> 30+ Years Experience
      </div>
      <div class="trust-pill badge-eco">
        <span class="icon">🌿</span> 100% Eco-Friendly
      </div>
      <div class="trust-pill badge-local">
        <span class="icon">⚜️</span> Quebec Company
      </div>
    </div>
  </section>

  <!-- 3. SERVICES (Fond Bleu Pâle - Contraste Doux) -->
  <section class="section section-services">
    <div class="container">
      <div class="section-header text-center">
        <span class="tag-blue">Complete Expertise</span>
        <h2 class="title-dark-blue text-gradient-empire">
          Our Cleaning Solutions
        </h2>
        <p class="lead-text">
          Targeted intervention for every surface of your home.
        </p>
      </div>

      <div class="services-grid-modern">
        <!-- 1. Meubles & Divans -->
        <a
          href="/services/meubles-tissu"
          class="service-card-modern fade-in-section delay-100"
        >
          <img
            src="/images/services/services-4.webp"
            alt="Upholstery cleaning"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">🛋️</div>
            <h3>Sofa, Couch, Armchair & Upholstery</h3>
            <p>Deep cleaning of upholstery fabrics. Stop stains and odors.</p>
            <span class="link-text">See details &rarr;</span>
          </div>
        </a>

        <!-- 2. Meubles en Cuir -->
        <a
          href="/services/meubles-cuir"
          class="service-card-modern fade-in-section delay-200"
        >
          <img
            src="/images/catalog/photo-leather-final.webp"
            alt="Leather furniture cleaning"
            class="card-img"
            loading="lazy"
          />
          <div class="card-content">
            <div class="card-icon icon-blue">🛡️</div>
            <h3>Leather Furniture</h3>
