      </div>
    </div>
  </section>

  <!-- 3.5 QUALITY DETAILS STRIP (Refined) -->
  <section class="section-quality-strip-refined">
    <div class="quality-image-wrapper">
      <img
        src="/images/catalog/souci-detail-team.webp"
