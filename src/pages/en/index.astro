  <!-- 6. CONCLUSION CTA (Rouge/Action) -->
  <section class="cta-final">
    <div class="container text-center">
      <h2 class="cta-title text-gradient-empire">Don't let dirt settle in</h2>
      <p>Get your free estimate in less than 2 minutes.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-gradient-blue-green">✉️ Contact Us</a>
      </div>
    </div>
  </section>

  <script>
    // Simple Cross-Fade Slideshow (Standardized)
    const slides = document.querySelectorAll(".slide");

    if (slides.length > 0) {
      let currentSlide = 0;
      const intervalTime = 4000; // 4 seconds

      setInterval(() => {
        slides[currentSlide].classList.remove("active");
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add("active");
      }, intervalTime);
    }

    // Hero Slideshow
    const heroSlides = document.querySelectorAll(".hero-slide");
    if (heroSlides.length > 0) {
      let currentHeroSlide = 0;
      const heroIntervalTime = 6000; // 6 seconds (Slower for hero)

      setInterval(() => {
        heroSlides[currentHeroSlide].classList.remove("active");
        currentHeroSlide = (currentHeroSlide + 1) % heroSlides.length;
        heroSlides[currentHeroSlide].classList.add("active");
      }, heroIntervalTime);
    }
  </script>

  <style>
    /* Power List Styling */
    .power-list {
      list-style: none;
      padding: 0;
      margin: 2rem 0;
    }

    .power-list li {
      display: flex;
      align-items: flex-start; /* Changed from center for better mobile alignment */
      gap: 12px;
      font-size: 1.1rem;
      margin-bottom: 12px;
      color: rgba(255, 255, 255, 0.9);
    }

    .check-icon {
      color: #ffd700; /* Gold for premium feel */
      font-weight: bold;
      font-size: 1.2rem;
      flex-shrink: 0; /* Prevent icon from shrinking */
      line-height: 1.4; /* Match text line-height */
    }

    .description-text {
      font-size: 1.1rem;
      line-height: 1.6;
      margin-bottom: 1.5rem;
      color: rgba(255, 255, 255, 0.85);
    }

    /* --- ANIMATIONS V3 (Staggered & Smooth) --- */
    .fade-in-section {
      opacity: 0;
      transform: translateY(30px);
      transition:
        opacity 0.8s ease-out,
        transform 0.8s ease-out;
      will-change: opacity, visibility;
    }
    .fade-in-section.is-visible {
      opacity: 1;
      transform: none;
    }

    /* CSS-Only Animation for Hero LCP */
    .animate-on-load {
      opacity: 0;
      animation: fadeInUp 0.8s ease-out forwards;
    }
    .delay-1 {
      animation-delay: 0.2s;
    }
    .delay-2 {
      animation-delay: 0.4s;
    }
    .delay-3 {
      animation-delay: 0.6s;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .delay-100 {
      transition-delay: 100ms;
    }
    .delay-200 {
      transition-delay: 200ms;
    }
    .delay-300 {
      transition-delay: 300ms;
    }

    .text-gradient-tricolor {
      background: linear-gradient(90deg, #a2c2e1 0%, #ffffff 50%, #d32f2f 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
    }

    /* --- NEW HERO --- */
    .hero-section {
      position: relative;
      /* Rich "Living Room" Background with Overlay */
      /* Rich "Living Room" Background with Overlay -> REPLACED BY SLIDESHOW */
      background: linear-gradient(rgba(10, 35, 66, 0.5), rgba(10, 35, 66, 0.5));
      /* Fallback color if images fail */
      background-color: #0a2342;
      color: white;
      padding: 12rem 0 14rem 0; /* More expansive padding */
      overflow: hidden;
    }

    /* Mobile Padding Adjustment */
    @media (max-width: 768px) {
      .hero-section {
        padding: 8rem 0 10rem 0; /* Reduced padding on mobile */
      }
    }

    /* --- SLIDESHOW CONTAINER --- */
    .hero-slideshow {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0; /* Behind content (which is z-index 10) */
    }

    .hero-slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      transition: opacity 2s ease-in-out; /* Smooth 2s transition */
      z-index: 1;
    }

    .hero-slide.active {
      opacity: 1;
      z-index: 2;
    }

    .hero-overlay {
      /* Ensure overlay is ABOVE slides but BELOW content */
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      /* Gradient: Transparent top to Dark Blue bottom for text readability */
      background: linear-gradient(
        to bottom,
        rgba(10, 35, 66, 0.1) 0%,
        rgba(10, 35, 66, 0.4) 50%,
