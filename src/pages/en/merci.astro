---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Thank You — Request Received | Empire Cleaning Group"
  description="Thank you for contacting Empire Cleaning Group. A member of our team will reply shortly about your request."
>
    <section class="section">
        <div class="container text-center">
            <div class="fade-in-section">
                <div class="check-icon">✓</div>
                <h1 class="text-gradient">Request Received!</h1>
                <p class="lead-text">
                    Thank you for contacting us.<br />
                    A member of our team will answer you shortly.
                </p>

                <div class="actions">
                    <a href="/" class="btn btn-primary">Back to Home</a>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .section {
        padding: 8rem 0;
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .check-icon {
        font-size: 5rem;
        color: var(--color-eco);
        margin-bottom: 2rem;
        background: var(--color-eco-light);
        width: 120px;
        height: 120px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem auto;
    }

    .lead-text {
        font-size: 1.4rem;
        color: var(--color-text-main);
        margin-bottom: 3rem;
    }
</style>
