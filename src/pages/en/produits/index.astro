---
import Layout from "../../../layouts/Layout.astro";
import { productImages } from "../../../data/productImages";
import { productPricing } from "../../../data/productPricing";

const duo = productImages.hubDuo;
const imgNeutral = productImages.neutralisant;
const imgEnz = productImages.enzymatique;
const pr = productPricing;
---

<Layout
  title="Professional cleaning products | Empire Cleaning Group"
  description="Odor Break and BioBreak professional products for odors and soils on carpets and upholstery. From $26.99 each; recommended pair $49.99. Montreal, Laval, South Shore."
  image={duo.src}
>
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <h1 class="text-gradient">Professional products</h1>
      <p class="intro">
        Solutions we actually use on the job — chosen after years of field testing, not random shelf picks.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="promo-visual fade-in-section">
        <img
          src={duo.src}
          alt={duo.altEn}
          class="promo-img"
          width={duo.width}
          height={duo.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <p class="promo-caption">
          Promotional visual for the range — ask our team which option fits your situation.
        </p>
      </div>

      <div class="product-grid">
        <a href="/en/produits/neutralisant-odeurs-urine-oxygene" class="product-card fade-in-section delay-100">
          <div class="card-thumb">
            <img
              src={imgNeutral.src}
              alt={imgNeutral.altEn}
              width={imgNeutral.width}
              height={imgNeutral.height}
              loading="lazy"
              decoding="async"
              class="card-thumb-img"
            />
          </div>
          <span class="card-badge">Tough odors</span>
          <h2>Odor Break</h2>
          <p class="card-tagline">Odor neutralization at the source</p>
          <p>
            Professional-grade hydrogen peroxide (H₂O₂) formulation with complementary agents — for urine odors and some biological soils when the fiber and label allow.
          </p>
          <p class="card-price" aria-label="Unit price">{pr.single.displayEn} <span class="card-price-curr">CAD</span></p>
          <span class="read-more">Product page →</span>
        </a>

        <a href="/en/produits/detachant-enzymatique-apres-nettoyage" class="product-card fade-in-section delay-200">
          <div class="card-thumb">
            <img
              src={imgEnz.src}
              alt={imgEnz.altEn}
              width={imgEnz.width}
              height={imgEnz.height}
              loading="lazy"
              decoding="async"
              class="card-thumb-img"
            />
          </div>
          <span class="card-badge">Organic soils</span>
          <h2>BioBreak</h2>
          <p class="card-tagline">Professional enzymatic spot cleaner</p>
          <p>
            Targeted upkeep between scheduled visits or on a small area of carpet or upholstery when the manufacturer allows this type of product.
          </p>
          <p class="card-price" aria-label="Unit price">{pr.single.displayEn} <span class="card-price-curr">CAD</span></p>
          <span class="read-more">Product page →</span>
        </a>
      </div>

      <div class="duo-panel fade-in-section delay-250">
        <h2 class="duo-title">Recommended duo</h2>
        <p class="duo-lead">
          For <strong>tougher organic soils</strong>, it’s often best to start with <strong>BioBreak</strong>, our <strong>enzyme-based spot cleaner</strong>, to <strong>work the soil in depth</strong>. After that first step, <strong>Odor Break</strong> is used as a <strong>second treatment</strong> to deodorize, <strong>neutralize odors at the source</strong>, and help <strong>sanitize</strong> the treated area — especially with <strong>pet-related</strong> damage.
        </p>
        <p class="duo-method">
          Used together, the two products support a <strong>more complete, professional approach</strong>. It’s the workflow <strong>Groupe Nettoyage Empire</strong> uses in many situations: <strong>enzyme stain work first</strong>, then a <strong>finishing pass with Odor Break</strong> to target odor-causing molecules and leave the textile <strong>cleaner and fresher</strong>.
        </p>
        <div class="duo-price-block">
          <p class="duo-price-row">
            <span class="duo-price-main">{pr.duo.displayEn}</span>
            <span class="duo-price-label">both · CAD</span>
          </p>
          <p class="duo-meta">
            Each product is also sold separately at <strong>{pr.single.displayEn}</strong>.
          </p>
          <p class="duo-meta">Taxes extra, where applicable.</p>
          <p class="duo-meta">
            Available from our technicians or by calling <a href="tel:5148939939">(514) 893-9939</a>.
          </p>
        </div>
      </div>

      <div class="reassurance-box fade-in-section delay-300">
        <h2 class="subhead">Why these products?</h2>
        <p>
          With over <strong>30 years of experience</strong>, we've compared many formulations. The ones featured here are solutions we <strong>use ourselves</strong> in the field with real customers — not a random marketing pick, but repeated on-the-job validation across Montreal, Laval, and the South Shore.
        </p>
        <p>
          For complex cases (persistent odor, large areas, delicate fibers, or unknown soil type), <a href="/en/contact">contact us</a>: a full professional service is often the safest route.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-bg-light-blue);
    padding: 2.25rem 0 1.25rem;
    text-align: center;
    border-bottom: 1px solid #eee;
  }
  .intro {
    max-width: 720px;
    margin: 0.5rem auto 0;
    font-size: 1.15rem;
    color: var(--color-text-light);
  }
  .section {
    padding-top: 1rem;
    padding-bottom: var(--spacing-lg, 4rem);
  }
  .promo-visual {
    max-width: 960px;
    margin: 0 auto 2.5rem;
    text-align: center;
    padding: 0.35rem 0.5rem 0;
  }
  .promo-img {
    width: 100%;
    max-width: min(100%, 560px);
    height: auto;
    margin-inline: auto;
    border-radius: var(--border-radius-md);
    box-shadow: 0 10px 36px rgba(13, 27, 48, 0.22);
    display: block;
  }
  .promo-caption {
    font-size: 0.95rem;
    color: #666;
    margin-top: 0.75rem;
    text-align: center;
    line-height: 1.5;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .card-thumb {
    margin: -0.25rem -0.35rem 1rem;
    border-radius: var(--border-radius-md);
    background: linear-gradient(180deg, #ffffff 0%, #eef6fc 100%);
    border: 1px solid rgba(0, 74, 159, 0.08);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    max-height: 240px;
  }
  .card-thumb-img {
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 220px;
    object-fit: contain;
    display: block;
  }
  .product-card {
    background: linear-gradient(165deg, #f2f8fd 0%, #ffffff 52%, #e8f3fc 100%);
    border: 1px solid rgba(66, 133, 244, 0.12);
    border-radius: var(--border-radius-md);
    padding: 1.5rem 1.35rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 18px rgba(0, 74, 159, 0.06);
  }
  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 28px rgba(0, 74, 159, 0.1);
  }
  .card-badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #4a7ebb;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .product-card h2 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: 0 0 0.25rem;
    line-height: 1.25;
  }
  .card-tagline {
    font-size: 0.82rem;
    color: #5a6b7d;
    margin: 0 0 0.65rem !important;
    font-weight: 600;
    line-height: 1.35;
  }
  .product-card p {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.55;
    flex: 1;
    margin: 0 0 1rem;
  }
  .card-price {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 0.75rem !important;
    letter-spacing: 0.02em;
  }
  .card-price-curr {
    font-size: 0.75rem;
    font-weight: 600;
    opacity: 0.85;
  }
  .duo-panel {
    max-width: 720px;
    margin: 0 auto 2.75rem;
    padding: 1.5rem 1.5rem 1.35rem;
    background: linear-gradient(168deg, #ffffff 0%, #f0f6fc 55%, #e8f2fa 100%);
    border: 1px solid rgba(0, 74, 159, 0.14);
    border-radius: 12px;
    box-shadow: 0 6px 22px rgba(0, 74, 159, 0.06);
  }
  .duo-title {
    margin: 0 0 0.65rem;
    font-size: 1.2rem;
    color: var(--color-primary);
    font-weight: 800;
  }
  .duo-lead {
    margin: 0 0 0.85rem;
    font-size: 0.96rem;
    line-height: 1.68;
    color: var(--color-text-main);
  }
  .duo-method {
    margin: 0 0 1.15rem;
    font-size: 0.96rem;
    line-height: 1.68;
    color: var(--color-text-main);
  }
  .duo-price-block {
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid rgba(0, 74, 159, 0.12);
  }
  .duo-price-row {
    margin: 0 0 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 0.75rem;
  }
  .duo-price-main {
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }
  .duo-price-label {
    font-size: 0.88rem;
    color: #555;
    font-weight: 600;
  }
  .duo-meta {
    margin: 0 0 0.4rem;
    font-size: 0.88rem;
    line-height: 1.55;
    color: #444;
  }
  .duo-meta:last-child {
    margin-bottom: 0;
  }
  .duo-meta a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }
  .duo-meta a:hover {
    text-decoration: underline;
  }
  .read-more {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .reassurance-box {
    max-width: 800px;
    margin: 0 auto;
    padding: 1.75rem;
    background: #f8f9fa;
    border-radius: 8px;
    border-left: 4px solid var(--color-accent);
  }
  .subhead {
    margin-top: 0;
    color: var(--color-primary);
    font-size: 1.35rem;
  }
  .reassurance-box p {
    line-height: 1.75;
    color: var(--color-text-main);
    margin-bottom: 1rem;
  }
  .reassurance-box p:last-child {
    margin-bottom: 0;
  }
  @media (max-width: 767px) {
    .page-header {
      padding: 1.5rem 0 1rem;
    }
    .product-grid {
      grid-template-columns: 1fr;
    }
    .promo-visual {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
      padding: 0;
    }
    .promo-img {
      max-width: 100%;
      border-radius: 0;
      box-shadow: none;
    }
    .promo-caption {
      padding: 0 1.5rem;
    }
    .card-thumb {
      width: calc(100% + 2 * (1.5rem + 1.35rem));
      max-width: none;
      margin-left: calc(-1 * (1.5rem + 1.35rem));
      margin-right: calc(-1 * (1.5rem + 1.35rem));
      min-height: unset;
      max-height: none;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .card-thumb-img {
      width: 100%;
      max-width: none;
      max-height: none;
      object-fit: contain;
    }
  }
</style>
