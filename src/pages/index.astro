      /* --- QUALITY STRIP (REFINED) --- */
      .section-quality-strip-refined {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        align-items: center;
        background: #f8fbff; /* Very subtle Ice Blue tint for premium separation */
        border-top: 1px solid rgba(0, 0, 0, 0.03);
        border-bottom: 1px solid rgba(0, 0, 0, 0.03);
