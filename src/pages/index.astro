---
import Layout from "../layouts/Layout.astro";
import GoogleReviewsSection from "../components/GoogleReviewsSection.astro";
import { HOMEPAGE_SERVICE_CARDS, getServiceImage } from "../data/serviceImagery";
---

<Layout
  title="Groupe Nettoyage Empire - L'Excellence du Nettoyage au Québec"
  description="Services de nettoyage de premier plan pour tapis, meubles et matelas à Montréal et Québec. Techniciens certifiés, produits écologiques haut de gamme et technologie de camion-usine."
>
  <!-- 1. HERO SECTION: IMPACT VISUEL FORT (Bleu Foncé & Or) -->
  <section class="hero-section">
    <!-- SLIDESHOW BACKGROUND -->
    <div class="hero-slideshow">
      <!-- Slide 1: Salon lumineux (blanc) — priorité LCP (fetchpriority high) -->
      <picture class="hero-bg-picture hero-bg-picture--secondary">
        <source
          media="(max-width: 768px)"
          type="image/webp"
          srcset="/images/catalog/hero-salon-nettoyage-vapeur-montreal-portrait-800.webp 800w, /images/catalog/hero-salon-nettoyage-vapeur-montreal-portrait.webp 1600w"
          sizes="100vw"
        />
        <img
          src="/images/catalog/hero-slide-2.webp"
          srcset="/images/catalog/hero-slide-2-mobile.webp 800w, /images/catalog/hero-slide-2.webp 1920w"
          sizes="100vw"
          alt="Nettoyage professionnel de tapis et divans à Montréal - Groupe Empire"
          class="hero-slide active"
          width={1200}
          height={675}
          decoding="async"
          fetchpriority="high"
        />
      </picture>

      <!-- Slide 2: Salon résidentiel luxe — tapis (portrait source) -->
      <picture class="hero-bg-picture">
        <source
          media="(max-width: 768px)"
          type="image/webp"
          srcset="/images/catalog/hero-salon-prestige-tapis-residentiel-quebec-portrait-800.webp 800w, /images/catalog/hero-salon-prestige-tapis-residentiel-quebec-portrait.webp 1600w"
          sizes="100vw"
        />
        <img
          src="/images/catalog/hero-salon-prestige-tapis-residentiel-quebec.webp"
          srcset="/images/catalog/hero-salon-prestige-tapis-residentiel-quebec-mobile.webp 800w, /images/catalog/hero-salon-prestige-tapis-residentiel-quebec.webp 1600w"
          sizes="100vw"
          alt="Salon résidentiel luxueux avec tapis impeccablement nettoyé - Groupe Nettoyage Empire, Québec"
          class="hero-slide"
          loading="lazy"
          width={1600}
          height={2000}
          decoding="async"
        />
      </picture>

      <!-- Slide 3: Tapis laine — tall ≤768px / wide desktop -->
      <picture class="hero-bg-picture hero-bg-picture--wool-tall">
        <source
          media="(max-width: 768px)"
          type="image/webp"
          srcset="/images/catalog/hero-tapis-laine-wool-quebec-tall-portrait-800.webp 800w, /images/catalog/hero-tapis-laine-wool-quebec-tall-portrait-1600.webp 1600w"
          sizes="100vw"
        />
        <img
          src="/images/catalog/hero-tapis-laine-wool-quebec-wide.webp"
          srcset="/images/catalog/hero-tapis-laine-wool-quebec-wide-800.webp 800w, /images/catalog/hero-tapis-laine-wool-quebec-wide.webp 1536w"
          sizes="100vw"
          alt="Tapis en laine professionnellement nettoyé, texture soignée - Groupe Nettoyage Empire, Québec"
          class="hero-slide"
          loading="lazy"
          width={1536}
          height={1024}
          decoding="async"
        />
      </picture>

      <!-- Slide 4: Commercial — espace 2 -->
      <picture class="hero-bg-picture">
        <source
          media="(max-width: 768px)"
          type="image/webp"
          srcset="/images/catalog/hero-commercial-bureau-espace2-quebec-portrait-800.webp 800w, /images/catalog/hero-commercial-bureau-espace2-quebec-portrait.webp 1600w"
          sizes="100vw"
        />
        <img
          src="/images/catalog/hero-commercial-bureau-espace2-quebec.webp"
          srcset="/images/catalog/hero-commercial-bureau-espace2-quebec-mobile.webp 800w, /images/catalog/hero-commercial-bureau-espace2-quebec.webp 1600w"
          sizes="100vw"
          alt="Espace commercial lumineux avec tapis professionnels - Groupe Nettoyage Empire, Québec"
          class="hero-slide"
          loading="lazy"
          width={1600}
          height={2000}
          decoding="async"
        />
      </picture>
    </div>

    <div class="hero-overlay"></div>
    <div
      class="container hero-content text-center"
      style="position: relative; z-index: 10;"
    >
      <div class="hero-badge animate-on-load">
        <span class="badge-main">
          <img
            src="/images/choix-quebec-optimized.webp"
            alt="Choix du Consommateur"
            class="badge-icon-img"
            width="40"
            height="40"
          />
          Le Choix Numéro 1
        </span>
        <span class="badge-sub">des consommateurs au Québec</span>
      </div>

      <h1 class="hero-title animate-on-load delay-1">
        <span class="hero-slogan-wrap">
          <span class="hero-slogan-rotate-stack">
            <span class="hero-slogan-sizer" aria-hidden="true">
              L'Art du Nettoyage<br />Haut de Gamme
            </span>
            <span class="hero-slogan-layer hero-slogan--a active">
              <span class="hero-slogan-white">L'Art du Nettoyage</span><br />
              <span class="text-gradient-tricolor">À la Vapeur</span>
            </span>
            <span class="hero-slogan-layer hero-slogan--b">
              <span class="hero-slogan-white">L'Art du Nettoyage</span><br />
              <span class="text-gradient-tricolor">Haut de Gamme</span>
            </span>
          </span>
        </span>
      </h1>
      <div class="hero-subtitle-group">
        <p class="hero-subtitle hero-subtitle--desktop animate-on-load delay-2">
          Tapis, Meubles et Matelas. Une propreté éclatante grâce à notre
          technologie de camion-usine exclusive et nos produits écologiques.
        </p>
        <p class="hero-subtitle hero-subtitle--mobile animate-on-load delay-2">
          Tapis, meubles, matelas et céramique.<br />
          Une propreté éclatante grâce à notre technologie de camion-usine exclusive.
        </p>
      </div>
      <div class="hero-actions animate-on-load delay-3">
        <a href="tel:5148939939" class="btn btn-glass pulse-btn">
          <span class="icon">📞</span> (514) 893-9939 (Estimation Gratuite)
        </a>
        <a href="/contact" class="btn btn-glass-outline">
          <span class="icon">📝</span> Soumission en Ligne
        </a>
      </div>
    </div>

    <!-- 2. TRUST (mobile: overlay bas du hero — desktop: inchangé visuellement via CSS) -->
    <section class="trust-container">
      <div class="container trust-band-inner">
        <p class="trust-kicker">Excellence reconnue</p>
        <div class="trust-unified-wrap">
          <div class="trust-grid trust-grid--desktop">
            <div class="trust-pill badge-google">
              <img
                src="/images/google-reviews-badge.png"
                alt="Avis clients Google — Groupe Nettoyage Empire"
                class="google-badge"
                width="302"
                height="167"
                loading="eager"
              />
            </div>
            <div class="trust-pill badge-exp">
              <span class="icon">💎</span> 30+ ans d'expérience
            </div>
            <div class="trust-pill badge-eco">
              <span class="icon">🌿</span> 100% Écologique
            </div>
            <div class="trust-pill badge-local">
              <span class="icon">⚜️</span> Entreprise Québécoise
            </div>
          </div>
          <div
            class="trust-grid trust-grid--mobile"
            aria-label="Points forts — Groupe Nettoyage Empire"
          >
            <div class="trust-pill">
              <span class="icon" aria-hidden="true">✓</span>
              <span>Techniciens certifiés</span>
            </div>
            <div class="trust-pill">
              <span class="icon" aria-hidden="true">💎</span>
              <span>30+ ans d'expérience</span>
            </div>
            <div class="trust-pill trust-pill--long">
              <span class="icon" aria-hidden="true">🌿</span>
              <span>Produits écologiques premium</span>
            </div>
            <div class="trust-pill">
              <span class="icon" aria-hidden="true">⚜️</span>
              <span>Entreprise québécoise</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </section>

  <!-- 3. SERVICES (Fond Bleu Pâle - Contraste Doux) -->
  <section class="section section-services">
    <div class="container">
      <div class="section-header text-center">
        <span class="tag-blue">Expertise Complète</span>
        <h2 class="title-dark-blue text-gradient-empire">
          Nos Solutions de Nettoyage
        </h2>
        <p class="lead-text">
          Une intervention ciblée pour chaque surface de votre intérieur.
        </p>
      </div>

      <div class="services-grid-modern">
        {
          HOMEPAGE_SERVICE_CARDS.map((card) => {
            const img = getServiceImage(card.imageKey);
            return (
              <a
                href={card.href}
                class={`service-card-modern fade-in-section ${card.delayClass}`}
              >
                <img
                  src={img.src}
                  alt={img.altFr}
                  class="card-img"
                  width={img.width}
                  height={img.height}
                  loading="lazy"
                  style={
                    img.objectPosition
                      ? `object-position: ${img.objectPosition}`
                      : undefined
                  }
                />
                <div class="card-content">
                  <div class={`card-icon ${card.iconTone}`}>{card.emoji}</div>
                  <h3>{card.titleFr}</h3>
                  <p>{card.descriptionFr}</p>
                  <span class="link-text">Voir détails &rarr;</span>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- 3.5 QUALITY DETAILS STRIP (Refined) -->
  <section class="section-quality-strip-refined">
    <div class="quality-image-wrapper">
      <img
        src="/images/catalog/team-facebook-optimized.webp"
        alt="L'équipe certifiée de Groupe Nettoyage Empire - Montréal et Rive-Sud"
        class="quality-img-full"
        width="800"
        height="533"
        loading="lazy"
      />
    </div>
    <div class="quality-content-refined text-center">
      <h3 class="text-gradient-eco">Une Équipe Dévouée</h3>
      <p>Experts certifiés et produits 100% écologiques.</p>
    </div>
    <div class="quality-image-wrapper">
      <img
        src="/images/catalog/team-van-back.webp"
        alt="L'équipe Groupe Empire avec le camion-usine"
        class="quality-img-full"
        width="800"
        height="800"
        loading="lazy"
      />
    </div>
  </section>

  <!-- 4. SECTION ÉCOLOGIQUE (Vert - Nature - Confiance) -->
  <section class="section section-eco">
    <div class="brand-watermark watermark-eco"></div>
    <div class="container split-eco">
      <div class="eco-content fade-in-section">
        <span class="tag-green">Engagement Vert</span>
        <h2 class="text-gradient-empire">Sécuritaire pour vos enfants</h2>
        <p class="eco-lead">
          Nous utilisons exclusivement des produits <strong
            >biodégradables et non-toxiques</strong
          >.
        </p>

        <ul class="eco-list">
          <li>
            <img
              src="/images/catalog/photo-8.webp"
              alt="Certification"
              class="icon-cert"
              style="width: 50px; height: auto;"
              width="533"
              height="224"
            />
            <div>
              <strong>Certifié Écologique</strong><br />Produits approuvés et
              sécuritaires.
            </div>
          </li>
          <li>
            <span class="check-green">👶</span>
            <div>
              <strong>Hypoallergénique</strong><br />Idéal pour les
              asthmatiques.
            </div>
          </li>
          <li>
            <span class="check-green">🐾</span>
            <div>
              <strong>Animaux Acceptés</strong><br />Vos animaux peuvent
              circuler librement.
            </div>
          </li>
        </ul>
      </div>
      <div class="eco-image-wrapper fade-in-section delay-100">
        <div class="eco-circle-bg"></div>
        <img
          src="/images/catalog/photo-76.webp"
          alt="Produits écologiques nettoyage"
          class="eco-img floating"
          width="1200"
          height="1100"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- 5. LA PUISSANCE (Fond Bleu Foncé - Tech - Sérieux) -->
  <section class="section section-dark-blue text-white">
    <div class="container">
      <div class="split-layout reverse-mobile">
        <div class="tech-image-wrapper">
          <h2>La Puissance de nos Camions-Usines</h2>

          <div class="tech-gallery">
            <img
              src="/images/catalog/photo-10.webp"
              alt="Technologie Camion Usine"
              class="tech-img"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-5.webp"
              alt="Équipement spécialisé"
              class="tech-img"
              loading="lazy"
            />
            <img
              src="/images/catalog/photo-56.webp"
              alt="Professional Intervention"
              class="tech-img"
              loading="lazy"
            />
          </div>

          <p class="description-text">
            Nos résultats sont supérieurs car nous ne faisons aucun compromis
            sur l'équipement. Contrairement aux machines portatives, notre unité
            mobile déploie une puissance d'aspiration et de chaleur inégalée.
          </p>

          <ul class="power-list">
            <li>
              <span class="check-icon">✓</span>
              <strong>20x plus puissant</strong> que l'équipement standard
            </li>
            <li>
              <span class="check-icon">✓</span>
              <strong>Extraction de 98%</strong> de l'humidité pour un séchage rapide
            </li>
          </ul>

          <div style="margin-top: 2rem;">
            <p class="video-cta-text">
              Découvrez notre savoir-faire en action :
            </p>
            <div class="social-links">
              <a
                href="https://www.facebook.com/NettoyageEmpire"
                target="_blank"
                rel="noopener"
                aria-label="Facebook"
                class="social-btn fb"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  width="20"
                  height="20"
                >
                  <path
                    d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
                  ></path>
                </svg>
              </a>
              <a
                href="https://instagram.com/groupenettoyageempire"
                target="_blank"
                rel="noopener"
                aria-label="Instagram"
                class="social-btn ig"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  width="20"
                  height="20"
                >
                  <path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.948-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path>
                </svg>
              </a>
              <a
                href="http://www.youtube.com/@NettoyageEmpire"
                target="_blank"
                rel="noopener"
                aria-label="YouTube"
                class="social-btn yt"
              >
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  width="20"
                  height="20"
                >
                  <path
                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5.5 AVIS GOOGLE (preuve sociale — après La puissance des camions-usines) -->
  <GoogleReviewsSection locale="fr" />

  <!-- 6. CONCLUSION CTA (Rouge/Action) -->
  <section class="cta-final">
    <div class="container text-center">
      <h2 class="cta-title text-gradient-empire">
        Ne laissez pas la saleté s'incruster
      </h2>
      <p>Obtenez votre estimation gratuite en moins de 2 minutes.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn btn-gradient-blue-green"
          >✉️ Nous Contacter</a
        >
      </div>
    </div>

    <script is:inline>
      // is:inline = exécuté tel quel sur le client (pas bundlé)
      (function () {
        function initHomeHeroSlideshow() {
          // Simple Cross-Fade Slideshow (Standardized)
          const slides = document.querySelectorAll(".slide");

          if (slides.length > 0) {
            let currentSlide = 0;
            const intervalTime = 4000; // 4 seconds

            setInterval(() => {
              slides[currentSlide].classList.remove("active");
              currentSlide = (currentSlide + 1) % slides.length;
              slides[currentSlide].classList.add("active");
            }, intervalTime);
          }

          // Hero slideshow (4 images) — desktop : swap direct. Mobile : crossfade court (CSS) + pause si touch récent (pas d’écouteur scroll : iOS le spamme pendant l’inertie et bloquait tous les swaps).
          const heroSlides = document.querySelectorAll(".hero-slide");
          if (heroSlides.length > 0) {
            let currentHeroSlide = 0;
            const firstSwapDelayMs = 4500;
            const swapIntervalMs = 9700;
            const isMobileHero =
              typeof window.matchMedia === "function" &&
              window.matchMedia("(max-width: 768px)").matches;

            const sloganA = document.querySelector(".hero-slogan--a");
            const sloganB = document.querySelector(".hero-slogan--b");

            const syncHeroSloganToSlide = (slideIndex) => {
              if (!sloganA || !sloganB) return;
              const showA = slideIndex % 2 === 0;
              sloganA.classList.toggle("active", showA);
              sloganB.classList.toggle("active", !showA);
            };

            const subtitleGroup = document.querySelector(".hero-subtitle-group");
            const syncHeroSubtitleGroup = (slideIndex) => {
              if (!subtitleGroup) return;
              const hide = slideIndex >= 2;
              subtitleGroup.classList.toggle(
                "hero-subtitle-group--hidden-on-slides-34",
                hide,
              );
              subtitleGroup.setAttribute("aria-hidden", hide ? "true" : "false");
            };

            const swapHeroSlide = () => {
              heroSlides[currentHeroSlide].classList.remove("active");
              currentHeroSlide = (currentHeroSlide + 1) % heroSlides.length;
              heroSlides[currentHeroSlide].classList.add("active");
              syncHeroSloganToSlide(currentHeroSlide);
              syncHeroSubtitleGroup(currentHeroSlide);
              /* Précharge la slide suivante (une fois par index) pour limiter les trous au fondu */
              const nextIdx = (currentHeroSlide + 1) % heroSlides.length;
              const nextImg = heroSlides[nextIdx];
              if (nextImg && !nextImg.dataset.heroPrefetched) {
                nextImg.dataset.heroPrefetched = "1";
                const u = nextImg.getAttribute("src");
                if (u) {
                  const pre = new Image();
                  pre.src = u;
                }
              }
            };

            let lastInteractionTime = 0;
            /** ms sans touch avant d’autoriser un swap (évite fondu pendant le doigt sur l’écran) */
            const IDLE_MS_BEFORE_SWAP = 650;

            const maybeSwapHeroSlide = () => {
              if (
                isMobileHero &&
                Date.now() - lastInteractionTime < IDLE_MS_BEFORE_SWAP
              ) {
                return;
              }
              swapHeroSlide();
            };

            const markUserInteraction = () => {
              lastInteractionTime = Date.now();
            };

            if (isMobileHero) {
              window.addEventListener("touchstart", markUserInteraction, {
                passive: true,
              });
              window.addEventListener("touchmove", markUserInteraction, {
                passive: true,
              });
              window.addEventListener("touchend", markUserInteraction, {
                passive: true,
              });
              window.addEventListener("touchcancel", markUserInteraction, {
                passive: true,
              });
            }

            syncHeroSubtitleGroup(0);

            setTimeout(() => {
              if (isMobileHero) {
                maybeSwapHeroSlide();
              } else {
                swapHeroSlide();
              }
              setInterval(
                isMobileHero ? maybeSwapHeroSlide : swapHeroSlide,
                swapIntervalMs,
              );
            }, firstSwapDelayMs);
          }
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initHomeHeroSlideshow);
        } else {
          initHomeHeroSlideshow();
        }
      })();
    </script>

    <style>
      /* Power List Styling */
      .power-list {
        list-style: none;
        padding: 0;
        margin: 2rem 0;
      }

      .power-list li {
        display: flex;
        align-items: flex-start; /* Changed from center to flex-start for better mobile alignment */
        gap: 12px;
        font-size: 1.1rem;
        margin-bottom: 12px;
        color: rgba(255, 255, 255, 0.9);
      }

      .check-icon {
        color: #ffd700; /* Gold for premium feel */
        font-weight: bold;
        font-size: 1.2rem;
        flex-shrink: 0; /* Prevent icon from shrinking */
        line-height: 1.4; /* Match text line-height for better alignment */
      }

      .description-text {
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        color: rgba(255, 255, 255, 0.85);
      }

      /* --- ANIMATIONS V3 (Staggered & Smooth) — match EN: hero + sections animate on all viewports */
      .fade-in-section {
        opacity: 0;
        transform: translateY(30px);
        transition:
          opacity 0.8s ease-out,
          transform 0.8s ease-out;
        will-change: opacity, visibility;
      }
      .fade-in-section.is-visible {
        opacity: 1;
        transform: none;
      }

      /* CSS-Only Animation for Hero LCP (badge, title, subtitle, CTAs) */
      .animate-on-load {
        opacity: 0;
        animation: fadeInUp 0.8s ease-out forwards;
      }
      .delay-1 {
        animation-delay: 0.2s;
      }
      .delay-2 {
        animation-delay: 0.4s;
      }
      .delay-3 {
        animation-delay: 0.6s;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .delay-100 {
        transition-delay: 100ms;
      }
      .delay-200 {
        transition-delay: 200ms;
      }
      .delay-300 {
        transition-delay: 300ms;
      }

      .text-gradient-tricolor {
        background: linear-gradient(
          90deg,
          #a2c2e1 0%,
          #ffffff 50%,
          #d32f2f 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
      }

      /* First line inside each full-slogan layer — solid white (no gradient) */
      .hero-slogan-white {
        color: #ffffff !important;
        -webkit-text-fill-color: #ffffff !important;
        background: none;
        -webkit-background-clip: border-box;
        background-clip: border-box;
      }

      /*
       * Slogan : même instant que le swap d’image — classe .active basculée dans swapHeroSlide() avec les .hero-slide.
       * transition: opacity = même durée que .hero-slide (5.2s desktop, 1.2s ≤768px).
       */
      .hero-slogan-wrap {
        display: inline-block;
        max-width: 100%;
        text-align: center;
        vertical-align: bottom;
      }

      .hero-slogan-rotate-stack {
        display: inline-grid;
        vertical-align: bottom;
        max-width: 100%;
        text-align: center;
      }

      .hero-slogan-sizer {
        grid-area: 1 / 1;
        visibility: hidden;
      }

      .hero-slogan-layer {
        grid-area: 1 / 1;
        transform: translateZ(0);
        opacity: 0;
        transition: opacity 5.2s ease-in-out;
        z-index: 1;
      }

      .hero-slogan-layer.active {
        opacity: 1;
        z-index: 2;
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-slogan-layer {
          transition: none !important;
        }

        .hero-slogan--a {
          opacity: 1 !important;
        }

        .hero-slogan--b {
          opacity: 0 !important;
          visibility: hidden;
        }

        .hero-slogan-sizer {
          display: none;
        }
      }

      /* --- NEW HERO --- */
      .hero-section {
        position: relative;
        /* Rich "Living Room" Background with Overlay */
        /* Rich "Living Room" Background with Overlay -> REPLACED BY SLIDESHOW */
        background: linear-gradient(
          rgba(10, 35, 66, 0.5),
          rgba(10, 35, 66, 0.5)
        );
        /* Fallback color if images fail */
        background-color: #0a2342;
        color: white;
        padding: 12rem 0 14rem 0; /* More expansive padding */
        overflow: hidden;
      }

      /* Mobile hero: padding défini dans @media ≤768 ; hauteur via global.css (vw + px, pas vh/svh) */

      /* --- SLIDESHOW CONTAINER --- */
      .hero-slideshow {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0; /* Behind content (which is z-index 10) */
      }

      .hero-slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center center;
        opacity: 0;
        transition: opacity 5.2s ease-in-out; /* 5.2s — même durée que .hero-slogan-layer (swap JS identique) */
        z-index: 1;
      }

      .hero-slide.active {
        opacity: 1;
        z-index: 2;
      }

      .hero-overlay {
        /* Ensure overlay is ABOVE slides but BELOW content */
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        /* Gradient: Transparent top to Dark Blue bottom for text readability */
        background: linear-gradient(
          to bottom,
          rgba(10, 35, 66, 0.1) 0%,
          rgba(10, 35, 66, 0.4) 50%,
          rgba(10, 35, 66, 0.9) 100%
        );
        z-index: 3;
        pointer-events: none;
      }

      .hero-badge {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        /* Much lighter, glass-like interaction */
        background: rgba(255, 255, 255, 0.08); /* Slightly more transparent */
        border: 1px solid rgba(255, 255, 255, 0.15); /* More subtle border */
        padding: 12px 30px;
        border-radius: 16px;
        margin-bottom: 2.5rem;
        backdrop-filter: blur(10px); /* Increased blur */
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease;
      }

      .hero-badge:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.3);
      }

      .badge-main {
        font-family: var(--font-heading);
        font-weight: 800;
        font-size: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #ffffff;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        line-height: 1.1;
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .badge-icon-img {
        width: 50px; /* Slightly larger for visibility */
        height: auto;
        filter: drop-shadow(
          0 2px 5px rgba(0, 0, 0, 0.3)
