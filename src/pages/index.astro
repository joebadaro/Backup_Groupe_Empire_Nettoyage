        font-size: clamp(3.5rem, 7vw, 6rem); /* Bigger, Bolder */
        margin-bottom: 2rem;
        line-height: 1; /* Tigher line height for punchier look */
        text-shadow: 0 10px 30px rgba(0, 0, 0, 0.3); /* Deep Shadow */
      }

      .hero-subtitle-group {
