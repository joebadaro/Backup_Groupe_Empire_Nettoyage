        display: block;
        border-radius: 24px; /* Slightly more rounded */
        box-shadow: 0 25px 50px rgba(0, 50, 100, 0.15); /* Stronger, more elegant shadow */
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* Elegant lift on hover */
      .quality-image-wrapper:hover .quality-img-full {
        transform: translateY(-10px);
        box-shadow: 0 30px 60px rgba(0, 50, 100, 0.12);
      }

      .quality-content-refined {
        padding: 3rem 2rem;
