---
import Layout from "../../layouts/Layout.astro";

const posts = [
  {
    slug: 'preparer-visite-nettoyage',
    title: '5 minutes pour préparer votre visite de nettoyage',
    excerpt: "Faut-il passer l'aspirateur ? Bouger les gros meubles ? Voici notre check-list simple pour un service efficace.",
    date: '12 Décembre 2024',
    category: 'Guide',
    icon: '📋'
  },
  {
    slug: 'frequence-nettoyage-tapis',
    title: 'À quelle fréquence devez-vous nettoyer vos tapis ?',
    excerpt: "Attendez-vous que le tapis soit sale visuellement ? C'est souvent trop tard. Voici les recommandations pour une maison saine.",
    date: '10 Décembre 2024',
    category: 'Santé',
    icon: '📅'
  },
  {
    slug: 'entretien-cuir-erreurs',
    title: "Cuir : Arrêtez d'utiliser des lingettes pour bébé !",
    excerpt: "Les produits hydratants de pharmacie encrassent les pores du cuir. Apprenez la vraie méthode d'entretien.",
    date: '08 Décembre 2024',
    category: 'Entretien',
    icon: '🛋️'
  },
  {
    slug: 'urine-animaux-tapis',
    title: 'Pourquoi l\'odeur d\'urine revient toujours ?',
    excerpt: 'Découvrez la science derrière les taches d\'urine. Comprenez pourquoi le vinaigre échoue et comment les enzymes détruisent l\'acide urique.',
    date: '17 Mars 2026',
    category: 'Animaux & Odeurs',
    icon: '🐶'
  },
  {
    slug: 'erreurs-taches-tapis',
    title: 'Le Guide Ultime pour Enlever les Taches',
    excerpt: 'Apprenez les gestes d\'urgence pour sauver votre tapis. Découvrez les erreurs fatales et comment traiter le vin rouge, café et sang.',
    date: '17 Mars 2026',
    category: 'Entretien',
    icon: '🛑'
  },
  {
    slug: 'nettoyage-vapeur-vs-location',
    title: 'Machine de Location vs Camion-Usine',
    excerpt: 'Pourquoi louer une machine de supermarché peut ruiner vos tapis. Comparatif technique avec le nettoyage professionnel.',
    date: '17 Mars 2026',
    category: 'Comparatif',
    icon: '🚛'
  }
];
---

<Layout
  title="Conseils de l'Expert | Groupe Nettoyage Empire"
  description="Conseils de l'Expert : astuces et guides pour l'entretien de vos tapis et le traitement des taches et odeurs. Méthodes professionnelles adaptées à Montréal et ses environs."
>
  <div class="page-header">
    <div class="container text-center fade-in-section">
      <h1 class="text-gradient">Conseils de l'Expert</h1>
      <p class="intro">Astuces, guides complets et recommandations pour préserver vos investissements.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      
      <div class="blog-grid fade-in-section delay-100">
        {posts.map(post => (
          <a href={`/conseils/${post.slug}`} class="blog-card">
            <div class="card-icon">{post.icon}</div>
            <div class="card-content">
              <span class="card-cat">{post.category}</span>
              <h3>{post.title}</h3>
              <p>{post.excerpt}</p>
              <span class="read-more">Lire l'article &rarr;</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-bg-light-blue);
    padding: 2.25rem 0 1.25rem;
    text-align: center;
    border-bottom: 1px solid #eee;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 0.5rem auto 0 auto;
    font-size: 1.2rem;
    color: var(--color-text-light);
  }

  /* Moins d'espace sous le titre : la classe .section ajoute 6rem en global.css */
  .section {
    padding-top: 0.75rem;
    padding-bottom: var(--spacing-lg, 4rem);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    padding: 0 0 2.5rem;
  }

  /* Dégradé bleu pâle : bandeau haut + corps très doux */
  .blog-card {
    background: linear-gradient(165deg, #f2f8fd 0%, #ffffff 52%, #e8f3fc 100%);
    border-radius: var(--border-radius-md);
    box-shadow: 0 4px 22px rgba(66, 133, 244, 0.06);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    border: 1px solid rgba(66, 133, 244, 0.12);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(66, 133, 244, 0.11);
    border-color: rgba(100, 181, 246, 0.45);
  }

  .card-icon {
    font-size: 2.35rem;
    background: linear-gradient(135deg, #a5c9f5 0%, #bbdefb 42%, #e3f2fd 78%, #f5f9ff 100%);
    padding: 1.15rem;
    text-align: center;
    line-height: 1;
  }

  .card-content {
    padding: 1.2rem 1.25rem 1.15rem;
  }

  .card-cat {
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 700;
    color: #4a7ebb;
    letter-spacing: 1px;
    margin-bottom: 0.5rem;
    display: block;
  }

  .blog-card h3 {
    color: var(--color-primary);
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .blog-card p {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.45;
    margin-bottom: 0.85rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .read-more {
    color: var(--color-primary);
    font-weight: bold;
    font-size: 0.84rem;
  }

  /* Mobile: cartes plus compactes (liste Conseils uniquement, ce fichier) */
  @media (max-width: 767px) {
    .page-header {
      padding: 1.75rem 0 1rem;
    }

    .section {
      padding-top: 0.5rem;
      padding-bottom: 2rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      gap: 0.65rem;
      padding: 0 0 1.5rem;
    }

    .blog-card {
      border-radius: 10px;
    }

    .card-icon {
      font-size: 1.45rem;
      padding: 0.5rem 0.65rem;
    }

    .card-content {
      padding: 0.7rem 0.85rem 0.65rem;
    }

    .card-cat {
      font-size: 0.62rem;
      letter-spacing: 0.06em;
      margin-bottom: 0.2rem;
    }

    .blog-card h3 {
      font-size: 0.95rem;
      margin-bottom: 0.3rem;
      line-height: 1.28;
    }

    .blog-card p {
      font-size: 0.8125rem;
      line-height: 1.36;
      margin-bottom: 0.4rem;
      -webkit-line-clamp: 2;
    }

    .read-more {
      font-size: 0.76rem;
    }
  }
</style>
