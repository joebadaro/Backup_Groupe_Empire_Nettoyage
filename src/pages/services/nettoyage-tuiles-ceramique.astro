---
import Layout from "../../layouts/Layout.astro";
import FAQSchema from "../../components/FAQSchema.astro";
---

<Layout
  title="Nettoyage de Tuiles et Coulis | Montréal, Laval & Rive-Sud"
  description="Expert en nettoyage de céramique et joints à haute pression. Élimination du gras, moisissure et application de scellant protecteur. Service résidentiel & commercial."
>
  <!-- SPLIT SCREEN HERO: BLOCK 1 -->
  <div class="split-hero-container mobile-hero-stack">
    <div class="container full-width-split">
      <div class="split-layout">
        <!-- LEFT COLUMN: CONTENT -->
        <div class="split-content fade-in-section">
          <span class="service-cat-badge">PLANCHERS & SURFACES</span>
          <h1 class="split-title fade-in-up text-gradient-empire">
            Nettoyage de Tuiles & joints (Coulis)
          </h1>

          <div class="mobile-hero-slideshow fade-in-up delay-050">
            <div class="slideshow-container">
              <img
                src="/images/catalog/tuile-optimized.webp"
                alt="Nettoyage professionnel de tuiles et joints de céramique - Résultat impeccable"
                class="slide active"
                width="1200"
                height="800"
                loading="eager"
              />
              <img
                src="/images/catalog/tuile-slide-new-2.webp"
                alt="Nettoyage professionnel plancher céramique Laval - Groupe Empire"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile-slide-new-3.webp"
                alt="Cuisine céramique impeccable Rive-Sud - Nettoyage joints profond"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile2-optimized.webp"
                alt="Plancher de céramique nettoyé et restauré par des professionnels - Montréal"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile3-v3.webp"
                alt="Nettoyage haute pression de tuiles et joints - Résultat impeccable"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
              <img
                src="/images/catalog/tuile-before-after-v3.webp"
                alt="Avant et après nettoyage de joints de céramique très encrassés"
                class="slide"
                width="1200"
                height="800"
                loading="lazy"
              />
            </div>
            <div class="image-overlay-gradient"></div>
          </div>

          <div class="problem-statement fade-in-up delay-100">
            <h3 class="problem-title">Le Problème :</h3>
            <p class="problem-text">
              Vos joints sont devenus noirs ou gris ? La moppe ne fait que déplacer la saleté 
              dans les pores du coulis. Sans un nettoyage à haute pression, les bactéries et 
              le gras s'accumulent, rendant vos planchers ternes et insalubres.
            </p>
          </div>

          <p class="lead-text fade-in-up delay-200">
            Retrouvez l'aspect original de vos sols. Notre technologie turbo à <strong>haute pression 
            contrôlée</strong> désincruste les joints en profondeur et redonne tout son éclat à votre 
            céramique, sans éclaboussures et avec un séchage quasi immédiat.
          </p>

          <div class="cta-group fade-in-up delay-300">
            <a href="tel:5148939939" class="btn btn-primary pulse-btn">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <button
              onclick="window.openEstimationWidget()"
              class="btn btn-outline-reveal"
            >
              <span class="icon">⚡</span> Estimation Instantanée
            </button>
          </div>
        </div>

        <!-- RIGHT COLUMN: IMAGE -->
        <div class="split-image-wrapper fade-in-section delay-200">
          <div class="slideshow-container">
            <img
              src="/images/catalog/tuile-optimized.webp"
              alt="Nettoyage professionnel de tuiles et joints de céramique - Résultat impeccable"
              class="slide active"
              width="1200"
              height="800"
              fetchpriority="high"
              loading="eager"
            />
            <img
              src="/images/catalog/tuile-slide-new-2.webp"
              alt="Nettoyage professionnel plancher céramique Laval - Groupe Empire"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-slide-new-3.webp"
              alt="Cuisine céramique impeccable Rive-Sud - Nettoyage joints profond"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile2-optimized.webp"
              alt="Plancher de céramique nettoyé et restauré par des professionnels - Montréal"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile3-v3.webp"
              alt="Nettoyage haute pression de tuiles et joints - Résultat impeccable"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
            <img
              src="/images/catalog/tuile-before-after-v3.webp"
              alt="Avant et après nettoyage de joints de céramique très encrassés"
              class="slide"
              width="1200"
              height="800"
              loading="lazy"
            />
          </div>
          <div class="image-overlay-gradient"></div>
        </div>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="service-layout">
        <!-- MAIN CONTENT -->
        <div class="service-main">
          
          <div class="fade-in-section delay-100" style="margin-top: 0;">
            <h2 class="section-title text-gradient-empire">
              Notre Processus Turbo (Haute Pression)
            </h2>
            <div class="process-timeline" style="margin-bottom: 3rem;">
              <div class="process-step">
                <div class="step-marker">1</div>
                <div class="step-content">
                  <h3>Inspection et Prétraitement</h3>
                  <p>Identification du type de tuile (céramique, porcelaine, pierre naturelle) et application d'un agent nettoyant alcalin spécifiquement conçu pour désagréger les graisses et les résidus de savon.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">2</div>
                <div class="step-content">
                  <h3>Agitation Mécanique des Joints</h3>
                  <p>Nous utilisons des brosses spécialisées pour frotter vigoureusement chaque ligne de coulis. Cette action mécanique est essentielle pour libérer la saleté noire incrustée avant l'aspiration.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">3</div>
                <div class="step-content">
                  <h3>Lavage Turbo Haute Pression (200°F)</h3>
                  <p>Notre machine projette de l'eau chaude pressurisée à l'intérieur d'une tête rotative fermée. Elle nettoie et aspire simultanément, garantissant zéro éclaboussure sur vos murs ou vos armoires.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">4</div>
                <div class="step-content">
                  <h3>Neutralisation et Séchage</h3>
                  <p>Un rinçage final au pH équilibré élimine tout résidu collant. Nous utilisons ensuite des ventilateurs haute puissance pour assurer un séchage rapide, prêt pour l'étape finale.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-marker">5</div>
                <div class="step-content">
                  <h3>Protection (Scellant de Coulis)</h3>
                  <p>Optionnel mais vital : nous appliquons un scellant protecteur professionnel qui pénètre les pores du coulis pour le rendre imperméable, empêchant ainsi la saleté de s'incruster à nouveau.</p>
                </div>
              </div>
            </div>

            <div class="info-box fade-in-section delay-100">
              <h3 style="color: var(--color-primary); margin-bottom: 10px;">
                Pourquoi vos joints redeviennent noirs si vite ?
              </h3>
              <p>
                Le coulis est comme une éponge : il est extrêmement poreux. Lorsque vous lavez votre plancher à la moppe, l'eau sale finit par s'accumuler dans les « creux » des joints. Une fois l'eau évaporée, seule la saleté reste au fond. 
                Seul un nettoyage par extraction à haute pression peut "vider" ces pores. L'application d'un **scellant protecteur** après le nettoyage est le meilleur investissement pour garder vos joints blancs pendant des années.
              </p>
            </div>
          </div>

          <!-- BENEFITS SECTION -->
          <div class="fade-in-section delay-200" style="margin-top: 4rem;">
            <h2 class="section-title text-gradient-empire">
              Avantages de notre nettoyage professionnel
            </h2>
            <div class="benefits-grid">
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Hygiène Totale :</strong> Élimine les bactéries, les moisissures et les allergènes logés dans les joints poreux.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Plancher comme neuf :</strong> Retrouvez la couleur d'origine de votre coulis sans le brosser vous-même pendant des heures.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Zéro éclaboussure :</strong> Notre équipement rotatif contient toute l'eau et l'aspiration à l'intérieur de la tête de nettoyage.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Protection durable :</strong> Nos scellants de haute qualité facilitent vos futurs nettoyages domestiques.</span>
              </div>
              <div class="benefit-item">
                <div class="check-circle">✓</div>
                <span><strong>Service rapide :</strong> Une cuisine standard est nettoyée et protégée en seulement 2 à 3 heures.</span>
              </div>
            </div>
          </div>

          <!-- ZONES DESSERVIES -->
          <div class="zones-section" style="margin-top: 4rem; margin-bottom: 3rem;">
            <h3 style="color: var(--color-primary); margin-bottom: 1rem; font-size: 1.4rem;">Zones desservies — Tuiles et Céramique</h3>
            <p>Nous desservons tout le Grand Montréal avec nos unités mobiles haute performance.</p>

            <div class="city-group">
                <p class="city-lead">🏙️ Montréal (Est et Ouest)</p>
                <div class="badges-container">
                    <span class="badge badge-blue">📍 Montréal</span>
                    <span class="badge badge-blue">📍 Westmount</span>
                    <span class="badge badge-blue">📍 Mont-Royal</span>
                    <span class="badge badge-blue">📍 Outremont</span>
                    <span class="badge badge-blue">📍 LaSalle</span>
                    <span class="badge badge-blue">📍 Ahuntsic</span>
                </div>
            </div>

            <div class="city-group">
                <p class="city-lead">🏘️ Laval</p>
                <div class="badges-container">
                    <span class="badge badge-blue">📍 Laval (tous quartiers)</span>
                    <span class="badge badge-blue">📍 Chomedey</span>
                    <span class="badge badge-blue">📍 Duvernay</span>
                    <span class="badge badge-blue">📍 Fabreville</span>
                </div>
            </div>

            <div class="city-group">
                <p class="city-lead">🌿 Rive-Sud de Montréal</p>
                <div class="badges-container">
                    <span class="badge badge-green">📍 Longueuil</span>
                    <span class="badge badge-green">📍 Brossard</span>
                    <span class="badge badge-green">📍 Saint-Hubert</span>
                    <span class="badge badge-green">📍 Boucherville</span>
                    <span class="badge badge-green">📍 Saint-Lambert</span>
                </div>
            </div>
          </div>

          <!-- FAQ SECTION -->
          <div class="fade-in-section delay-300" style="margin-top: 3rem;">
              <h2 class="section-title text-gradient-empire">
                  Questions Fréquentes — Tuiles & Coulis
              </h2>
              <FAQSchema
                  faqs={[
                      {
                          question: "Combien de temps faut-il attendre avant de marcher sur le plancher ?",
                          answer: "Grâce à notre aspiration puissante, le plancher est sec au toucher presque immédiatement. Cependant, si nous appliquons un scellant protecteur, nous recommandons d'attendre environ 2 à 4 heures avant de marcher dessus avec des chaussures, et 24 heures avant de passer la moppe avec de l'eau.",
                      },
                      {
                          question: "Est-ce que votre machine va envoyer de l'eau sur mes armoires de cuisine ?",
                          answer: "Pas du tout. Nous utilisons un outil 'Turbo' qui est une cloche fermée hermétique. L'eau à haute pression est projetée à l'intérieur de cette cloche et aspirée instantanément par le vide. Vos murs, plinthes et armoires restent parfaitement secs du début à la fin.",
                      },
                      {
                          question: "Pouvez-vous nettoyer les joints de douche moisis ?",
                          answer: "Oui, nous pouvons éliminer la moisissure de surface et les résidus de savon. Cependant, si la moisissure a pénétré *derrière* le coulis ou si le silicone est noirci en profondeur, le nettoyage ne suffira pas; un remplacement du joint de silicone (calfeutrant) pourrait être nécessaire.",
                      },
                      {
                          question: "Quelle est la différence entre un nettoyage vapeur et votre méthode ?",
                          answer: "La vapeur seule manque souvent de force d'impact pour déloger le gras durci. Notre système combine la chaleur (200°F), une pression contrôlée (800-1200 PSI) et une aspiration industrielle. C'est la combinaison de ces trois forces qui permet d'extraire la saleté du fond du coulis.",
                      },
                      {
                          question: "Est-ce que le scellant change la couleur de mes joints ?",
                          answer: "Nous utilisons généralement un scellant pénétrant invisible qui ne change pas l'apparence naturelle de vos joints. Il protège de l'intérieur. Si vous souhaitez changer la couleur de vos joints, il existe des scellants colorés (ColorSeal), mais c'est un service spécialisé distinct.",
                      },
                      {
                          question: "Nettoyez-vous aussi les dosserets de cuisine (backsplashes) ?",
                          answer: "Oui ! Nous utilisons des outils à main plus petits, spécialement conçus pour les surfaces verticales, afin de nettoyer vos dosserets et vos murs de douche avec la même efficacité que vos planchers.",
                      },
                  ]}
              />
          </div>

        </div>

        <!-- SIDEBAR -->
        <aside class="service-sidebar">
          <div class="sticky-card fade-in-section">
            <h3 class="card-title text-gradient-gold">Estimation Gratuite</h3>
            <p class="card-desc">Redonnez l'éclat à vos planchers dès aujourd'hui.</p>
            <a href="tel:5148939939" class="btn btn-gradient-green full-width pop-effect pulse-phone">
              <span class="icon">📞</span> (514) 893-9939
            </a>
            <div style="margin: 1rem 0; text-align: center; color: #888; font-size: 0.9rem;">ou</div>
            <button onclick="window.openEstimationWidget()" class="btn btn-gradient-green full-width">
              Estimation Instantanée
            </button>
            <div class="guarantee-badge">
              <span>💎 Joints Protégés & Imperméables</span>
              <div style="margin-top: 5px; color: #ffbf00; font-weight: bold;">★★★★★</div>
              <span style="font-size: 0.8rem; color: #666;">Service Pro & Propre</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<script is:inline>
  (function () {
    document.querySelectorAll(".slideshow-container").forEach((container) => {
      const slides = container.querySelectorAll(".slide");
      if (slides.length <= 1) return;
      let currentSlide = 0;
      setInterval(() => {
        slides[currentSlide].classList.remove("active");
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].classList.add("active");
      }, 4000);
    });
  })();
</script>

  <style>
    /* HERO */
    /* SPLIT SCREEN HERO (Sky Blue Theme) */
    .split-hero-container {
      background-color: #fff; /* Reset container to white */
      padding-top: 0; /* Remove container padding so image hits top */
      padding-bottom: 0;
      overflow: hidden; /* CRITICAL: Prevent slides from spilling out */
      width: 100vw;
    }
    .full-width-split {
      width: 100%;
      max-width: none;
      padding: 0;
      margin: 0;
    }
    .split-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      align-items: stretch;
      min-height: 80vh; /* Consistent viewport height */
    }
    /* LEFT TEXT COLUMN */
    .split-content {
      /* Background handled by utility class */
      padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      z-index: 2;
    }
    .service-cat-badge {
      text-transform: uppercase;
      color: var(--color-accent);
      font-weight: 700;
      letter-spacing: 2px;
      font-size: 0.85rem;
      display: block;
      margin-bottom: 1rem;
    }
    .split-title {
      font-size: clamp(2.5rem, 3.5vw, 4rem);
      color: var(--color-primary); /* Dark Blue text */
      margin-bottom: 2rem;
      line-height: 1.1;
    }
    .problem-statement {
      background: #ffffff;
      border-left: 4px solid #ff4444;
      padding: 1.5rem;
      border-radius: 4px; /* Slight radius */
      margin-bottom: 2rem;
      box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3);
    }
    .problem-title {
      color: #cc0000;
      font-weight: 800;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      font-size: 1.1rem; /* Adjusted for visibility */
      display: block;
    }
    .lead-text {
      font-size: 1.15rem;
      line-height: 1.7;
      color: var(--color-text-main); /* Dark grey text */
      margin-bottom: 2.5rem;
      max-width: 650px;
    }
    .cta-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }
    @media (max-width: 900px) {
      .cta-group {
        display: none !important;
      }
    }
    /* RIGHT IMAGE COLUMN */
    .split-image-wrapper {
      position: relative;
      height: 100%;
      min-height: 500px;
      width: 100%;
      margin: 0;
      background-color: #f0f0f0; /* Slight gray background while loading */
      overflow: hidden; /* Ensure blur doesn't bleed */
    }
    /* Slideshow Styles */
    .slideshow-container {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden; /* CRITICAL: Prevent slides from spilling out */
    }
    .slide {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover; /* RESTORED TO COVER AS REQUESTED */
      opacity: 0;
      transition: opacity 1.5s ease-in-out;
      z-index: 1;
    }
    .slide.active {
      opacity: 1;
      z-index: 2;
    }
    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .split-layout {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .lead-text {
        max-width: 100%;
      }
    }
    /* LAYOUT */
    .service-layout {
      display: grid;
      grid-template-columns: 1.8fr 1fr;
      gap: 5rem;
    }
    /* TYPOGRAPHY */
    .section-title {
      font-size: 1.8rem;
      color: var(--color-primary);
      margin-bottom: 1.5rem;
      border-bottom: 2px solid #eee;
      padding-bottom: 0.5rem;
      display: inline-block;
    }
    /* Benefit List Styles from original */
    .benefit-list {
      margin: 2rem 0;
      list-style: none; /* Ensure no default bullets */
      padding: 0;
    }
    .benefit-list li {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
      position: relative;
      font-size: 1.05rem;
    }
    .benefit-list li::before {
      content: "✓";
      color: #d32f2f; /* Empire Red or Gold */
      position: absolute;
      left: 0;
      font-weight: bold;
    }
    .info-box {
      background-color: #f8f9fa;
      border-left: 4px solid var(--color-accent);
      padding: 1.5rem;
      margin: 2rem 0;
      border-radius: 4px;
    }
    /* NEW BUTTON STYLE */
    .btn-outline-reveal {
      background: transparent;
      border: 2px solid var(--color-primary);
      color: var(--color-primary);
      padding: 0.75rem 1.5rem; /* Nice padding */
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      border-radius: 4px; /* Rounded corners */
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .btn-outline-reveal:hover {
      background: var(--color-primary);
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }
    .seo-content-hidden {
      display: none;
      margin-top: 2rem;
      padding-top: 1rem;
      animation: fadeIn 0.5s ease-in-out;
    }
    .seo-content-hidden.visible {
      display: block;
    }
    /* Animation */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .separator {
      border: 0;
      height: 1px;
      background: rgba(0, 0, 0, 0.1);
      margin: 1.5rem 0;
    }
    /* SIDEBAR */
    .service-sidebar {
      position: relative;
    }
    .sticky-card {
      background: white;
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      position: sticky;
      top: 2rem;
      border: 1px solid #eee;
    }
    .card-title {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
      font-weight: 800;
    }
    .card-desc {
      color: #666;
      margin-bottom: 1.5rem;
      font-size: 0.95rem;
    }
    .full-width {
      width: 100%;
      margin-bottom: 0.5rem;
      justify-content: center;
    }
    .guarantee-badge {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px dashed #eee;
      text-align: center;
      font-size: 0.9rem;
      color: var(--color-accent);
      font-weight: 600;
    }
    @media (max-width: 900px) {
      .service-layout {
        grid-template-columns: 1fr;
      }
    }
    
    /* Utility class to prevent aggressive zooming on specific images */
    .img-contain {
      object-fit: contain !important;
      background-color: transparent !important;
    }
  </style>
</Layout>
