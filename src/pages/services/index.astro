---
import Layout from "../../layouts/Layout.astro";

const services = [
  {
    slug: "meubles-tissu",
    title: "Sofa, divan, fauteuil, chaise, meubles en tissu",
    desc: "Nettoyage en profondeur pour sofas, divans et fauteuils en tissu.",
    img: "/images/services/services-4.webp",
  },
  {
    slug: "meubles-cuir",
    title: "Nettoyage de meubles en cuir",
    desc: "Soin hydratant et nettoyant spécialisé pour tous vos cuirs.",
    img: "/images/catalog/photo-leather-final.webp",
  },
  {
    slug: "nettoyage-desinfection-matelas",
    title: "Nettoyage et désinfection de matelas",
    desc: "Élimination des acariens et allergènes pour un sommeil sain.",
    img: "/images/catalog/photo-matelas-custom.webp",
  },

  {
    slug: "nettoyage-tapis-residentiel",
    title: "Nettoyage de tapis résidentiel",
    desc: "Tapis mur-à-mur et carpettes pour la maison.",
    img: "/images/catalog/photo-tapis-clean.webp",
  },
  {
    slug: "nettoyage-tapis-commercial",
    title: "Nettoyage de tapis commercial",
    desc: "Solutions pour bureaux et grands espaces.",
    img: "/images/catalog/tapis-commercial-combo.webp",
  },
  {
    slug: "tapis-synthetique",
    title: "Nettoyage de tapis synthétique à domicile",
    desc: "Technique adaptée aux fibres modernes et résistantes.",
    img: "/images/catalog/photo-47.webp",
  },

  {
    slug: "tapis-laine",
    title: "Nettoyage de tapis en laine à domicile",
    desc: "Traitement délicat pH neutre pour la laine naturelle.",
    img: "/images/catalog/photo-22.webp",
  },
  {
    slug: "tapis-orientaux",
    title: "Nettoyage de tapis orientaux à domicile",
    desc: "Restauration experte pour tapis persans et orientaux.",
    img: "/images/catalog/photo-oriental-custom.webp",
  },
  {
    slug: "nettoyage-tuiles-ceramique",
    title: "Nettoyage Tuiles & Céramique",
    desc: "Décapage et nettoyage haute pression des joints et tuiles.",
    img: "/images/catalog/photo-78.webp",
  },

  {
    slug: "protecteur",
    title: "Application de protecteurs antitâches",
    desc: "Protection Teflon/Scotchgard pour tissus, cuirs et tapis.",
    img: "/images/catalog/photo-20.webp",
  },
];
---

<Layout
  title="Nos Services | Groupe Nettoyage Empire"
  description="Découvrez nos services de nettoyage professionnel : tapis, divans, matelas, meubles en cuir, céramique et protecteurs antitâches. Techniciens certifiés pour Montréal, Laval et la Rive-Sud."
>
  <div class="page-header">
    <div class="container fade-in-section">
      <h1 class="text-gradient">Nos Services</h1>
      <p class="intro">
        Découvrez notre gamme complète de services de nettoyage professionnel.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      
      <!-- SEO INTRO -->
      <div class="seo-intro-block fade-in-section">
        <h2 class="text-gradient-empire" style="margin-bottom: 1rem; font-size: 1.8rem;">Experts en Assainissement de Fibres</h2>
        <p>
          Depuis plus de trois décennies, <strong>Groupe Nettoyage Empire</strong> se positionne comme le chef de file du nettoyage professionnel à l'extraction à l'eau chaude (vapeur) dans la grande région de Montréal. De la restauration minutieuse de tapis d'orient tissés à la main au grand nettoyage commercial de vos immeubles à bureaux, nos techniciens certifiés déploient un arsenal de plus de 40 solutions nettoyantes écologiques et d'équipements haute performance (camions-usines) pour garantir un résultat dépassant systématiquement les standards de l'industrie.
        </p>
      </div>

      <div class="services-grid fade-in-section delay-100" style="margin-top: 3rem;">
        {
          services.map((service) => (
            <a
              href={`/services/${service.slug}`}
              class="service-card"
              style={`--card-bg: url('${service.img}');`}
            >
              <div class="card-overlay" />
              <div class="card-content">
                <h3>{service.title}</h3>
                <p>{service.desc}</p>
                <span class="more">En savoir plus &rarr;</span>
              </div>
            </a>
          ))
        }
      </div>

      <!-- SEO CONCLUSION -->
      <div class="seo-text-block fade-in-section delay-200" style="margin-top: 5rem;">
        <h2 class="text-gradient-empire" style="margin-bottom: 1rem; font-size: 1.8rem;">Des Solutions Adaptées à Chaque Défi</h2>
        <p style="margin-bottom: 1rem;">
          L'entretien de vos revêtements textiles n'est pas qu'une question d'esthétique : c'est une question de santé respiratoire. Un nettoyage résidentiel ou commercial exécuté dans les règles de l'art par des <strong>nettoyeurs certifiés</strong> permet d'extraire les acariens, les peaux mortes, le pollen et les bactéries incrustées profondément dans l'assise de vos sofas en tissu, de vos matelas et de vos carpettes. 
        </p>
        <p style="margin-bottom: 1rem;">
          Contrairement aux méthodes grand public ou à la location de machines de supermarché qui laissent vos fibres détrempées et gorgées de résidus savonneux toxiques, notre procédé d'injection-extraction garantit un rinçage parfait et un <strong>séchage rapide</strong> en quelques heures seulement.
        </p>
        <div class="areas-served-inline" style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; border-left: 4px solid var(--color-primary); margin-top: 2rem;">
          <h3 style="color: var(--color-primary); font-size: 1.1rem; margin-bottom: 0.5rem;">Déploiement sur le Grand Montréal</h3>
          <p style="font-size: 0.95rem; color: var(--color-text-main); margin: 0;">
            Nos unités mobiles de nettoyage desservent avec fierté toute l'<strong>Île de Montréal</strong> (Centre-ville, Ahuntsic, Lasalle, Westmount), <strong>Laval</strong> (Chomedey, Sainte-Rose) ainsi que la <strong>Rive-Sud</strong> (Longueuil, Brossard, Boucherville, Saint-Lambert). Consultez les pages individuelles ci-dessus pour obtenir votre estimation gratuite et sur mesure.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background-color: var(--color-primary);
    background-image: linear-gradient(135deg, #0a2342 0%, #121212 100%);
    padding: 6rem 0 4rem 0; /* More balanced padding */
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    position: relative;
    overflow: hidden;
  }

  /* Optional decorative accent */
  .page-header::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.3),
      transparent
    );
  }

  .section {
    padding: 4rem 0;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 1.5rem auto 0 auto;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.85); /* Proper contrast text */
    font-weight: 300;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background-color: white;
    padding: 0;
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-subtle);
    transition: transform 0.2s;
    border: 1px solid #eee;
    display: block;
    color: inherit;
    position: relative;
    overflow: hidden;
    height: 100%;
    min-height: 250px;
    z-index: 0; /* Create stacking context */
  }

  /* Layer 1: Blurred Background (Fills the card) */
  .service-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--card-bg);
    background-size: cover;
    background-position: center;
    filter: blur(15px);
    transform: scale(1.2); /* Prevent blur edges from showing */
    opacity: 0.6;
    z-index: 1;
  }

  /* Layer 2: Sharp Image (Contained and centered) */
  .service-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--card-bg);
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    z-index: 2;
  }

  /* Layer 3: White overlay for readability */
  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.75); /* Slightly stronger base opacity */
    z-index: 3;
    transition: background 0.3s;
  }

  .service-card:hover .card-overlay {
    background: rgba(255, 255, 255, 0.6); /* Reveal more image on hover */
  }

  .card-content {
    position: relative;
    z-index: 4;
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .service-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-hover);
  }

  .service-card h3 {
    color: var(--color-primary);
    margin-bottom: 1rem;
    font-size: 1.2rem;
    font-weight: 800;
    text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
  }

  .service-card p {
    flex-grow: 1;
    color: #444;
    font-weight: 500;
  }

  .more {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-accent);
    font-weight: bold;
    font-size: 0.9rem;
  }
</style>
