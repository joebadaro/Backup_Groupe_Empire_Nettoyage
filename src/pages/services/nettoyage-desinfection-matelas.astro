---
import Layout from "../../layouts/Layout.astro";
import FAQSchema from "../../components/FAQSchema.astro";
---

<Layout
    title="Nettoyage de Matelas à Domicile"
    description="Service professionnel de nettoyage et désinfection de matelas à domicile. Élimine acariens, taches et mauvaises odeurs. Produits écologiques."
>
    <!-- SPLIT SCREEN HERO: BLOCK 1 -->
    <div class="split-hero-container">
        <div class="container full-width-split">
            <div class="split-layout">
                <!-- LEFT COLUMN: CONTENT -->
                <div class="split-content fade-in-section bg-gradient-premium">
                    <span class="service-cat-badge">MEUBLES</span>
                    <h1 class="split-title fade-in-up text-gradient-empire">
                        Nettoyage & Désinfection de Matelas
                    </h1>

                    <!-- BLOCK 1: INTRO (VISIBLE) -->
                    <div class="problem-statement fade-in-up delay-100">
                        <h3 class="problem-title">Le Problème :</h3>
                        <p class="problem-text">
                            Vous souffrez d'allergies, de congestion nasale le
                            matin ou votre matelas présente des cernes jaunâtres
                            ? L'aspirateur seul ne suffit pas à éliminer les
                            acariens incrustés et les bactéries.
                        </p>
                    </div>

                    <p class="lead-text fade-in-up delay-200">
                        Passez un tiers de votre vie dans un environnement sain.
                        Nous offrons un service complet de <strong
                            >nettoyage et désinfection de matelas à domicile</strong
                        > qui élimine les allergènes, les taches et les odeurs pour
                        bon.
                    </p>

                    <div class="cta-group fade-in-up delay-300">
                        <a
                            href="tel:5148939939"
                            class="btn btn-gradient-green pulse-btn"
                        >
                            <span class="icon">📞</span> (514) 893-9939
                        </a>
                        <button
                            onclick="window.openEstimationWidget()"
                            class="btn btn-gradient-green"
                        >
                            <span class="icon">⚡</span> Estimation Instantanée en
                            Ligne
                        </button>
                    </div>
                </div>

                <!-- RIGHT COLUMN: IMAGE -->
                <div class="split-image-wrapper fade-in-section delay-200">
                    <div class="slideshow-container">
                        <img
                            src="/images/catalog/photo-matelas-2.webp"
                            alt="Nettoyage désinfection matelas à domicile Montréal - Élimination acariens"
                            class="slide active"
                            width="1200"
                            height="800"
                            fetchpriority="high"
                            loading="eager"
                        />
                        <img
                            src="/images/catalog/photo-matelas-6.webp"
                            alt="Service nettoyage matelas professionnel Laval - Groupe Empire"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                        <img
                            src="/images/catalog/photo-matelas-8.webp"
                            alt="Désinfection matelas écologique Rive-Sud - Sommeil sain"
                            class="slide"
                            width="1200"
                            height="800"
                            loading="lazy"
                        />
                    </div>
                    <div class="image-overlay-gradient"></div>
                </div>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="container">
            <div class="service-layout" style="display: block;">
                <!-- MAIN CONTENT (Centered, No Sidebar) -->
                <div
                    class="service-main"
                    style="max-width: 800px; margin: 0 auto;"
                >
                    <div class="fade-in-section delay-100">
                        <!-- TOGGLE BUTTON (INITIAL VIEW) -->
                        <div style="margin-top: 1rem;">
                            <button
                                id="toggle-seo-btn"
                                class="btn-outline-reveal"
                            >
                                En savoir plus sur la désinfection de matelas ▼
                            </button>
                        </div>

                        <!-- HIDDEN CONTENT: PROCESS -> LIST -> PROTECTION -->
                        <div id="seo-content" class="seo-content-hidden">
                            <hr class="separator" />
                            <h3 style="color: var(--color-primary);">
                                Un sommeil sain commence par un matelas propre
                            </h3>
                            <p>
                                Un matelas propre est essentiel pour un sommeil
                                sain et réparateur. Chez <strong
                                    >Groupe Nettoyage Empire</strong
                                >, nous offrons un service professionnel de <strong
                                    >nettoyage de matelas à domicile</strong
                                > à <strong>Montréal</strong>, <strong
                                    >Laval</strong
                                > et sur la <strong>Rive-Sud</strong>, conçu
                                pour éliminer poussière, taches, acariens et
                                allergènes incrustés dans les fibres.
                            </p>
                            <p style="margin-top: 1rem;">
                                Grâce à notre <strong
                                    >technologie de nettoyage en profondeur</strong
                                >, nous utilisons des méthodes sécuritaires et
                                écologiques qui désinfectent efficacement sans
                                produits chimiques agressifs. Ce procédé permet
                                de neutraliser les bactéries et les mauvaises
                                odeurs tout en prolongeant la durée de vie de
                                votre matelas.
                            </p>
                            <p style="margin-top: 1rem;">
                                Notre équipe de spécialistes adapte le
                                traitement en fonction du type de matelas – <strong
                                    >mousse mémoire, latex, hybride ou ressorts</strong
                                > – pour préserver sa qualité et son confort.
                            </p>

                            <!-- Floating Sleep Image -->
                            <div class="floating-img-container fade-in-section">
                                <img
                                    src="/images/catalog/photo-matelas-floating.webp"
                                    alt="Sommeil réparateur matelas propre Longueuil - Santé et confort"
                                    class="floating-img"
                                    width="1200"
                                    height="675"
                                    loading="lazy"
                                />
                            </div>
                            <br />

                            <h3
                                class="section-title text-gradient-empire"
                                style="font-size: 1.5rem; margin-bottom: 1rem;"
                            >
                                Les avantages de notre service :
                            </h3>
                            <ul class="benefit-list">
                                <li>
                                    <strong
                                        >Élimination des acariens et allergènes</strong
                                    >
                                </li>
                                <li>
                                    <strong>Désinfection complète</strong> pour un
                                    environnement plus sain
                                </li>
                                <li>
                                    <strong>Séchage rapide</strong> et résultat impeccable
                                </li>
                                <li>
                                    <strong>Produits sécuritaires</strong> pour toute
                                    la famille
                                </li>
                            </ul>

                            <!-- Additional Image -->
                            <div
                                class="fade-in-section"
                                style="margin: 2rem 0; text-align: center;"
                            >
                                <img
                                    src="/images/catalog/photo-matelas-1.webp"
                                    alt="Technicien nettoyant matelas Montréal - Service professionnel à domicile"
                                    class="rounded-img shadow-premium"
                                    style="width: 100%; max-width: 600px; border-radius: 8px;"
                                    width="1200"
                                    height="800"
                                    loading="lazy"
                                />
                            </div>
                            <!-- BLOCK 4: PROTECTION - REMOVED AS REQUESTED -->
                            <br />
                            <!-- BLOCK 6 -->
                            <p>
                                Améliorez la qualité de votre sommeil et la
                                propreté de votre maison grâce au nettoyage de
                                matelas professionnel de <strong
                                    >Groupe Nettoyage Empire</strong
                                >.
                            </p>
                            <p style="margin-top: 0.5rem;">
                                Contactez-nous dès aujourd'hui pour un <strong
                                    >devis rapide</strong
                                > et un service de confiance.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- NEW SECTIONS: BENEFITS & FAQ -->
    <section class="section" style="padding-top: 0;">
        <div class="container">
            <div class="service-layout" style="display: block;">
                <!-- Full width for these bottom sections -->
                <div
                    class="service-main"
                    style="max-width: 800px; margin: 0 auto;"
                >
                    <!-- BENEFITS -->
                    <div
                        class="fade-in-section delay-200"
                        style="margin-top: 3rem;"
                    >
                        <h2 class="section-title text-gradient-empire">
                            Pourquoi nous choisir ?
                        </h2>
                        <div class="benefits-grid">
                            <div class="benefit-item">
                                <div class="check-circle">✓</div>
                                <span
                                    >Élimination 99% allergènes & acariens</span
                                >
                            </div>
                            <div class="benefit-item">
                                <div class="check-circle">✓</div>
                                <span>Désinfection écologique sans odeur</span>
                            </div>
                            <div class="benefit-item">
                                <div class="check-circle">✓</div>
                                <span>Séchage rapide (quelques heures)</span>
                            </div>
                        </div>
                    </div>

                    <!-- FAQ with Schema Component -->
                    <FAQSchema
                        faqs={[
                            {
                                question:
                                    "Comment éliminer les acariens d'un matelas efficacement ?",
                                answer: "L'élimination des acariens nécessite une approche en deux étapes : désinfection et extraction profonde. Chez Groupe Nettoyage Empire, nous utilisons un procédé spécialisé qui combine l'injection de solutions anti-acariens écologiques avec une extraction à haute puissance. Cette méthode élimine jusqu'à 99% des acariens, leurs déjections et les allergènes associés. Contrairement à un simple aspirateur ou aux produits en aérosol, notre technique agit en profondeur dans toutes les couches du matelas. Le traitement est complété par une désinfection qui crée un environnement hostile aux acariens, réduisant significativement leur réapparition. Pour les personnes allergiques, nous recommandons un nettoyage annuel ou bi-annuel.",
                            },
                            {
                                question:
                                    "Combien de temps faut-il pour qu'un matelas sèche après un nettoyage professionnel ?",
                                answer: "Un matelas nettoyé professionnellement avec notre méthode d'injection-extraction sèche généralement en 4 à 6 heures. Notre équipement à haute succion extrait 95% de l'humidité immédiatement après le traitement, laissant le matelas seulement légèrement humide au toucher. Le temps de séchage peut varier selon le type de matelas (mousse mémoire, ressorts, latex), l'épaisseur, et les conditions de ventilation de la chambre. Pour accélérer le séchage, nous recommandons d'ouvrir les fenêtres et d'utiliser un ventilateur. Contrairement aux méthodes à saturation complète, vous pouvez généralement réutiliser votre lit le soir même.",
                            },
                            {
                                question:
                                    "Le nettoyage de matelas peut-il vraiment éliminer les taches d'urine et les odeurs ?",
                                answer: "Oui, absolument. Les taches et odeurs d'urine nécessitent un traitement enzymatique spécifique que nous maîtrisons parfaitement. Les enzymes décomposent les cristaux d'acide urique qui causent les odeurs persistantes, même après que la tache visuelle ait disparu. Pour les cas sévères où l'urine a pénétré profondément dans le matelas, nous appliquons le traitement en plusieurs étapes avec temps de pause pour permettre aux enzymes d'agir. Dans 95% des cas, nous éliminons complètement l'odeur et la tache en une seule intervention. Pour les matelas très endommagés, nous évaluons honnêtement si un remplacement serait plus approprié.",
                            },
                            {
                                question:
                                    "Est-ce que le nettoyage professionnel de matelas endommage la mousse mémoire ?",
                                answer: "Non, au contraire. Notre méthode est spécifiquement adaptée pour chaque type de matelas, y compris la mousse mémoire qui est plus délicate. Nous utilisons une technique à faible humidité et des produits au pH neutre qui n'affectent pas les propriétés viscoélastiques de la mousse. Les fabricants recommandent d'ailleurs un nettoyage professionnel périodique pour prolonger la durée de vie du matelas. L'accumulation de sueur, d'huiles corporelles et d'acariens peut effectivement dégrader la mousse plus rapidement qu'un nettoyage approprié. Notre procédé préserve la structure cellulaire de la mousse tout en éliminant les contaminants.",
                            },
                        ]}
                    />
                </div>
            </div>
        </div>
    </section>

    <script is:inline>
        // Force script to run immediately using is:inline
        (function () {
            // Slideshow Logic
            const slides = document.querySelectorAll(".slide");
            if (slides.length > 0) {
                let currentSlide = 0;
                const intervalTime = 4000; // 4 seconds
                setInterval(() => {
                    slides[currentSlide].classList.remove("active");
                    currentSlide = (currentSlide + 1) % slides.length;
                    slides[currentSlide].classList.add("active");
                }, intervalTime);
            }

            // Toggle Logic
            const toggleBtn = document.getElementById("toggle-seo-btn");
            const seoContent = document.getElementById("seo-content");

            if (toggleBtn && seoContent) {
                toggleBtn.addEventListener("click", function () {
                    if (seoContent.style.display === "block") {
                        seoContent.style.display = "none";
                        toggleBtn.textContent =
                            "En savoir plus sur la désinfection de matelas ▼";
                    } else {
                        seoContent.style.display = "block";
                        seoContent.classList.add("visible");
                        toggleBtn.textContent = "Réduire le contenu ▲";
                    }
                });
            }
        })();
    </script>

    <style>
        /* HERO */
        /* SPLIT SCREEN HERO (Sky Blue Theme) */
        .split-hero-container {
            background-color: #fff; /* Reset container to white */
            padding-top: 0; /* Remove container padding so image hits top */
            padding-bottom: 0;
            overflow: hidden;
            width: 100vw;
        }
        .full-width-split {
            width: 100%;
            max-width: none;
            padding: 0;
            margin: 0;
        }
        .split-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0;
            align-items: stretch;
            min-height: 80vh; /* Consistent viewport height */
        }
        /* LEFT TEXT COLUMN */
        .split-content {
            background-color: #ffffff;
            padding: 100px 4rem 4rem 10%; /* Add header offset internal padding */
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            z-index: 2;
        }
        .service-cat-badge {
            text-transform: uppercase;
            color: var(--color-accent);
            font-weight: 700;
            letter-spacing: 2px;
            font-size: 0.85rem;
            display: block;
            margin-bottom: 1rem;
        }
        .split-title {
            font-size: clamp(2.5rem, 3.5vw, 4rem);
            color: var(--color-primary); /* Dark Blue text */
            margin-bottom: 2rem;
            line-height: 1.1;
        }
        .problem-statement {
            background: #ffffff; /* White box */
            border-left: 4px solid #ff4444; /* Red border returns for alertness */
            padding: 1.5rem;
            border-radius: 0;
            margin-bottom: 2rem;
            box-shadow: 0 4px 15px rgba(174, 206, 235, 0.3); /* Soft blue shadow */
        }
        .problem-title {
            font-size: 1rem;
            color: #cc0000;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            font-weight: 700;
        }
        .problem-text {
            font-size: 1.05rem;
            color: var(--color-text-main);
            font-style: italic;
        }
        .lead-text {
            font-size: 1.15rem;
            line-height: 1.7;
            color: var(--color-text-main); /* Dark grey text */
            margin-bottom: 2.5rem;
            max-width: 650px;
        }
        .cta-group {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        @media (max-width: 900px) {
            .cta-group {
                display: none !important;
            }
        }
        /* Reset Secondary Button for Light Mode */
        .split-content .btn-secondary-outline {
            border-color: #ddd;
            color: #666;
        }
        .split-content .btn-secondary-outline:hover {
            background: white;
            color: var(--color-primary);
            border-color: var(--color-primary);
        }
        /* RIGHT IMAGE COLUMN */
        .split-image-wrapper {
            position: relative;
            height: 100%;
            min-height: 500px;
            width: 100%;
            border-radius: 0;
            transform: none;
            box-shadow: none;
            margin: 0;
            background-color: #fff; /* Ensure white background if image loads late */
        }
        /* Slideshow Styles reused but adapted for full height */
        .slideshow-container {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transition: opacity 1.5s ease-in-out;
        }
        .slide.active {
            opacity: 1;
        }
        /* RESPONSIVE */
        @media (max-width: 1024px) {
            .split-layout {
                grid-template-columns: 1fr;
                min-height: auto;
            }
            .split-content {
                padding: 3rem 1.5rem;
                order: 1; /* Content first */
            }
            .split-image-wrapper {
                order: 2; /* Image second */
                height: 400px;
                min-height: 0;
            }
            .lead-text {
                max-width: 100%;
            }
        }
        /* LAYOUT */
        .service-layout {
            display: grid;
            grid-template-columns: 1.8fr 1fr;
            gap: 5rem;
        }
        /* TYPOGRAPHY */
        .section-title {
            font-size: 1.8rem;
            color: var(--color-primary);
            margin-bottom: 1.5rem;
            border-bottom: 2px solid #eee;
            padding-bottom: 0.5rem;
            display: inline-block;
        }
        /* Benefit List Styles from original */
        .benefit-list {
            margin: 2rem 0;
            list-style: none; /* Ensure no default bullets */
            padding: 0;
        }
        .benefit-list li {
            margin-bottom: 1rem;
            padding-left: 1.5rem;
            position: relative;
            font-size: 1.05rem;
        }
        .benefit-list li::before {
            content: "✓";
            color: #d32f2f; /* Empire Red or Gold */
            position: absolute;
            left: 0;
            font-weight: bold;
        }
        .info-box {
            background-color: #f8f9fa;
            border-left: 4px solid var(--color-accent);
            padding: 1.5rem;
            margin: 2rem 0;
            border-radius: 4px;
        }
        /* NEW BUTTON STYLE */
        .btn-outline-reveal {
            background: transparent;
            border: 2px solid var(--color-primary);
            color: var(--color-primary);
            padding: 0.75rem 1.5rem; /* Nice padding */
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            border-radius: 4px; /* Rounded corners */
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-outline-reveal:hover {
            background: var(--color-primary);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        }
        .seo-content-hidden {
            display: none;
            margin-top: 2rem;
            padding-top: 1rem;
            animation: fadeIn 0.5s ease-in-out;
        }
        /* Animation */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .separator {
            border: 0;
            height: 1px;
            background: rgba(0, 0, 0, 0.1);
            margin: 1.5rem 0;
        }
        /* SIDEBAR */
        .service-sidebar {
            position: relative;
        }
        .sticky-card {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            position: sticky;
            top: 2rem;
            border: 1px solid #eee;
        }
        .card-title {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            font-weight: 800;
        }
        .card-desc {
            color: #666;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }
        .full-width {
            width: 100%;
            margin-bottom: 0.5rem;
            justify-content: center;
        }
        .guarantee-badge {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px dashed #eee;
            text-align: center;
            font-size: 0.9rem;
            color: var(--color-accent);
            font-weight: 600;
        }
        @media (max-width: 900px) {
            .service-layout {
                grid-template-columns: 1fr;
            }
        }
        /* Floating Image Style */
        .floating-img-container {
            width: 100%;
            margin: 2rem 0;
            text-align: center;
            overflow: hidden;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }
        .floating-img {
            width: 100%;
            height: auto;
            max-height: 300px;
            object-fit: cover;
            border-radius: 12px;
            animation: float-sleep 6s ease-in-out infinite;
        }
        @keyframes float-sleep {
            0% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
            100% {
                transform: translateY(0px);
            }
        }
        /* NEW SECTIONS CSS */
        .benefits-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .benefit-item {
            display: flex;
            align-items: center;
            gap: 15px;
            background: white;
            padding: 1rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            border: 1px solid #eee;
        }
        .check-circle {
            width: 25px;
            height: 25px;
            background: #e6f7e6;
            color: #2e7d32;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 0.9rem;
            flex-shrink: 0;
        }
        .faq-list {
            margin-top: 1.5rem;
        }
        .faq-item {
            background: #f9f9f9;
            padding: 1.5rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            border-left: 3px solid var(--color-primary);
        }
        .question {
            color: var(--color-primary);
            margin-bottom: 0.5rem;
            font-size: 1.05rem;
            font-weight: 700;
        }
        .answer {
            color: var(--color-text-main);
            line-height: 1.6;
            font-size: 0.95rem;
        }
        @media (min-width: 768px) {
            .benefits-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }
    </style>
</Layout>
